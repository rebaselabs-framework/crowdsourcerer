# CrowdSorcerer API — Environment Variables
# Copy to .env and fill in values

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/crowdsourcerer
POSTGRES_PASSWORD=postgres

# ─── Security (generate with: openssl rand -hex 32) ───────────────────────────
JWT_SECRET=change-me-use-openssl-rand-hex-32
API_KEY_SALT=change-me-use-openssl-rand-hex-32

# ─── RebaseKit (worker APIs) ──────────────────────────────────────────────────
REBASEKIT_API_KEY=your-rebasekit-api-key
REBASEKIT_BASE_URL=https://api.rebaselabs.online

# ─── Stripe (optional — required for credit purchases) ────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
