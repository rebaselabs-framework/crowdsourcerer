---
import { getToken } from "@/lib/api";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "CrowdSorcerer — AI Task Platform",
  description = "Submit any task. CrowdSorcerer routes it to the right AI worker and delivers results.",
} = Astro.props;

const token = getToken(Object.fromEntries(
  Astro.cookies.getAll().map((c) => [c.name, c.value])
));
const isLoggedIn = !!token;

// Fetch unread notification count (SSR) — fails gracefully
let unreadCount = 0;
if (isLoggedIn) {
  try {
    const API_URL = import.meta.env.PUBLIC_API_URL ?? "http://api:8100";
    const r = await fetch(`${API_URL}/v1/notifications/unread-count`, {
      headers: { Authorization: `Bearer ${token}` },
    });
    if (r.ok) {
      const data = await r.json();
      unreadCount = data.unread_count ?? 0;
    }
  } catch {
    // silently ignore — non-critical
  }
}

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- PWA theme color -->
    <meta name="theme-color" content="#0f0f1a" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  </head>
  <body class="h-full bg-gray-950 text-gray-100 font-sans antialiased">
    <!-- Nav -->
    <nav class="sticky top-0 z-50 border-b border-gray-800 bg-gray-950/95 backdrop-blur-sm px-4 sm:px-6 py-3">
      <div class="flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 font-bold text-lg text-violet-400 shrink-0">
          <span class="text-2xl">🔮</span>
          <span class="hidden sm:inline">CrowdSorcerer</span>
        </a>

        <!-- Desktop nav links -->
        <div class="hidden md:flex items-center gap-5 text-sm">
          <a href="/tasks" class:list={["transition-colors", currentPath === "/tasks" ? "text-white" : "text-gray-400 hover:text-gray-100"]}>
            Browse Tasks
          </a>
          <a href="/docs" class:list={["transition-colors", currentPath.startsWith("/docs") ? "text-white" : "text-gray-400 hover:text-gray-100"]}>
            Docs
          </a>
          <a href="/docs/api-reference" class:list={["transition-colors", currentPath === "/docs/api-reference" ? "text-white" : "text-gray-400 hover:text-gray-100"]}>
            API Reference
          </a>
          <a href="/pricing" class:list={["transition-colors", currentPath === "/pricing" ? "text-white" : "text-gray-400 hover:text-gray-100"]}>
            Pricing
          </a>
          {isLoggedIn ? (
            <>
              <a href="/dashboard" class:list={["transition-colors", currentPath === "/dashboard" ? "text-white" : "text-gray-400 hover:text-gray-100"]}>
                Dashboard
              </a>
              <a href="/worker" class:list={["transition-colors", currentPath.startsWith("/worker") ? "text-violet-400" : "text-gray-400 hover:text-gray-100"]}>
                Earn
              </a>
              <!-- Notification bell -->
              <a href="/dashboard/notifications" class="relative inline-flex items-center text-gray-400 hover:text-gray-100 transition-colors" title="Notifications">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
                {unreadCount > 0 && (
                  <span class="absolute -top-1 -right-1 h-4 w-4 rounded-full bg-violet-500 text-white text-[10px] flex items-center justify-center font-bold leading-none">
                    {unreadCount > 9 ? "9+" : unreadCount}
                  </span>
                )}
              </a>
              <a href="/dashboard/new-task" class="px-3 py-1.5 rounded-lg bg-violet-600 hover:bg-violet-500 text-white text-sm transition-colors">
                + New task
              </a>
              <a href="/logout" class="text-gray-500 hover:text-gray-300 transition-colors text-xs">Sign out</a>
            </>
          ) : (
            <>
              <a href="/login" class="px-3 py-1.5 rounded-lg border border-gray-700 text-sm hover:border-gray-500 transition-colors">
                Sign in
              </a>
              <a href="/register" class="px-3 py-1.5 rounded-lg bg-violet-600 hover:bg-violet-500 text-white text-sm transition-colors">
                Get started
              </a>
            </>
          )}
        </div>

        <!-- Mobile: notification + hamburger -->
        <div class="flex items-center gap-3 md:hidden">
          {isLoggedIn && (
            <a href="/dashboard/notifications" class="relative inline-flex items-center text-gray-400 p-1.5" title="Notifications">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
              {unreadCount > 0 && (
                <span class="absolute top-0 right-0 h-4 w-4 rounded-full bg-violet-500 text-white text-[10px] flex items-center justify-center font-bold leading-none">
                  {unreadCount > 9 ? "9+" : unreadCount}
                </span>
              )}
            </a>
          )}
          <!-- Hamburger button -->
          <button
            id="nav-toggle"
            class="p-2 text-gray-400 hover:text-gray-100 transition-colors"
            aria-label="Toggle menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu (hidden by default) -->
      <div
        id="mobile-menu"
        class="hidden md:hidden border-t border-gray-800 mt-3 pt-3 pb-2 space-y-1"
        role="menu"
      >
        <a href="/tasks" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
          🌐 Browse Tasks
        </a>
        <a href="/docs" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
          📚 Docs
        </a>
        <a href="/docs/api-reference" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
          📖 API Reference
        </a>
        <a href="/pricing" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
          💵 Pricing
        </a>
        {isLoggedIn ? (
          <>
            <div class="h-px bg-gray-800 my-2"></div>
            <a href="/dashboard" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              🏠 Dashboard
            </a>
            <a href="/dashboard/new-task" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              ✨ New Task
            </a>
            <a href="/dashboard/credits" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              💳 Credits
            </a>
            <a href="/dashboard/billing" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              🏦 Billing & Plan
            </a>
            <a href="/dashboard/quality" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              🎯 Quality
            </a>
            <a href="/dashboard/review" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              📬 Review Queue
            </a>
            <a href="/dashboard/disputes" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              ⚖️ Disputes
            </a>
            <a href="/dashboard/team" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              🏢 Teams
            </a>
            <a href="/dashboard/pipelines" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              ⛓️ Pipelines
            </a>
            <a href="/dashboard/analytics" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              📊 Analytics
            </a>
            <a href="/dashboard/marketplace" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              🏪 Marketplace
            </a>
            <a href="/dashboard/triggers" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              ⚡ Triggers
            </a>
            <a href="/dashboard/search" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              🔍 Search
            </a>
            <a href="/dashboard/experiments" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              🧪 A/B Experiments
            </a>
            <a href="/dashboard/sla" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              ⏱ SLA
            </a>
            <a href="/dashboard/quota" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              📊 Plan & Quota
            </a>
            <div class="h-px bg-gray-800 my-2"></div>
            <a href="/worker" class="flex items-center gap-3 px-3 py-2.5 text-sm text-violet-300 hover:bg-violet-900/30 rounded-lg transition-colors font-medium">
              🔮 Worker Hub
            </a>
            <a href="/worker/onboarding" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              🎉 Onboarding
            </a>
            <a href="/worker/marketplace" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              🛒 Marketplace
            </a>
            <a href="/worker/reputation" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              ⭐ Reputation
            </a>
            <a href="/worker/certifications" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              🎓 Certifications
            </a>
            <a href="/worker/earnings" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              💰 Earnings
            </a>
            <a href="/worker/leaderboard" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-300 hover:bg-gray-800 rounded-lg transition-colors">
              🏆 Leaderboard
            </a>
            <div class="h-px bg-gray-800 my-2"></div>
            <a href="/logout" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-500 hover:bg-gray-800 rounded-lg transition-colors">
              Sign out
            </a>
          </>
        ) : (
          <>
            <div class="h-px bg-gray-800 my-2"></div>
            <a href="/login" class="flex items-center justify-center gap-3 mx-3 py-2.5 text-sm text-gray-200 border border-gray-700 hover:border-gray-500 rounded-lg transition-colors text-center">
              Sign in
            </a>
            <a href="/register" class="flex items-center justify-center gap-3 mx-3 py-2.5 text-sm text-white bg-violet-600 hover:bg-violet-500 rounded-lg transition-colors text-center font-medium">
              Get started free
            </a>
          </>
        )}
      </div>
    </nav>

    <!-- Content -->
    <!-- Extra bottom padding on mobile to account for the bottom nav bar -->
    <div class:list={["pb-0", isLoggedIn ? "sm:pb-0 pb-20" : ""]}>
      <slot />
    </div>

    <!-- Footer (hidden on mobile when logged in to not compete with bottom nav) -->
    <footer class:list={["border-t border-gray-800 px-4 sm:px-6 py-8 mt-16 sm:mt-20", isLoggedIn ? "hidden sm:block" : ""]}>
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center sm:justify-between gap-4 text-sm text-gray-500">
        <div class="flex items-center gap-2">
          <span>🔮</span>
          <span>CrowdSorcerer by <a href="https://rebaselabs.online" class="text-violet-400 hover:text-violet-300">RebaseLabs</a></span>
        </div>
        <div class="flex gap-6">
          <a href="/docs" class="hover:text-gray-300 transition-colors">Docs</a>
          <a href="/pricing" class="hover:text-gray-300 transition-colors">Pricing</a>
          <a href="/widget" class="hover:text-gray-300 transition-colors">Widget</a>
          <a href="https://github.com/rebaselabs-framework" class="hover:text-gray-300 transition-colors">GitHub</a>
        </div>
      </div>
    </footer>

    <!-- Mobile bottom navigation (logged-in only, hidden on md+) -->
    {isLoggedIn && (
      <nav class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-gray-950/98 backdrop-blur-sm border-t border-gray-800 px-2 py-2 safe-area-bottom">
        <div class="flex items-center justify-around max-w-sm mx-auto">
          <!-- Home -->
          <a href="/dashboard" class:list={["flex flex-col items-center gap-0.5 px-3 py-1.5 rounded-xl transition-colors min-w-0", currentPath === "/dashboard" ? "text-violet-400" : "text-gray-500 hover:text-gray-300"]}>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <span class="text-[10px] leading-tight">Home</span>
          </a>
          <!-- Browse -->
          <a href="/worker/marketplace" class:list={["flex flex-col items-center gap-0.5 px-3 py-1.5 rounded-xl transition-colors min-w-0", currentPath.startsWith("/worker/marketplace") ? "text-emerald-400" : "text-gray-500 hover:text-gray-300"]}>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            <span class="text-[10px] leading-tight">Earn</span>
          </a>
          <!-- New Task (CTA) -->
          <a href="/dashboard/new-task" class="flex flex-col items-center gap-0.5 px-1 py-1">
            <div class="w-11 h-11 rounded-full bg-violet-600 hover:bg-violet-500 flex items-center justify-center transition-colors shadow-lg shadow-violet-900/50 -mt-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
            </div>
            <span class="text-[10px] leading-tight text-gray-500">New</span>
          </a>
          <!-- Tasks list -->
          <a href="/dashboard/tasks" class:list={["flex flex-col items-center gap-0.5 px-3 py-1.5 rounded-xl transition-colors min-w-0", currentPath.startsWith("/dashboard/tasks") ? "text-violet-400" : "text-gray-500 hover:text-gray-300"]}>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            <span class="text-[10px] leading-tight">Tasks</span>
          </a>
          <!-- Profile / Notifications -->
          <a href="/dashboard/notifications" class:list={["relative flex flex-col items-center gap-0.5 px-3 py-1.5 rounded-xl transition-colors min-w-0", currentPath.startsWith("/dashboard/notifications") ? "text-violet-400" : "text-gray-500 hover:text-gray-300"]}>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
            </svg>
            {unreadCount > 0 && (
              <span class="absolute top-0.5 right-1.5 h-4 w-4 rounded-full bg-violet-500 text-white text-[9px] flex items-center justify-center font-bold leading-none">
                {unreadCount > 9 ? "9+" : unreadCount}
              </span>
            )}
            <span class="text-[10px] leading-tight">Alerts</span>
          </a>
        </div>
      </nav>
    )}

    <!-- Mobile nav toggle script -->
    <script is:inline>
      (function () {
        const btn = document.getElementById("nav-toggle");
        const menu = document.getElementById("mobile-menu");
        const hamburger = document.getElementById("hamburger-icon");
        const closeIco = document.getElementById("close-icon");
        if (!btn || !menu) return;

        btn.addEventListener("click", () => {
          const open = menu.classList.toggle("hidden");
          btn.setAttribute("aria-expanded", String(!open));
          hamburger.classList.toggle("hidden", !open);
          closeIco.classList.toggle("hidden", open);
        });

        // Close menu on link click
        menu.querySelectorAll("a").forEach((a) => {
          a.addEventListener("click", () => {
            menu.classList.add("hidden");
            btn.setAttribute("aria-expanded", "false");
            hamburger.classList.remove("hidden");
            closeIco.classList.add("hidden");
          });
        });
      })();
    </script>
  </body>
</html>
