---
import { getToken } from "@/lib/api";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "CrowdSorcerer — AI Task Platform",
  description = "Submit any task. CrowdSorcerer routes it to the right AI worker and delivers results.",
} = Astro.props;

const token = getToken(Object.fromEntries(
  Astro.cookies.getAll().map((c) => [c.name, c.value])
));
const isLoggedIn = !!token;

// Fetch unread notification count (SSR) — fails gracefully
let unreadCount = 0;
if (isLoggedIn) {
  try {
    const API_URL = import.meta.env.PUBLIC_API_URL ?? "http://api:8100";
    const r = await fetch(`${API_URL}/v1/notifications/unread-count`, {
      headers: { Authorization: `Bearer ${token}` },
    });
    if (r.ok) {
      const data = await r.json();
      unreadCount = data.unread_count ?? 0;
    }
  } catch {
    // silently ignore — non-critical
  }
}
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="h-full bg-gray-950 text-gray-100 font-sans antialiased">
    <!-- Nav -->
    <nav class="border-b border-gray-800 px-6 py-3 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-bold text-lg text-violet-400">
        <span class="text-2xl">🔮</span>
        CrowdSorcerer
      </a>
      <div class="flex items-center gap-6 text-sm">
        <a href="/tasks" class="text-gray-400 hover:text-gray-100 transition-colors">Browse Tasks</a>
        <a href="/docs" class="text-gray-400 hover:text-gray-100 transition-colors">Docs</a>
        <a href="/pricing" class="text-gray-400 hover:text-gray-100 transition-colors">Pricing</a>
        {isLoggedIn ? (
          <>
            <a href="/dashboard" class="text-gray-400 hover:text-gray-100 transition-colors">Dashboard</a>
            <a href="/dashboard/credits" class="text-gray-400 hover:text-gray-100 transition-colors">Credits</a>
            <a href="/dashboard/quality" class="text-gray-400 hover:text-gray-100 transition-colors">Quality</a>
            <a href="/dashboard/review" class="text-gray-400 hover:text-gray-100 transition-colors">Review</a>
            <a href="/worker" class="text-gray-400 hover:text-gray-100 transition-colors">Earn</a>
            <a href="/worker/leaderboard" class="text-gray-400 hover:text-gray-100 transition-colors">Leaderboard</a>
            <!-- Notification bell -->
            <a href="/dashboard/notifications" class="relative inline-flex items-center text-gray-400 hover:text-gray-100 transition-colors" title="Notifications">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
              {unreadCount > 0 && (
                <span class="absolute -top-1 -right-1 h-4 w-4 rounded-full bg-violet-500 text-white text-[10px] flex items-center justify-center font-bold leading-none">
                  {unreadCount > 9 ? "9+" : unreadCount}
                </span>
              )}
            </a>
            <a href="/dashboard/new-task" class="px-3 py-1.5 rounded-lg bg-violet-600 hover:bg-violet-500 text-white text-sm transition-colors">
              + New task
            </a>
            <a href="/logout" class="text-gray-500 hover:text-gray-300 transition-colors">Sign out</a>
          </>
        ) : (
          <>
            <a href="/login" class="px-3 py-1.5 rounded-lg border border-gray-700 text-sm hover:border-gray-500 transition-colors">
              Sign in
            </a>
            <a href="/register" class="px-3 py-1.5 rounded-lg bg-violet-600 hover:bg-violet-500 text-white text-sm transition-colors">
              Get started
            </a>
          </>
        )}
      </div>
    </nav>

    <!-- Content -->
    <slot />

    <!-- Footer -->
    <footer class="border-t border-gray-800 px-6 py-8 mt-20">
      <div class="max-w-5xl mx-auto flex items-center justify-between text-sm text-gray-500">
        <div class="flex items-center gap-2">
          <span>🔮</span>
          <span>CrowdSorcerer by <a href="https://rebaselabs.online" class="text-violet-400 hover:text-violet-300">RebaseLabs</a></span>
        </div>
        <div class="flex gap-6">
          <a href="/docs" class="hover:text-gray-300 transition-colors">Docs</a>
          <a href="/pricing" class="hover:text-gray-300 transition-colors">Pricing</a>
          <a href="https://github.com/rebaselabs-framework" class="hover:text-gray-300 transition-colors">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>
