    <!-- Dark mode toggle script -->
    <script is:inline>
      (function () {
        function isDark() {
          return document.documentElement.classList.contains("dark");
        }

        function setTheme(dark) {
          if (dark) {
            document.documentElement.classList.add("dark");
            localStorage.setItem("theme", "dark");
          } else {
            document.documentElement.classList.remove("dark");
            localStorage.setItem("theme", "light");
          }
          updateIcons();
        }

        function updateIcons() {
          var dark = isDark();
          // Desktop icons
          var moonD = document.getElementById("theme-icon-moon");
          var sunD = document.getElementById("theme-icon-sun");
          if (moonD) moonD.classList.toggle("hidden", dark);
          if (sunD) sunD.classList.toggle("hidden", !dark);
          // Mobile icons
          var moonM = document.getElementById("theme-icon-moon-mobile");
          var sunM = document.getElementById("theme-icon-sun-mobile");
          if (moonM) moonM.classList.toggle("hidden", dark);
          if (sunM) sunM.classList.toggle("hidden", !dark);
        }

        // Init icons after DOM ready
        updateIcons();

        // Desktop toggle
        var btn = document.getElementById("theme-toggle");
        if (btn) {
          btn.addEventListener("click", function () {
            setTheme(!isDark());
          });
        }

        // Mobile toggle
        var btnM = document.getElementById("theme-toggle-mobile");
        if (btnM) {
          btnM.addEventListener("click", function () {
            setTheme(!isDark());
          });
        }
      })();
    </script>

    <!-- Mobile nav toggle script -->
    <script is:inline>
      (function () {
        const btn = document.getElementById("nav-toggle");
        const menu = document.getElementById("mobile-menu");
        const hamburger = document.getElementById("hamburger-icon");
        const closeIco = document.getElementById("close-icon");
        if (!btn || !menu) return;

        btn.addEventListener("click", () => {
          const open = menu.classList.toggle("hidden");
          btn.setAttribute("aria-expanded", String(!open));
          hamburger.classList.toggle("hidden", !open);
          closeIco.classList.toggle("hidden", open);
        });

        // Close menu on link click
        menu.querySelectorAll("a").forEach((a) => {
          a.addEventListener("click", () => {
            menu.classList.add("hidden");
            btn.setAttribute("aria-expanded", "false");
            hamburger.classList.remove("hidden");
            closeIco.classList.add("hidden");
          });
        });
      })();
    </script>

    <!-- ── Global Search Modal ──────────────────────────────────────────────── -->
    {isLoggedIn && (
      <>
        <!-- Modal overlay -->
        <div
          id="global-search-modal"
          class="fixed inset-0 z-[200] hidden"
          role="dialog"
          aria-modal="true"
          aria-label="Global search"
        >
          <!-- Backdrop -->
          <div id="global-search-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

          <!-- Panel -->
          <div class="absolute top-[10vh] left-1/2 -translate-x-1/2 w-full max-w-xl px-4">
            <div class="bg-gray-900 border border-gray-700 rounded-2xl shadow-2xl overflow-hidden">
              <!-- Input row -->
              <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-800">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input
                  id="global-search-input"
                  type="text"
                  placeholder="Search tasks, workers, orgs…"
                  autocomplete="off"
                  spellcheck="false"
                  class="flex-1 bg-transparent text-gray-100 placeholder-gray-500 text-sm focus:outline-none"
                />
                <kbd class="hidden sm:inline-flex items-center gap-1 px-1.5 py-0.5 bg-gray-800 border border-gray-700 rounded text-gray-500 text-xs">Esc</kbd>
              </div>

              <!-- Results -->
              <div id="global-search-results" class="max-h-[60vh] overflow-y-auto py-2">
                <div id="global-search-placeholder" class="px-4 py-8 text-center text-gray-500 text-sm">
                  Type to search across tasks, workers, and orgs…
                </div>
                <div id="global-search-spinner" class="hidden px-4 py-6 text-center text-gray-500 text-sm">
                  Searching…
                </div>
                <div id="global-search-content" class="hidden"></div>
                <div id="global-search-empty" class="hidden px-4 py-8 text-center text-gray-500 text-sm">
                  No results found
                </div>
              </div>
            </div>
          </div>
        </div>

        <script>
          // ── Global search modal ──────────────────────────────────────────────
          const modal = document.getElementById("global-search-modal")!;
          const backdrop = document.getElementById("global-search-backdrop")!;
          const searchInput = document.getElementById("global-search-input") as HTMLInputElement;
          const resultsContent = document.getElementById("global-search-content")!;
          const placeholder = document.getElementById("global-search-placeholder")!;
          const spinner = document.getElementById("global-search-spinner")!;
          const emptyEl = document.getElementById("global-search-empty")!;
          const trigger = document.getElementById("global-search-trigger");

          function openModal() {
            modal.classList.remove("hidden");
            setTimeout(() => searchInput?.focus(), 50);
          }
          function closeModal() {
            modal.classList.add("hidden");
            if (searchInput) searchInput.value = "";
            showPlaceholder();
          }
          function showPlaceholder() {
            placeholder.classList.remove("hidden");
            spinner.classList.add("hidden");
            resultsContent.classList.add("hidden");
            emptyEl.classList.add("hidden");
          }
          function showSpinner() {
            placeholder.classList.add("hidden");
            spinner.classList.remove("hidden");
            resultsContent.classList.add("hidden");
            emptyEl.classList.add("hidden");
          }
          function showResults(html: string) {
            spinner.classList.add("hidden");
            placeholder.classList.add("hidden");
            if (!html) {
              emptyEl.classList.remove("hidden");
              resultsContent.classList.add("hidden");
            } else {
              emptyEl.classList.add("hidden");
              resultsContent.innerHTML = html;
              resultsContent.classList.remove("hidden");
            }
          }

          trigger?.addEventListener("click", openModal);
          backdrop.addEventListener("click", closeModal);

          // Keyboard shortcuts
          document.addEventListener("keydown", (e) => {
            if ((e.ctrlKey || e.metaKey) && e.key === "k") {
              e.preventDefault();
              if (modal.classList.contains("hidden")) openModal();
              else closeModal();
            }
            if (e.key === "Escape" && !modal.classList.contains("hidden")) {
              closeModal();
            }
          });

          // Debounced search
          let _debounceTimer: ReturnType<typeof setTimeout> | null = null;
          searchInput?.addEventListener("input", () => {
            const q = searchInput.value.trim();
            if (!q) { showPlaceholder(); return; }
            if (_debounceTimer) clearTimeout(_debounceTimer);
            showSpinner();
            _debounceTimer = setTimeout(() => runSearch(q), 300);
          });

          async function runSearch(q: string) {
            try {
              const res = await fetch(`/api/search/global?q=${encodeURIComponent(q)}&limit=20`);
              if (!res.ok) { showResults(""); return; }
              const data = await res.json();
              showResults(buildResultsHTML(data));
            } catch {
              showResults("");
            }
          }

          function buildResultsHTML(data: any): string {
            const sections: string[] = [];

            if (data.tasks?.length) {
              sections.push(`<div class="px-3 pt-2 pb-1"><div class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-1 mb-1">Tasks</div>${
                data.tasks.map((t: any) => `
                  <a href="${t.url}" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-gray-800 transition-colors group block">
                    <span class="text-base shrink-0">📋</span>
                    <div class="flex-1 min-w-0">
                      <div class="text-sm text-gray-200 truncate group-hover:text-white">${escHtml(t.title)}</div>
                      <div class="text-xs text-gray-500">${escHtml(t.type)} · ${escHtml(t.status)}</div>
                    </div>
                  </a>`).join("")
              }</div>`);
            }

            if (data.workers?.length) {
              sections.push(`<div class="px-3 pt-2 pb-1"><div class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-1 mb-1">Workers</div>${
                data.workers.map((w: any) => `
                  <a href="${w.url}" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-gray-800 transition-colors group block">
                    <span class="text-base shrink-0">👷</span>
                    <div class="flex-1 min-w-0">
                      <div class="text-sm text-gray-200 truncate group-hover:text-white">${escHtml(w.display_name)}</div>
                      <div class="text-xs text-gray-500">${escHtml(w.tier)}</div>
                    </div>
                  </a>`).join("")
              }</div>`);
            }

            if (data.orgs?.length) {
              sections.push(`<div class="px-3 pt-2 pb-1"><div class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-1 mb-1">Organizations</div>${
                data.orgs.map((o: any) => `
                  <a href="${o.url}" class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-gray-800 transition-colors group block">
                    <span class="text-base shrink-0">🏢</span>
                    <div class="flex-1 min-w-0">
                      <div class="text-sm text-gray-200 truncate group-hover:text-white">${escHtml(o.name)}</div>
                      <div class="text-xs text-gray-500">${escHtml(o.slug)}</div>
                    </div>
                  </a>`).join("")
              }</div>`);
            }

            return sections.join('<div class="h-px bg-gray-800 mx-4 my-1"></div>');
          }

          function escHtml(s: string): string {
            return String(s ?? "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
          }
        </script>
      </>
    )}

    <!-- Email verification banner JS (resend + dismiss) -->
    {showVerifyBanner && (
      <script>
        (function setupVerifyBanner() {
          const banner = document.getElementById("email-verify-banner");
          const resendBtn = document.getElementById("banner-resend-btn") as HTMLButtonElement | null;
          const dismissBtn = document.getElementById("banner-dismiss-btn");
          const statusEl = document.getElementById("banner-status");

          dismissBtn?.addEventListener("click", () => {
            banner?.remove();
          });

          resendBtn?.addEventListener("click", async () => {
            if (!resendBtn) return;
            resendBtn.textContent = "Sending…";
            resendBtn.style.pointerEvents = "none";
            try {
              const res = await fetch("/api/auth/resend-verification", { method: "POST" });
              const data = await res.json().catch(() => ({}));
              if (res.ok) {
                resendBtn.textContent = "✓ Sent! Check your inbox.";
                if (statusEl) {
                  statusEl.textContent = "Verification email sent. Links expire in 24 hours.";
                  statusEl.classList.remove("hidden");
                }
              } else {
                resendBtn.textContent = "Resend verification email";
                resendBtn.style.pointerEvents = "";
                if (statusEl) {
                  statusEl.textContent = data.detail ?? "Failed to send. Please try again.";
                  statusEl.classList.remove("hidden");
                }
              }
            } catch {
              resendBtn.textContent = "Resend verification email";
              resendBtn.style.pointerEvents = "";
              if (statusEl) {
                statusEl.textContent = "Network error — please try again.";
                statusEl.classList.remove("hidden");
              }
            }
          });
        })();
      </script>
    )}

    <!-- Live notification + message badge polling (every 60s, only when logged in) -->
    {isLoggedIn && (
      <script>
        (function pollNavBadges() {
          async function refresh() {
            try {
              // Notifications
              const notifRes = await fetch("/api/notifications/unread-count");
              if (notifRes.ok) {
                const data = await notifRes.json();
                const count: number = data.unread_count ?? 0;
                const display = count > 0 ? "" : "none";
                const text = count > 9 ? "9+" : String(count);
                ["nav-notif-badge", "nav-notif-badge-mobile"].forEach((id) => {
                  const el = document.getElementById(id);
                  if (el) { el.style.display = display; el.textContent = text; }
                });
              }
            } catch { /* ignore */ }
            try {
              // Task messages
              const msgRes = await fetch("/api/tasks/messages/unread-count");
              if (msgRes.ok) {
                const data = await msgRes.json();
                const count: number = data.count ?? 0;
                const display = count > 0 ? "" : "none";
                const text = count > 9 ? "9+" : String(count);
                ["nav-msg-badge", "nav-msg-badge-mobile"].forEach((id) => {
                  const el = document.getElementById(id);
                  if (el) { el.style.display = display; el.textContent = text; }
                });
              }
            } catch { /* ignore */ }
          }
          // Initial fetch after 5s (allow page to fully load first)
          setTimeout(refresh, 5_000);
          setInterval(refresh, 60_000);
        })();
      </script>
    )}
  </body>
