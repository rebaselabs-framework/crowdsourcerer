---
import { getToken } from "@/lib/api";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
  // Accepted but unused — some pages pass these for forward compatibility
  active?: string;
  user?: any;
}

const {
  title = "CrowdSorcerer — AI Task Platform",
  description = "Submit any task. CrowdSorcerer routes it to the right AI worker and delivers results. Web research, entity lookup, document parsing, code execution — at 1¢ per task.",
  ogImage = "https://crowdsorcerer.dev/og-default.png",
  ogType = "website",
  canonicalUrl,
  noIndex = false,
} = Astro.props;

const siteUrl = "https://crowdsorcerer.dev";
const canonical = canonicalUrl ?? `${siteUrl}${Astro.url.pathname}`;

const token = getToken(Astro.cookies);
const isLoggedIn = !!token;

// Fetch unread notification count + email verified status (SSR) — fails gracefully
let unreadCount = 0;
let unreadMsgCount = 0;
let emailVerified = true; // default true to avoid false-positive banners on fetch failure
if (isLoggedIn) {
  try {
    const API_URL = import.meta.env.PUBLIC_API_URL ?? "http://api:8100";
    const authHeader = { Authorization: `Bearer ${token}` };
    const [notifRes, msgRes, meRes] = await Promise.allSettled([
      fetch(`${API_URL}/v1/notifications/unread-count`, { headers: authHeader }),
      fetch(`${API_URL}/v1/tasks/messages/unread-count`, { headers: authHeader }),
      fetch(`${API_URL}/v1/users/me`, { headers: authHeader }),
    ]);
    if (notifRes.status === "fulfilled" && notifRes.value.ok) {
      const data = await notifRes.value.json();
      unreadCount = data.unread_count ?? 0;
    }
    if (msgRes.status === "fulfilled" && msgRes.value.ok) {
      const data = await msgRes.value.json();
      unreadMsgCount = data.count ?? 0;
    }
    if (meRes.status === "fulfilled" && meRes.value.ok) {
      const data = await meRes.value.json();
      emailVerified = data.email_verified !== false; // treat missing field as verified
    }
  } catch {
    // silently ignore — non-critical
  }
}

// Show email verification banner only when logged in, unverified, and not on the verify page
const showVerifyBanner =
  isLoggedIn &&
  !emailVerified &&
  !Astro.url.pathname.startsWith("/verify-email");

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="CrowdSorcerer" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:site" content="@crowdsorcerer" />

    <!-- PWA theme color -->
    <meta name="theme-color" content="#0f0f1a" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <!-- Dark mode: apply class before paint to avoid flash -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem("theme");
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (stored === "dark" || (!stored && prefersDark)) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>

    <style is:global>
      /* ── CSS custom properties ──────────────────────────────────────── */
      :root {
        --bg: #030712;
        --text: #f3f4f6;
        --card-bg: #111827;
        --border: #1f2937;
        --nav-bg: rgba(3, 7, 18, 0.95);
        --muted: #6b7280;
      }

      html.dark {
        --bg: #030712;
        --text: #f3f4f6;
        --card-bg: #111827;
        --border: #1f2937;
        --nav-bg: rgba(3, 7, 18, 0.95);
