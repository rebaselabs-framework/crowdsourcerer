---
import { clearAuthCookies } from "@/lib/auth";
import { apiFetch } from "@/lib/api";

// Revoke refresh token on backend (best-effort)
const refreshToken = Astro.cookies.get("cs_refresh")?.value;
if (refreshToken) {
  try {
    await apiFetch("/v1/auth/logout", {
      method: "POST",
      body: JSON.stringify({ refresh_token: refreshToken }),
    });
  } catch {
    // Ignore — we clear cookies regardless
  }
}

// Clear both auth cookies and redirect to login
clearAuthCookies(Astro.cookies);
return Astro.redirect("/login");
---
