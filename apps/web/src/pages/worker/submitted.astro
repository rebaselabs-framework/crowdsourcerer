---
/**
 * Task submitted success page — shown after worker submits a task.
 * Shows earned credits, XP, and streak bonus if applicable.
 */
import Layout from "@/layouts/Layout.astro";
import { getToken } from "@/lib/api";

const token = getToken(Astro.cookies);

if (!token) return Astro.redirect("/login");

const url = new URL(Astro.request.url);

// Guard: if the page is accessed directly without URL params (e.g. someone
// bookmarks /worker/submitted), redirect to marketplace rather than showing
// a confusing "0 credits, 0 XP" success screen.
if (!url.searchParams.has("credits")) {
  return Astro.redirect("/worker/marketplace");
}

const credits = parseInt(url.searchParams.get("credits") ?? "0");
const xp = parseInt(url.searchParams.get("xp") ?? "0");
// streak_multiplier and streak_days are passed from the submit handler
const streakMultiplier = parseFloat(url.searchParams.get("streak_multiplier") ?? "1");
const streakDays = parseInt(url.searchParams.get("streak_days") ?? "0");
const hasStreakBonus = streakMultiplier > 1.0;
// Streak freeze earned at 7-day milestones
const earnedFreeze = streakDays > 0 && streakDays >= 7 && streakDays % 7 === 0;

// Human-readable multiplier label
function streakLabel(days: number): string {
  if (days >= 30) return "🔥 30-day streak!";
  if (days >= 14) return "🔥 2-week streak!";
  if (days >= 7) return "🔥 7-day streak!";
  if (days >= 3) return "🔥 3-day streak!";
  return "";
}
const streakBadgeLabel = streakLabel(streakDays);
const multiplierDisplay = `${streakMultiplier}×`;
---

<Layout title="Task Submitted — CrowdSorcerer">
  <div class="max-w-lg mx-auto px-6 py-20 text-center">
    <!-- Success animation -->
    <div class="text-7xl mb-6 animate-bounce">🎉</div>

    <h1 class="text-3xl font-bold mb-3">Task Submitted!</h1>
    <p class="text-gray-400 mb-10">Your answer has been recorded. Thanks for contributing!</p>

    <!-- Streak bonus banner (shown only when multiplier > 1×) -->
    {hasStreakBonus && (
      <div class="mb-6 px-4 py-3 bg-orange-900/30 border border-orange-700/50 rounded-xl flex items-center justify-center gap-3 text-sm">
        <span class="text-2xl">🔥</span>
        <div class="text-left">
          <span class="text-orange-300 font-semibold">{streakBadgeLabel}</span>
          <span class="text-orange-400 ml-2">{multiplierDisplay} XP bonus applied</span>
        </div>
      </div>
    )}

    <!-- Rewards -->
    <div class="grid grid-cols-2 gap-4 mb-10">
      <div class="bg-gray-900 border border-emerald-800/50 rounded-2xl p-6">
        <div class="text-4xl font-bold text-emerald-400 mb-1">+{credits}</div>
        <div class="text-sm text-gray-400">Credits earned</div>
        <div class="text-xs text-gray-500 mt-1">≈ ${(credits / 100).toFixed(2)}</div>
      </div>
      <div class="bg-gray-900 border border-violet-800/50 rounded-2xl p-6">
        <div class="text-4xl font-bold text-violet-400 mb-1">+{xp}</div>
        <div class="text-sm text-gray-400">XP gained</div>
        <div class="text-xs text-gray-500 mt-1">
          {hasStreakBonus ? `${multiplierDisplay} streak bonus` : "Progress to next level"}
        </div>
      </div>
    </div>

    <!-- Streak freeze earned banner -->
    {earnedFreeze && (
      <div class="mb-6 px-4 py-3 bg-cyan-900/30 border border-cyan-700/50 rounded-xl flex items-center justify-center gap-3 text-sm">
        <span class="text-2xl">🧊</span>
        <div class="text-left">
          <span class="text-cyan-300 font-semibold">Streak Freeze earned!</span>
          <span class="text-cyan-400 ml-1">Protects your streak if you miss a day</span>
        </div>
      </div>
    )}

    <!-- Actions -->
    <div class="flex flex-col gap-3 max-w-sm mx-auto">
      <a
        href="/worker/marketplace"
        class="py-3.5 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold rounded-xl transition-colors"
      >
        Complete another task
      </a>
      <a
        href="/worker"
        class="py-3.5 border border-gray-700 hover:border-gray-500 text-gray-300 rounded-xl transition-colors text-sm"
      >
        View my stats
      </a>
    </div>

    <!-- Streak tip / progress -->
    <div class="mt-12 text-sm text-gray-500">
      {hasStreakBonus ? (
        streakDays >= 30
          ? <span><span class="text-orange-400">🔥</span> Amazing! {streakDays}-day streak — you're at max XP multiplier!</span>
          : streakDays >= 14
            ? <span><span class="text-orange-400">🔥</span> {streakDays}-day streak — keep going to reach 30 days for 2× XP!</span>
            : streakDays >= 7
              ? <span><span class="text-orange-400">🔥</span> {streakDays}-day streak — keep going to reach 14 days for 1.5× XP!</span>
              : <span><span class="text-orange-400">🔥</span> {streakDays}-day streak — keep going to reach 7 days for 1.25× XP!</span>
      ) : (
        <span><span class="text-orange-400">🔥</span> Complete tasks every day to build a streak and earn up to 2× XP!</span>
      )}
    </div>
  </div>
</Layout>

<style>
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
  .animate-bounce { animation: bounce 1s ease-in-out 2; }
</style>
