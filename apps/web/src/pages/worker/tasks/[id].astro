---
/**
 * Worker task completion page.
 * Shows type-specific UI. Worker claims then completes the task.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);

if (!token) return Astro.redirect("/login");

const { id } = Astro.params;
let task: any = null;
let hasActiveAssignment = false;
let activeAssignment: any = null;
let priorAssignment: any = null;  // submitted / approved / rejected — already done
let error = "";
let user: any = null;
let taskMessages: any[] = [];
let timedOutAssignment: any = null;

try {
  [user, task] = await Promise.all([
    apiFetch<any>("/v1/users/me", { token }),
    apiFetch<any>(`/v1/worker/tasks/${id}`, { token }),
  ]);
  if (!user || (user.role !== "worker" && user.role !== "both")) {
    return Astro.redirect("/worker");
  }
  // Check active assignment AND prior submissions in parallel (including timed_out)
  const [activeAssignments, submittedAssignments, approvedAssignments, rejectedAssignments, timedOutAssignments] =
    await Promise.all([
      apiFetch<any[]>(`/v1/worker/assignments?status=active&page_size=50`, { token }).catch(() => []),
      apiFetch<any[]>(`/v1/worker/assignments?status=submitted&page_size=50`, { token }).catch(() => []),
      apiFetch<any[]>(`/v1/worker/assignments?status=approved&page_size=50`, { token }).catch(() => []),
      apiFetch<any[]>(`/v1/worker/assignments?status=rejected&page_size=50`, { token }).catch(() => []),
      apiFetch<any[]>(`/v1/worker/assignments?status=timed_out&page_size=50`, { token }).catch(() => []),
    ]);
  activeAssignment = activeAssignments?.find((a: any) => a.task_id === id) ?? null;
  hasActiveAssignment = !!activeAssignment;
  if (!hasActiveAssignment) {
    // Check if worker already submitted/was approved/rejected/timed_out for this task
    priorAssignment =
      submittedAssignments?.find((a: any) => a.task_id === id) ??
      approvedAssignments?.find((a: any) => a.task_id === id) ??
      rejectedAssignments?.find((a: any) => a.task_id === id) ??
      null;
    // Check for timed_out assignment (sweeper expired it between page loads)
    if (!priorAssignment) {
      timedOutAssignment = timedOutAssignments?.find((a: any) => a.task_id === id) ?? null;
    }
  }
  // Non-blocking: load task messages so worker can ask requester for clarification
  try {
    const msgData = await apiFetch<any>(`/v1/tasks/${id}/messages?per_page=50`, { token });
    taskMessages = msgData?.messages ?? (Array.isArray(msgData) ? msgData : []);
  } catch (_) {
    taskMessages = [];
  }
} catch (e: any) {
  error = (e as Error).message ?? "Task not found";
}

const TASK_META: Record<string, { label: string; icon: string }> = {
  label_image:          { label: "Label Image",       icon: "🖼️" },
  label_text:           { label: "Classify Text",     icon: "📝" },
  rate_quality:         { label: "Rate Quality",      icon: "⭐" },
  verify_fact:          { label: "Verify Fact",       icon: "✅" },
  moderate_content:     { label: "Moderate Content",  icon: "🛡️" },
  compare_rank:         { label: "A/B Comparison",    icon: "⚖️" },
  answer_question:      { label: "Answer Question",   icon: "💬" },
  transcription_review: { label: "Review Transcript", icon: "🎙️" },
};

const meta = task ? (TASK_META[task.type] ?? { label: task.type, icon: "🔮" }) : null;
const inp = task?.input ?? {};

// compare_rank: support both `items` array (form builder) and legacy `option_a`/`option_b`
const COMPARE_LETTERS = "ABCDEFGHIJKL";
const COMPARE_COLORS = ["text-blue-400","text-purple-400","text-emerald-400","text-amber-400","text-rose-400","text-cyan-400"];
const COMPARE_BORDER = ["hover:border-blue-500","hover:border-purple-500","hover:border-emerald-500","hover:border-amber-500","hover:border-rose-500"];
const compareItems: string[] = task?.type === "compare_rank"
  ? (Array.isArray(inp.items) && inp.items.length > 0
      ? inp.items
      : [inp.option_a ?? "Option A", inp.option_b ?? "Option B"])
  : [];

const timeoutIso = activeAssignment?.timeout_at ?? null;
---

<Layout title={`${meta?.label ?? "Task"} — CrowdSorcerer`}>
  <div class="max-w-3xl mx-auto px-6 py-10">
    <div class="flex items-center justify-between mb-8">
      <a href="/worker/marketplace" class="text-sm text-gray-400 hover:text-gray-200 transition-colors">
        ← Marketplace
      </a>
      {timeoutIso && (
        <div id="timeout-badge" class="text-sm text-amber-400 flex items-center gap-2">
          <span>⏱</span>
          <span id="timeout-label">Loading…</span>
        </div>
      )}
    </div>
    {/* Expired banner — hidden by default, shown by JS when time runs out */}
    <div id="expired-banner" class="hidden mb-6 p-4 bg-red-900/30 border border-red-700 rounded-xl text-red-300 text-sm flex items-start gap-3">
      <span class="text-lg">⏰</span>
      <div>
        <p class="font-semibold text-red-200 mb-1">Assignment expired</p>
        <p>Your time to complete this task has run out. Return to the marketplace to claim it again if slots are still available.</p>
        <a href="/worker/marketplace" class="inline-block mt-2 text-red-300 hover:text-red-100 underline">← Back to marketplace</a>
      </div>
    </div>

    {error && (
      <div class="text-center py-20">
        <div class="text-5xl mb-4">😕</div>
        <p class="text-gray-400 text-lg mb-4">{error}</p>
        <a href="/worker/marketplace" class="text-violet-400 hover:text-violet-300 text-sm">← Back to marketplace</a>
      </div>
    )}

    {task && (
      <div>
        {/* Tutorial banner for demo tasks */}
        {Array.isArray(task.tags) && task.tags.includes("tutorial") && (
          <div class="mb-6 p-4 bg-violet-900/20 border border-violet-700/50 rounded-xl text-violet-200 text-sm flex items-start gap-3">
            <span class="text-lg">🎓</span>
            <div>
              <p class="font-semibold text-violet-100 mb-1">Tutorial Task</p>
              <p>This is a practice task to help you learn the platform. Complete it to earn XP and credits. Your answer will be compared against a known correct answer to track your accuracy.</p>
            </div>
          </div>
        )}

        <!-- Task header card -->
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 mb-6">
          <div class="flex items-start gap-4">
            <span class="text-4xl">{meta?.icon}</span>
            <div class="flex-1">
              <h1 class="text-xl font-bold mb-1">{meta?.label}</h1>
              {task.task_instructions && (
                <div class="mt-2 p-3 bg-gray-800/60 border border-gray-700 rounded-lg text-sm text-gray-300">
                  <strong class="text-gray-200 block mb-1">Instructions:</strong>
                  {task.task_instructions}
                </div>
              )}
            </div>
          </div>
          <div class="flex items-center gap-6 mt-4 pt-4 border-t border-gray-800 text-sm text-gray-400">
            <span class="text-emerald-400 font-bold">+{task.worker_reward_credits ?? 2} credits</span>
            <span>Priority: <span class="capitalize">{task.priority}</span></span>
            <span>{task.assignments_completed}/{task.assignments_required} completed</span>
          </div>
        </div>

        <!-- Task content area -->
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 mb-6">
          <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Task Content</h2>

          {task.type === "label_image" && (
            <div>
              {inp.image_url && (
                <img
                  src={inp.image_url}
                  alt="Task image"
                  class="max-w-full rounded-xl mb-4 max-h-80 object-contain mx-auto block border border-gray-700"
                />
              )}
              {inp.description && (
                <p class="text-gray-300 text-sm">{inp.description}</p>
              )}
            </div>
          )}

          {task.type === "label_text" && (
            <div class="bg-gray-800 rounded-xl p-4 text-gray-200 leading-relaxed">
              {inp.text ?? "No text provided."}
            </div>
          )}

          {task.type === "rate_quality" && (
            <div>
              {inp.title && <h3 class="font-semibold mb-2">{inp.title}</h3>}
              <div class="bg-gray-800 rounded-xl p-4 text-gray-200 leading-relaxed">
                {inp.content ?? inp.text ?? "No content provided."}
              </div>
              {inp.criteria && (
                <div class="mt-3 text-sm text-gray-400">
                  <strong class="text-gray-300">Rating criteria:</strong> {inp.criteria}
                </div>
              )}
            </div>
          )}

          {task.type === "verify_fact" && (
            <div class="bg-gray-800 rounded-xl p-5 border-l-4 border-violet-500">
              <div class="text-xs text-violet-400 uppercase tracking-wider mb-2">Claim to verify</div>
              <p class="text-lg text-gray-100 font-medium">{inp.claim ?? "No claim provided."}</p>
              {inp.context && (
                <div class="mt-3 pt-3 border-t border-gray-700 text-sm text-gray-400">
                  <strong class="text-gray-300">Context:</strong> {inp.context}
                </div>
              )}
            </div>
          )}

          {task.type === "moderate_content" && (
            <div>
              {inp.content_type && (
                <div class="text-xs text-gray-500 mb-2">Content type: {inp.content_type}</div>
              )}
              <div class="bg-gray-800 rounded-xl p-4 text-gray-200 leading-relaxed">
                {inp.content ?? "No content provided."}
              </div>
              {inp.policy_context && (
                <div class="mt-3 text-sm text-gray-400 bg-gray-800/50 rounded-lg p-3">
                  <strong class="text-gray-300">Policy context:</strong> {inp.policy_context}
                </div>
              )}
            </div>
          )}

          {task.type === "compare_rank" && (
            <div>
              {inp.criteria && (
                <div class="mb-4 bg-violet-950/30 border border-violet-800/40 rounded-lg px-4 py-2.5">
                  <span class="text-xs text-violet-400 font-semibold uppercase tracking-wide">Criteria: </span>
                  <span class="text-sm text-gray-200">{inp.criteria}</span>
                </div>
              )}
              <div class:list={["grid gap-4", compareItems.length === 2 ? "grid-cols-2" : "grid-cols-2 sm:grid-cols-3"]}>
                {compareItems.map((item: string, i: number) => (
                  <div class="bg-gray-800 rounded-xl p-4">
                    <div class:list={["text-xs font-bold uppercase tracking-wider mb-2", COMPARE_COLORS[i % COMPARE_COLORS.length]]}>
                      Option {COMPARE_LETTERS[i] ?? String(i + 1)}
                    </div>
                    <p class="text-gray-200 text-sm leading-relaxed">{item}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          {task.type === "answer_question" && (
            <div>
              {inp.content && (
                <div class="bg-gray-800 rounded-xl p-4 mb-4 text-gray-200 text-sm leading-relaxed max-h-60 overflow-y-auto">
                  {inp.content}
                </div>
              )}
              <div class="bg-violet-900/20 border border-violet-700/40 rounded-xl p-4">
                <div class="text-xs text-violet-400 uppercase tracking-wider mb-2">Question</div>
                <p class="text-gray-100 font-medium">{inp.question ?? "No question provided."}</p>
              </div>
            </div>
          )}

          {task.type === "transcription_review" && (
            <div>
              {inp.audio_url && (
                <div class="mb-4">
                  <div class="text-xs text-gray-500 mb-2">Audio:</div>
                  <audio controls class="w-full rounded-lg">
                    <source src={inp.audio_url} />
                    Your browser does not support the audio element.
                  </audio>
                </div>
              )}
              <div class="text-xs text-gray-500 mb-2">AI transcript (may contain errors):</div>
              <div class="bg-gray-800 rounded-xl p-4 text-gray-300 text-sm leading-relaxed">
                {inp.ai_transcript ?? "No transcript provided."}
              </div>
            </div>
          )}
        </div>

        <!-- Response area -->
        {priorAssignment ? (
          <!-- Already submitted: show outcome panel instead of claim button -->
          <div class:list={[
            "rounded-2xl border p-6 text-center",
            priorAssignment.status === "approved"
              ? "bg-emerald-950/30 border-emerald-800"
              : priorAssignment.status === "rejected"
                ? "bg-red-950/30 border-red-800"
                : "bg-blue-950/30 border-blue-800"
          ]}>
            <div class="text-4xl mb-3">
              {priorAssignment.status === "approved" ? "✅" : priorAssignment.status === "rejected" ? "❌" : "⏳"}
            </div>
            <h2 class:list={[
              "text-lg font-bold mb-2",
              priorAssignment.status === "approved" ? "text-emerald-300"
                : priorAssignment.status === "rejected" ? "text-red-300"
                : "text-blue-300"
            ]}>
              {priorAssignment.status === "approved"
                ? "Submission accepted!"
                : priorAssignment.status === "rejected"
                  ? "Submission not selected"
                  : "Submission under review"}
            </h2>
            <p class="text-sm text-gray-400 mb-4">
              {priorAssignment.status === "approved"
                ? "Your answer was chosen as the winning response. Great work!"
                : priorAssignment.status === "rejected"
                  ? "Another worker's response was selected for this task."
                  : "Your answer has been recorded and is awaiting consensus or requester review."}
            </p>
            {priorAssignment.requester_note && (
              <div class="mb-4 mx-auto max-w-xs px-4 py-3 bg-gray-800/60 border border-gray-700 rounded-xl text-left">
                <p class="text-xs font-semibold text-gray-400 mb-1">Requester note</p>
                <p class="text-sm text-gray-300 italic">"{priorAssignment.requester_note}"</p>
              </div>
            )}
            {priorAssignment.submitted_at && (
              <p class="text-xs text-gray-500 mb-5">
                Submitted {new Date(priorAssignment.submitted_at).toLocaleString()}
                {priorAssignment.earnings_credits != null && (
                  <span class="ml-2 text-emerald-400 font-medium">
                    +{priorAssignment.earnings_credits} cr earned
                  </span>
                )}
              </p>
            )}
            <a
              href="/worker/marketplace"
              class="inline-block px-6 py-3 bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm font-medium rounded-xl transition-colors"
            >
              ← Back to marketplace
            </a>
          </div>
        ) : timedOutAssignment ? (
          <!-- Assignment was timed_out by sweeper between page loads -->
          <div class="rounded-2xl border border-amber-700 bg-amber-950/30 p-6 text-center">
            <div class="text-4xl mb-3">⏰</div>
            <h2 class="text-lg font-bold mb-2 text-amber-300">Assignment expired</h2>
            <p class="text-sm text-gray-400 mb-4">
              Your time limit ran out before you could submit. The task has been re-opened for other workers to claim.
            </p>
            <p class="text-xs text-gray-500 mb-5">
              Expired {new Date(timedOutAssignment.timeout_at ?? timedOutAssignment.updated_at).toLocaleString()}
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              {task.status === "open" && (
                <button
                  id="claim-btn"
                  data-task-id={task.id}
                  class="px-6 py-3 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold rounded-xl transition-colors"
                >
                  Claim it again
                </button>
              )}
              <a
                href="/worker/marketplace"
                class="px-6 py-3 bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm font-medium rounded-xl transition-colors"
              >
                ← Back to marketplace
              </a>
            </div>
            <p id="claim-error" class="text-sm text-red-400 mt-3 hidden"></p>
          </div>
        ) : !hasActiveAssignment ? (
          <!-- Pre-claim: show claim button -->
          <div class="text-center">
            <button
              id="claim-btn"
              data-task-id={task.id}
              class="px-10 py-4 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-2xl transition-colors text-lg shadow-lg shadow-emerald-900/40"
            >
              Claim & Start
            </button>
            <p class="text-sm text-gray-500 mt-3">
              You'll have {task.claim_timeout_minutes} min to complete after claiming.
              Max 5 active tasks at once.
            </p>
            <p id="claim-error" class="text-sm text-red-400 mt-2 hidden"></p>
          </div>
        ) : (
          <!-- Active assignment: completion form -->
          <div class="bg-gray-900 border border-emerald-800/40 rounded-2xl p-6">
            <h2 class="text-lg font-bold mb-6">Your Answer</h2>

            <!-- Type-specific response UI -->
            {task.type === "label_image" || task.type === "label_text" ? (
              <div>
                <p class="text-sm text-gray-400 mb-4">Select all that apply:</p>
                <div class="flex flex-wrap gap-2" id="labels-container">
                  {(inp.labels ?? inp.categories ?? ["Category A", "Category B", "Category C"]).map((label: string) => (
                    <button
                      type="button"
                      class="label-btn px-4 py-2 border border-gray-700 hover:border-emerald-500 rounded-xl text-sm transition-all"
                      data-label={label}
                    >
                      {label}
                    </button>
                  ))}
                </div>
                <p class="text-xs text-gray-500 mt-3">Click to select/deselect. Multiple selections allowed.</p>
              </div>
            ) : task.type === "rate_quality" ? (
              <div>
                <p class="text-sm text-gray-400 mb-4">Select a quality rating:</p>
                <div class="flex gap-3 mb-6">
                  {[1, 2, 3, 4, 5].map((n) => (
                    <button
                      type="button"
                      class="star-btn flex-1 py-4 border border-gray-700 hover:border-amber-500 rounded-xl text-center transition-all"
                      data-rating={String(n)}
                    >
                      <div class="text-2xl mb-1">{"⭐".repeat(n)}</div>
                      <div class="text-xs text-gray-400">
                        {n === 1 ? "Poor" : n === 2 ? "Fair" : n === 3 ? "Good" : n === 4 ? "Great" : "Excellent"}
                      </div>
                    </button>
                  ))}
                </div>
                <label for="justification" class="block text-sm text-gray-400 mb-2">Justification (optional)</label>
                <textarea
                  id="justification"
                  rows="3"
                  placeholder="What influenced your rating?"
                  class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-violet-500/40 focus:border-violet-500"
                ></textarea>
              </div>
            ) : task.type === "verify_fact" ? (
              <div>
                <p class="text-sm text-gray-400 mb-4">Is the claim true or false?</p>
                <div class="grid grid-cols-3 gap-3 mb-6">
                  {[
                    { verdict: "true", label: "✅ True", color: "hover:border-emerald-500" },
                    { verdict: "false", label: "❌ False", color: "hover:border-red-500" },
                    { verdict: "unverifiable", label: "❓ Can't tell", color: "hover:border-gray-400" },
                  ].map(({ verdict, label, color }) => (
                    <button
                      type="button"
                      class={`verdict-btn py-4 border border-gray-700 ${color} rounded-xl text-sm font-medium transition-all`}
                      data-verdict={verdict}
                    >
                      {label}
                    </button>
                  ))}
                </div>
                <label for="citation" class="block text-sm text-gray-400 mb-2">Citation or source (optional)</label>
                <input
                  id="citation"
                  type="text"
                  placeholder="https://..."
                  class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-violet-500/40 focus:border-violet-500"
                />
              </div>
            ) : task.type === "moderate_content" ? (
              <div>
                <p class="text-sm text-gray-400 mb-4">Your moderation decision:</p>
                <div class="grid grid-cols-3 gap-3 mb-6">
                  {[
                    { decision: "approve", label: "✅ Approve", color: "hover:border-emerald-500" },
                    { decision: "reject", label: "🚫 Reject", color: "hover:border-red-500" },
                    { decision: "escalate", label: "⚠️ Escalate", color: "hover:border-amber-500" },
                  ].map(({ decision, label, color }) => (
                    <button
                      type="button"
                      class={`mod-btn py-4 border border-gray-700 ${color} rounded-xl text-sm font-medium transition-all`}
                      data-decision={decision}
                    >
                      {label}
                    </button>
                  ))}
                </div>
                <label for="mod-reason" class="block text-sm text-gray-400 mb-2">Reason</label>
                <textarea
                  id="mod-reason"
                  rows="3"
                  placeholder="Why did you make this decision?"
                  class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-violet-500/40 focus:border-violet-500"
                ></textarea>
              </div>
            ) : task.type === "compare_rank" ? (
              <div>
                {inp.criteria && (
                  <p class="text-sm text-violet-300 font-medium mb-4">{inp.criteria}</p>
                )}
                <p class="text-sm text-gray-400 mb-4">Select the best option:</p>
                <div class:list={["grid gap-3 mb-3", compareItems.length === 2 ? "grid-cols-3" : "grid-cols-2 sm:grid-cols-3"]}>
                  {compareItems.map((item: string, i: number) => (
                    <button
                      type="button"
                      class:list={["rank-btn py-3 px-4 border border-gray-700 rounded-xl text-sm font-medium transition-all text-left", COMPARE_BORDER[i % COMPARE_BORDER.length]]}
                      data-choice={(COMPARE_LETTERS[i] ?? String(i + 1)).toLowerCase()}
                    >
                      <div class="text-xs text-gray-500 mb-0.5">Option {COMPARE_LETTERS[i] ?? String(i + 1)}</div>
                      <div class="text-xs text-gray-300 line-clamp-2">{item}</div>
                    </button>
                  ))}
                  <button
                    type="button"
                    class="rank-btn py-3 px-4 border border-gray-700 hover:border-gray-400 rounded-xl text-sm font-medium transition-all"
                    data-choice="tie"
                  >
                    ⚪ <span class="block text-xs text-gray-400 mt-0.5">About equal</span>
                  </button>
                </div>
                <label for="rank-reason" class="block text-sm text-gray-400 mb-2">Reason (optional)</label>
                <textarea
                  id="rank-reason"
                  rows="3"
                  placeholder="Why is this option better?"
                  class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-violet-500/40 focus:border-violet-500"
                ></textarea>
              </div>
            ) : task.type === "answer_question" ? (
              <div>
                <label for="free-answer" class="block text-sm text-gray-400 mb-2">Your answer:</label>
                <textarea
                  id="free-answer"
                  rows="5"
                  placeholder="Type your answer here..."
                  class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-violet-500/40 focus:border-violet-500"
                ></textarea>
              </div>
            ) : task.type === "transcription_review" ? (
              <div>
                <label for="corrected-text" class="block text-sm text-gray-400 mb-2">Corrected transcript:</label>
                <textarea
                  id="corrected-text"
                  rows="8"
                  class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm font-mono text-gray-200 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-violet-500/40 focus:border-violet-500"
                >{inp.ai_transcript ?? ""}</textarea>
                <p class="text-xs text-gray-500 mt-1">Edit any errors in the transcript above.</p>
              </div>
            ) : (
              <div class="text-gray-500 text-sm">
                No completion UI for task type: {task.type}
              </div>
            )}

            <!-- Worker note -->
            <div class="mt-6">
              <label for="worker-note" class="block text-sm text-gray-400 mb-2">Note to requester (optional)</label>
              <textarea
                id="worker-note"
                rows="2"
                placeholder="Anything to flag or add context?"
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-violet-500/40 focus:border-violet-500"
              ></textarea>
            </div>

            <!-- Actions -->
            <div class="flex gap-3 mt-6">
              <button
                id="submit-btn"
                data-task-id={task.id}
                class="flex-1 py-3 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold rounded-xl transition-colors"
              >
                Submit answer (+{task.worker_reward_credits ?? 2} credits)
              </button>
              <button
                id="release-btn"
                data-task-id={task.id}
                class="px-6 py-3 border border-gray-700 hover:border-red-600/60 text-gray-400 hover:text-red-400 text-sm rounded-xl transition-colors"
              >
                Release
              </button>
            </div>
            <p id="submit-error" class="text-sm text-red-400 mt-3 hidden"></p>
          </div>
        )}
      </div>
    )}

    {/* ── Task messaging ──────────────────────────────────────────────────── */}
    {task && (hasActiveAssignment || priorAssignment) && (
      <div class="mt-8 max-w-3xl mx-auto">
        <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
          <div class="px-5 py-4 border-b border-gray-800 flex items-center justify-between">
            <h3 class="text-sm font-semibold text-gray-300 flex items-center gap-2">
              💬 Ask the requester
              {taskMessages.length > 0 && (
                <span class="text-xs text-gray-500 font-normal">({taskMessages.length} message{taskMessages.length !== 1 ? "s" : ""})</span>
              )}
            </h3>
            <span class="text-xs text-gray-500">Message history is visible to both sides</span>
          </div>

          {/* Message thread */}
          <div id="msg-thread" class="divide-y divide-gray-800 max-h-72 overflow-y-auto">
            {taskMessages.length === 0 ? (
              <div class="px-5 py-8 text-center">
                <div class="text-2xl mb-2">✉️</div>
                <p class="text-sm text-gray-500">No messages yet. Ask the requester if you need clarification.</p>
              </div>
            ) : (
              taskMessages.map((msg: any) => {
                const isMe = msg.sender_id === user?.id;
                return (
                  <div class={`px-5 py-3 ${isMe ? "bg-gray-800/30" : ""}`}>
                    <div class="flex items-baseline gap-2 mb-1">
                      <span class={`text-xs font-semibold ${isMe ? "text-violet-400" : "text-amber-400"}`}>
                        {isMe ? "You" : (msg.sender_name ?? "Requester")}
                      </span>
                      <span class="text-xs text-gray-500">
                        {new Date(msg.created_at).toLocaleString("en-US", { month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" })}
                      </span>
                    </div>
                    <p class="text-sm text-gray-300 whitespace-pre-wrap leading-relaxed">
                      {msg.body ?? msg.content ?? msg.message ?? ""}
                    </p>
                  </div>
                );
              })
            )}
          </div>

          {/* Compose */}
          <div class="px-5 py-4 border-t border-gray-800 flex gap-3">
            <textarea
              id="msg-body"
              rows="2"
              placeholder="Ask about task requirements, report an issue, or request clarification…"
              class="flex-1 px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-violet-500/40 focus:border-violet-500 resize-none"
            ></textarea>
            <button
              id="msg-send"
              data-task-id={task.id}
              class="shrink-0 px-4 py-2 bg-violet-700 hover:bg-violet-600 text-white text-sm font-medium rounded-lg transition-colors self-end"
            >
              Send
            </button>
          </div>
          <p id="msg-error" class="hidden px-5 pb-3 text-xs text-red-400"></p>
        </div>
      </div>
    )}
  </div>

  <!-- Release task confirmation modal -->
  <div id="release-modal" class="hidden fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4">
    <div class="bg-gray-900 border border-gray-800 rounded-xl w-full max-w-sm p-6">
      <h2 class="font-semibold text-gray-200 mb-2">Release this task?</h2>
      <p class="text-sm text-gray-400 mb-5">It will return to the marketplace and you'll lose your progress. Your assignment will be cancelled.</p>
      <div id="release-error" class="text-sm text-red-400 bg-red-950/20 border border-red-800 rounded-lg px-3 py-2 hidden mb-3"></div>
      <div class="flex gap-3 justify-end">
        <button type="button" id="release-cancel" class="px-4 py-2 text-sm text-gray-300 border border-gray-700 rounded-lg hover:bg-gray-800">Keep working</button>
        <button type="button" id="release-confirm" class="px-4 py-2 text-sm bg-red-700 hover:bg-red-600 text-white rounded-lg font-medium">Release task</button>
      </div>
    </div>
  </div>
</Layout>

<input type="hidden" id="task-type" value={task?.type ?? ""} />
<input type="hidden" id="task-id" value={task?.id ?? ""} />
<input type="hidden" id="timeout-at" value={timeoutIso ?? ""} />

<script>
// ─── Response builder ─────────────────────────────────────────────────────
function getResponse(): Record<string, unknown> {
  const type = (document.getElementById("task-type") as HTMLInputElement)?.value;
  switch (type) {
    case "label_image":
    case "label_text": {
      const labels = [...document.querySelectorAll<HTMLElement>(".label-btn.selected")]
        .map(b => b.dataset.label!);
      return { labels };
    }
    case "rate_quality": {
      const ratingEl = document.querySelector<HTMLElement>(".star-btn.selected");
      const rating = ratingEl ? parseInt(ratingEl.dataset.rating!) : 0;
      const justification = (document.getElementById("justification") as HTMLTextAreaElement)?.value ?? "";
      return { rating, justification };
    }
    case "verify_fact": {
      const verdictEl = document.querySelector<HTMLElement>(".verdict-btn.selected");
      return {
        verdict: verdictEl?.dataset.verdict ?? "",
        citation: (document.getElementById("citation") as HTMLInputElement)?.value ?? "",
      };
    }
    case "moderate_content": {
      const decisionEl = document.querySelector<HTMLElement>(".mod-btn.selected");
      return {
        decision: decisionEl?.dataset.decision ?? "",
        reason: (document.getElementById("mod-reason") as HTMLTextAreaElement)?.value ?? "",
      };
    }
    case "compare_rank": {
      const choiceEl = document.querySelector<HTMLElement>(".rank-btn.selected");
      return {
        choice: choiceEl?.dataset.choice ?? "",
        reason: (document.getElementById("rank-reason") as HTMLTextAreaElement)?.value ?? "",
      };
    }
    case "answer_question":
      return { answer: (document.getElementById("free-answer") as HTMLTextAreaElement)?.value ?? "" };
    case "transcription_review":
      return { corrected_text: (document.getElementById("corrected-text") as HTMLTextAreaElement)?.value ?? "" };
    default:
      return {};
  }
}

function setSelected(btn: HTMLElement, groupSelector: string) {
  document.querySelectorAll<HTMLElement>(groupSelector).forEach(b => {
    b.classList.remove("selected", "bg-emerald-900/30", "border-emerald-500");
    b.classList.add("border-gray-700");
  });
  btn.classList.add("selected", "bg-emerald-900/30", "border-emerald-500");
  btn.classList.remove("border-gray-700");
}

function toggleLabel(btn: HTMLElement) {
  if (btn.classList.contains("selected")) {
    btn.classList.remove("selected", "bg-emerald-900/30", "border-emerald-500");
    btn.classList.add("border-gray-700");
  } else {
    btn.classList.add("selected", "bg-emerald-900/30", "border-emerald-500");
    btn.classList.remove("border-gray-700");
  }
}

// Wire up buttons
document.querySelectorAll<HTMLElement>(".label-btn").forEach(btn =>
  btn.addEventListener("click", () => toggleLabel(btn))
);
["star-btn", "verdict-btn", "mod-btn", "rank-btn"].forEach(cls => {
  document.querySelectorAll<HTMLElement>(`.${cls}`).forEach(btn =>
    btn.addEventListener("click", () => setSelected(btn, `.${cls}`))
  );
});

// ─── Claim ────────────────────────────────────────────────────────────────
document.getElementById("claim-btn")?.addEventListener("click", async (e) => {
  const btn = e.currentTarget as HTMLButtonElement;
  const taskId = btn.dataset.taskId;
  const errEl = document.getElementById("claim-error")!;

  btn.textContent = "Claiming...";
  btn.disabled = true;

  try {
    const res = await fetch(`/api/worker/tasks/${taskId}/claim`, { method: "POST" });
    if (res.ok) {
      window.location.reload();
    } else {
      const body = await res.json().catch(() => ({}));
      errEl.textContent = body.detail ?? "Failed to claim. Try again.";
      errEl.classList.remove("hidden");
      btn.textContent = "Claim & Start";
      btn.disabled = false;
    }
  } catch {
    errEl.textContent = "Network error. Please try again.";
    errEl.classList.remove("hidden");
    btn.textContent = "Claim & Start";
    btn.disabled = false;
  }
});

// ─── Submission validation ────────────────────────────────────────────────
function validateResponse(type: string): string {
  switch (type) {
    case "label_image":
    case "label_text": {
      const selected = document.querySelectorAll(".label-btn.selected");
      if (selected.length === 0) return "Please select at least one label before submitting.";
      return "";
    }
    case "rate_quality": {
      const ratingEl = document.querySelector(".star-btn.selected");
      if (!ratingEl) return "Please select a quality rating (1–5 stars) before submitting.";
      return "";
    }
    case "verify_fact": {
      const verdictEl = document.querySelector(".verdict-btn.selected");
      if (!verdictEl) return "Please select a verdict (True / False / Can't tell) before submitting.";
      return "";
    }
    case "moderate_content": {
      const decisionEl = document.querySelector(".mod-btn.selected");
      if (!decisionEl) return "Please select a moderation decision before submitting.";
      return "";
    }
    case "compare_rank": {
      const choiceEl = document.querySelector(".rank-btn.selected");
      if (!choiceEl) return "Please select the best option before submitting.";
      return "";
    }
    case "answer_question": {
      const ans = ((document.getElementById("free-answer") as HTMLTextAreaElement)?.value ?? "").trim();
      if (!ans) return "Please write an answer before submitting.";
      if (ans.length < 5) return "Your answer seems too short. Please provide more detail.";
      return "";
    }
    case "transcription_review": {
      const txt = ((document.getElementById("corrected-text") as HTMLTextAreaElement)?.value ?? "").trim();
      if (!txt) return "Please provide the corrected transcript before submitting.";
      return "";
    }
    default:
      return "";
  }
}

// ─── Submit ───────────────────────────────────────────────────────────────
document.getElementById("submit-btn")?.addEventListener("click", async (e) => {
  const btn = e.currentTarget as HTMLButtonElement;
  const taskId = btn.dataset.taskId;
  const errEl = document.getElementById("submit-error")!;
  const originalText = btn.textContent ?? "Submit answer";

  // Client-side validation
  const type = (document.getElementById("task-type") as HTMLInputElement)?.value ?? "";
  const validationError = validateResponse(type);
  if (validationError) {
    errEl.textContent = validationError;
    errEl.classList.remove("hidden");
    errEl.scrollIntoView({ behavior: "smooth", block: "nearest" });
    return;
  }
  errEl.classList.add("hidden");

  const response = getResponse();
  const note = (document.getElementById("worker-note") as HTMLTextAreaElement)?.value ?? "";

  btn.textContent = "Submitting…";
  btn.disabled = true;

  try {
    const res = await fetch(`/api/worker/tasks/${taskId}/submit`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ response, worker_note: note || null }),
    });

    if (res.ok) {
      const data = await res.json();
      const params = new URLSearchParams({
        credits: String(data.earnings_credits ?? 0),
        xp: String(data.xp_earned ?? 0),
        streak_multiplier: String(data.streak_multiplier ?? 1),
        streak_days: String(data.streak_days ?? 0),
      });
      window.location.href = `/worker/submitted?${params}`;
    } else {
      const body = await res.json().catch(() => ({}));
      if (res.status === 410) {
        // Assignment expired between page load and submit — show CTA to marketplace
        errEl.innerHTML = 'Assignment expired — your time ran out. Redirecting to marketplace…&nbsp;<a href="/worker/marketplace" class="underline font-medium">Go now →</a>';
        errEl.classList.remove("hidden");
        btn.disabled = true;
        btn.textContent = "Assignment expired";
        btn.classList.remove("bg-emerald-600", "hover:bg-emerald-500");
        btn.classList.add("bg-gray-700", "cursor-not-allowed", "opacity-60");
        // Disable release button too
        const relBtn = document.getElementById("release-btn") as HTMLButtonElement | null;
        if (relBtn) { relBtn.disabled = true; relBtn.textContent = "Expired"; relBtn.classList.add("opacity-40", "cursor-not-allowed"); }
        // Auto-redirect after 4 seconds
        setTimeout(() => { window.location.href = "/worker/marketplace"; }, 4000);
      } else {
        errEl.textContent = body.detail ?? "Submission failed. Try again.";
        errEl.classList.remove("hidden");
        btn.disabled = false;
        btn.textContent = originalText;
      }
    }
  } catch {
    errEl.textContent = "Network error. Please try again.";
    errEl.classList.remove("hidden");
    btn.disabled = false;
    btn.textContent = originalText;
  }
});

// ─── Release — confirmation modal ─────────────────────────────────────────
const releaseModal = document.getElementById("release-modal");
const releaseErrEl = document.getElementById("release-error");
document.getElementById("release-btn")?.addEventListener("click", () => {
  if (releaseErrEl) releaseErrEl.classList.add("hidden");
  releaseModal?.classList.remove("hidden");
});
document.getElementById("release-cancel")?.addEventListener("click", () => {
  releaseModal?.classList.add("hidden");
});
document.getElementById("release-confirm")?.addEventListener("click", async () => {
  const taskId = document.getElementById("release-btn")?.dataset.taskId;
  const confirmBtn = document.getElementById("release-confirm") as HTMLButtonElement | null;
  if (confirmBtn) { confirmBtn.textContent = "Releasing…"; confirmBtn.disabled = true; }
  try {
    const res = await fetch(`/api/worker/tasks/${taskId}/release`, { method: "DELETE" });
    if (res.ok || res.status === 204) {
      window.location.href = "/worker/marketplace";
    } else {
      const body = await res.json().catch(() => ({}));
      releaseModal?.classList.add("hidden");
      if (releaseErrEl) { releaseErrEl.textContent = body.detail ?? "Failed to release. Please try again."; releaseErrEl.classList.remove("hidden"); }
      if (confirmBtn) { confirmBtn.textContent = "Release task"; confirmBtn.disabled = false; }
    }
  } catch {
    releaseModal?.classList.add("hidden");
    if (releaseErrEl) { releaseErrEl.textContent = "Network error — please try again."; releaseErrEl.classList.remove("hidden"); }
    if (confirmBtn) { confirmBtn.textContent = "Release task"; confirmBtn.disabled = false; }
  }
});

// ─── Assignment timeout countdown ─────────────────────────────────────────
(function () {
  const isoEl = document.getElementById("timeout-at") as HTMLInputElement | null;
  if (!isoEl?.value) return;

  const expiresAt = new Date(isoEl.value).getTime();
  const labelEl = document.getElementById("timeout-label");
  const badgeEl = document.getElementById("timeout-badge");
  const bannerEl = document.getElementById("expired-banner");
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;

  function pad(n: number): string {
    return String(n).padStart(2, "0");
  }

  function tick() {
    const remaining = expiresAt - Date.now();

    if (remaining <= 0) {
      // Assignment has expired
      if (labelEl) labelEl.textContent = "Expired";
      if (badgeEl) {
        badgeEl.classList.remove("text-amber-400");
        badgeEl.classList.add("text-red-400");
      }
      if (bannerEl) bannerEl.classList.remove("hidden");
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = "Assignment expired";
        submitBtn.classList.remove("bg-emerald-600", "hover:bg-emerald-500");
        submitBtn.classList.add("bg-gray-700", "cursor-not-allowed", "opacity-60");
      }
      // Disable release button too — it will 404 once the assignment is timed_out
      const releaseBtn = document.getElementById("release-btn") as HTMLButtonElement | null;
      if (releaseBtn) {
        releaseBtn.disabled = true;
        releaseBtn.textContent = "Expired";
        releaseBtn.classList.add("opacity-40", "cursor-not-allowed");
        releaseBtn.classList.remove("hover:border-red-600/60", "hover:text-red-400");
      }
      clearInterval(timer);
      return;
    }

    const totalSecs = Math.ceil(remaining / 1000);
    const mins = Math.floor(totalSecs / 60);
    const secs = totalSecs % 60;

    if (labelEl) labelEl.textContent = `${pad(mins)}:${pad(secs)} remaining`;

    // Turn red when under 5 minutes
    if (remaining < 5 * 60 * 1000) {
      if (badgeEl) {
        badgeEl.classList.remove("text-amber-400");
        badgeEl.classList.add("text-red-400");
      }
    }
  }

  tick(); // run immediately so there's no blank flash
  const timer = setInterval(tick, 1000);
})();

// ─── Task messaging ────────────────────────────────────────────────────────
(function () {
  const sendBtn  = document.getElementById("msg-send") as HTMLButtonElement | null;
  const bodyEl   = document.getElementById("msg-body") as HTMLTextAreaElement | null;
  const errorEl  = document.getElementById("msg-error");
  const thread   = document.getElementById("msg-thread");
  if (!sendBtn || !bodyEl) return;

  sendBtn.addEventListener("click", async () => {
    const body = bodyEl.value.trim();
    if (!body) { bodyEl.focus(); return; }
    const taskId = sendBtn.dataset.taskId!;

    sendBtn.disabled = true;
    sendBtn.textContent = "Sending…";
    if (errorEl) errorEl.classList.add("hidden");

    try {
      const res = await fetch(`/api/tasks/${taskId}/messages`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ body }),
      });
      if (res.ok) {
        const msg = await res.json().catch(() => ({}));
        bodyEl.value = "";
        // Append message to thread
        if (thread) {
          // Remove empty-state if present
          const empty = thread.querySelector("div.px-5.py-8");
          if (empty) empty.remove();
          // Add new message row
          const row = document.createElement("div");
          row.className = "px-5 py-3 bg-gray-800/30";
          const now = new Date().toLocaleString("en-US", { month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" });
          row.innerHTML = `<div class="flex items-baseline gap-2 mb-1"><span class="text-xs font-semibold text-violet-400">You</span><span class="text-xs text-gray-500">${now}</span></div><p class="text-sm text-gray-300 whitespace-pre-wrap leading-relaxed">${(msg.body ?? body).replace(/</g, "&lt;")}</p>`;
          thread.appendChild(row);
          thread.scrollTop = thread.scrollHeight;
        }
      } else {
        const data = await res.json().catch(() => ({}));
        if (errorEl) {
          errorEl.textContent = data.detail ?? "Failed to send message.";
          errorEl.classList.remove("hidden");
        }
      }
    } catch {
      if (errorEl) {
        errorEl.textContent = "Network error. Try again.";
        errorEl.classList.remove("hidden");
      }
    } finally {
      sendBtn.disabled = false;
      sendBtn.textContent = "Send";
    }
  });

  // Send on Ctrl+Enter / Cmd+Enter
  bodyEl.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Enter" && (e.ctrlKey || e.metaKey)) {
      e.preventDefault();
      sendBtn.click();
    }
  });
})();
</script>
