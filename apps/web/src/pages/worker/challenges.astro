---
/**
 * Daily Challenges — today's challenge + history.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);

if (!token) {
  return Astro.redirect("/login?next=/worker/challenges");
}

let todayChallenge: any = null;
let history: any = [];
let error: string | null = null;

try {
  [todayChallenge, history] = await Promise.all([
    apiFetch("/v1/challenges/today", { token }),
    apiFetch("/v1/challenges/history", { token }).catch(() => []),
  ]);
} catch (e: any) {
  error = e.message ?? "Failed to load challenges";
}

const TASK_TYPE_LABELS: Record<string, string> = {
  label_image: "Label Image", label_text: "Classify Text",
  rate_quality: "Rate Quality", verify_fact: "Verify Fact",
  moderate_content: "Moderate Content", compare_rank: "A/B Compare",
  answer_question: "Answer Question", transcription_review: "Review Transcript",
};

const TASK_TYPE_ICONS: Record<string, string> = {
  label_image: "🖼️", label_text: "📝", rate_quality: "⭐",
  verify_fact: "🔍", moderate_content: "🛡️", compare_rank: "⚖️",
  answer_question: "💬", transcription_review: "🎧",
};
---

<Layout title="Daily Challenges — CrowdSorcerer">
  <div class="max-w-4xl mx-auto px-6 py-10">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold">📅 Daily Challenges</h1>
        <p class="text-gray-400 text-sm mt-0.5">Complete tasks to earn bonus XP and credits</p>
      </div>
      <a href="/worker" class="text-sm text-gray-400 hover:text-white transition-colors">
        ← Back to Earn
      </a>
    </div>

    {error ? (
      <div class="text-red-400 bg-red-900/20 border border-red-800/40 rounded-xl p-6 text-center">
        {error === "Not enrolled as a worker." ? (
          <div>
            <p class="mb-4">You need to enroll as a worker to access daily challenges.</p>
            <a href="/worker" class="text-emerald-400 hover:text-emerald-300">Enroll now →</a>
          </div>
        ) : error}
      </div>
    ) : todayChallenge && (
      <div>
        <!-- Today's challenge card -->
        <div class={`rounded-2xl p-7 mb-8 border ${
          todayChallenge.bonus_claimed
            ? "bg-gradient-to-br from-emerald-900/30 to-gray-900 border-emerald-700/40"
            : todayChallenge.is_complete
            ? "bg-gradient-to-br from-amber-900/30 to-gray-900 border-amber-600/60"
            : "bg-gradient-to-br from-indigo-900/20 to-gray-900 border-indigo-700/40"
        }`}>
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-3xl">
                  {TASK_TYPE_ICONS[todayChallenge.challenge?.task_type] ?? "🎯"}
                </span>
                <div>
                  <div class="text-xs text-gray-400 uppercase tracking-wider mb-0.5">Today's Challenge</div>
                  <h2 class="text-xl font-bold">{todayChallenge.challenge?.title}</h2>
                </div>
              </div>
              <p class="text-gray-300 text-sm mb-5 leading-relaxed">
                {todayChallenge.challenge?.description}
              </p>

              <!-- Rewards -->
              <div class="flex flex-wrap gap-3 mb-5">
                <span class="flex items-center gap-1.5 text-sm bg-indigo-900/40 text-indigo-300 border border-indigo-800/40 px-3 py-1.5 rounded-lg">
                  ⭐ +{todayChallenge.challenge?.bonus_xp} XP bonus
                </span>
                <span class="flex items-center gap-1.5 text-sm bg-amber-900/40 text-amber-300 border border-amber-800/40 px-3 py-1.5 rounded-lg">
                  💰 +{todayChallenge.challenge?.bonus_credits} credits bonus
                </span>
                <span class="flex items-center gap-1.5 text-sm bg-gray-800 text-gray-300 border border-gray-700 px-3 py-1.5 rounded-lg">
                  {TASK_TYPE_LABELS[todayChallenge.challenge?.task_type] ?? todayChallenge.challenge?.task_type} tasks
                </span>
              </div>

              <!-- Progress -->
              <div class="mb-4">
                <div class="flex items-center justify-between text-sm mb-2">
                  <span class="text-gray-400">Progress</span>
                  <span class={todayChallenge.is_complete ? "text-emerald-400 font-semibold" : "text-gray-300"}>
                    {todayChallenge.tasks_completed} / {todayChallenge.challenge?.target_count} tasks
                  </span>
                </div>
                <div class="h-3 bg-gray-800 rounded-full overflow-hidden">
                  <div
                    class={`h-full rounded-full transition-all ${
                      todayChallenge.bonus_claimed
                        ? "bg-gradient-to-r from-emerald-600 to-emerald-400"
                        : todayChallenge.is_complete
                        ? "bg-gradient-to-r from-amber-600 to-amber-400"
                        : "bg-gradient-to-r from-indigo-600 to-indigo-400"
                    }`}
                    style={`width: ${Math.min(100, (todayChallenge.tasks_completed / todayChallenge.challenge?.target_count) * 100)}%`}
                  ></div>
                </div>
              </div>
            </div>
          </div>

          <!-- CTA -->
          {todayChallenge.bonus_claimed ? (
            <div class="flex items-center gap-3 text-emerald-400 font-semibold">
              <span class="text-2xl">✅</span>
              <span>Challenge complete! Bonus claimed for today.</span>
            </div>
          ) : todayChallenge.is_complete ? (
            <div class="flex items-center gap-4">
              <button
                id="claim-btn"
                class="px-6 py-3 bg-amber-600 hover:bg-amber-500 text-white font-semibold rounded-xl transition-colors text-sm"
              >
                🎁 Claim Your Bonus!
              </button>
              <p id="claim-msg" class="text-sm text-gray-400 hidden"></p>
            </div>
          ) : (
            <a
              href={`/worker/marketplace?type=${todayChallenge.challenge?.task_type}`}
              class="inline-flex items-center gap-2 px-6 py-3 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold rounded-xl transition-colors text-sm"
            >
              Find {TASK_TYPE_LABELS[todayChallenge.challenge?.task_type] ?? "tasks"} →
            </a>
          )}
        </div>

        <!-- Challenge history -->
        {history.length > 0 && (
          <div>
            <h2 class="text-lg font-semibold mb-4">Challenge History</h2>
            <div class="space-y-3">
              {history.map((item: any) => (
                <div class={`flex items-center justify-between bg-gray-900 border rounded-xl px-5 py-4 ${
                  item.bonus_claimed ? "border-emerald-800/40" : item.is_complete ? "border-amber-800/30" : "border-gray-800"
                }`}>
                  <div class="flex items-center gap-3">
                    <span class="text-xl">
                      {item.bonus_claimed ? "✅" : item.is_complete ? "⏳" : "❌"}
                    </span>
                    <div>
                      <div class="font-medium text-sm">{item.challenge?.title}</div>
                      <div class="text-xs text-gray-500 mt-0.5">
                        {new Date(item.challenge?.challenge_date).toLocaleDateString(undefined, { weekday: "short", month: "short", day: "numeric" })}
                      </div>
                    </div>
                  </div>
                  <div class="text-right text-sm">
                    <div class={`font-semibold ${item.bonus_claimed ? "text-emerald-400" : item.is_complete ? "text-amber-400" : "text-gray-500"}`}>
                      {item.bonus_claimed
                        ? `+${item.challenge?.bonus_xp} XP + ${item.challenge?.bonus_credits} cr`
                        : item.is_complete
                        ? "Completed (unclaimed)"
                        : `${item.tasks_completed}/${item.challenge?.target_count}`}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    )}
  </div>
</Layout>

<script>
  import { extractDetail } from "@/lib/api";

  const btn = document.getElementById("claim-btn") as HTMLButtonElement | null;
  const msg = document.getElementById("claim-msg");

  btn?.addEventListener("click", async () => {
    if (btn) {
      btn.textContent = "Claiming...";
      btn.disabled = true;
    }

    try {
      const res = await fetch("/api/challenges/claim", { method: "POST" });
      if (res.ok) {
        // Update DOM in place — no page reload needed
        // 1. Replace the CTA button area with "claimed" state
        const ctaContainer = btn.parentElement;
        if (ctaContainer) {
          const claimed = document.createElement("div");
          claimed.className = "flex items-center gap-3 text-emerald-400 font-semibold";
          claimed.innerHTML = '<span class="text-2xl">✅</span><span>Challenge complete! Bonus claimed for today.</span>';
          ctaContainer.replaceWith(claimed);
        }
        // 2. Update the progress bar to emerald (claimed colour)
        const progressBar = document.querySelector<HTMLElement>(".h-full.rounded-full");
        if (progressBar) {
          progressBar.className = "h-full rounded-full transition-all bg-gradient-to-r from-emerald-600 to-emerald-400";
          progressBar.style.width = "100%";
        }
        // 3. Update the card border to reflect completion
        const card = document.querySelector<HTMLElement>("[class*='from-amber-900']");
        if (card) {
          card.className = card.className.replace("border-amber-600/60", "border-emerald-600/60");
        }
      } else {
        const body = await res.json().catch(() => ({}));
        if (msg) {
          msg.textContent = extractDetail(body, "Failed to claim. Try again.");
          msg.classList.remove("hidden");
        }
        if (btn) {
          btn.textContent = "🎁 Claim Your Bonus!";
          btn.disabled = false;
        }
      }
    } catch {
      if (msg) {
        msg.textContent = "Network error. Please try again.";
        msg.classList.remove("hidden");
      }
      if (btn) {
        btn.textContent = "🎁 Claim Your Bonus!";
        btn.disabled = false;
      }
    }
  });
</script>
