---
/**
 * Worker dashboard — shows stats, active assignments, and quick access to marketplace.
 * If not enrolled as a worker, shows an enrollment prompt.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);

if (!token) {
  return Astro.redirect("/login?next=/worker");
}

let user: any = null;
let stats: any = null;
let assignments: any = [];
let isWorker = false;
let dailyChallenge: any = null;
let reputation: any = null;
let notifications: any = null;

let profileStatus: any = null;
let unreadMessages = 0;
let onboardingStatus: any = null;

try {
  user = await apiFetch("/v1/users/me", { token });
  isWorker = user?.role === "worker" || user?.role === "both";

  if (isWorker) {
    [stats, assignments, dailyChallenge, reputation, notifications, profileStatus, onboardingStatus] = await Promise.all([
      apiFetch("/v1/worker/stats", { token }),
      apiFetch("/v1/worker/assignments?status=active&page_size=5", { token }),
      apiFetch("/v1/challenges/today", { token }).catch(() => null),
      apiFetch("/v1/reputation/me", { token }).catch(() => null),
      apiFetch("/v1/notifications?unread_only=true&page_size=3", { token }).catch(() => null),
      apiFetch("/v1/users/me/profile-status", { token }).catch(() => null),
      apiFetch<any>("/v1/onboarding/status", { token }).catch(() => null),
    ]);
    const msgCount: any = await apiFetch("/v1/tasks/messages/unread-count", { token }).catch(() => null);
    unreadMessages = msgCount?.count ?? 0;
  }
} catch (e) {
  // Non-fatal; page will show enrollment prompt
}

// Auto-redirect brand-new workers (0 steps complete, never skipped) to onboarding
const isNewWorker = Boolean(
  isWorker &&
  onboardingStatus &&
  onboardingStatus.completed_steps === 0 &&
  !onboardingStatus.skipped_at &&
  !onboardingStatus.is_complete
);
if (isNewWorker) {
  return Astro.redirect("/worker/onboarding");
}

// Show onboarding banner if worker has not completed/skipped/dismissed onboarding
const showOnboardingBanner = Boolean(
  isWorker &&
  onboardingStatus &&
  !onboardingStatus.is_complete &&
  !onboardingStatus.banner_dismissed &&
  !onboardingStatus.skipped_at
);

const profilePct = profileStatus?.completeness_pct ?? 100;
const showProfileBanner = isWorker && profilePct < 80;

const LEVEL_NAMES: Record<number, string> = {
  1: "Apprentice", 2: "Novice", 3: "Learner", 4: "Explorer", 5: "Contributor",
  6: "Analyst", 7: "Specialist", 8: "Expert", 9: "Veteran", 10: "Elite",
  11: "Master", 12: "Grand Master", 13: "Champion", 14: "Legend", 15: "Mythic",
  16: "Transcendent", 17: "Ascendant", 18: "Radiant", 19: "Immortal", 20: "Divine",
};

function levelName(level: number): string {
  return LEVEL_NAMES[level] ?? `Level ${level}`;
}

const TASK_TYPE_LABELS: Record<string, string> = {
  label_image: "Label Image", label_text: "Classify Text",
  rate_quality: "Rate Quality", verify_fact: "Verify Fact",
  moderate_content: "Moderate Content", compare_rank: "A/B Compare",
  answer_question: "Answer Q", transcription_review: "Review Transcript",
};
---

<Layout title="Earn — CrowdSorcerer">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold">Earn Credits</h1>
        <p class="text-gray-400 text-sm mt-0.5">Complete tasks, earn credits, level up</p>
      </div>
      {isWorker && (
        <a
          href="/worker/marketplace"
          class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition-colors"
        >
          Browse tasks →
        </a>
      )}
    </div>

    {/* Availability toggle */}
    {isWorker && (
      <div class="bg-gray-900 border border-gray-800 rounded-xl px-5 py-4 mb-6 flex items-center justify-between gap-4">
        <div class="text-sm text-gray-300 font-medium">Availability</div>
        <div class="flex items-center gap-2" id="availability-btns">
          {["available", "busy", "away"].map((s) => (
            <button
              class:list={[
                "availability-btn px-3 py-1.5 rounded-lg text-xs font-medium border transition-colors",
                (user?.availability_status ?? "available") === s
                  ? s === "available" ? "bg-green-950/60 text-green-400 border-green-700"
                    : s === "busy" ? "bg-yellow-950/60 text-yellow-400 border-yellow-700"
                    : "bg-gray-800 text-gray-400 border-gray-600"
                  : "text-gray-500 border-gray-700 hover:border-gray-500"
              ]}
              data-status={s}
            >
              {s === "available" ? "🟢 Available" : s === "busy" ? "🟡 Busy" : "🔴 Away"}
            </button>
          ))}
        </div>
      </div>
    )}

    {/* Onboarding progress banner — shown to new workers until dismissed or completed */}
    {showOnboardingBanner && (
      <div id="onboarding-banner" class="bg-violet-950/40 border border-violet-700/50 rounded-xl px-5 py-4 mb-4 flex items-center justify-between gap-4">
        <div class="flex items-center gap-4 flex-1 min-w-0">
          <div class="hidden sm:flex w-12 h-12 shrink-0 items-center justify-center bg-violet-900/50 rounded-xl text-2xl">🚀</div>
          <div class="flex-1 min-w-0">
            <div class="font-semibold text-violet-300 text-sm mb-1">
              Getting started — {onboardingStatus?.pct_complete ?? 0}% complete
            </div>
            <div class="w-full max-w-xs h-1.5 bg-violet-900/60 rounded-full mb-1">
              <div
                class="h-full bg-violet-500 rounded-full transition-all"
                style={`width:${onboardingStatus?.pct_complete ?? 0}%`}
              />
            </div>
            <p class="text-xs text-violet-200/60 truncate">
              {onboardingStatus?.completed_steps ?? 0} of {onboardingStatus?.total_steps ?? 5} steps done — complete all 5 to earn +100 bonus credits
            </p>
          </div>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <a
            href="/worker/onboarding"
            class="whitespace-nowrap text-xs bg-violet-600 hover:bg-violet-500 text-white px-3 py-1.5 rounded-lg font-medium transition-colors"
          >
            Continue →
          </a>
          <button
            id="dismiss-onboarding-banner"
            class="text-violet-400 hover:text-violet-300 transition-colors p-1 rounded"
            title="Dismiss banner"
            aria-label="Dismiss onboarding banner"
          >✕</button>
        </div>
      </div>
    )}

    {/* Profile completion banner */}
    {showProfileBanner && (
      <div class="bg-amber-950/40 border border-amber-700/60 rounded-xl px-5 py-4 mb-6 flex items-center justify-between gap-4">
        <div class="flex items-start gap-3">
          <span class="text-2xl mt-0.5">👤</span>
          <div>
            <div class="font-semibold text-amber-300 text-sm">Complete your profile — {profilePct}% done</div>
            <div class="w-48 h-1.5 bg-amber-900/60 rounded-full mt-1.5 mb-1">
              <div
                class="h-full bg-amber-400 rounded-full"
                style={`width:${profilePct}%`}
              />
            </div>
            <p class="text-xs text-amber-200/70">
              A complete profile helps requesters find you and increases your chances of getting invited to tasks.
              {profileStatus?.missing?.length > 0 && (
                <span> Missing: {(profileStatus.missing as string[]).join(", ")}.</span>
              )}
            </p>
          </div>
        </div>
        <a
          href="/worker/profile-setup"
          class="whitespace-nowrap text-xs bg-amber-600 hover:bg-amber-500 text-white px-3 py-1.5 rounded-lg font-medium transition-colors"
        >
          Complete profile →
        </a>
      </div>
    )}

    {!isWorker ? (
      <!-- Enrollment prompt -->
      <div class="bg-gray-900 border border-emerald-800/40 rounded-2xl p-10 text-center max-w-2xl mx-auto">
        <div class="text-5xl mb-4">🎯</div>
        <h2 class="text-2xl font-bold mb-3">Become a Worker</h2>
        <p class="text-gray-400 mb-6 leading-relaxed">
          Complete short tasks — label images, classify text, verify facts — and earn credits for each one.
          Level up, unlock bonuses, and compete on the leaderboard.
        </p>
        <ul class="text-left text-sm text-gray-300 space-y-3 mb-8 max-w-sm mx-auto">
          <li class="flex items-center gap-3">
            <span class="text-emerald-400 text-lg">✓</span>
            <span>Earn credits for every completed task</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="text-emerald-400 text-lg">✓</span>
            <span>Level up from Apprentice to Divine</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="text-emerald-400 text-lg">✓</span>
            <span>Streak bonuses for consecutive days</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="text-emerald-400 text-lg">✓</span>
            <span>Tasks take 1–5 minutes each</span>
          </li>
        </ul>
        <button
          id="enroll-btn"
          class="px-8 py-3 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold rounded-xl transition-colors"
        >
          Enable Worker Mode
        </button>
        <p id="enroll-msg" class="text-sm text-gray-500 mt-3 hidden"></p>
      </div>
    ) : (
      <!-- Worker dashboard -->
      <div>
        <!-- Level + XP bar -->
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 mb-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <div class="text-xs text-gray-500 uppercase tracking-wider mb-1">Worker Level</div>
              <div class="text-2xl font-bold">
                Lv.{stats?.level ?? 1} — {levelName(stats?.level ?? 1)}
              </div>
            </div>
            <div class="text-right">
              <div class="text-xs text-gray-500 mb-1">{stats?.xp?.toLocaleString() ?? 0} XP total</div>
              <div class="text-sm text-emerald-400">
                {stats?.xp_to_next_level > 0
                  ? `${stats.xp_to_next_level.toLocaleString()} XP to next level`
                  : "Max level!"}
              </div>
            </div>
          </div>
          <!-- XP progress bar -->
          {stats?.xp_to_next_level > 0 && (
            <div class="h-2 bg-gray-800 rounded-full overflow-hidden">
              <div
                class="h-full bg-gradient-to-r from-emerald-600 to-emerald-400 rounded-full transition-all"
                style={`width: ${Math.min(100, 100 - (stats.xp_to_next_level / (stats.xp + stats.xp_to_next_level)) * 100).toFixed(1)}%`}
              ></div>
            </div>
          )}
        </div>

        <!-- Stats grid -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="text-sm text-gray-400 mb-1">Tasks completed</div>
            <div class="text-3xl font-bold text-emerald-300">{stats?.tasks_completed?.toLocaleString() ?? 0}</div>
          </div>
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="text-sm text-gray-400 mb-1">Total earned</div>
            <div class="text-3xl font-bold text-amber-300">{stats?.total_earnings_credits?.toLocaleString() ?? 0}</div>
            <div class="text-xs text-gray-500 mt-0.5">credits</div>
          </div>
          <div class:list={[
            "rounded-xl p-5 border",
            stats?.streak_at_risk
              ? "bg-amber-950/30 border-amber-700/50"
              : "bg-gray-900 border-gray-800"
          ]}>
            <div class="text-sm text-gray-400 mb-1">Streak</div>
            <div class:list={["text-3xl font-bold", stats?.streak_at_risk ? "text-amber-300" : "text-orange-300"]}>
              {stats?.streak_days ?? 0}
              <span class="text-base ml-1">{stats?.streak_days > 0 ? "🔥" : "💤"}</span>
            </div>
            {stats?.streak_at_risk ? (
              <div class="text-xs text-amber-400 mt-1 font-medium">⚠ Complete a task today!</div>
            ) : (
              <div class="text-xs text-gray-500 mt-0.5">days</div>
            )}
          </div>
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="text-sm text-gray-400 mb-1">Accuracy</div>
            <div class="text-3xl font-bold">
              {stats?.accuracy != null
                ? `${(stats.accuracy * 100).toFixed(0)}%`
                : "—"}
            </div>
          </div>
        </div>

        <!-- Streak activity calendar (last 14 days) -->
        {(stats?.streak_days ?? 0) > 0 && (
          <div class="bg-gray-900 border border-gray-800 rounded-xl px-5 py-4 mb-6">
            <div class="flex items-center justify-between mb-3">
              <div class="text-sm font-semibold text-gray-300 flex items-center gap-2">
                🔥 Streak Calendar
                {stats?.streak_at_risk && (
                  <span class="text-xs bg-amber-900/50 text-amber-300 border border-amber-700/50 rounded px-2 py-0.5 font-normal">
                    at risk
                  </span>
                )}
              </div>
              <div class="text-xs text-gray-500">{stats?.streak_days} day streak</div>
            </div>
            <!-- 14 day dot grid — populated by JS -->
            <div id="streak-calendar" class="flex gap-1.5 flex-wrap">
              {Array.from({length: 14}).map((_, i) => (
                <div
                  class="w-6 h-6 rounded-sm bg-gray-800 border border-gray-700/50 streak-dot"
                  data-day-offset={13 - i}
                  title="Loading..."
                ></div>
              ))}
            </div>
            <div class="flex items-center gap-3 mt-2 text-xs text-gray-600">
              <div class="flex items-center gap-1"><div class="w-3 h-3 rounded-sm bg-emerald-600"></div> Active</div>
              <div class="flex items-center gap-1"><div class="w-3 h-3 rounded-sm bg-gray-800 border border-gray-700/50"></div> Inactive</div>
              <div class="flex items-center gap-1"><div class="w-3 h-3 rounded-sm bg-violet-600/70"></div> Today</div>
            </div>
          </div>
        )}

        <!-- Reputation panel -->
        {reputation && (
          <a
            href="/worker/reputation"
            class="flex items-center justify-between bg-gray-900 border border-gray-800 hover:border-violet-700 rounded-xl px-5 py-4 mb-6 transition-colors"
          >
            <div class="flex items-center gap-4">
              <div class="text-2xl">⭐</div>
              <div>
                <div class="text-xs text-gray-500 uppercase tracking-wider mb-0.5">Reputation</div>
                <div class="text-lg font-bold">{reputation.score ?? 0}<span class="text-sm font-normal text-gray-400 ml-1">/ 100</span></div>
              </div>
              <div class="h-8 w-px bg-gray-700 mx-2"></div>
              <div>
                <div class="text-xs text-gray-500 mb-0.5">Tier</div>
                <div class:list={["text-sm font-semibold",
                  reputation.tier === "Elite" || reputation.tier === "Expert" ? "text-amber-400" :
                  reputation.tier === "Reliable" ? "text-green-400" : "text-gray-300"
                ]}>{reputation.tier ?? "New"}</div>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-24 h-2 bg-gray-800 rounded-full overflow-hidden">
                <div
                  class="h-full bg-gradient-to-r from-violet-600 to-violet-400 rounded-full"
                  style={`width: ${Math.min(100, reputation.score ?? 0)}%`}
                ></div>
              </div>
              <span class="text-sm text-gray-400">→</span>
            </div>
          </a>
        )}

        <!-- Unread notifications strip -->
        {notifications?.items?.length > 0 && (
          <div class="bg-gray-900 border border-gray-800 rounded-xl mb-6 overflow-hidden">
            <div class="flex items-center justify-between px-5 py-3 border-b border-gray-800">
              <div class="text-sm font-semibold flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-violet-400 animate-pulse"></span>
                Unread notifications
              </div>
              <a href="/dashboard/notifications" class="text-xs text-violet-400 hover:text-violet-300">View all →</a>
            </div>
            {notifications.items.map((n: any) => (
              <a
                href={n.link ?? "/dashboard/notifications"}
                class="flex items-start gap-3 px-5 py-3 hover:bg-gray-800/50 transition-colors border-b border-gray-800/50 last:border-b-0"
              >
                <div class="text-base mt-0.5 flex-shrink-0">
                  {n.type === "task_completed" ? "✅" :
                   n.type === "submission_approved" ? "🎉" :
                   n.type === "badge_earned" ? "🏅" :
                   n.type === "payout_update" ? "💰" :
                   n.type === "referral_bonus" ? "🎁" : "🔔"}
                </div>
                <div class="min-w-0">
                  <div class="text-sm font-medium text-gray-200 truncate">{n.title}</div>
                  <div class="text-xs text-gray-500 truncate">{n.body}</div>
                </div>
              </a>
            ))}
          </div>
        )}

        <!-- Active assignments -->
        {assignments.length > 0 ? (
          <div class="mb-8">
            <h2 class="text-lg font-semibold mb-4">Active assignments ({stats?.tasks_active ?? 0})</h2>
            <div class="space-y-3">
              {assignments.map((a: any) => {
                const claimedMs = a.claimed_at ? new Date(a.claimed_at).getTime() : 0;
                const timeoutMs = a.timeout_at ? new Date(a.timeout_at).getTime() : 0;
                const totalMs = timeoutMs - claimedMs;
                const nowMs = Date.now();
                const remainingMs = Math.max(0, timeoutMs - nowMs);
                const pct = totalMs > 0 ? Math.min(100, Math.round((remainingMs / totalMs) * 100)) : 0;
                const remainMins = Math.floor(remainingMs / 60000);
                const remainHours = Math.floor(remainMins / 60);
                const remainMinsLeft = remainMins % 60;
                const timeLabel = remainHours > 0
                  ? `${remainHours}h ${remainMinsLeft}m left`
                  : `${remainMins}m left`;
                const barColor = pct > 50 ? "bg-emerald-500" : pct > 25 ? "bg-amber-400" : "bg-red-500";
                return (
                  <a
                    href={`/worker/tasks/${a.task_id}`}
                    class="block bg-gray-900 border border-amber-800/40 hover:border-amber-600/60 rounded-xl p-4 transition-colors"
                    data-claimed-at={a.claimed_at}
                    data-timeout-at={a.timeout_at}
                  >
                    <div class="flex items-center justify-between mb-2">
                      <div class="flex items-center gap-3">
                        <span class="text-amber-400 text-xs uppercase font-bold tracking-wider bg-amber-900/30 px-2 py-0.5 rounded">
                          Active
                        </span>
                        <span class="text-sm font-medium">{TASK_TYPE_LABELS[a.task_type] ?? a.task_type}</span>
                      </div>
                      <div class="flex items-center gap-3 text-sm text-gray-400">
                        <span class="assignment-time-label text-xs" data-timeout-at={a.timeout_at} data-claimed-at={a.claimed_at}>
                          {a.timeout_at ? timeLabel : "—"}
                        </span>
                        <span class="text-emerald-400 text-xs">→</span>
                      </div>
                    </div>
                    {a.timeout_at && (
                      <div class="w-full bg-gray-800 rounded-full h-1.5 overflow-hidden">
                        <div
                          class:list={["h-1.5 rounded-full transition-all assignment-progress-bar", barColor]}
                          style={`width: ${pct}%`}
                          data-timeout-at={a.timeout_at}
                          data-claimed-at={a.claimed_at}
                        />
                      </div>
                    )}
                  </a>
                );
              })}
            </div>
          </div>
        ) : (
          <!-- No active assignments -->
          <div class="bg-gray-900/40 border border-dashed border-gray-700 rounded-2xl p-10 text-center mb-8">
            <div class="text-3xl mb-3">🎯</div>
            <p class="text-gray-400 mb-4">No active tasks. Head to the marketplace to start earning!</p>
            <a
              href="/worker/marketplace"
              class="inline-block px-6 py-2.5 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition-colors"
            >
              Browse marketplace
            </a>
          </div>
        )}

        <!-- Daily challenge teaser -->
        {dailyChallenge && !dailyChallenge.bonus_claimed && (
          <a
            href="/worker/challenges"
            class={`flex items-center justify-between rounded-xl px-5 py-4 mb-6 border transition-colors ${
              dailyChallenge.is_complete
                ? "bg-amber-900/20 border-amber-700/60 hover:border-amber-500"
                : "bg-indigo-900/20 border-indigo-700/40 hover:border-indigo-500"
            }`}
          >
            <div class="flex items-center gap-3">
              <span class="text-2xl">📅</span>
              <div>
                <div class="text-sm font-semibold">
                  {dailyChallenge.is_complete ? "🎁 Claim your daily bonus!" : `Daily Challenge: ${dailyChallenge.challenge?.title}`}
                </div>
                <div class="text-xs text-gray-400 mt-0.5">
                  {dailyChallenge.tasks_completed}/{dailyChallenge.challenge?.target_count} tasks · +{dailyChallenge.challenge?.bonus_xp} XP + {dailyChallenge.challenge?.bonus_credits} credits
                </div>
              </div>
            </div>
            <span class="text-sm text-gray-400">→</span>
          </a>
        )}

        <!-- Quick links -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <a
            href="/worker/marketplace"
            class="flex items-center gap-4 bg-gray-900 border border-gray-800 hover:border-emerald-700 rounded-xl p-5 transition-colors group"
          >
            <span class="text-3xl">🛒</span>
            <div>
              <div class="font-semibold group-hover:text-emerald-300 transition-colors">Marketplace</div>
              <div class="text-sm text-gray-400">Browse and claim tasks</div>
            </div>
          </a>
          <a
            href="/worker/challenges"
            class="flex items-center gap-4 bg-gray-900 border border-indigo-800/40 hover:border-indigo-600 rounded-xl p-5 transition-colors group"
          >
            <span class="text-3xl">📅</span>
            <div>
              <div class="font-semibold group-hover:text-indigo-300 transition-colors">Daily Challenge</div>
              <div class="text-sm text-gray-400">Earn bonus XP &amp; credits</div>
            </div>
          </a>
          <a
            href="/worker/leaderboard"
            class="flex items-center gap-4 bg-gray-900 border border-gray-800 hover:border-amber-700 rounded-xl p-5 transition-colors group"
          >
            <span class="text-3xl">🏆</span>
            <div>
              <div class="font-semibold group-hover:text-amber-300 transition-colors">Leaderboard</div>
              <div class="text-sm text-gray-400">Top workers ranking</div>
            </div>
          </a>
          <a
            href="/worker/achievements"
            class="flex items-center gap-4 bg-gray-900 border border-gray-800 hover:border-amber-700 rounded-xl p-5 transition-colors group"
          >
            <span class="text-3xl">🏅</span>
            <div>
              <div class="font-semibold group-hover:text-amber-300 transition-colors">Achievements</div>
              <div class="text-sm text-gray-400">Badges &amp; milestones</div>
            </div>
          </a>
          <a
            href="/worker/skills"
            class="flex items-center gap-4 bg-gray-900 border border-purple-800/40 hover:border-purple-600 rounded-xl p-5 transition-colors group"
          >
            <span class="text-3xl">🎯</span>
            <div>
              <div class="font-semibold group-hover:text-purple-300 transition-colors">My Skills</div>
              <div class="text-sm text-gray-400">Proficiency &amp; recommendations</div>
            </div>
          </a>
          <a
            href="/worker/certifications"
