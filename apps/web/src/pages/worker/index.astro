---
/**
 * Worker dashboard — shows stats, active assignments, and quick access to marketplace.
 * If not enrolled as a worker, shows an enrollment prompt.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken, withTimeout } from "@/lib/api";

const token = getToken(Astro.cookies);

if (!token) {
  return Astro.redirect("/login?next=/worker");
}

let user: any = null;
let stats: any = null;
let assignments: any = [];
let isWorker = false;
let dailyChallenge: any = null;
let reputation: any = null;
let notifications: any = null;
let feedPreview: any = null;
let recentActivity: any = [];

let profileStatus: any = null;
let unreadMessages = 0;
let onboardingStatus: any = null;

try {
  user = await apiFetch("/v1/users/me", { token });
  isWorker = user?.role === "worker" || user?.role === "both";

  if (isWorker) {
    // Critical (visible above the fold): stats and active assignments
    // Non-critical (enrichment, 2s cap): challenges, reputation, notifications, feed, activity
    [stats, assignments, dailyChallenge, reputation, notifications, profileStatus, onboardingStatus, feedPreview, recentActivity] = await Promise.all([
      withTimeout(apiFetch("/v1/worker/stats", { token }), 2000),
      withTimeout(apiFetch("/v1/worker/assignments?status=active&page_size=5", { token }), 2000),
      withTimeout(apiFetch("/v1/challenges/today", { token }), 2000),
      withTimeout(apiFetch("/v1/reputation/me", { token }), 2000),
      withTimeout(apiFetch("/v1/notifications?unread_only=true&page_size=3", { token }), 2000),
      withTimeout(apiFetch("/v1/users/me/profile-status", { token }), 2000),
      withTimeout(apiFetch<any>("/v1/onboarding/status", { token }), 2000),
      withTimeout(apiFetch("/v1/worker/tasks/feed?page=1&page_size=3", { token }), 2000),
      withTimeout(apiFetch("/v1/worker/activity?page_size=5", { token }), 2000, []),
    ]);
    const msgCount: any = await withTimeout(apiFetch("/v1/tasks/messages/unread-count", { token }), 1000);
    unreadMessages = msgCount?.count ?? 0;
  }
} catch (e) {
  // Non-fatal; page will show enrollment prompt
}

// Auto-redirect brand-new workers (0 steps complete, never skipped) to onboarding
const isNewWorker = Boolean(
  isWorker &&
  onboardingStatus &&
  onboardingStatus.completed_steps === 0 &&
  !onboardingStatus.skipped_at &&
  !onboardingStatus.is_complete
);
if (isNewWorker) {
  return Astro.redirect("/worker/onboarding");
}

// Show onboarding banner if worker has not completed/skipped/dismissed onboarding
const showOnboardingBanner = Boolean(
  isWorker &&
  onboardingStatus &&
  !onboardingStatus.is_complete &&
  !onboardingStatus.banner_dismissed &&
  !onboardingStatus.skipped_at
);

const profilePct = profileStatus?.completeness_pct ?? 100;
const showProfileBanner = isWorker && profilePct < 80;

const LEVEL_NAMES: Record<number, string> = {
  1: "Apprentice", 2: "Novice", 3: "Learner", 4: "Explorer", 5: "Contributor",
  6: "Analyst", 7: "Specialist", 8: "Expert", 9: "Veteran", 10: "Elite",
  11: "Master", 12: "Grand Master", 13: "Champion", 14: "Legend", 15: "Mythic",
  16: "Transcendent", 17: "Ascendant", 18: "Radiant", 19: "Immortal", 20: "Divine",
};

function levelName(level: number): string {
  return LEVEL_NAMES[level] ?? `Level ${level}`;
}

const TASK_TYPE_META: Record<string, { label: string; icon: string }> = {
  label_image:          { label: "Label Image",       icon: "🖼️" },
  label_text:           { label: "Classify Text",     icon: "📝" },
  rate_quality:         { label: "Rate Quality",      icon: "⭐" },
  verify_fact:          { label: "Verify Fact",       icon: "✅" },
  moderate_content:     { label: "Moderate Content",  icon: "🛡️" },
  compare_rank:         { label: "A/B Compare",       icon: "⚖️" },
  answer_question:      { label: "Answer Question",   icon: "💬" },
  transcription_review: { label: "Review Transcript", icon: "🎙️" },
};

const TASK_TYPE_LABELS: Record<string, string> = Object.fromEntries(
  Object.entries(TASK_TYPE_META).map(([k, v]) => [k, v.label])
);

const PRIORITY_COLORS: Record<string, string> = {
  low:    "text-gray-400 bg-gray-800/60",
  normal: "text-blue-300 bg-blue-900/30",
  high:   "text-orange-300 bg-orange-900/30",
  urgent: "text-red-300 bg-red-900/30",
};

const feedTasks: any[] = feedPreview?.items ?? [];
// Detect workers with no skills — personalised feed will be empty for them
const noSkills = Array.isArray(profileStatus?.missing) &&
  (profileStatus.missing as string[]).includes("skills");
---

<Layout title="Earn — CrowdSorcerer">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold">Earn Credits</h1>
        <p class="text-gray-400 text-sm mt-0.5">Complete tasks, earn credits, level up</p>
      </div>
      {isWorker && (
        <a
          href="/worker/marketplace"
          class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition-colors"
        >
          Browse tasks →
        </a>
      )}
    </div>

    {/* Availability toggle */}
    {isWorker && (
      <div class="bg-gray-900 border border-gray-800 rounded-xl px-5 py-4 mb-6 flex items-center justify-between gap-4">
        <div class="text-sm text-gray-300 font-medium">Availability</div>
        <div class="flex items-center gap-2" id="availability-btns">
          {["available", "busy", "away"].map((s) => (
            <button
              class:list={[
                "availability-btn px-3 py-1.5 rounded-lg text-xs font-medium border transition-colors",
                (user?.availability_status ?? "available") === s
                  ? s === "available" ? "bg-green-950/60 text-green-400 border-green-700"
                    : s === "busy" ? "bg-yellow-950/60 text-yellow-400 border-yellow-700"
                    : "bg-gray-800 text-gray-400 border-gray-600"
                  : "text-gray-500 border-gray-700 hover:border-gray-500"
              ]}
              data-status={s}
            >
              {s === "available" ? "🟢 Available" : s === "busy" ? "🟡 Busy" : "🔴 Away"}
            </button>
          ))}
        </div>
      </div>
    )}

    {/* Onboarding progress banner — shown to new workers until dismissed or completed */}
    {showOnboardingBanner && (
      <div id="onboarding-banner" class="bg-violet-950/40 border border-violet-700/50 rounded-xl px-5 py-4 mb-4 flex items-center justify-between gap-4">
        <div class="flex items-center gap-4 flex-1 min-w-0">
          <div class="hidden sm:flex w-12 h-12 shrink-0 items-center justify-center bg-violet-900/50 rounded-xl text-2xl">🚀</div>
          <div class="flex-1 min-w-0">
            <div class="font-semibold text-violet-300 text-sm mb-1">
              Getting started — {onboardingStatus?.pct_complete ?? 0}% complete
            </div>
            <div class="w-full max-w-xs h-1.5 bg-violet-900/60 rounded-full mb-1">
              <div
                class="h-full bg-violet-500 rounded-full transition-all"
                style={`width:${onboardingStatus?.pct_complete ?? 0}%`}
              />
            </div>
            <p class="text-xs text-violet-200/60 truncate">
              {onboardingStatus?.completed_steps ?? 0} of {onboardingStatus?.total_steps ?? 5} steps done — complete all 5 to earn +100 bonus credits
            </p>
          </div>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <a
            href="/worker/onboarding"
            class="whitespace-nowrap text-xs bg-violet-600 hover:bg-violet-500 text-white px-3 py-1.5 rounded-lg font-medium transition-colors"
          >
            Continue →
          </a>
          <button
            id="dismiss-onboarding-banner"
            class="text-violet-400 hover:text-violet-300 transition-colors p-1 rounded"
            title="Dismiss banner"
            aria-label="Dismiss onboarding banner"
          >✕</button>
        </div>
      </div>
    )}

    {/* Profile completion banner */}
    {showProfileBanner && (
      <div class="bg-amber-950/40 border border-amber-700/60 rounded-xl px-5 py-4 mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div class="flex items-start gap-3 min-w-0">
          <span class="text-2xl mt-0.5 shrink-0">👤</span>
          <div class="min-w-0">
            <div class="font-semibold text-amber-300 text-sm">Complete your profile — {profilePct}% done</div>
            <div class="w-full max-w-[12rem] h-1.5 bg-amber-900/60 rounded-full mt-1.5 mb-1">
              <div
                class="h-full bg-amber-400 rounded-full"
                style={`width:${profilePct}%`}
              />
            </div>
            <p class="text-xs text-amber-200/70">
              A complete profile helps requesters find you and increases your chances of getting invited to tasks.
              {profileStatus?.missing?.length > 0 && (
                <span> Missing: {(profileStatus.missing as string[]).join(", ")}.</span>
              )}
            </p>
          </div>
        </div>
        <a
          href="/worker/profile-setup"
          class="whitespace-nowrap text-xs bg-amber-600 hover:bg-amber-500 text-white px-3 py-1.5 rounded-lg font-medium transition-colors"
        >
          Complete profile →
        </a>
      </div>
    )}

    {!isWorker ? (
      <!-- Enrollment prompt -->
      <div class="bg-gray-900 border border-emerald-800/40 rounded-2xl p-10 text-center max-w-2xl mx-auto">
        <div class="text-5xl mb-4">🎯</div>
        <h2 class="text-2xl font-bold mb-3">Become a Worker</h2>
        <p class="text-gray-400 mb-6 leading-relaxed">
          Complete short tasks — label images, classify text, verify facts — and earn credits for each one.
          Level up, unlock bonuses, and compete on the leaderboard.
        </p>
        <ul class="text-left text-sm text-gray-300 space-y-3 mb-8 max-w-sm mx-auto">
          <li class="flex items-center gap-3">
            <span class="text-emerald-400 text-lg">✓</span>
            <span>Earn credits for every completed task</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="text-emerald-400 text-lg">✓</span>
            <span>Level up from Apprentice to Divine</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="text-emerald-400 text-lg">✓</span>
            <span>Streak bonuses for consecutive days</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="text-emerald-400 text-lg">✓</span>
            <span>Tasks take 1–5 minutes each</span>
          </li>
        </ul>
        <button
          id="enroll-btn"
          class="px-8 py-3 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold rounded-xl transition-colors"
        >
          Enable Worker Mode
        </button>
        <p id="enroll-msg" class="text-sm text-gray-500 mt-3 hidden"></p>
      </div>
    ) : (
      <!-- Worker dashboard -->
      <div>
        <!-- Level + XP bar -->
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 mb-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <div class="text-xs text-gray-500 uppercase tracking-wider mb-1">Worker Level</div>
              <div class="text-2xl font-bold">
                Lv.{stats?.level ?? 1} — {levelName(stats?.level ?? 1)}
              </div>
            </div>
            <div class="text-right">
              <div class="text-xs text-gray-500 mb-1">{stats?.xp?.toLocaleString() ?? 0} XP total</div>
              <div class="text-sm text-emerald-400">
                {stats?.xp_to_next_level > 0
                  ? `${stats.xp_to_next_level.toLocaleString()} XP to next level`
                  : "Max level!"}
              </div>
            </div>
          </div>
          <!-- XP progress bar -->
          {stats?.xp_to_next_level > 0 && (
            <div class="h-2 bg-gray-800 rounded-full overflow-hidden">
              <div
                class="h-full bg-gradient-to-r from-emerald-600 to-emerald-400 rounded-full transition-all"
                style={`width: ${Math.min(100, 100 - (stats.xp_to_next_level / (stats.xp + stats.xp_to_next_level)) * 100).toFixed(1)}%`}
              ></div>
            </div>
          )}
        </div>

        <!-- Stats grid -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="text-sm text-gray-400 mb-1">Tasks completed</div>
            <div class="text-3xl font-bold text-emerald-300">{stats?.tasks_completed?.toLocaleString() ?? 0}</div>
          </div>
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="text-sm text-gray-400 mb-1">Total earned</div>
            <div class="text-3xl font-bold text-amber-300">{stats?.total_earnings_credits?.toLocaleString() ?? 0}</div>
            <div class="text-xs text-gray-500 mt-0.5">credits</div>
          </div>
          <div class:list={[
            "rounded-xl p-5 border",
            stats?.streak_at_risk
              ? "bg-amber-950/30 border-amber-700/50"
              : "bg-gray-900 border-gray-800"
          ]}>
            <div class="text-sm text-gray-400 mb-1">Streak</div>
            <div class:list={["text-3xl font-bold", stats?.streak_at_risk ? "text-amber-300" : "text-orange-300"]}>
              {stats?.streak_days ?? 0}
              <span class="text-base ml-1">{stats?.streak_days > 0 ? "🔥" : "💤"}</span>
            </div>
            {stats?.streak_at_risk ? (
              <div class="text-xs text-amber-400 mt-1 font-medium">
                ⚠ Complete a task today!
                {(stats?.streak_freezes ?? 0) > 0 && (
                  <span class="text-emerald-400 ml-1">🧊 {stats.streak_freezes} freeze{stats.streak_freezes > 1 ? "s" : ""} ready</span>
                )}
              </div>
            ) : (
              <div class="text-xs text-gray-500 mt-0.5">
                days
                {(stats?.streak_freezes ?? 0) > 0 && (
                  <span class="text-emerald-500 ml-2">🧊 {stats.streak_freezes}</span>
                )}
              </div>
            )}
          </div>
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="text-sm text-gray-400 mb-1">Accuracy</div>
            <div class="text-3xl font-bold">
              {stats?.accuracy != null
                ? `${(stats.accuracy * 100).toFixed(0)}%`
                : "—"}
            </div>
          </div>
        </div>

        <!-- Streak activity calendar (last 14 days) -->
        {(stats?.streak_days ?? 0) > 0 && (
          <div class="bg-gray-900 border border-gray-800 rounded-xl px-5 py-4 mb-6">
            <div class="flex items-center justify-between mb-3">
              <div class="text-sm font-semibold text-gray-300 flex items-center gap-2">
                🔥 Streak Calendar
                {stats?.streak_at_risk && (
                  <span class="text-xs bg-amber-900/50 text-amber-300 border border-amber-700/50 rounded px-2 py-0.5 font-normal">
                    at risk
                  </span>
                )}
              </div>
              <div class="text-xs text-gray-500">{stats?.streak_days} day streak</div>
            </div>
            <!-- 14 day dot grid — populated by JS -->
            <div id="streak-calendar" class="flex gap-1.5 flex-wrap">
              {Array.from({length: 14}).map((_, i) => (
                <div
                  class="w-6 h-6 rounded-sm bg-gray-800 border border-gray-700/50 streak-dot"
                  data-day-offset={13 - i}
                  title="Loading..."
                ></div>
              ))}
            </div>
            <div class="flex items-center gap-3 mt-2 text-xs text-gray-600">
              <div class="flex items-center gap-1"><div class="w-3 h-3 rounded-sm bg-emerald-600"></div> Active</div>
              <div class="flex items-center gap-1"><div class="w-3 h-3 rounded-sm bg-gray-800 border border-gray-700/50"></div> Inactive</div>
              <div class="flex items-center gap-1"><div class="w-3 h-3 rounded-sm bg-violet-600/70"></div> Today</div>
            </div>
          </div>
        )}

        <!-- Reputation panel -->
        {reputation && (
          <a
            href="/worker/reputation"
            class="flex items-center justify-between bg-gray-900 border border-gray-800 hover:border-violet-700 rounded-xl px-5 py-4 mb-6 transition-colors"
          >
            <div class="flex items-center gap-4">
              <div class="text-2xl">⭐</div>
              <div>
                <div class="text-xs text-gray-500 uppercase tracking-wider mb-0.5">Reputation</div>
                <div class="text-lg font-bold">{reputation.score ?? 0}<span class="text-sm font-normal text-gray-400 ml-1">/ 100</span></div>
              </div>
              <div class="h-8 w-px bg-gray-700 mx-2"></div>
              <div>
                <div class="text-xs text-gray-500 mb-0.5">Tier</div>
                <div class:list={["text-sm font-semibold",
                  reputation.tier === "Elite" || reputation.tier === "Expert" ? "text-amber-400" :
                  reputation.tier === "Reliable" ? "text-green-400" : "text-gray-300"
                ]}>{reputation.tier ?? "New"}</div>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-24 h-2 bg-gray-800 rounded-full overflow-hidden">
                <div
                  class="h-full bg-gradient-to-r from-violet-600 to-violet-400 rounded-full"
                  style={`width: ${Math.min(100, reputation.score ?? 0)}%`}
                ></div>
              </div>
              <span class="text-sm text-gray-400">→</span>
            </div>
          </a>
        )}

        <!-- Unread notifications strip -->
        {notifications?.items?.length > 0 && (
          <div class="bg-gray-900 border border-gray-800 rounded-xl mb-6 overflow-hidden">
            <div class="flex items-center justify-between px-5 py-3 border-b border-gray-800">
              <div class="text-sm font-semibold flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-violet-400 animate-pulse"></span>
                Unread notifications
              </div>
              <a href="/dashboard/notifications" class="text-xs text-violet-400 hover:text-violet-300">View all →</a>
            </div>
            {notifications.items.map((n: any) => (
              <a
                href={n.link ?? "/dashboard/notifications"}
                class="flex items-start gap-3 px-5 py-3 hover:bg-gray-800/50 transition-colors border-b border-gray-800/50 last:border-b-0"
              >
                <div class="text-base mt-0.5 flex-shrink-0">
                  {n.type === "task_completed" ? "✅" :
                   n.type === "submission_approved" ? "🎉" :
                   n.type === "badge_earned" ? "🏅" :
                   n.type === "payout_update" ? "💰" :
                   n.type === "referral_bonus" ? "🎁" : "🔔"}
                </div>
                <div class="min-w-0">
                  <div class="text-sm font-medium text-gray-200 truncate">{n.title}</div>
                  <div class="text-xs text-gray-500 truncate">{n.body}</div>
                </div>
              </a>
            ))}
          </div>
        )}

        <!-- Active assignments -->
        {assignments.length > 0 ? (
          <div class="mb-8">
            <h2 class="text-lg font-semibold mb-4">Active assignments ({stats?.tasks_active ?? 0})</h2>
            <div class="space-y-3">
              {assignments.map((a: any) => {
                const claimedMs = a.claimed_at ? new Date(a.claimed_at).getTime() : 0;
                const timeoutMs = a.timeout_at ? new Date(a.timeout_at).getTime() : 0;
                const totalMs = timeoutMs - claimedMs;
                const nowMs = Date.now();
                const remainingMs = Math.max(0, timeoutMs - nowMs);
                const pct = totalMs > 0 ? Math.min(100, Math.round((remainingMs / totalMs) * 100)) : 0;
                const remainMins = Math.floor(remainingMs / 60000);
                const remainHours = Math.floor(remainMins / 60);
                const remainMinsLeft = remainMins % 60;
                const timeLabel = remainHours > 0
                  ? `${remainHours}h ${remainMinsLeft}m left`
                  : `${remainMins}m left`;
                const barColor = pct > 50 ? "bg-emerald-500" : pct > 25 ? "bg-amber-400" : "bg-red-500";
                return (
                  <a
                    href={`/worker/tasks/${a.task_id}`}
                    class="block bg-gray-900 border border-amber-800/40 hover:border-amber-600/60 rounded-xl p-4 transition-colors"
                    data-claimed-at={a.claimed_at}
                    data-timeout-at={a.timeout_at}
                  >
                    <div class="flex items-center justify-between mb-2">
                      <div class="flex items-center gap-3">
                        <span class="text-amber-400 text-xs uppercase font-bold tracking-wider bg-amber-900/30 px-2 py-0.5 rounded">
                          Active
                        </span>
                        <span class="text-sm font-medium">{TASK_TYPE_LABELS[a.task_type] ?? a.task_type}</span>
                      </div>
                      <div class="flex items-center gap-3 text-sm text-gray-400">
                        <span class="assignment-time-label text-xs" data-timeout-at={a.timeout_at} data-claimed-at={a.claimed_at}>
                          {a.timeout_at ? timeLabel : "—"}
                        </span>
                        <span class="text-emerald-400 text-xs">→</span>
                      </div>
                    </div>
                    {a.timeout_at && (
                      <div class="w-full bg-gray-800 rounded-full h-1.5 overflow-hidden">
                        <div
                          class:list={["h-1.5 rounded-full transition-all assignment-progress-bar", barColor]}
                          style={`width: ${pct}%`}
                          data-timeout-at={a.timeout_at}
                          data-claimed-at={a.claimed_at}
                        />
                      </div>
                    )}
                  </a>
                );
              })}
            </div>
          </div>
        ) : null}

        <!-- ── Available tasks feed preview ─────────────────────────────── -->
        {feedTasks.length > 0 && (
          <div class="mb-8">
            <div class="flex items-center justify-between mb-3">
              <h2 class="text-base font-semibold text-gray-200 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
                Available for you
              </h2>
              <a href="/worker/marketplace" class="text-xs text-emerald-400 hover:text-emerald-300 transition-colors">
                Browse all →
              </a>
            </div>
            <div class="space-y-3">
              {feedTasks.map((t: any) => {
                const meta = TASK_TYPE_META[t.type] ?? { label: t.type, icon: "📋" };
                const matchPct = t.match_score != null ? Math.round(t.match_score * 100) : null;
                const instrSnippet = t.task_instructions
                  ? t.task_instructions.slice(0, 80) + (t.task_instructions.length > 80 ? "…" : "")
                  : null;
                return (
                  <a
                    href={`/worker/tasks/${t.id}`}
                    class="flex items-center gap-4 bg-gray-900 border border-gray-800 hover:border-emerald-700/60 rounded-xl px-5 py-4 transition-colors group"
                  >
                    <div class="text-2xl flex-shrink-0">{meta.icon}</div>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 mb-0.5">
                        <span class="text-sm font-semibold text-gray-200">{meta.label}</span>
                        {t.priority && t.priority !== "normal" && (
                          <span class:list={["text-[10px] uppercase font-bold px-1.5 py-0.5 rounded", PRIORITY_COLORS[t.priority] ?? "text-gray-400"]}>
                            {t.priority}
                          </span>
                        )}
                        {matchPct != null && matchPct >= 70 && (
                          <span class="text-[10px] text-emerald-400 bg-emerald-900/30 px-1.5 py-0.5 rounded font-medium">
                            {matchPct}% match
                          </span>
                        )}
                        {Array.isArray(t.tags) && t.tags.includes("tutorial") && (
                          <span class="text-[10px] text-violet-300 bg-violet-900/40 px-1.5 py-0.5 rounded font-medium">
                            Tutorial
                          </span>
                        )}
                      </div>
                      {instrSnippet && (
                        <p class="text-xs text-gray-500 truncate">{instrSnippet}</p>
                      )}
                    </div>
                    <div class="flex-shrink-0 text-right">
                      <div class="text-base font-bold text-emerald-400">+{t.reward_credits}</div>
                      <div class="text-xs text-gray-500">credits</div>
                      {t.estimated_minutes > 0 && (
                        <div class="text-[11px] text-gray-600 mt-0.5">~{t.estimated_minutes}m</div>
                      )}
                    </div>
                    <div class="text-gray-600 group-hover:text-emerald-400 transition-colors text-sm flex-shrink-0">→</div>
                  </a>
                );
              })}
            </div>
          </div>
        )}
        {assignments.length === 0 && feedTasks.length === 0 && (
          <div class="bg-gray-900/40 border border-dashed border-gray-700 rounded-2xl p-10 text-center mb-8">
            {noSkills ? (
              <!-- No skills → personalised feed will always be empty -->
              <>
                <div class="text-4xl mb-3">🎓</div>
                <p class="text-gray-200 font-semibold mb-2">Add skills to get matched with tasks</p>
                <p class="text-gray-400 text-sm mb-6 max-w-sm mx-auto">
                  Your personalised feed is empty because you haven't added any skills yet.
                  Skills help us match you with tasks that suit your abilities.
                </p>
                <div class="flex flex-wrap justify-center gap-3">
                  <a
                    href="/worker/skills"
                    class="inline-block px-6 py-2.5 bg-violet-600 hover:bg-violet-500 text-white text-sm font-semibold rounded-lg transition-colors"
                  >
                    Add skills →
                  </a>
                  <a
                    href="/worker/marketplace?mode=browse"
                    class="inline-block px-6 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-200 text-sm font-medium rounded-lg border border-gray-700 transition-colors"
                  >
                    Browse all tasks
                  </a>
                </div>
              </>
            ) : (
              <!-- Skills exist but no open tasks right now -->
              <>
                <div class="text-3xl mb-3">🎯</div>
                <p class="text-gray-400 mb-4">No tasks available right now. Check back soon!</p>
                <a
                  href="/worker/marketplace"
                  class="inline-block px-6 py-2.5 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition-colors"
                >
                  Browse marketplace
                </a>
              </>
            )}
          </div>
        )}

        <!-- ── Recent activity ───────────────────────────────────────────── -->
        {(recentActivity as any[]).length > 0 && (
          <div class="mb-8">
            <div class="flex items-center justify-between mb-3">
              <h2 class="text-base font-semibold text-gray-200">Recent activity</h2>
              <a href="/worker/marketplace" class="text-xs text-gray-500 hover:text-gray-400 transition-colors">
                View history →
              </a>
            </div>
            <div class="bg-gray-900 border border-gray-800 rounded-xl divide-y divide-gray-800/60">
              {(recentActivity as any[]).map((act: any) => {
                const meta = TASK_TYPE_META[act.task_type] ?? { label: act.task_type, icon: "📋" };
                const isApproved = act.status === "approved" || act.status === "released";
                const isPending = act.status === "submitted";
                const submittedAt: Date | null = act.submitted_at ? new Date(act.submitted_at) : null;
                const now = new Date();
                const diffMs = submittedAt ? now.getTime() - submittedAt.getTime() : 0;
                const diffH = Math.floor(diffMs / 3600000);
                const diffD = Math.floor(diffH / 24);
                const timeAgo = diffD > 0 ? `${diffD}d ago` : diffH > 0 ? `${diffH}h ago` : "just now";
                return (
                  <a
                    href={`/worker/tasks/${act.task_id}`}
                    class="flex items-center gap-4 px-5 py-3 hover:bg-gray-800/40 transition-colors"
                  >
                    <span class="text-lg flex-shrink-0">{meta.icon}</span>
                    <div class="flex-1 min-w-0">
                      <div class="text-sm text-gray-300 font-medium">{meta.label}</div>
                      <div class="text-xs text-gray-500">{timeAgo}</div>
                    </div>
                    <div class="flex items-center gap-3 flex-shrink-0">
                      <span class:list={[
                        "text-[11px] font-semibold px-2 py-0.5 rounded-full",
                        isApproved ? "bg-emerald-900/40 text-emerald-400" : isPending ? "bg-yellow-900/40 text-yellow-400" : "bg-gray-800 text-gray-400"
                      ]}>
                        {isApproved ? "Approved" : isPending ? "Pending" : act.status}
                      </span>
                      <span class="text-sm font-medium text-emerald-400">+{act.earnings_credits}</span>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        <!-- Daily challenge teaser -->
        {dailyChallenge && !dailyChallenge.bonus_claimed && (
          <a
            href="/worker/challenges"
            class={`flex items-center justify-between rounded-xl px-5 py-4 mb-6 border transition-colors ${
              dailyChallenge.is_complete
                ? "bg-amber-900/20 border-amber-700/60 hover:border-amber-500"
                : "bg-indigo-900/20 border-indigo-700/40 hover:border-indigo-500"
            }`}
          >
            <div class="flex items-center gap-3">
              <span class="text-2xl">📅</span>
              <div>
                <div class="text-sm font-semibold">
                  {dailyChallenge.is_complete ? "🎁 Claim your daily bonus!" : `Daily Challenge: ${dailyChallenge.challenge?.title}`}
                </div>
                <div class="text-xs text-gray-400 mt-0.5">
                  {dailyChallenge.tasks_completed}/{dailyChallenge.challenge?.target_count} tasks · +{dailyChallenge.challenge?.bonus_xp} XP + {dailyChallenge.challenge?.bonus_credits} credits
                </div>
              </div>
            </div>
            <span class="text-sm text-gray-400">→</span>
          </a>
        )}

        <!-- Quick links — 8 essentials -->
        <div class="border-t border-gray-800/60 pt-6">
          <h2 class="text-xs text-gray-600 uppercase tracking-wider font-semibold mb-4">More</h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            <a
              href="/worker/marketplace"
              class="flex items-center gap-3 bg-gray-900 border border-gray-800 hover:border-emerald-700 rounded-xl px-4 py-3 transition-colors group"
            >
              <span class="text-2xl">🛒</span>
              <div>
                <div class="text-sm font-semibold group-hover:text-emerald-300 transition-colors">Marketplace</div>
                <div class="text-xs text-gray-500">Browse all tasks</div>
              </div>
            </a>
            <a
              href="/worker/leaderboard"
              class="flex items-center gap-3 bg-gray-900 border border-gray-800 hover:border-amber-700 rounded-xl px-4 py-3 transition-colors group"
            >
              <span class="text-2xl">🏆</span>
              <div>
                <div class="text-sm font-semibold group-hover:text-amber-300 transition-colors">Leaderboard</div>
                <div class="text-xs text-gray-500">Top workers</div>
              </div>
            </a>
            <a
              href="/worker/achievements"
              class="flex items-center gap-3 bg-gray-900 border border-gray-800 hover:border-amber-700 rounded-xl px-4 py-3 transition-colors group"
            >
              <span class="text-2xl">🏅</span>
              <div>
                <div class="text-sm font-semibold group-hover:text-amber-300 transition-colors">Achievements</div>
                <div class="text-xs text-gray-500">Badges &amp; milestones</div>
              </div>
            </a>
            <a
              href="/worker/leagues"
              class="flex items-center gap-3 bg-gray-900 border border-emerald-800/40 hover:border-emerald-600 rounded-xl px-4 py-3 transition-colors group"
            >
              <span class="text-2xl">⚔️</span>
              <div>
                <div class="text-sm font-semibold group-hover:text-emerald-300 transition-colors">Leagues</div>
                <div class="text-xs text-gray-500">Weekly competition</div>
              </div>
            </a>
            <a
              href="/worker/quests"
              class="flex items-center gap-3 bg-gray-900 border border-purple-800/40 hover:border-purple-600 rounded-xl px-4 py-3 transition-colors group"
            >
              <span class="text-2xl">🗺️</span>
              <div>
                <div class="text-sm font-semibold group-hover:text-purple-300 transition-colors">Quests</div>
                <div class="text-xs text-gray-500">Weekly challenges</div>
              </div>
            </a>
            <a
              href="/worker/skills"
              class="flex items-center gap-3 bg-gray-900 border border-purple-800/40 hover:border-purple-600 rounded-xl px-4 py-3 transition-colors group"
            >
              <span class="text-2xl">🎯</span>
              <div>
                <div class="text-sm font-semibold group-hover:text-purple-300 transition-colors">My Skills</div>
                <div class="text-xs text-gray-500">Proficiency</div>
              </div>
            </a>
            <a
              href="/worker/performance"
              class="flex items-center gap-3 bg-gray-900 border border-violet-800/40 hover:border-violet-600 rounded-xl px-4 py-3 transition-colors group"
            >
              <span class="text-2xl">📊</span>
              <div>
                <div class="text-sm font-semibold group-hover:text-violet-300 transition-colors">My Performance</div>
                <div class="text-xs text-gray-500">Approval rate stats</div>
              </div>
            </a>
            <a
              href="/worker/recommendations"
              class="flex items-center gap-3 bg-gray-900 border border-violet-800/40 hover:border-violet-600 rounded-xl px-4 py-3 transition-colors group"
            >
              <span class="text-2xl">💡</span>
              <div>
                <div class="text-sm font-semibold group-hover:text-violet-300 transition-colors">Recommendations</div>
                <div class="text-xs text-gray-500">Maximise earnings</div>
              </div>
            </a>
            <a
              href="/worker/earnings"
              class="flex items-center gap-3 bg-gray-900 border border-gray-800 hover:border-amber-700 rounded-xl px-4 py-3 transition-colors group"
            >
              <span class="text-2xl">💰</span>
              <div>
                <div class="text-sm font-semibold group-hover:text-amber-300 transition-colors">Earnings</div>
                <div class="text-xs text-gray-500">Payouts &amp; history</div>
              </div>
            </a>
            <a
              href="/worker/invites"
              class="flex items-center gap-3 bg-gray-900 border border-yellow-800/40 hover:border-yellow-600 rounded-xl px-4 py-3 transition-colors group"
            >
              <span class="text-2xl">✉️</span>
              <div>
                <div class="text-sm font-semibold group-hover:text-yellow-300 transition-colors">Invites</div>
                <div class="text-xs text-gray-500">Direct invitations</div>
              </div>
            </a>
            <a
              href="/worker/messages"
              class="relative flex items-center gap-3 bg-gray-900 border border-violet-800/40 hover:border-violet-600 rounded-xl px-4 py-3 transition-colors group"
            >
              <span class="text-2xl">💬</span>
              <div>
                <div class="text-sm font-semibold group-hover:text-violet-300 transition-colors">Messages</div>
                <div class="text-xs text-gray-500">
                  {unreadMessages > 0 ? `${unreadMessages} unread` : "Task DMs"}
                </div>
              </div>
              {unreadMessages > 0 && (
                <span class="absolute top-2 right-2 w-4 h-4 rounded-full bg-violet-500 text-white text-[9px] flex items-center justify-center font-bold">
                  {unreadMessages > 9 ? "9+" : unreadMessages}
                </span>
              )}
            </a>
            <a
              href="/worker/portfolio"
              class="flex items-center gap-3 bg-gray-900 border border-gray-800 hover:border-indigo-600 rounded-xl px-4 py-3 transition-colors group"
            >
              <span class="text-2xl">🗂️</span>
              <div>
                <div class="text-sm font-semibold group-hover:text-indigo-300 transition-colors">Portfolio</div>
                <div class="text-xs text-gray-500">Showcase work</div>
              </div>
            </a>
            <a
              href="/worker/saved-searches"
              class="flex items-center gap-3 bg-gray-900 border border-gray-800 hover:border-emerald-700 rounded-xl px-4 py-3 transition-colors group"
            >
              <span class="text-2xl">🔔</span>
              <div>
                <div class="text-sm font-semibold group-hover:text-emerald-300 transition-colors">Saved Searches</div>
                <div class="text-xs text-gray-500">Task alerts</div>
              </div>
            </a>
          </div>
        </div>
      </div>
    )}
  </div>
</Layout>

<script>
  // Availability toggle
  document.querySelectorAll(".availability-btn").forEach(btn => {
    btn.addEventListener("click", async () => {
      const status = (btn as HTMLElement).dataset.status;
      if (!status) return;
      // Disable all availability buttons while saving
      const allBtns = document.querySelectorAll<HTMLButtonElement>(".availability-btn");
      allBtns.forEach(b => { b.disabled = true; });
      try {
        const res = await fetch("/api/worker/availability", {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ status }),
        });
        if (res.ok) {
          // Update button styles
          allBtns.forEach(b => {
            const s = (b as HTMLElement).dataset.status;
            b.className = b.className.replace(
              /bg-\w+-\d+\/\d+ text-\w+-\d+ border-\w+-\d+/g, ""
            );
            if (s === status) {
              if (s === "available") {
                b.classList.add("bg-green-950/60", "text-green-400", "border-green-700");
                b.classList.remove("text-gray-500", "border-gray-700");
              } else if (s === "busy") {
                b.classList.add("bg-yellow-950/60", "text-yellow-400", "border-yellow-700");
                b.classList.remove("text-gray-500", "border-gray-700");
              } else {
                b.classList.add("bg-gray-800", "text-gray-400", "border-gray-600");
                b.classList.remove("text-gray-500", "border-gray-700");
              }
            } else {
              b.classList.add("text-gray-500", "border-gray-700");
              b.classList.remove("bg-green-950/60", "text-green-400", "border-green-700",
                "bg-yellow-950/60", "text-yellow-400", "border-yellow-700",
                "bg-gray-800", "text-gray-400", "border-gray-600");
            }
          });
        } else {
          const errData = await res.json().catch(() => ({}));
          const t = document.createElement("div");
          t.className = "fixed bottom-4 right-4 px-4 py-2 rounded-lg text-white text-sm z-50 bg-red-600";
          t.textContent = (errData as any).detail ?? "Failed to update availability";
          document.body.appendChild(t);
          setTimeout(() => t.remove(), 4000);
        }
      } catch {
        const t = document.createElement("div");
        t.className = "fixed bottom-4 right-4 px-4 py-2 rounded-lg text-white text-sm z-50 bg-red-600";
        t.textContent = "Network error — could not update availability";
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 4000);
      } finally {
        allBtns.forEach(b => { b.disabled = false; });
      }
    });
  });

  // Onboarding banner dismiss
  const dismissBtn = document.getElementById("dismiss-onboarding-banner");
  dismissBtn?.addEventListener("click", async () => {
    document.getElementById("onboarding-banner")?.remove();
    try {
      await fetch("/api/onboarding/dismiss-banner", { method: "POST" });
    } catch { /* ignore — UI already updated */ }
  });

  const btn = document.getElementById("enroll-btn");
  const msg = document.getElementById("enroll-msg");

  btn?.addEventListener("click", async () => {
    btn.textContent = "Enrolling...";
    btn.setAttribute("disabled", "true");

    try {
      const res = await fetch("/api/worker/enroll", { method: "POST" });
      if (res.ok) {
        // Redirect new workers to onboarding flow on first enrollment
        window.location.href = "/worker/onboarding";
      } else {
        const body = await res.json().catch(() => ({}));
        if (msg) {
          msg.textContent = body.detail ?? "Enrollment failed. Try again.";
          msg.classList.remove("hidden");
        }
        btn.textContent = "Enable Worker Mode";
        btn.removeAttribute("disabled");
      }
    } catch {
      if (msg) {
        msg.textContent = "Network error. Please try again.";
        msg.classList.remove("hidden");
      }
      btn.textContent = "Enable Worker Mode";
      btn.removeAttribute("disabled");
    }
  });

  // Live countdown for active assignment progress bars
  function updateAssignmentTimers() {
    const bars = document.querySelectorAll<HTMLElement>(".assignment-progress-bar");
    bars.forEach(bar => {
      const claimedAt = bar.dataset.claimedAt;
      const timeoutAt = bar.dataset.timeoutAt;
      if (!claimedAt || !timeoutAt) return;
      const claimedMs = new Date(claimedAt).getTime();
      const timeoutMs = new Date(timeoutAt).getTime();
      const totalMs = timeoutMs - claimedMs;
      const remainingMs = Math.max(0, timeoutMs - Date.now());
      const pct = totalMs > 0 ? Math.min(100, Math.round((remainingMs / totalMs) * 100)) : 0;
      bar.style.width = `${pct}%`;
      bar.className = bar.className.replace(/bg-(emerald|amber|red)-\d+/, "");
      if (pct > 50) {
        bar.classList.add("bg-emerald-500");
        bar.classList.remove("bg-amber-400", "bg-red-500");
      } else if (pct > 25) {
        bar.classList.add("bg-amber-400");
        bar.classList.remove("bg-emerald-500", "bg-red-500");
      } else {
        bar.classList.add("bg-red-500");
        bar.classList.remove("bg-emerald-500", "bg-amber-400");
      }
    });

    document.querySelectorAll<HTMLElement>(".assignment-time-label").forEach(label => {
      const timeoutAt = label.dataset.timeoutAt;
      if (!timeoutAt) return;
      const remainingMs = Math.max(0, new Date(timeoutAt).getTime() - Date.now());
      const remainMins = Math.floor(remainingMs / 60000);
      const remainHours = Math.floor(remainMins / 60);
      const remainMinsLeft = remainMins % 60;
      label.textContent = remainHours > 0
        ? `${remainHours}h ${remainMinsLeft}m left`
        : `${remainMins}m left`;
    });
  }

  updateAssignmentTimers();
  setInterval(updateAssignmentTimers, 60000);

  // ── Streak activity calendar ──────────────────────────────────────────────
  // Load last 14 days of activity and fill in the dot grid.
  (async () => {
    const calendar = document.getElementById("streak-calendar");
    if (!calendar) return;

    try {
      const res = await fetch("/api/worker/activity-calendar?days=14");
      if (!res.ok) return;
      const data = await res.json();
      const activeDates = new Set(data.active_dates ?? []);

      // Build a set of the last 14 date strings (UTC)
      const today = new Date();
      const todayStr = today.toISOString().slice(0, 10);

      const dots = calendar.querySelectorAll<HTMLElement>(".streak-dot");
      dots.forEach(dot => {
        const offsetDays = parseInt(dot.dataset.dayOffset ?? "0", 10);
        const d = new Date(today);
        d.setUTCDate(d.getUTCDate() - offsetDays);
        const dateStr = d.toISOString().slice(0, 10);

        dot.title = dateStr;

        if (dateStr === todayStr) {
          // Today — show violet whether active or not
          if (activeDates.has(dateStr)) {
            dot.classList.remove("bg-gray-800", "border-gray-700/50");
            dot.classList.add("bg-violet-600", "border-violet-400/50");
          } else {
            dot.classList.remove("bg-gray-800");
            dot.classList.add("bg-violet-900/50", "border-violet-700/50");
          }
        } else if (activeDates.has(dateStr)) {
          dot.classList.remove("bg-gray-800", "border-gray-700/50");
          dot.classList.add("bg-emerald-600", "border-emerald-400/30");
        }
        // Otherwise keep default gray (inactive)
      });
    } catch { /* ignore — calendar is decorative */ }
  })();
</script>
