---
/**
 * Worker Performance — personal approval rate stats, task type breakdown,
 * weekly trend, and platform comparison.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login?next=/worker/performance");

let data: any = null;
let error: string | null = null;

try {
  data = await apiFetch<any>("/v1/worker/performance", { token });
} catch (e: any) {
  if (e.message?.includes("401") || e.message?.includes("403")) {
    return Astro.redirect("/login");
  }
  error = e.message ?? "Failed to load performance data";
}

const allTime = data?.all_time ?? {};
const last30d = data?.last_30d ?? {};
const byType: any[] = data?.by_task_type ?? [];
const platformAvgPct: number = data?.platform_avg_approval_rate_pct ?? 0;
const rankPct: number | null = data?.rank_percentile ?? null;
const weekly: any[] = data?.weekly_trend ?? [];

// Colour helpers
function rateColor(pct: number | null | undefined): string {
  if (pct == null) return "text-gray-500";
  if (pct >= 85) return "text-emerald-400";
  if (pct >= 70) return "text-yellow-400";
  return "text-red-400";
}
function rateBg(pct: number | null | undefined): string {
  if (pct == null) return "bg-gray-700";
  if (pct >= 85) return "bg-emerald-500";
  if (pct >= 70) return "bg-yellow-500";
  return "bg-red-500";
}

const TASK_ICONS: Record<string, string> = {
  label_image: "🖼️", label_text: "📝", rate_quality: "⭐",
  verify_fact: "✅", moderate_content: "🛡️", compare_rank: "📊",
  answer_question: "💬", transcription_review: "🎙️",
  web_research: "🔍", entity_lookup: "🏢", document_parse: "📄",
  data_transform: "⚙️", llm_generate: "🤖", screenshot: "📸",
  audio_transcribe: "🎤", pii_detect: "🔒", code_execute: "💻", web_intel: "🌐",
};

const weeklyMax = Math.max(...weekly.map((w: any) => w.total || 0), 1);
---

<Layout title="My Performance — CrowdSorcerer">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10">
    <!-- Header -->
    <div class="mb-8">
      <div class="text-sm text-gray-500 mb-1">
        <a href="/worker" class="hover:text-gray-300 transition-colors">Worker</a>
        <span class="mx-2">›</span>
        <span>My Performance</span>
      </div>
      <h1 class="text-2xl font-bold text-gray-100">My Performance</h1>
      <p class="text-sm text-gray-400 mt-1">
        Your approval rate and quality stats across all reviewed tasks.
      </p>
    </div>

    {error && (
      <div class="mb-6 px-4 py-3 bg-red-950/40 border border-red-800 rounded-xl text-red-300 text-sm">{error}</div>
    )}

    {/* No data state */}
    {allTime.total_reviewed === 0 || allTime.total_reviewed == null ? (
      <div class="bg-gray-900 border border-gray-800 rounded-xl px-6 py-16 text-center">
        <div class="text-4xl mb-3">📊</div>
        <div class="text-gray-300 font-medium mb-1">No reviewed tasks yet</div>
        <p class="text-sm text-gray-500 mb-4">
          Complete human tasks and wait for requesters to review your submissions to see your performance stats.
        </p>
        <a href="/worker/marketplace"
          class="px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors inline-block">
          Browse tasks →
        </a>
      </div>
    ) : (
      <>
        {/* Overview cards */}
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
          <!-- All-time approval rate -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
            <div class="text-xs text-gray-500 mb-1">All-time approval rate</div>
            <div class={`text-3xl font-bold ${rateColor(allTime.approval_rate_pct)}`}>
              {allTime.approval_rate_pct != null ? `${allTime.approval_rate_pct}%` : "—"}
            </div>
            <div class="text-xs text-gray-600 mt-1">{allTime.total_reviewed} tasks reviewed</div>
          </div>
          <!-- Last 30d approval rate -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
            <div class="text-xs text-gray-500 mb-1">Last 30 days</div>
            <div class={`text-3xl font-bold ${rateColor(last30d.approval_rate_pct)}`}>
              {last30d.approval_rate_pct != null ? `${last30d.approval_rate_pct}%` : "—"}
            </div>
            <div class="text-xs text-gray-600 mt-1">{last30d.total_reviewed || 0} tasks reviewed</div>
          </div>
          <!-- Platform average -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
            <div class="text-xs text-gray-500 mb-1">Platform average</div>
            <div class="text-3xl font-bold text-gray-300">
              {platformAvgPct > 0 ? `${platformAvgPct}%` : "—"}
            </div>
            <div class="text-xs text-gray-600 mt-1">across all workers</div>
          </div>
          <!-- Rank percentile -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
            <div class="text-xs text-gray-500 mb-1">Rank percentile</div>
            <div class={`text-3xl font-bold ${rankPct != null && rankPct >= 75 ? "text-emerald-400" : rankPct != null && rankPct >= 50 ? "text-yellow-400" : "text-gray-300"}`}>
              {rankPct != null ? `${rankPct}th` : "—"}
            </div>
            <div class="text-xs text-gray-600 mt-1">
              {rankPct != null ? "better than " + rankPct + "% of workers" : "need 5+ reviews"}
            </div>
          </div>
        </div>

        {/* Platform comparison bar */}
        {allTime.approval_rate_pct != null && platformAvgPct > 0 && (
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mb-6">
            <h2 class="text-sm font-semibold text-gray-300 mb-4">Platform comparison</h2>
            <div class="space-y-3">
              <div>
                <div class="flex justify-between text-xs mb-1">
                  <span class="text-gray-400">Your all-time rate</span>
                  <span class={rateColor(allTime.approval_rate_pct)}>{allTime.approval_rate_pct}%</span>
                </div>
                <div class="w-full bg-gray-700 rounded-full h-2">
                  <div class={`h-2 rounded-full ${rateBg(allTime.approval_rate_pct)}`}
                    style={`width: ${Math.min(allTime.approval_rate_pct, 100)}%`}></div>
                </div>
              </div>
              <div>
                <div class="flex justify-between text-xs mb-1">
                  <span class="text-gray-400">Platform average</span>
                  <span class="text-gray-400">{platformAvgPct}%</span>
                </div>
                <div class="w-full bg-gray-700 rounded-full h-2">
                  <div class="h-2 rounded-full bg-gray-500"
                    style={`width: ${Math.min(platformAvgPct, 100)}%`}></div>
                </div>
              </div>
            </div>
            {allTime.approval_rate_pct > platformAvgPct ? (
              <p class="text-xs text-emerald-400 mt-3">
                ✓ You're {(allTime.approval_rate_pct - platformAvgPct).toFixed(1)}% above the platform average.
              </p>
            ) : allTime.approval_rate_pct < platformAvgPct ? (
              <p class="text-xs text-amber-400 mt-3">
                ↗ You're {(platformAvgPct - allTime.approval_rate_pct).toFixed(1)}% below the platform average.
                Focus on accuracy to improve your score.
              </p>
            ) : (
              <p class="text-xs text-gray-400 mt-3">You're right at the platform average.</p>
            )}
          </div>
        )}

        {/* By task type */}
        {byType.length > 0 && (
          <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-6">
            <div class="px-5 py-3 border-b border-gray-800">
              <h2 class="text-sm font-semibold text-gray-300">Performance by task type</h2>
            </div>
            <div class="divide-y divide-gray-800">
              {byType.map((t: any) => (
                <div class="px-5 py-3 flex items-center gap-4">
                  <div class="w-6 text-base shrink-0">{TASK_ICONS[t.type] ?? "🔧"}</div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm text-gray-200 font-medium">{t.type.replace(/_/g, " ")}</div>
                    <div class="text-xs text-gray-500 mt-0.5">{t.total} reviewed · {t.approved} approved</div>
                  </div>
                  <div class="w-28 shrink-0">
                    <div class="flex justify-between text-xs mb-1">
                      <span class="text-gray-600">{t.approved}/{t.total}</span>
                      <span class={rateColor(t.approval_rate_pct)}>{t.approval_rate_pct != null ? `${t.approval_rate_pct}%` : "—"}</span>
                    </div>
                    <div class="w-full bg-gray-700 rounded-full h-1.5">
                      <div class={`h-1.5 rounded-full ${rateBg(t.approval_rate_pct)}`}
                        style={`width: ${t.approval_rate_pct != null ? Math.min(t.approval_rate_pct, 100) : 0}%`}></div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* Weekly trend */}
        {weekly.length > 0 && (
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <h2 class="text-sm font-semibold text-gray-300 mb-4">Weekly trend (last 8 weeks)</h2>
            <div class="flex items-end gap-2 h-24">
              {weekly.map((w: any) => {
                const heightPct = Math.round((w.total / weeklyMax) * 100);
                const weekLabel = w.week_start
                  ? new Date(w.week_start).toLocaleDateString(undefined, { month: "short", day: "numeric" })
                  : "";
                return (
                  <div class="flex-1 flex flex-col items-center gap-1">
                    <div class="text-xs text-gray-600">{w.approval_rate_pct != null ? `${w.approval_rate_pct}%` : "—"}</div>
                    <div
                      title={`${weekLabel}: ${w.total} tasks, ${w.approval_rate_pct ?? "—"}% approval`}
                      class={`w-full rounded-t transition-all ${rateBg(w.approval_rate_pct)}`}
                      style={`height: ${Math.max(heightPct, 4)}%`}
                    ></div>
                    <div class="text-xs text-gray-600 truncate w-full text-center">{weekLabel}</div>
                  </div>
                );
              })}
            </div>
          </div>
        )}
      </>
    )}

    <div class="mt-8 flex gap-4">
      <a href="/worker" class="text-sm text-gray-500 hover:text-gray-300 transition-colors">← Worker home</a>
      <a href="/worker/recommendations" class="text-sm text-gray-500 hover:text-gray-300 transition-colors">Skill recommendations →</a>
    </div>
  </div>
</Layout>
