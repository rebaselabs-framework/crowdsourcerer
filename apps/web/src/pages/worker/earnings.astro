---
/**
 * Worker earnings & payout dashboard — with analytics charts.
 * Tabs: Task history | Analytics | Payout requests
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login");

const url = new URL(Astro.request.url);
const page = parseInt(url.searchParams.get("page") ?? "1");
const activeTab = url.searchParams.get("tab") ?? "history";
const payoutStatusFilter = url.searchParams.get("payout_status") ?? "";

let user: any = null, stats: any = null, assignments: any[] = [];
let payouts: any[] = [], payoutsTotal = 0, analytics: any = null, error = "";
let payoutSummary: any = null;
const PAGE_SIZE = 20, MIN_PAYOUT = 1000;

try {
  [user, stats] = await Promise.all([
    apiFetch<any>("/v1/users/me", { token }),
    apiFetch<any>("/v1/worker/stats", { token }),
  ]);
  if (!user || (user.role !== "worker" && user.role !== "both")) return Astro.redirect("/worker");
  if (activeTab === "payouts") {
    const qs = new URLSearchParams({ page: String(page), page_size: String(PAGE_SIZE) });
    if (payoutStatusFilter) qs.set("status", payoutStatusFilter);
    const [r, s] = await Promise.all([
      apiFetch<any>(`/v1/payouts?${qs}`, { token }),
      apiFetch<any>("/v1/payouts/summary", { token }).catch(() => null),
    ]);
    payouts = r?.items ?? []; payoutsTotal = r?.total ?? 0;
    payoutSummary = s;
  } else if (activeTab === "analytics") {
    analytics = await apiFetch<any>("/v1/worker/earnings/analytics", { token }).catch(() => null);
  } else {
    assignments = (await apiFetch<any[]>(`/v1/worker/assignments?status=submitted&page_size=${PAGE_SIZE}&page=${page}`, { token })) ?? [];
  }
} catch (e: any) {
  if ((e as Error).message?.includes("403")) return Astro.redirect("/worker");
  error = (e as Error).message ?? "Failed to load";
}

const TYPE_LABELS: Record<string,string> = {
  label_image:"Label Image",label_text:"Classify Text",rate_quality:"Rate Quality",
  verify_fact:"Verify Fact",moderate_content:"Moderate",compare_rank:"A/B Compare",
  answer_question:"Answer",transcription_review:"Transcription",web_research:"Web Research",
  entity_lookup:"Entity Lookup",document_parse:"Doc Parse",data_transform:"Transform",
  llm_generate:"LLM Generate",screenshot:"Screenshot",audio_transcribe:"Transcribe",
  pii_detect:"PII Detect",code_execute:"Code Execute",web_intel:"Web Intel",
};
const TYPE_COLORS = ["#10b981","#6366f1","#f59e0b","#3b82f6","#ec4899","#8b5cf6","#14b8a6","#f97316","#84cc16","#ef4444"];
const PAYOUT_STYLES: Record<string,string> = {
  pending:"bg-yellow-900/40 text-yellow-300",
  processing:"bg-blue-900/40 text-blue-300",
  paid:"bg-emerald-900/40 text-emerald-400",
  rejected:"bg-red-900/40 text-red-400",
};
const fmt = (d:string) => new Date(d).toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric",hour:"2-digit",minute:"2-digit"});
const totalCredits = user?.credits ?? 0;
const canPayout = totalCredits >= MIN_PAYOUT;
const analyticsJson = JSON.stringify(analytics);
---
<Layout title="Earnings & Payouts — CrowdSorcerer">
<div class="max-w-5xl mx-auto px-6 py-10">

  <!-- Header -->
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold">Earnings & Payouts</h1>
      <p class="text-gray-400 text-sm">Your task history, analytics, and withdrawal requests</p>
    </div>
    <div class="flex items-center gap-4">
      <a href="/worker/recommendations" class="text-sm text-violet-400 hover:text-violet-300 transition-colors">
        💡 Skill recommendations →
      </a>
      <a href="/worker" class="text-sm text-gray-400 hover:text-gray-200">← Worker hub</a>
    </div>
  </div>

  <!-- KPI row -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
    <div class="bg-gray-900 border border-emerald-800/40 rounded-xl p-5">
      <div class="text-xs text-gray-400 mb-1 uppercase tracking-wider">Balance</div>
      <div class="text-3xl font-bold text-emerald-300">{totalCredits.toLocaleString()}</div>
      <div class="text-xs text-gray-500">≈ ${(totalCredits/100).toFixed(2)}</div>
    </div>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
      <div class="text-xs text-gray-400 mb-1 uppercase tracking-wider">Total earned</div>
      <div class="text-3xl font-bold">{(stats?.total_earnings_credits??0).toLocaleString()}</div>
      <div class="text-xs text-gray-500">credits lifetime</div>
    </div>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
      <div class="text-xs text-gray-400 mb-1 uppercase tracking-wider">Tasks done</div>
      <div class="text-3xl font-bold">{stats?.tasks_completed?.toLocaleString()??0}</div>
    </div>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
      <div class="text-xs text-gray-400 mb-1 uppercase tracking-wider">Accuracy</div>
      <div class="text-3xl font-bold">{stats?.accuracy!=null?`${(stats.accuracy*100).toFixed(0)}%`:"—"}</div>
    </div>
  </div>

  <!-- Payout CTA / progress -->
  {canPayout ? (
    <div class="bg-emerald-900/20 border border-emerald-700/40 rounded-xl p-5 mb-6 flex items-center justify-between">
      <div>
        <div class="text-emerald-300 font-semibold text-sm">You're eligible for a payout! 💸</div>
        <div class="text-gray-400 text-xs">{totalCredits.toLocaleString()} credits ≈ ${(totalCredits/100).toFixed(2)}</div>
      </div>
      <a href="?tab=payouts#request-payout" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition-colors ml-4 whitespace-nowrap">Request payout</a>
    </div>
  ) : (
    <div class="bg-gray-900 border border-gray-700 rounded-xl p-5 mb-6">
      <div class="text-sm text-gray-300 mb-2">Payout progress</div>
      <div class="flex items-center gap-3">
        <div class="flex-1 bg-gray-800 rounded-full h-2">
          <div class="bg-emerald-500 h-2 rounded-full" style={`width:${Math.min(100,Math.round(totalCredits/MIN_PAYOUT*100))}%`}></div>
        </div>
        <span class="text-xs text-gray-400 whitespace-nowrap">{totalCredits.toLocaleString()} / {MIN_PAYOUT.toLocaleString()}</span>
      </div>
      <p class="text-xs text-gray-500 mt-1">Earn {Math.max(0,MIN_PAYOUT-totalCredits).toLocaleString()} more credits to unlock payouts ($10 min)</p>
    </div>
  )}

  <!-- Tabs -->
  <div class="flex gap-1 mb-6 border-b border-gray-800">
    {[["history","Task history"],["analytics","📊 Analytics"],["payouts","Payout requests"]].map(([t,label]) => (
      <a href={`?tab=${t}`} class={`px-4 py-2 text-sm font-medium border-b-2 transition-colors ${activeTab===t?"border-emerald-500 text-emerald-400":"border-transparent text-gray-400 hover:text-gray-200"}`}>{label}</a>
    ))}
  </div>

  {error && <div class="bg-red-900/30 border border-red-700/50 rounded-xl p-4 mb-6 text-red-300 text-sm">{error}</div>}

  <!-- ── TASK HISTORY ──────────────────────────────────────────────────────── -->
  {activeTab==="history" && (
    assignments.length===0 ? (
      <div class="text-center py-20">
        <div class="text-5xl mb-4">📭</div>
        <p class="text-gray-400 text-lg mb-2">No completed tasks yet</p>
        <a href="/worker/marketplace" class="inline-block px-6 py-2.5 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition-colors">Browse marketplace</a>
      </div>
    ) : (
      <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
        <table class="w-full text-sm">
          <thead class="border-b border-gray-800">
            <tr class="text-gray-500 text-xs uppercase tracking-wider">
              <th class="text-left px-5 py-3">Task type</th>
              <th class="text-left px-5 py-3">Completed</th>
              <th class="text-right px-5 py-3">Credits</th>
              <th class="text-right px-5 py-3">XP</th>
              <th class="text-left px-5 py-3">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            {assignments.map((a:any)=>(
              <tr class="hover:bg-gray-800/40 transition-colors">
                <td class="px-5 py-3 font-medium">{TYPE_LABELS[a.task_type]??a.task_id?.slice(0,8)}</td>
                <td class="px-5 py-3 text-gray-400 text-xs">{a.submitted_at?fmt(a.submitted_at):"—"}</td>
                <td class="px-5 py-3 text-right text-emerald-400 font-semibold">+{a.earnings_credits}</td>
                <td class="px-5 py-3 text-right text-violet-400">+{a.xp_earned}</td>
                <td class="px-5 py-3">
                  <span class={`text-xs px-2 py-0.5 rounded capitalize ${a.status==="approved"?"bg-emerald-900/40 text-emerald-400":a.status==="submitted"?"bg-blue-900/40 text-blue-300":"bg-gray-800 text-gray-400"}`}>{a.status}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  )}

  <!-- ── ANALYTICS ─────────────────────────────────────────────────────────── -->
  {activeTab==="analytics" && (
    <div>
      <!-- Lifetime KPI strip -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-400 mb-1 uppercase tracking-wider">Lifetime earned</div>
          <div class="text-2xl font-bold text-emerald-400">${analytics?analytics.lifetime_usd_earned.toFixed(2):"—"}</div>
          <div class="text-xs text-gray-500">{analytics?.lifetime_credits_earned?.toLocaleString()??0} credits</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-400 mb-1 uppercase tracking-wider">Total paid out</div>
          <div class="text-2xl font-bold text-blue-400">${analytics?analytics.lifetime_usd_paid_out.toFixed(2):"—"}</div>
          <div class="text-xs text-gray-500">{analytics?.total_payouts_completed??0} payouts</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-400 mb-1 uppercase tracking-wider">Avg / task</div>
          <div class="text-2xl font-bold">{analytics?.avg_credits_per_task??0}</div>
          <div class="text-xs text-gray-500">credits</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-xs text-gray-400 mb-1 uppercase tracking-wider">Best month</div>
          <div class="text-2xl font-bold text-violet-400">{analytics?.best_month_credits?.toLocaleString()??0}</div>
          <div class="text-xs text-gray-500">credits</div>
        </div>
      </div>

      <!-- Projected Earnings Banner -->
      {analytics && (analytics.projected_next_month_credits > 0 || analytics.projected_next_week_credits > 0) && (
        <div class={`rounded-2xl p-5 mb-6 border ${
          analytics.earnings_trend === 'up'
            ? 'bg-emerald-900/30 border-emerald-700/50'
            : analytics.earnings_trend === 'down'
            ? 'bg-amber-900/30 border-amber-700/50'
            : 'bg-gray-900 border-gray-700/50'
        }`}>
          <div class="flex items-start justify-between gap-4 flex-wrap">
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="text-sm font-semibold text-gray-200">📈 Projected Earnings</span>
                <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${
                  analytics.earnings_trend === 'up'
                    ? 'bg-emerald-700/60 text-emerald-300'
                    : analytics.earnings_trend === 'down'
                    ? 'bg-amber-700/60 text-amber-300'
                    : 'bg-gray-700 text-gray-300'
                }`}>
                  {analytics.earnings_trend === 'up' ? '↑ Trending up' : analytics.earnings_trend === 'down' ? '↓ Trending down' : '→ Stable'}
                </span>
              </div>
              <p class="text-xs text-gray-400">Based on your last 3 months of activity</p>
            </div>
            <div class="flex gap-6">
              <div class="text-center">
                <div class="text-xs text-gray-400 mb-0.5 uppercase tracking-wider">Next week</div>
                <div class={`text-xl font-bold ${analytics.earnings_trend === 'up' ? 'text-emerald-400' : analytics.earnings_trend === 'down' ? 'text-amber-400' : 'text-gray-300'}`}>
                  ${analytics.projected_next_week_usd.toFixed(2)}
                </div>
                <div class="text-xs text-gray-500">{analytics.projected_next_week_credits.toLocaleString()} cr</div>
              </div>
              <div class="text-center">
                <div class="text-xs text-gray-400 mb-0.5 uppercase tracking-wider">Next month</div>
                <div class={`text-xl font-bold ${analytics.earnings_trend === 'up' ? 'text-emerald-400' : analytics.earnings_trend === 'down' ? 'text-amber-400' : 'text-gray-300'}`}>
                  ${analytics.projected_next_month_usd.toFixed(2)}
                </div>
                <div class="text-xs text-gray-500">{analytics.projected_next_month_credits.toLocaleString()} cr</div>
              </div>
            </div>
          </div>
        </div>
      )}

      <!-- Weekly Earnings Chart — primary, full-width -->
      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 mb-6">
        <div class="flex items-center justify-between mb-4 flex-wrap gap-3">
          <div>
            <h3 class="text-sm font-semibold text-gray-300">Weekly Earnings</h3>
            <p class="text-xs text-gray-500 mt-0.5">Credits earned per week — current week highlighted</p>
          </div>
          <!-- Range selector -->
          <div class="flex gap-1 bg-gray-800 rounded-lg p-1" id="weekly-range-btns">
            {["4W","8W","12W"].map(r=>(
              <button
                data-range={r}
                class={`px-3 py-1 text-xs font-medium rounded-md transition-colors ${r==="12W"?"bg-gray-700 text-emerald-400":"text-gray-400 hover:text-gray-200"}`}
              >{r}</button>
            ))}
          </div>
        </div>
        <div style="height:220px"><canvas id="weeklyEarningsChart"></canvas></div>
        <!-- Summary row below chart -->
        <div class="grid grid-cols-3 gap-4 mt-5 pt-4 border-t border-gray-800" id="weekly-summary">
          <div class="text-center">
            <div class="text-xs text-gray-500 mb-1">This week</div>
            <div id="weekly-this-week" class="text-lg font-bold text-emerald-400">—</div>
            <div class="text-xs text-gray-500">credits</div>
          </div>
          <div class="text-center">
            <div class="text-xs text-gray-500 mb-1">Weekly avg</div>
            <div id="weekly-avg" class="text-lg font-bold text-gray-300">—</div>
            <div class="text-xs text-gray-500">credits</div>
          </div>
          <div class="text-center">
            <div class="text-xs text-gray-500 mb-1">Best week</div>
            <div id="weekly-best" class="text-lg font-bold text-violet-400">—</div>
            <div class="text-xs text-gray-500">credits</div>
          </div>
        </div>
      </div>

      <!-- Charts row -->
      <div class="grid lg:grid-cols-2 gap-6 mb-6">
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
          <h3 class="text-sm font-semibold text-gray-300 mb-4">Monthly Earnings (credits)</h3>
          <div style="height:180px"><canvas id="monthlyEarningsChart"></canvas></div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
          <h3 class="text-sm font-semibold text-gray-300 mb-4">Monthly Payouts (USD)</h3>
          <div style="height:180px"><canvas id="monthlyPayoutsChart"></canvas></div>
        </div>
      </div>

      <!-- Task type breakdown -->
      <div class="grid lg:grid-cols-2 gap-6">
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
          <h3 class="text-sm font-semibold text-gray-300 mb-4">Earnings by Task Type</h3>
          {analytics&&Object.keys(analytics.by_task_type).length>0?(
            <div class="flex items-center gap-6">
              <div style="width:140px;height:140px;flex-shrink:0"><canvas id="taskTypeChart"></canvas></div>
              <div class="flex-1 space-y-1.5">
                {Object.entries(analytics.by_task_type).slice(0,6).map(([type,creds]:any,i:number)=>(
                  <div class="flex items-center justify-between text-xs">
                    <div class="flex items-center gap-2">
                      <div class="w-2.5 h-2.5 rounded-full flex-shrink-0" style={`background-color:${TYPE_COLORS[i%TYPE_COLORS.length]}`}></div>
                      <span class="text-gray-300">{TYPE_LABELS[type]??type}</span>
                    </div>
                    <span class="text-emerald-400 font-semibold">{Number(creds).toLocaleString()}</span>
                  </div>
                ))}
              </div>
            </div>
          ):(
            <div class="text-center py-8 text-gray-500 text-sm">No earnings data yet</div>
          )}
        </div>

        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
          <h3 class="text-sm font-semibold text-gray-300 mb-4">Share by Task Type</h3>
          {analytics&&Object.keys(analytics.by_task_type).length>0?(
            <div class="space-y-3 max-h-52 overflow-y-auto pr-1">
              {Object.entries(analytics.by_task_type).map(([type,creds]:any)=>{
                const total=analytics.lifetime_credits_earned||1;
                const pct=Math.round(Number(creds)/total*100);
                return(
                  <div>
                    <div class="flex justify-between text-xs mb-1">
                      <span class="text-gray-300">{TYPE_LABELS[type]??type}</span>
                      <span class="text-emerald-400 font-semibold">{Number(creds).toLocaleString()} ({pct}%)</span>
                    </div>
                    <div class="bg-gray-800 rounded-full h-1.5">
                      <div class="bg-emerald-500 h-1.5 rounded-full" style={`width:${pct}%`}></div>
                    </div>
                  </div>
                );
              })}
            </div>
          ):(
            <div class="text-center py-8 text-gray-500 text-sm">Complete tasks to see breakdown</div>
          )}
        </div>
      </div>
    </div>
  )}

  <!-- ── PAYOUTS ────────────────────────────────────────────────────────────── -->
  {activeTab==="payouts" && (
    <div>
      <!-- Payout summary stats -->
      {payoutSummary && (
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
            <div class="text-xs text-gray-500 mb-1 uppercase tracking-wider">Total paid out</div>
            <div class="text-2xl font-bold text-emerald-400">${payoutSummary.total_paid_usd.toFixed(2)}</div>
            <div class="text-xs text-gray-500">{payoutSummary.by_status?.paid?.count ?? 0} payouts</div>
          </div>
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
            <div class="text-xs text-gray-500 mb-1 uppercase tracking-wider">In progress</div>
            <div class="text-2xl font-bold text-blue-400">${payoutSummary.total_pending_usd.toFixed(2)}</div>
            <div class="text-xs text-gray-500">
              {((payoutSummary.by_status?.pending?.count??0)+(payoutSummary.by_status?.processing?.count??0))} pending
            </div>
          </div>
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
            <div class="text-xs text-gray-500 mb-1 uppercase tracking-wider">Total requests</div>
            <div class="text-2xl font-bold">{payoutSummary.total_payouts}</div>
          </div>
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
            <div class="text-xs text-gray-500 mb-1 uppercase tracking-wider">Success rate</div>
            <div class="text-2xl font-bold text-emerald-400">
              {payoutSummary.total_payouts > 0
                ? `${Math.round((payoutSummary.by_status?.paid?.count??0) / payoutSummary.total_payouts * 100)}%`
                : "—"}
            </div>
          </div>
        </div>
      )}

      <!-- Filter + Export row -->
      <div class="flex items-center gap-3 mb-4 flex-wrap">
        <form method="GET" class="flex items-center gap-2">
          <input type="hidden" name="tab" value="payouts" />
          <select name="payout_status" class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 focus:outline-none">
            <option value="" selected={payoutStatusFilter === ""}>All statuses</option>
            <option value="pending" selected={payoutStatusFilter === "pending"}>Pending</option>
            <option value="processing" selected={payoutStatusFilter === "processing"}>Processing</option>
            <option value="paid" selected={payoutStatusFilter === "paid"}>Paid</option>
            <option value="rejected" selected={payoutStatusFilter === "rejected"}>Rejected</option>
          </select>
          <button type="submit" class="px-3 py-2 bg-gray-700 hover:bg-gray-600 text-sm text-gray-300 rounded-lg transition-colors">Filter</button>
          {payoutStatusFilter && (
            <a href="?tab=payouts" class="text-xs text-gray-500 hover:text-gray-300">Clear</a>
          )}
        </form>
        <div class="ml-auto flex gap-2">
          <button
            id="export-csv-btn"
            class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-sm text-gray-300 rounded-lg transition-colors border border-gray-700"
            title="Download payout history as CSV"
          >
            ⬇ Export CSV
          </button>
          {canPayout && (
            <a href="#request-payout" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition-colors">
              + Request payout
            </a>
          )}
        </div>
      </div>

      {payouts.length>0&&(
        <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden mb-8">
          <table class="w-full text-sm" id="payouts-table">
            <thead class="border-b border-gray-800">
              <tr class="text-gray-500 text-xs uppercase tracking-wider">
                <th class="text-left px-5 py-3">Amount</th>
                <th class="text-left px-5 py-3">Method</th>
                <th class="text-left px-5 py-3">Requested</th>
                <th class="text-left px-5 py-3">Processed</th>
                <th class="text-left px-5 py-3">Status</th>
                <th class="text-left px-5 py-3">Note</th>
                <th></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
              {payouts.map((p:any)=>(
                <tr class="hover:bg-gray-800/40" data-payout-id={p.id}>
                  <td class="px-5 py-3">
                    <div class="font-semibold text-emerald-400">${p.usd_amount.toFixed(2)}</div>
                    <div class="text-xs text-gray-500">{p.credits_requested.toLocaleString()} cr</div>
                  </td>
                  <td class="px-5 py-3 text-gray-300 capitalize text-xs">
                    {p.payout_method === "paypal" ? "💙 PayPal" :
                     p.payout_method === "bank_transfer" ? "🏦 Bank transfer" :
                     "🔷 Crypto"}
                  </td>
                  <td class="px-5 py-3 text-gray-400 text-xs">{fmt(p.created_at)}</td>
                  <td class="px-5 py-3 text-gray-400 text-xs">{p.processed_at ? fmt(p.processed_at) : "—"}</td>
                  <td class="px-5 py-3">
                    <span class={`text-xs px-2 py-0.5 rounded-full capitalize ${PAYOUT_STYLES[p.status]??"bg-gray-800 text-gray-400"}`}>{p.status}</span>
                  </td>
                  <td class="px-5 py-3 text-xs text-gray-400 max-w-xs truncate" title={p.admin_note??""}>
                    {p.admin_note ? (
                      <span class:list={[p.status === "rejected" ? "text-red-300" : "text-gray-400"]}>{p.admin_note}</span>
                    ) : "—"}
                  </td>
                  <td class="px-4 py-3 text-right">
                    {p.status==="pending"&&(
                      <button class="text-xs text-red-400 hover:text-red-300 cancel-payout" data-id={p.id}>Cancel</button>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      {payouts.length === 0 && (
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-12 text-center mb-8">
          <div class="text-4xl mb-3">💸</div>
          <p class="text-gray-300 font-medium mb-1">
            {payoutStatusFilter ? `No ${payoutStatusFilter} payouts` : "No payout requests yet"}
          </p>
          <p class="text-gray-500 text-sm">
            {payoutStatusFilter ? "Try a different filter." : "Request your first payout once you reach 1,000 credits."}
          </p>
        </div>
      )}

      <!-- Pagination for payouts -->
      {(payoutsTotal > PAGE_SIZE) && (
        <div class="flex items-center justify-between mb-8">
          <span class="text-sm text-gray-500">Page {page} · {payoutsTotal} total</span>
          <div class="flex gap-2">
            {page > 1 && (
              <a href={`?tab=payouts&page=${page-1}${payoutStatusFilter ? `&payout_status=${payoutStatusFilter}` : ""}`}
                class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-sm text-gray-300 rounded-lg transition-colors">
                ← Previous
              </a>
            )}
            {page * PAGE_SIZE < payoutsTotal && (
              <a href={`?tab=payouts&page=${page+1}${payoutStatusFilter ? `&payout_status=${payoutStatusFilter}` : ""}`}
                class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-sm text-gray-300 rounded-lg transition-colors">
                Next →
              </a>
            )}
          </div>
        </div>
      )}

      <div id="request-payout">
        {canPayout?(
          <div class="bg-gray-900 border border-gray-700 rounded-2xl p-6">
            <h2 class="text-lg font-semibold mb-1">Request a payout</h2>
            <p class="text-gray-400 text-sm mb-5">Minimum 1,000 credits ($10). Processing takes 1–5 business days.</p>
            <form id="payout-form" class="space-y-4">
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs text-gray-400 mb-1.5">Credits to withdraw</label>
                  <input id="payout-credits" type="number" min="1000" max={totalCredits} step="100" value="1000"
                    class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-500"/>
                  <p class="text-xs text-gray-500 mt-1">Available: {totalCredits.toLocaleString()}</p>
                </div>
                <div>
                  <label class="block text-xs text-gray-400 mb-1.5">USD equivalent</label>
                  <div id="usd-display" class="bg-gray-800/60 border border-gray-700 rounded-lg px-3 py-2 text-sm text-emerald-400 font-semibold h-[38px] flex items-center">$10.00</div>
                </div>
              </div>
              <div>
                <label class="block text-xs text-gray-400 mb-1.5">Payout method</label>
                <select id="payout-method" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-500">
                  <option value="paypal">PayPal</option>
                  <option value="bank_transfer">Bank transfer (SEPA/SWIFT)</option>
                  <option value="crypto">Crypto (USDC/USDT)</option>
                </select>
              </div>
              <div id="fields-paypal">
                <label class="block text-xs text-gray-400 mb-1.5">PayPal email</label>
                <input id="paypal-email" type="email" placeholder="you@example.com"
                  class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-500"/>
              </div>
              <div id="fields-bank" class="space-y-3 hidden">
                <div>
                  <label class="block text-xs text-gray-400 mb-1.5">Account holder name</label>
                  <input id="bank-name" type="text" placeholder="Full name" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-500"/>
                </div>
                <div>
                  <label class="block text-xs text-gray-400 mb-1.5">IBAN / Account number</label>
                  <input id="bank-iban" type="text" placeholder="IBAN or SWIFT" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-500"/>
                </div>
              </div>
              <div id="fields-crypto" class="space-y-3 hidden">
                <div>
                  <label class="block text-xs text-gray-400 mb-1.5">Network</label>
                  <select id="crypto-network" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-500">
                    <option value="ethereum">Ethereum (USDC ERC-20)</option>
                    <option value="solana">Solana (USDC SPL)</option>
                    <option value="polygon">Polygon (USDC)</option>
                    <option value="base">Base (USDC)</option>
                  </select>
                </div>
                <div>
                  <label class="block text-xs text-gray-400 mb-1.5">Wallet address</label>
                  <input id="crypto-address" type="text" placeholder="0x... or Solana address" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-500"/>
                </div>
              </div>
              <div id="payout-error" class="text-red-400 text-sm hidden"></div>
              <div id="payout-success" class="text-emerald-400 text-sm hidden"></div>
              <button type="submit" class="w-full py-2.5 bg-emerald-600 hover:bg-emerald-500 text-white font-medium rounded-lg transition-colors text-sm">
                Submit withdrawal request
              </button>
            </form>
          </div>
        ):(
          <div class="bg-gray-900/60 border border-gray-800 rounded-2xl p-8 text-center">
            <div class="text-3xl mb-3">🔒</div>
            <p class="text-gray-300 font-medium mb-1">Payouts unlock at 1,000 credits</p>
            <p class="text-gray-500 text-sm">Keep earning to reach the threshold!</p>
          </div>
        )}
      </div>
    </div>
  )}
  <!-- Cancel payout confirmation modal -->
  <div id="cancel-payout-modal" class="hidden fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4">
    <div class="bg-gray-900 border border-gray-800 rounded-xl w-full max-w-sm p-6">
      <h2 class="font-semibold text-gray-200 mb-2">Cancel payout request?</h2>
      <p class="text-sm text-gray-400 mb-5">Your credits will be refunded to your account immediately.</p>
      <div id="cancel-payout-error" class="text-sm text-red-400 bg-red-950/20 border border-red-800 rounded-lg px-3 py-2 hidden mb-3"></div>
      <div class="flex gap-3 justify-end">
        <button type="button" id="cancel-payout-no" class="px-4 py-2 text-sm text-gray-300 border border-gray-700 rounded-lg hover:bg-gray-800">Keep request</button>
        <button type="button" id="cancel-payout-yes" class="px-4 py-2 text-sm bg-red-700 hover:bg-red-600 text-white rounded-lg font-medium">Yes, cancel it</button>
      </div>
    </div>
  </div>
</div>
</Layout>

<script is:inline define:vars={{ analyticsJson }}>
function toast(msg, ok = true) {
  const t = document.createElement('div');
  t.className = `fixed bottom-4 right-4 px-4 py-2 rounded-lg text-white text-sm z-50 ${ok ? 'bg-emerald-600' : 'bg-red-600'}`;
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 3500);
}

const analytics = JSON.parse(analyticsJson);

// Charts
if (analytics && (document.getElementById("weeklyEarningsChart") || document.getElementById("monthlyEarningsChart"))) {
  const COLORS = ["#10b981","#6366f1","#f59e0b","#3b82f6","#ec4899","#8b5cf6","#14b8a6","#f97316","#84cc16","#ef4444"];
  const TT = { backgroundColor:"#1f2937", titleColor:"#9ca3af", bodyColor:"#e5e7eb", borderColor:"#374151", borderWidth:1 };
  const SCALES = { x:{ticks:{color:"#6b7280",font:{size:10}},grid:{color:"#1f2937"}}, y:{ticks:{color:"#6b7280",font:{size:10}},grid:{color:"#1f2937"},beginAtZero:true} };

  const s = document.createElement("script");
  s.src = "https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js";
  s.onload = () => {
    // ── Weekly Earnings Chart ──────────────────────────────────────────────
    const weeklyEl = document.getElementById("weeklyEarningsChart");
    const weekly = analytics.weekly_earnings ?? [];
    let weeklyRange = 12; // default to 12 weeks
    let weeklyChart = null;

    function weekLabel(key) {
      // "2026-W12" → "W12"
      return key.split("-")[1] ?? key;
    }

    function buildWeeklyColors(data, range) {
      return data.slice(-range).map(w =>
        w.is_current ? "#8b5cf6" : "#10b98160"
      );
    }
    function buildWeeklyBorders(data, range) {
      return data.slice(-range).map(w =>
        w.is_current ? "#8b5cf6" : "#10b981"
      );
    }

    function updateWeeklySummary(data, range) {
      const slice = data.slice(-range);
      const current = data.find(w => w.is_current);
      const credits = slice.map(w => w.credits);
      const nonZero = credits.filter(c => c > 0);
      const avg = nonZero.length > 0 ? Math.round(nonZero.reduce((a,b)=>a+b,0) / nonZero.length) : 0;
      const best = Math.max(0, ...credits);
      const thisWeek = current?.credits ?? 0;
      const el1 = document.getElementById("weekly-this-week");
      const el2 = document.getElementById("weekly-avg");
      const el3 = document.getElementById("weekly-best");
      if (el1) el1.textContent = thisWeek.toLocaleString();
      if (el2) el2.textContent = avg.toLocaleString();
      if (el3) el3.textContent = best.toLocaleString();
    }

    function renderWeeklyChart(range) {
      if (!weeklyEl) return;
      const slice = weekly.slice(-range);
      const labels = slice.map(w => weekLabel(w.week));
      const data = slice.map(w => w.credits);
      const bgColors = buildWeeklyColors(weekly, range);
      const borderColors = buildWeeklyBorders(weekly, range);

      if (weeklyChart) {
        weeklyChart.data.labels = labels;
        weeklyChart.data.datasets[0].data = data;
        weeklyChart.data.datasets[0].backgroundColor = bgColors;
        weeklyChart.data.datasets[0].borderColor = borderColors;
        weeklyChart.update("active");
      } else {
        weeklyChart = new Chart(weeklyEl, {
          type: "bar",
          data: {
            labels,
            datasets: [{
              data,
              backgroundColor: bgColors,
              borderColor: borderColors,
              borderWidth: 1.5,
              borderRadius: 5,
              borderSkipped: false,
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            animation: { duration: 300 },
            plugins: {
              legend: { display: false },
              tooltip: {
                ...TT,
                callbacks: {
                  title: (items) => {
                    const w = weekly.slice(-range)[items[0].dataIndex];
                    return `${w.week}${w.is_current ? " (this week)" : ""}`;
                  },
                  label: (c) => {
                    const w = weekly.slice(-range)[c.dataIndex];
                    const usd = (c.parsed.y / 100).toFixed(2);
                    return [
                      ` ${c.parsed.y.toLocaleString()} credits ($${usd})`,
                      ` ${w.tasks} task${w.tasks !== 1 ? "s" : ""}`,
                    ];
                  },
                },
              },
            },
            scales: {
              x: {
                ...SCALES.x,
                ticks: {
                  ...SCALES.x.ticks,
                  maxRotation: 0,
                  callback(_val, idx) {
                    // Only show every 2nd label when showing 12 weeks to avoid crowding
                    if (range === 12 && idx % 2 !== 0) return "";
                    return labels[idx];
                  },
                },
              },
              y: {
                ...SCALES.y,
                ticks: {
                  ...SCALES.y.ticks,
                  callback: (v) => v.toLocaleString(),
                },
              },
            },
          },
        });
      }
      updateWeeklySummary(weekly, range);
    }

    // Initial render
    renderWeeklyChart(weeklyRange);

    // Range selector
    document.getElementById("weekly-range-btns")?.querySelectorAll("button").forEach(btn => {
      btn.addEventListener("click", () => {
        const range = parseInt(btn.dataset.range);
        weeklyRange = range;
        document.querySelectorAll("#weekly-range-btns button").forEach(b => {
          const active = b.dataset.range === btn.dataset.range;
          b.className = `px-3 py-1 text-xs font-medium rounded-md transition-colors ${active ? "bg-gray-700 text-emerald-400" : "text-gray-400 hover:text-gray-200"}`;
        });
        renderWeeklyChart(range);
      });
    });

    // ── Monthly charts ─────────────────────────────────────────────────────
    const el1 = document.getElementById("monthlyEarningsChart");
    if (el1) new Chart(el1, {
      type:"bar",
      data:{ labels:analytics.monthly_earnings.map(m=>m.month.slice(5)), datasets:[{ data:analytics.monthly_earnings.map(m=>m.credits), backgroundColor:"#10b98160", borderColor:"#10b981", borderWidth:1.5, borderRadius:4 }] },
      options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{display:false}, tooltip:{...TT,callbacks:{label:c=>` ${c.parsed.y.toLocaleString()} credits`}} }, scales:SCALES },
    });

    const el2 = document.getElementById("monthlyPayoutsChart");
    if (el2) new Chart(el2, {
      type:"line",
      data:{ labels:analytics.monthly_payouts.map(m=>m.month.slice(5)), datasets:[{ data:analytics.monthly_payouts.map(m=>m.usd), borderColor:"#6366f1", backgroundColor:"#6366f120", fill:true, tension:0.3, pointRadius:3, pointBackgroundColor:"#6366f1" }] },
      options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{display:false}, tooltip:{...TT,callbacks:{label:c=>` $${c.parsed.y.toFixed(2)}`}} }, scales:SCALES },
    });

    const el3 = document.getElementById("taskTypeChart");
    const byType = analytics.by_task_type;
    if (el3 && Object.keys(byType).length>0) new Chart(el3, {
      type:"doughnut",
      data:{ labels:Object.keys(byType), datasets:[{ data:Object.values(byType), backgroundColor:COLORS, borderColor:"#111827", borderWidth:2 }] },
      options:{ responsive:true, maintainAspectRatio:false, cutout:"65%", plugins:{ legend:{display:false}, tooltip:TT } },
    });
  };
  document.head.appendChild(s);
}

// USD display
const cInput = document.getElementById("payout-credits");
const usdDisp = document.getElementById("usd-display");
if (cInput && usdDisp) cInput.addEventListener("input", () => { usdDisp.textContent = `$${(parseInt(cInput.value)/100).toFixed(2)}`; });

// Method switcher
const mSel = document.getElementById("payout-method");
function switchFields() {
  ["paypal","bank","crypto"].forEach(id => document.getElementById(`fields-${id}`)?.classList.add("hidden"));
  const m = mSel?.value;
  document.getElementById(m==="bank_transfer"?"fields-bank":m==="crypto"?"fields-crypto":"fields-paypal")?.classList.remove("hidden");
}
mSel?.addEventListener("change", switchFields);

// Submit payout
document.getElementById("payout-form")?.addEventListener("submit", async e => {
  e.preventDefault();
  const err = document.getElementById("payout-error"), ok = document.getElementById("payout-success");
  err?.classList.add("hidden"); ok?.classList.add("hidden");
  const credits = parseInt(cInput?.value??"0");
  const method = mSel?.value??"paypal";
  let details = {};
  if (method==="paypal") {
    const email = document.getElementById("paypal-email")?.value?.trim();
    if (!email) { if(err){err.textContent="Please enter your PayPal email";err.classList.remove("hidden");} return; }
    details={email};
  } else if (method==="bank_transfer") {
    const name=document.getElementById("bank-name")?.value?.trim(), iban=document.getElementById("bank-iban")?.value?.trim();
    if(!name||!iban){if(err){err.textContent="Please fill in all bank fields";err.classList.remove("hidden");}return;}
    details={account_name:name,iban};
  } else {
    const network=document.getElementById("crypto-network")?.value??"ethereum", address=document.getElementById("crypto-address")?.value?.trim();
    if(!address){if(err){err.textContent="Please enter your wallet address";err.classList.remove("hidden");}return;}
    details={network,address};
  }
  const submitBtn = e.currentTarget.querySelector("button[type='submit']");
  if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = "Submitting…"; }
  try {
    const res = await fetch(`/api/payouts`,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({credits_requested:credits,payout_method:method,payout_details:details})});
    const data = await res.json().catch(function(){return {};});
    if(!res.ok) throw new Error(data.detail??"Request failed");
    if(ok){ok.textContent=`✅ Withdrawal request submitted! $${data.usd_amount.toFixed(2)} is being processed.`;ok.classList.remove("hidden");}
    setTimeout(function(){window.location.href="?tab=payouts";},1500);
  } catch(e){
    if(err){err.textContent=e.message;err.classList.remove("hidden");}
    if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = "Submit withdrawal request"; }
  }
});

// Cancel payout — confirmation modal
let _cancelPayoutId = null;
const cancelModal = document.getElementById("cancel-payout-modal");
const cancelErrEl = document.getElementById("cancel-payout-error");
const cancelYesBtn = document.getElementById("cancel-payout-yes");
const cancelNoBtn = document.getElementById("cancel-payout-no");

document.querySelectorAll(".cancel-payout").forEach(btn => {
  btn.addEventListener("click", () => {
    _cancelPayoutId = btn.dataset.id;
    if (cancelErrEl) cancelErrEl.classList.add("hidden");
    cancelModal?.classList.remove("hidden");
  });
});
cancelNoBtn?.addEventListener("click", () => {
  cancelModal?.classList.add("hidden");
  _cancelPayoutId = null;
});
cancelYesBtn?.addEventListener("click", async () => {
  if (!_cancelPayoutId) return;
  const orig = cancelYesBtn.textContent;
  cancelYesBtn.textContent = "Cancelling…";
  cancelYesBtn.disabled = true;
  try {
    const res = await fetch(`/api/payouts/${_cancelPayoutId}`, { method: "DELETE" });
    if (res.ok || res.status === 204) {
      cancelModal?.classList.add("hidden");
      toast("Payout request cancelled — credits refunded");
      setTimeout(() => window.location.reload(), 800);
    } else {
      const d = await res.json().catch(() => ({}));
      if (cancelErrEl) { cancelErrEl.textContent = d.detail ?? "Failed to cancel"; cancelErrEl.classList.remove("hidden"); }
    }
  } catch {
    if (cancelErrEl) { cancelErrEl.textContent = "Network error — please try again"; cancelErrEl.classList.remove("hidden"); }
  } finally {
    cancelYesBtn.textContent = orig;
    cancelYesBtn.disabled = false;
  }
});

// CSV export — fetch all payouts (up to 500) and download as CSV
document.getElementById("export-csv-btn")?.addEventListener("click", async () => {
  const btn = document.getElementById("export-csv-btn");
  if (!btn) return;
  const orig = btn.textContent;
  btn.textContent = "Exporting…";
  btn.setAttribute("disabled", "true");

  try {
    // Fetch up to 500 payouts for export
    const res = await fetch(`/api/payouts?page=1&page_size=500`);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();
    const items = data?.items ?? [];

    // Build CSV
    const rows = [
      ["ID", "Amount (USD)", "Credits", "Method", "Status", "Requested At", "Processed At", "Admin Note"],
      ...items.map((p) => [
        p.id,
        p.usd_amount.toFixed(2),
        p.credits_requested,
        p.payout_method,
        p.status,
        p.created_at ? new Date(p.created_at).toISOString() : "",
        p.processed_at ? new Date(p.processed_at).toISOString() : "",
        (p.admin_note ?? "").replace(/"/g, '""'),
      ]),
    ];
    const csv = rows.map(r => r.map((v) => `"${v}"`).join(",")).join("\n");
    const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = `payouts-${new Date().toISOString().slice(0,10)}.csv`;
    a.click();
    URL.revokeObjectURL(url);
  } catch {
    toast("Failed to export payouts — please try again", false);
  } finally {
    btn.textContent = orig;
    btn.removeAttribute("disabled");
  }
});
</script>
