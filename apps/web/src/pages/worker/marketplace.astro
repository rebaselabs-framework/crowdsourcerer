---
/**
 * Task Marketplace — browse open human tasks available for workers.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);

if (!token) {
  return Astro.redirect("/login?next=/worker/marketplace");
}

const url = new URL(Astro.request.url);
const page = parseInt(url.searchParams.get("page") ?? "1");
const filterType = url.searchParams.get("type") ?? "";
const filterPriority = url.searchParams.get("priority") ?? "";
// "feed" mode = skill-ranked; "browse" mode = chronological with filters
const mode = url.searchParams.get("mode") ?? "feed";

let user: any = null;
let tasks: any = null;
let error = "";

try {
  user = await apiFetch("/v1/users/me", { token });

  if (user?.role !== "worker" && user?.role !== "both") {
    return Astro.redirect("/worker");
  }

  if (mode === "feed") {
    // Skill-ranked personalised feed
    const params = new URLSearchParams({ page: String(page), page_size: "20" });
    tasks = await apiFetch(`/v1/worker/tasks/feed?${params}`, { token });
  } else {
    const params = new URLSearchParams({
      page: String(page),
      page_size: "20",
      ...(filterType ? { type: filterType } : {}),
      ...(filterPriority ? { priority: filterPriority } : {}),
    });
    tasks = await apiFetch(`/v1/worker/tasks?${params}`, { token });
  }
} catch (e: any) {
  if ((e as Error).message?.includes("403")) {
    return Astro.redirect("/worker");
  }
  error = (e as Error).message ?? "Failed to load tasks";
}

const TASK_TYPE_META: Record<string, { label: string; icon: string; desc: string }> = {
  label_image:          { label: "Label Image",       icon: "🖼️",  desc: "Classify an image into categories" },
  label_text:           { label: "Classify Text",     icon: "📝",  desc: "Assign labels to text content" },
  rate_quality:         { label: "Rate Quality",      icon: "⭐",  desc: "Score content quality 1–5" },
  verify_fact:          { label: "Verify Fact",       icon: "✅",  desc: "Confirm or refute a claim" },
  moderate_content:     { label: "Moderate",          icon: "🛡️",  desc: "Review content for policy" },
  compare_rank:         { label: "A/B Compare",       icon: "⚖️",  desc: "Pick the better of two options" },
  answer_question:      { label: "Answer Q",          icon: "💬",  desc: "Answer a question about content" },
  transcription_review: { label: "Review Transcript", icon: "🎙️", desc: "Correct an AI transcript" },
};

const PRIORITY_COLORS: Record<string, string> = {
  low:    "text-gray-400 bg-gray-800",
  normal: "text-blue-300 bg-blue-900/40",
  high:   "text-orange-300 bg-orange-900/40",
  urgent: "text-red-300 bg-red-900/40",
};

const HUMAN_TASK_TYPES = Object.keys(TASK_TYPE_META);
---

<Layout title="Task Marketplace — CrowdSorcerer">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold">Task Marketplace</h1>
        <p class="text-gray-400 text-sm mt-0.5">
          {tasks?.total ?? 0} task{tasks?.total !== 1 ? "s" : ""} available
          {mode === "feed" && <span class="ml-2 text-violet-400 text-xs">· ranked by your skills</span>}
        </p>
      </div>
      <a href="/worker" class="text-sm text-gray-400 hover:text-gray-200">← Worker hub</a>
    </div>

    <!-- Mode toggle -->
    <div class="flex gap-2 mb-6">
      <a
        href="/worker/marketplace?mode=feed"
        class:list={[
          "px-4 py-2 rounded-lg text-sm font-medium transition-colors",
          mode === "feed"
            ? "bg-violet-600 text-white"
            : "bg-gray-800 text-gray-400 hover:text-gray-200 hover:bg-gray-700"
        ]}
      >
        🎯 For You
      </a>
      <a
        href="/worker/marketplace?mode=browse"
        class:list={[
          "px-4 py-2 rounded-lg text-sm font-medium transition-colors",
          mode === "browse"
            ? "bg-violet-600 text-white"
            : "bg-gray-800 text-gray-400 hover:text-gray-200 hover:bg-gray-700"
        ]}
      >
        🌐 Browse All
      </a>
    </div>

    <!-- Filters (browse mode only) -->
    {mode === "browse" && <form method="get" class="flex flex-wrap gap-3 mb-8">
      <input type="hidden" name="mode" value="browse" />
      <select
        name="type"
        class="bg-gray-900 border border-gray-700 text-sm rounded-lg px-3 py-2 text-gray-200 focus:outline-none focus:border-violet-500"
      >
        <option value="" selected={!filterType}>All types</option>
        {HUMAN_TASK_TYPES.map((t) => (
          <option value={t} selected={filterType === t}>
            {TASK_TYPE_META[t].icon} {TASK_TYPE_META[t].label}
          </option>
        ))}
      </select>

      <select
        name="priority"
        class="bg-gray-900 border border-gray-700 text-sm rounded-lg px-3 py-2 text-gray-200 focus:outline-none focus:border-violet-500"
      >
        <option value="" selected={!filterPriority}>All priorities</option>
        <option value="urgent" selected={filterPriority === "urgent"}>🔴 Urgent</option>
        <option value="high" selected={filterPriority === "high"}>🟠 High</option>
        <option value="normal" selected={filterPriority === "normal"}>🔵 Normal</option>
        <option value="low" selected={filterPriority === "low"}>⚪ Low</option>
      </select>

      <button
        type="submit"
        class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-sm rounded-lg transition-colors"
      >
        Filter
      </button>
      {(filterType || filterPriority) && (
        <a
          href="/worker/marketplace"
          class="px-4 py-2 text-sm text-gray-400 hover:text-gray-200 transition-colors"
        >
          Clear
        </a>
      )}
    </form>}

    <!-- Error -->
    {error && (
      <div class="bg-red-900/30 border border-red-700/50 rounded-xl p-4 mb-6 text-red-300 text-sm">
        {error}
      </div>
    )}

    <!-- Task list -->
    {tasks?.items?.length === 0 ? (
      <div class="py-12">
        <div class="text-center mb-10">
          <div class="text-5xl mb-4">🔮</div>
          <h3 class="text-xl font-semibold mb-2">No tasks right now</h3>
          {(filterType || filterPriority) ? (
            <p class="text-gray-400 text-sm mb-4">No tasks match your current filters. Try clearing them or check back soon.</p>
          ) : mode === "feed" ? (
            <p class="text-gray-400 text-sm mb-4">Your personalised feed is empty. Add skills to your profile to get matched with tasks — or browse all tasks.</p>
          ) : (
            <p class="text-gray-400 text-sm mb-4">The marketplace is quiet right now. Tasks are posted by requesters on demand — check back soon or set up an alert.</p>
          )}
          <div class="flex flex-wrap justify-center gap-3">
            {mode === "feed" ? (
              <a href="/worker/marketplace?mode=browse"
                class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-200 text-sm rounded-lg border border-gray-700 transition-colors">
                Browse all tasks
              </a>
            ) : (
              <a href="/worker/marketplace?mode=feed"
                class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-200 text-sm rounded-lg border border-gray-700 transition-colors">
                Switch to personalised feed
              </a>
            )}
            <a href="/worker/skills"
              class="px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors">
              Add skills
            </a>
            <a href="/dashboard/saved-searches"
              class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-200 text-sm rounded-lg border border-gray-700 transition-colors">
              🔔 Set task alert
            </a>
          </div>
        </div>

        <!-- What kinds of tasks are available here? -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
          <h4 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Task types you can earn from</h4>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            {Object.entries(TASK_TYPE_META).map(([_type, meta]) => (
              <div class="bg-gray-800/50 rounded-lg p-3 text-center">
                <div class="text-2xl mb-1">{meta.icon}</div>
                <div class="text-xs font-medium text-gray-300">{meta.label}</div>
                <div class="text-xs text-gray-500 mt-0.5">{meta.desc}</div>
              </div>
            ))}
          </div>
          <p class="text-xs text-gray-500 text-center mt-4">
            New tasks appear as requesters post them. Complete your profile and add skills to get notified first.
          </p>
        </div>
      </div>
    ) : (
      <div class="space-y-3">
        {tasks?.items?.map((task: any) => {
          const meta = TASK_TYPE_META[task.type] ?? { label: task.type, icon: "🔮", desc: "" };
          const priorityClass = PRIORITY_COLORS[task.priority] ?? PRIORITY_COLORS.normal;
          const slotsLeft = task.slots_available ?? (task.assignments_required - task.assignments_completed);

          return (
            <a
              href={`/worker/tasks/${task.id}`}
              class="group block bg-gray-900 border border-gray-800 hover:border-emerald-700/60 active:border-emerald-600 rounded-xl p-4 sm:p-5 transition-colors"
            >
              <!-- Mobile: stacked layout; Desktop: row layout -->
              <div class="flex items-start gap-3 sm:gap-4">
                <span class="text-2xl sm:text-3xl shrink-0 mt-0.5">{meta.icon}</span>
                <div class="flex-1 min-w-0">
                  <!-- Top row: label + reward -->
                  <div class="flex items-start justify-between gap-2 mb-1">
                    <div class="flex items-center gap-2 flex-wrap">
                      <span class="font-semibold text-sm sm:text-base">{meta.label}</span>
                      <span class={`text-xs font-medium px-1.5 py-0.5 rounded capitalize ${priorityClass}`}>
                        {task.priority}
                      </span>
                    </div>
                    <!-- Reward — always top right -->
                    <div class="shrink-0 text-right">
                      <span class="text-emerald-300 font-bold text-base sm:text-lg">+{task.reward_credits}</span>
                      <span class="text-gray-500 text-xs ml-1">cr</span>
                    </div>
                  </div>
                  <p class="text-xs sm:text-sm text-gray-400 mb-1.5">{meta.desc}</p>
                  {task.task_instructions && (
                    <p class="text-xs sm:text-sm text-gray-300 line-clamp-2 mb-1.5">{task.task_instructions}</p>
                  )}
                  <!-- Bottom row: meta + CTA -->
                  <div class="flex items-center justify-between gap-2 mt-2">
                    <div class="flex items-center gap-3 text-xs text-gray-500 flex-wrap">
                      <span>⏱ ~{task.estimated_minutes}m</span>
                      <span>👥 {task.assignments_completed}/{task.assignments_required}</span>
                      {slotsLeft <= 2 && slotsLeft > 0 && (
                        <span class="text-orange-400 font-medium">Only {slotsLeft} left!</span>
                      )}
                      {task.min_skill_level && (
                        <span class="text-purple-400">Lv{task.min_skill_level}+ required</span>
                      )}
                      {task.match_score != null && (
                        <span class:list={[
                          "font-medium",
                          task.match_score >= 0.7 ? "text-green-400" :
                          task.match_score >= 0.4 ? "text-yellow-400" : "text-gray-500"
                        ]}>
                          🎯 {Math.round(task.match_score * 100)}% match
                        </span>
                      )}
                    </div>
                    <div class="flex items-center gap-2 flex-shrink-0">
                      <button
                        class="watchlist-btn p-1.5 rounded-lg text-gray-500 hover:text-amber-400 hover:bg-gray-800 transition-colors"
                        data-task-id={task.id}
                        title="Bookmark task"
                        onclick="event.preventDefault(); toggleWatchlist(this, event)"
                      >
                        🔖
                      </button>
                      <span class="px-3 py-1.5 bg-emerald-700 group-hover:bg-emerald-600 text-white text-xs font-medium rounded-lg transition-colors">
                        Claim →
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    )}

    <!-- Pagination -->
    {tasks && tasks.total > 20 && (
      <div class="flex justify-center gap-3 mt-10">
        {page > 1 && (
          <a
            href={`?page=${page - 1}${filterType ? `&type=${filterType}` : ""}${filterPriority ? `&priority=${filterPriority}` : ""}`}
            class="px-4 py-2 bg-gray-900 border border-gray-700 hover:border-gray-500 rounded-lg text-sm transition-colors"
          >
            ← Prev
          </a>
        )}
        <span class="px-4 py-2 text-sm text-gray-400">
          Page {page} of {Math.ceil(tasks.total / 20)}
        </span>
        {tasks.has_next && (
          <a
            href={`?page=${page + 1}${filterType ? `&type=${filterType}` : ""}${filterPriority ? `&priority=${filterPriority}` : ""}`}
            class="px-4 py-2 bg-gray-900 border border-gray-700 hover:border-gray-500 rounded-lg text-sm transition-colors"
          >
            Next →
          </a>
        )}
      </div>
    )}
  </div>

  <script>
    // Watchlist toggle — bookmark/unbookmark a task
    async function toggleWatchlist(btn: HTMLButtonElement, event: MouseEvent) {
      event.preventDefault();
      event.stopPropagation();
      const taskId = btn.dataset.taskId;
      if (!taskId) return;

      const isBookmarked = btn.dataset.bookmarked === "true";
      const method = isBookmarked ? "DELETE" : "POST";

      try {
        const res = await fetch(`/api/worker/watchlist/${taskId}`, { method });
        if (res.ok) {
          btn.dataset.bookmarked = isBookmarked ? "false" : "true";
          btn.title = isBookmarked ? "Bookmark task" : "Remove from watchlist";
          btn.style.color = isBookmarked ? "" : "#f59e0b"; // amber when bookmarked
          const msg = isBookmarked ? "Removed from watchlist" : "Added to watchlist ✅";
          showToast(msg);
        }
      } catch {
        // silent fail
      }
    }

    function showToast(msg: string) {
      const el = document.createElement("div");
      el.textContent = msg;
      el.className = "fixed bottom-20 left-1/2 -translate-x-1/2 bg-gray-900 text-white text-sm px-4 py-2 rounded-full shadow-lg z-50";
      document.body.appendChild(el);
      setTimeout(() => el.remove(), 2500);
    }
    (window as any).toggleWatchlist = toggleWatchlist;
  </script>
</Layout>
