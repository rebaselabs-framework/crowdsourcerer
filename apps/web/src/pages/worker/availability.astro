---
/**
 * Worker Availability Calendar — set weekly schedule and blackout dates.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login?next=/worker/availability");

let availabilityData: any = null;
let error: string | null = null;

try {
  availabilityData = await apiFetch("/v1/worker/availability", { token });
} catch (e: any) {
  error = e.message ?? "Failed to load availability.";
}

// Weekly slots: days × hour-blocks
const DAYS = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];
const DAY_KEYS = ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"];
const HOUR_BLOCKS = [
  { label: "0–2 am",   start: 0,  end: 2  },
  { label: "2–4 am",   start: 2,  end: 4  },
  { label: "4–6 am",   start: 4,  end: 6  },
  { label: "6–8 am",   start: 6,  end: 8  },
  { label: "8–10 am",  start: 8,  end: 10 },
  { label: "10–12 pm", start: 10, end: 12 },
  { label: "12–2 pm",  start: 12, end: 14 },
  { label: "2–4 pm",   start: 14, end: 16 },
  { label: "4–6 pm",   start: 16, end: 18 },
  { label: "6–8 pm",   start: 18, end: 20 },
  { label: "8–10 pm",  start: 20, end: 22 },
  { label: "10–12 am", start: 22, end: 24 },
];

// Convert API response (slots array) → weekly schedule map
const DAY_KEYS_BY_INDEX: Record<number, string> = {
  0: "monday", 1: "tuesday", 2: "wednesday", 3: "thursday",
  4: "friday", 5: "saturday", 6: "sunday",
};
const weeklySchedule: Record<string, Array<{start: number; end: number}>> = {};
for (const slot of (availabilityData?.slots ?? [])) {
  const dayKey = DAY_KEYS_BY_INDEX[slot.day_of_week as number];
  if (!dayKey) continue;
  if (!weeklySchedule[dayKey]) weeklySchedule[dayKey] = [];
  weeklySchedule[dayKey].push({ start: slot.start_hour as number, end: slot.end_hour as number });
}

// Pre-compute which slots are checked
function isSlotActive(dayKey: string, block: {start: number; end: number}): boolean {
  const slots = weeklySchedule[dayKey] ?? [];
  return slots.some((s: any) => s.start <= block.start && s.end >= block.end);
}

const blackoutDates: any[] = availabilityData?.blackouts ?? [];
---

<Layout title="My Availability — CrowdSorcerer">
  <div class="max-w-5xl mx-auto px-6 py-10">

    <!-- Header -->
    <div class="flex items-start justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold">📅 My Availability</h1>
        <p class="text-gray-400 text-sm mt-0.5">
          Set your weekly working hours and block out dates you're unavailable.
        </p>
      </div>
      <a href="/worker" class="text-sm text-gray-400 hover:text-white transition-colors">
        ← Back to Earn
      </a>
    </div>

    {error && (
      <div class="text-red-400 bg-red-900/20 border border-red-800/40 rounded-xl p-6 mb-6 text-center">
        {error}
      </div>
    )}

    <!-- Save feedback -->
    <div id="save-msg" class="hidden mb-4 px-4 py-3 rounded-lg text-sm font-medium"></div>

    <!-- Weekly Availability Grid -->
    <section class="bg-gray-900 border border-gray-800 rounded-2xl p-6 mb-8">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-lg font-semibold">Weekly Schedule</h2>
          <p class="text-gray-500 text-xs mt-0.5">Check the hour blocks when you're typically available</p>
        </div>
        <button
          id="save-schedule-btn"
          class="px-5 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors"
        >
          Save Schedule
        </button>
      </div>

      <!-- Grid: rows = hour blocks, cols = days -->
      <div class="overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr>
              <th class="text-left pr-4 py-2 text-gray-500 font-medium w-24">Hours</th>
              {DAYS.map((day) => (
                <th class="text-center px-2 py-2 text-gray-300 font-semibold">{day}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {HOUR_BLOCKS.map((block) => (
              <tr class="border-t border-gray-800/60">
                <td class="pr-4 py-2 text-gray-500 whitespace-nowrap">{block.label}</td>
                {DAY_KEYS.map((dayKey, _di) => (
                  <td class="px-2 py-2 text-center">
                    <input
                      type="checkbox"
                      class="availability-slot w-4 h-4 rounded accent-violet-500 cursor-pointer"
                      data-day={dayKey}
                      data-start={block.start}
                      data-end={block.end}
                      checked={isSlotActive(dayKey, block)}
                    />
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Quick select buttons -->
      <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t border-gray-800">
        <span class="text-xs text-gray-500 self-center mr-1">Quick select:</span>
        <button id="select-weekdays" class="px-3 py-1 text-xs rounded-lg border border-gray-700 hover:border-violet-600 text-gray-400 hover:text-violet-300 transition-colors">
          Weekdays 9–5
        </button>
        <button id="select-evenings" class="px-3 py-1 text-xs rounded-lg border border-gray-700 hover:border-violet-600 text-gray-400 hover:text-violet-300 transition-colors">
          Evenings (6–10 pm)
        </button>
        <button id="select-all" class="px-3 py-1 text-xs rounded-lg border border-gray-700 hover:border-violet-600 text-gray-400 hover:text-violet-300 transition-colors">
          All hours
        </button>
        <button id="clear-all" class="px-3 py-1 text-xs rounded-lg border border-gray-700 hover:border-red-600 text-gray-400 hover:text-red-400 transition-colors">
          Clear all
        </button>
      </div>
    </section>

    <!-- Blackout Dates -->
    <section class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
      <h2 class="text-lg font-semibold mb-1">Blackout Dates</h2>
      <p class="text-gray-500 text-xs mb-5">Block specific dates when you won't be available at all (e.g. holidays, travel).</p>

      <!-- Add new blackout -->
      <div class="flex flex-col sm:flex-row gap-3 mb-6">
        <input
          type="date"
          id="blackout-date-input"
          class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-violet-500"
        />
        <input
          type="text"
          id="blackout-reason-input"
          placeholder="Reason (optional)"
          maxlength="200"
          class="flex-1 bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-violet-500"
        />
        <button
          id="add-blackout-btn"
          class="px-5 py-2 bg-gray-700 hover:bg-gray-600 text-white text-sm rounded-lg transition-colors whitespace-nowrap"
        >
          + Add date
        </button>
      </div>
      <div id="blackout-error" class="hidden mb-3 text-xs text-red-400"></div>

      <!-- Existing blackout dates -->
      <div id="blackout-list" class="space-y-2">
        {blackoutDates.length === 0 ? (
          <p class="text-gray-600 text-sm">No blackout dates set.</p>
        ) : (
          blackoutDates.map((bd: any) => (
            <div class="flex items-center justify-between bg-gray-800/60 border border-gray-700/60 rounded-lg px-4 py-3" data-blackout-id={bd.id}>
              <div class="flex items-center gap-3">
                <span class="text-red-400 font-mono text-sm">{bd.blackout_date}</span>
                {bd.reason && (
                  <span class="text-gray-400 text-xs">{bd.reason}</span>
                )}
              </div>
              <button
                class="remove-blackout-btn text-xs text-gray-600 hover:text-red-400 transition-colors"
                data-id={bd.id}
                data-date={bd.blackout_date}
              >
                Remove
              </button>
            </div>
          ))
        )}
      </div>
    </section>

  </div>
</Layout>

<script is:inline>
  function toast(msg, ok) {
    var t = document.createElement('div');
    t.className = 'fixed bottom-4 right-4 px-4 py-2 rounded-lg text-white text-sm z-50 ' + (ok !== false ? 'bg-emerald-600' : 'bg-red-600');
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(function() { t.remove(); }, 3500);
  }

  // ── Weekly schedule save ────────────────────────────────────────────────────
  const saveBtn = document.getElementById("save-schedule-btn");
  const saveMsg = document.getElementById("save-msg");

  function showMsg(text, ok) {
    saveMsg.textContent = text;
    saveMsg.className = ok
      ? "mb-4 px-4 py-3 rounded-lg text-sm font-medium bg-green-900/30 border border-green-700 text-green-300"
      : "mb-4 px-4 py-3 rounded-lg text-sm font-medium bg-red-900/30 border border-red-700 text-red-300";
    saveMsg.classList.remove("hidden");
    setTimeout(() => saveMsg.classList.add("hidden"), 4000);
  }

  function buildSchedule() {
    var schedule = {};
    document.querySelectorAll(".availability-slot:checked").forEach(function(cb) {
      var day = cb.dataset.day;
      var start = parseInt(cb.dataset.start);
      var end = parseInt(cb.dataset.end);
      if (!schedule[day]) schedule[day] = [];
      schedule[day].push({ start: start, end: end });
    });
    return schedule;
  }

  saveBtn.addEventListener("click", async function() {
    saveBtn.disabled = true;
    saveBtn.textContent = "Saving…";
    try {
      var schedule = buildSchedule();
      var res = await fetch("/api/worker/availability-schedule", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ weekly_schedule: schedule }),
      });
      if (res.ok) {
        showMsg("✓ Schedule saved successfully!", true);
      } else {
        var d = await res.json().catch(function() { return {}; });
        showMsg(d.detail || "Failed to save schedule.", false);
      }
    } catch (e) {
      showMsg("Network error — please try again.", false);
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = "Save Schedule";
    }
  });

  // ── Quick select helpers ────────────────────────────────────────────────────
  function setSlots(predicate) {
    document.querySelectorAll(".availability-slot").forEach(function(cb) {
      cb.checked = predicate(cb);
    });
  }

  document.getElementById("select-weekdays").addEventListener("click", function() {
    setSlots(function(cb) {
      var day = cb.dataset.day;
      var start = parseInt(cb.dataset.start);
      var workdays = ["monday","tuesday","wednesday","thursday","friday"];
      return workdays.includes(day) && start >= 8 && start < 16;
    });
  });

  document.getElementById("select-evenings").addEventListener("click", function() {
    setSlots(function(cb) {
      var start = parseInt(cb.dataset.start);
      return start >= 18 && start < 22;
    });
  });

  document.getElementById("select-all").addEventListener("click", function() {
    setSlots(function() { return true; });
  });

  document.getElementById("clear-all").addEventListener("click", function() {
    setSlots(function() { return false; });
  });

  // ── Blackout dates ──────────────────────────────────────────────────────────
  var addBtn = document.getElementById("add-blackout-btn");
  var dateInput = document.getElementById("blackout-date-input");
  var reasonInput = document.getElementById("blackout-reason-input");
  var blackoutError = document.getElementById("blackout-error");
  var blackoutList = document.getElementById("blackout-list");

  addBtn.addEventListener("click", async function() {
    var date = dateInput.value;
    if (!date) {
      blackoutError.textContent = "Please select a date.";
      blackoutError.classList.remove("hidden");
      return;
    }
    blackoutError.classList.add("hidden");
    addBtn.disabled = true;
    addBtn.textContent = "Adding…";
    try {
      var res = await fetch("/api/worker/blackout-dates", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ date: date, reason: reasonInput.value.trim() || null }),
      });
      if (res.ok) {
        var bd = await res.json();
        // Append to list
        var noMsg = blackoutList.querySelector("p");
        if (noMsg) noMsg.remove();
        var row = document.createElement("div");
        row.className = "flex items-center justify-between bg-gray-800/60 border border-gray-700/60 rounded-lg px-4 py-3";
        row.dataset.blackoutId = bd.id || date;
        row.innerHTML =
          '<div class="flex items-center gap-3">' +
            '<span class="text-red-400 font-mono text-sm">' + date + '</span>' +
            (reasonInput.value.trim() ? '<span class="text-gray-400 text-xs">' + reasonInput.value.trim() + '</span>' : '') +
          '</div>' +
          '<button class="remove-blackout-btn text-xs text-gray-600 hover:text-red-400 transition-colors" data-id="' + (bd.id || date) + '" data-date="' + date + '">Remove</button>';
        blackoutList.appendChild(row);
        row.querySelector(".remove-blackout-btn").addEventListener("click", handleRemove);
        dateInput.value = "";
        reasonInput.value = "";
      } else {
        var d = await res.json().catch(function() { return {}; });
        blackoutError.textContent = d.detail || "Failed to add blackout date.";
        blackoutError.classList.remove("hidden");
      }
    } catch (e) {
      blackoutError.textContent = "Network error.";
      blackoutError.classList.remove("hidden");
    } finally {
      addBtn.disabled = false;
      addBtn.textContent = "+ Add date";
    }
  });

  async function handleRemove(e) {
    var btn = e.currentTarget;
    var id = btn.dataset.id;
    // Two-step confirm: first click → set pending, second click → proceed
    if (btn.dataset.pending !== "true") {
      btn.dataset.pending = "true";
      var orig = btn.textContent;
      btn.textContent = "Remove?";
      btn.classList.remove("text-gray-600");
      btn.classList.add("text-red-400");
      setTimeout(function() {
        if (btn.dataset.pending === "true") {
          btn.dataset.pending = "";
          btn.textContent = orig;
          btn.classList.remove("text-red-400");
          btn.classList.add("text-gray-600");
        }
      }, 3000);
      return;
    }
    btn.dataset.pending = "";
    btn.disabled = true;
    try {
      var res = await fetch("/api/worker/blackout-dates/" + encodeURIComponent(id), {
        method: "DELETE",
      });
      if (res.ok || res.status === 204) {
        btn.closest("[data-blackout-id]").remove();
        if (blackoutList.children.length === 0) {
          var p = document.createElement("p");
          p.className = "text-gray-600 text-sm";
          p.textContent = "No blackout dates set.";
          blackoutList.appendChild(p);
        }
      } else {
        toast("Failed to remove blackout date.", false);
        btn.disabled = false;
      }
    } catch (e) {
      toast("Network error — please try again.", false);
      btn.disabled = false;
    }
  }

  // Attach remove handlers to existing rows
  document.querySelectorAll(".remove-blackout-btn").forEach(function(btn) {
    btn.addEventListener("click", handleRemove);
  });
</script>
