---
import Layout from '../../layouts/Layout.astro';
import { apiFetch, getToken } from '@/lib/api';

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect('/login');

// Fetch portfolio items
let items: any[] = [];
try {
  items = await apiFetch<any[]>('/v1/worker/portfolio', { token });
} catch {}

// Fetch recently completed tasks for pinning
let completedTasks: any[] = [];
try {
  const data = await apiFetch<any>('/v1/tasks?status=completed&limit=50', { token });
  completedTasks = (data.tasks ?? data).slice(0, 50);
} catch {}

const clientApiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8100';
---
<Layout title="My Portfolio Showcase">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold">🗂️ Portfolio Showcase</h1>
        <p class="text-gray-500 text-sm mt-1">Pin your best completed tasks to your public profile. Up to 10 items.</p>
      </div>
      <button
        onclick="document.getElementById('pin-modal').classList.remove('hidden')"
        class="bg-violet-600 hover:bg-violet-500 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors"
      >
        + Pin a Task
      </button>
    </div>

    <!-- Portfolio grid -->
    {items.length === 0 ? (
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-12 text-center">
        <div class="text-5xl mb-3">📌</div>
        <h3 class="font-semibold text-gray-300 mb-1">Nothing pinned yet</h3>
        <p class="text-sm text-gray-400 mb-4">Pin your best completed tasks to showcase your work to requesters.</p>
        <button
          onclick="document.getElementById('pin-modal').classList.remove('hidden')"
          class="bg-violet-600 text-white px-4 py-2 rounded-lg text-sm"
        >
          Pin First Task
        </button>
      </div>
    ) : (
      <div class="grid sm:grid-cols-2 gap-4" id="portfolio-grid">
        {items.map((item: any) => (
          <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden portfolio-card" data-id={item.id}>
            <!-- Header -->
            <div class="px-5 py-4 border-b border-gray-800 bg-gradient-to-r from-indigo-950/40 to-purple-950/40 flex items-center justify-between">
              <div>
                <span class="text-xs font-medium bg-indigo-900/40 text-indigo-300 px-2 py-0.5 rounded-full uppercase">
                  {item.task_type?.replace('_', ' ')}
                </span>
                {item.avg_rating && (
                  <span class="ml-2 text-xs text-yellow-600 font-medium">
                    {'⭐'.repeat(Math.round(item.avg_rating))} {item.avg_rating.toFixed(1)}
                  </span>
                )}
              </div>
              <span class="text-xs text-gray-400">#{item.display_order + 1}</span>
            </div>
            <!-- Body -->
            <div class="px-5 py-4">
              {item.caption && (
                <p class="text-sm text-gray-300 italic mb-2">"{item.caption}"</p>
              )}
              {item.result_snippet && (
                <p class="text-xs text-gray-500 line-clamp-3">{item.result_snippet}</p>
              )}
              <div class="mt-3 flex items-center justify-between">
                <span class="text-xs text-gray-400">
                  Pinned {new Date(item.pinned_at).toLocaleDateString()}
                </span>
                <div class="flex gap-2">
                  <button
                    class="edit-pin-btn text-xs text-violet-400 hover:underline"
                    data-id={item.id}
                    data-caption={item.caption || ''}
                    data-order={item.display_order}
                  >Edit</button>
                  <button
                    class="delete-pin-btn text-xs text-red-500 hover:underline"
                    data-id={item.id}
                  >Remove</button>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    )}

    <p class="text-xs text-gray-400 mt-4 text-right">{items.length}/10 slots used</p>
  </div>

  <!-- Pin modal -->
  <div id="pin-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
    <div class="bg-gray-900 border border-gray-800 rounded-xl w-full max-w-md p-6">
      <h2 class="font-semibold text-gray-200 mb-4">📌 Pin a Completed Task</h2>
      <form id="pin-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1">Task</label>
          <select id="pin-task-id" class="w-full bg-gray-800 border border-gray-700 text-gray-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-violet-500" required>
            <option value="">Select a completed task…</option>
            {completedTasks.map((t: any) => (
              <option value={t.id}>[{t.task_type}] {t.id.slice(0, 8)}… — {new Date(t.created_at).toLocaleDateString()}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1">Caption <span class="text-gray-400 font-normal">(optional)</span></label>
          <textarea
            id="pin-caption"
            rows="3"
            maxlength="500"
            placeholder="Describe what made this task interesting or showcase-worthy…"
            class="w-full bg-gray-800 border border-gray-700 text-gray-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-violet-500 resize-none placeholder-gray-600"
          ></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1">Display Order</label>
          <input type="number" id="pin-order" value="0" min="0" max="9"
            class="w-24 bg-gray-800 border border-gray-700 text-gray-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-violet-500" />
        </div>
        <div id="pin-error" class="text-sm text-red-400 hidden"></div>
        <div class="flex gap-3 justify-end pt-2">
          <button type="button" onclick="document.getElementById('pin-modal').classList.add('hidden')"
            class="px-4 py-2 text-sm text-gray-300 border border-gray-700 rounded-lg hover:bg-gray-800">Cancel</button>
          <button type="submit"
            class="px-4 py-2 text-sm bg-violet-600 text-white rounded-lg hover:bg-violet-500 font-medium">
            Pin Task
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Edit modal -->
  <div id="edit-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
    <div class="bg-gray-900 border border-gray-800 rounded-xl w-full max-w-md p-6">
      <h2 class="font-semibold text-gray-200 mb-4">✏️ Edit Portfolio Item</h2>
      <form id="edit-form" class="space-y-4">
        <input type="hidden" id="edit-pin-id" />
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1">Caption</label>
          <textarea id="edit-caption" rows="3" maxlength="500"
            class="w-full bg-gray-800 border border-gray-700 text-gray-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-violet-500 resize-none"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1">Display Order</label>
          <input type="number" id="edit-order" value="0" min="0" max="9"
            class="w-24 bg-gray-800 border border-gray-700 text-gray-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-violet-500" />
        </div>
        <div class="flex gap-3 justify-end pt-2">
          <button type="button" onclick="document.getElementById('edit-modal').classList.add('hidden')"
            class="px-4 py-2 text-sm text-gray-300 border border-gray-700 rounded-lg hover:bg-gray-800">Cancel</button>
          <button type="submit"
            class="px-4 py-2 text-sm bg-violet-600 text-white rounded-lg hover:bg-violet-500 font-medium">
            Save Changes
          </button>
        </div>
      </form>
    </div>
  </div>
</Layout>

<script is:inline define:vars={{ clientApiUrl }}>
const token = document.cookie.split('; ').find(r => r.startsWith('token='))?.split('=')[1];

function toast(msg, ok = true) {
  const t = document.createElement('div');
  t.className = `fixed bottom-4 right-4 px-4 py-2 rounded-lg text-white text-sm z-50 ${ok ? 'bg-emerald-600' : 'bg-red-600'}`;
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 3000);
}

// Pin form
document.getElementById('pin-form').addEventListener('submit', async e => {
  e.preventDefault();
  const taskId = document.getElementById('pin-task-id').value;
  const caption = document.getElementById('pin-caption').value.trim();
  const order = parseInt(document.getElementById('pin-order').value) || 0;
  const errEl = document.getElementById('pin-error');

  const res = await fetch(`${clientApiUrl}/v1/worker/portfolio`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
    body: JSON.stringify({ task_id: taskId, caption: caption || null, display_order: order }),
  });
  if (res.ok) {
    toast('Task pinned to portfolio!');
    document.getElementById('pin-modal').classList.add('hidden');
    setTimeout(() => location.reload(), 500);
  } else {
    const err = await res.json().catch(() => ({}));
    errEl.textContent = err.detail || 'Failed to pin task';
    errEl.classList.remove('hidden');
  }
});

// Edit buttons
document.querySelectorAll('.edit-pin-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.getElementById('edit-pin-id').value = btn.dataset.id;
    document.getElementById('edit-caption').value = btn.dataset.caption;
    document.getElementById('edit-order').value = btn.dataset.order;
    document.getElementById('edit-modal').classList.remove('hidden');
  });
});

// Edit form
document.getElementById('edit-form').addEventListener('submit', async e => {
  e.preventDefault();
  const pinId = document.getElementById('edit-pin-id').value;
  const caption = document.getElementById('edit-caption').value.trim();
  const order = parseInt(document.getElementById('edit-order').value) || 0;

  const res = await fetch(`${clientApiUrl}/v1/worker/portfolio/${pinId}`, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
    body: JSON.stringify({ caption: caption || null, display_order: order }),
  });
  if (res.ok) {
    toast('Updated!');
    document.getElementById('edit-modal').classList.add('hidden');
    setTimeout(() => location.reload(), 500);
  } else {
    toast('Update failed', false);
  }
});

// Delete buttons
document.querySelectorAll('.delete-pin-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    if (!confirm('Remove this task from your portfolio?')) return;
    const res = await fetch(`${clientApiUrl}/v1/worker/portfolio/${btn.dataset.id}`, {
      method: 'DELETE',
      headers: { Authorization: `Bearer ${token}` },
    });
    if (res.ok || res.status === 204) {
      toast('Removed from portfolio');
      btn.closest('.portfolio-card').remove();
    } else {
      toast('Failed to remove', false);
    }
  });
});
</script>
