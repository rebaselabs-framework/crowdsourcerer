---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login");

// Handle cert attempt submission
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const taskType = form.get("task_type") as string;
  const answersJson = form.get("answers_json") as string;

  try {
    const answers = JSON.parse(answersJson || "[]");
    // POST → redirect → GET: avoids form resubmission on browser refresh
    const r = await apiFetch<any>(`/v1/certifications/${taskType}/attempt`, {
      method: "POST",
      token,
      body: JSON.stringify({ answers }),
    });
    if (r.details && Astro.session) {
      Astro.session.set("cert_last_attempt", r.details);
    }
    return Astro.redirect(
      `/worker/certifications?result_type=${encodeURIComponent(taskType)}&score=${r.score}&passed=${r.passed}&earned=${r.earned_points}&total=${r.total_points}&correct=${r.correct_count}&count=${r.question_count}`
    );
  } catch (e: any) {
    if (e.message?.includes("401") || e.message?.includes("403")) return Astro.redirect("/login");
    return Astro.redirect(`/worker/certifications?error=attempt_failed&type=${taskType}`);
  }
}

// Get params
const selectedType = Astro.url.searchParams.get("take");
const resultType = Astro.url.searchParams.get("result_type");
const resultScore = Astro.url.searchParams.get("score");
const resultPassed = Astro.url.searchParams.get("passed");
const resultEarned = Astro.url.searchParams.get("earned");
const resultTotal = Astro.url.searchParams.get("total");
const resultCorrect = Astro.url.searchParams.get("correct");
const resultCount = Astro.url.searchParams.get("count");

let certifications: any[] = [];
let myCerts: any[] = [];
let certDetail: any = null;
let error: string | null = Astro.url.searchParams.get("error");
// Read per-question attempt details from session (stored by POST handler before redirect)
const lastAttemptDetails: unknown[] | null = resultType
  ? ((await Astro.session?.get("cert_last_attempt")) as unknown[] | null) ?? null
  : null;

try {
  certifications = await apiFetch<any[]>("/v1/certifications", { token });
} catch (e: any) {
  if (e.message?.includes("401") || e.message?.includes("403")) return Astro.redirect("/login");
  error = "Failed to load certifications";
}

try {
  myCerts = await apiFetch<any[]>("/v1/certifications/me/earned", { token });
} catch (_) {}

if (selectedType) {
  try {
    certDetail = await apiFetch<any>(`/v1/certifications/${selectedType}`, { token });
  } catch (_) {}
}

// Build my cert lookup
const myMap: Record<string, any> = {};
for (const c of myCerts) {
  myMap[c.task_type] = c;
}
---

<Layout title="Worker Certifications — CrowdSorcerer">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-white">🎓 Worker Certifications</h1>
      <p class="text-gray-500 mt-1">Earn certifications to unlock higher-value tasks and boost your credibility</p>
    </div>

    {error && (
      <div class="bg-red-950/30 border border-red-800 text-red-400 px-4 py-3 rounded-lg mb-6">
        {error === "attempt_failed" ? "Failed to submit your answers. Please try again." : error}
      </div>
    )}

    <!-- Attempt Result -->
    {resultType && (
      <div class={`rounded-2xl p-6 mb-8 border-2 ${resultPassed === "true" ? "bg-emerald-950/30 border-emerald-700" : "bg-red-950/30 border-red-800"}`}>
        <div class="flex items-center gap-4">
          <div class="text-5xl">{resultPassed === "true" ? "🎉" : "😞"}</div>
          <div>
            <h2 class="text-2xl font-bold text-white">{resultPassed === "true" ? "Certification Passed!" : "Not Passed This Time"}</h2>
            <p class="text-gray-400 mt-1">
              Score: <strong class="text-gray-200">{resultScore}%</strong> — Got {resultCorrect} of {resultCount} questions right
              ({resultEarned} / {resultTotal} points)
            </p>
            {resultPassed === "true" ? (
              <p class="text-emerald-400 mt-2">✅ You are now certified for <strong>{resultType}</strong> tasks!</p>
            ) : (
              <p class="text-red-400 mt-2">You can retake this certification after 60 minutes.</p>
            )}
          </div>
        </div>
      </div>
    )}

    <!-- Answer Review (shown after attempt, powered by session details) -->
    {resultType && lastAttemptDetails && lastAttemptDetails.length > 0 && (
      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 mb-8">
        <h3 class="text-lg font-bold text-white mb-4">📋 Answer Review</h3>
        <div class="space-y-3">
          {lastAttemptDetails.map((d: any, i: number) => (
            <div class={`p-4 rounded-xl border ${d.is_correct ? "border-emerald-800/60 bg-emerald-950/20" : "border-red-800/60 bg-red-950/20"}`}>
              <div class="flex items-start gap-3">
                <span class="text-base mt-0.5 flex-shrink-0">{d.is_correct ? "✅" : "❌"}</span>
                <div class="flex-1 min-w-0">
                  <p class="font-medium text-gray-200 text-sm leading-snug">
                    <span class="text-gray-500 text-xs mr-1">Q{i + 1}.</span>{d.question}
                  </p>
                  <p class="text-xs mt-1.5">
                    {d.is_correct ? (
                      <span class="text-emerald-400">Correct — {d.points_earned}/{d.points_possible} point{d.points_possible !== 1 ? "s" : ""}</span>
                    ) : (
                      <span class="text-red-400">Incorrect — 0/{d.points_possible} point{d.points_possible !== 1 ? "s" : ""}</span>
                    )}
                  </p>
                  {!d.is_correct && d.explanation && (
                    <p class="text-xs text-gray-400 mt-2 leading-relaxed">
                      <span class="text-violet-400 font-medium">💡 Tip: </span>{d.explanation}
                    </p>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Take Certification Test -->
    {certDetail && (
      <div class="bg-gray-900 border border-gray-800 rounded-2xl mb-8">
        <div class="p-6 border-b border-gray-800 flex items-center justify-between">
          <div>
            <h2 class="text-xl font-bold">{certDetail.badge_icon} {certDetail.name}</h2>
            <p class="text-gray-500 text-sm mt-1">{certDetail.question_count} questions • Pass with {certDetail.passing_score}%+</p>
          </div>
          <a href="/worker/certifications" class="text-gray-400 hover:text-gray-500 text-2xl">×</a>
        </div>
        <form method="POST" id="cert-form" class="p-6">
          <input type="hidden" name="task_type" value={certDetail.task_type} />
          <input type="hidden" name="answers_json" id="answers-json" value="[]" />

          <!-- Progress indicator -->
          <div class="flex items-center gap-3 mb-6 p-3 bg-gray-800/50 rounded-xl">
            <div class="flex-1 bg-gray-700 rounded-full h-2 overflow-hidden">
              <div id="quiz-progress-bar" class="bg-violet-500 h-2 rounded-full transition-all duration-200" style="width:0%"></div>
            </div>
            <span id="quiz-progress-text" class="text-xs text-gray-400 whitespace-nowrap tabular-nums">
              0 of {certDetail.question_count} answered
            </span>
          </div>

          <div class="space-y-8">
            {certDetail.questions?.map((q: any, i: number) => (
              <div class="space-y-3" data-question-id={q.id}>
                <div class="flex gap-3">
                  <span class="w-7 h-7 rounded-full bg-violet-100 text-violet-700 text-sm font-bold flex-shrink-0 flex items-center justify-center mt-0.5">
                    {i + 1}
                  </span>
                  <p class="font-medium text-gray-200">{q.question}</p>
                </div>
                <div class="ml-10 space-y-2">
                  {q.question_type === "single_choice" && q.options?.map((opt: any) => (
                    <label class="flex items-center gap-3 p-3 rounded-xl border border-gray-700 hover:border-violet-500 hover:bg-violet-900/20 cursor-pointer transition">
                      <input
                        type="radio"
                        name={`q_${q.id}`}
                        value={opt.id}
                        data-qid={q.id}
                        data-qtype="single"
                        onchange="updateAnswers()"
                        class="text-violet-600"
                      />
                      <span class="text-sm text-gray-200">{opt.text}</span>
                    </label>
                  ))}
                  {q.question_type === "multi_choice" && q.options?.map((opt: any) => (
                    <label class="flex items-center gap-3 p-3 rounded-xl border border-gray-700 hover:border-violet-500 hover:bg-violet-900/20 cursor-pointer transition">
                      <input
                        type="checkbox"
                        name={`q_${q.id}`}
                        value={opt.id}
                        data-qid={q.id}
                        data-qtype="multi"
                        onchange="updateAnswers()"
                        class="text-violet-600 rounded"
                      />
                      <span class="text-sm text-gray-200">{opt.text}</span>
                    </label>
                  ))}
                </div>
              </div>
            ))}
          </div>

          <div id="quiz-submit-error" class="hidden text-sm text-red-400 bg-red-950/20 border border-red-800 rounded-lg px-3 py-2 mt-2"></div>
          <div class="mt-4 flex gap-4">
            <a href="/worker/certifications"
              class="flex-1 text-center border border-gray-700 text-gray-300 px-4 py-3 rounded-xl text-sm font-medium hover:bg-gray-800">
              Cancel
            </a>
            <button
              type="submit"
              onclick="return submitCert()"
              class="flex-1 bg-violet-600 hover:bg-violet-700 text-white px-4 py-3 rounded-xl text-sm font-bold"
            >
              Submit Answers
            </button>
          </div>
        </form>
      </div>
    )}

    <!-- First-timer prompt: no earned certs yet -->
    {myCerts.length === 0 && !certDetail && !resultType && (
      <div class="mb-8 bg-violet-950/20 border border-violet-800 rounded-2xl p-6">
        <div class="flex items-start gap-4">
          <div class="text-4xl flex-shrink-0">🎓</div>
          <div>
            <h2 class="font-bold text-white text-lg">Earn your first certification</h2>
            <p class="text-sm text-gray-400 mt-1">
              Certifications unlock higher-paying tasks and show requesters you're qualified.
              Pick a category below — the quiz takes just a few minutes!
            </p>
          </div>
        </div>
      </div>
    )}

    <!-- My Certifications -->
    {myCerts.length > 0 && !certDetail && (
      <div class="mb-8">
        <h2 class="text-xl font-bold text-white mb-4">My Certifications ({myCerts.length})</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {myCerts.map((c: any) => (
            <div class={`p-5 rounded-2xl border-2 ${c.passed ? "border-emerald-700 bg-emerald-900/20" : "border-gray-700 bg-gray-800"}`}>
              <div class="flex items-center justify-between mb-3">
                <div class="text-3xl">{c.passed ? "✅" : "❌"}</div>
                <span class={`text-sm font-bold px-2 py-0.5 rounded-full ${c.passed ? "bg-emerald-900/40 text-emerald-300" : "bg-red-900/40 text-red-400"}`}>
                  {c.score}%
                </span>
              </div>
              <h3 class="font-bold text-white">{c.cert_name}</h3>
              <p class="text-xs text-gray-400 mt-1">{c.task_type}</p>
              {c.passed && c.certified_at && (
                <p class="text-xs text-green-600 mt-2">Certified {new Date(c.certified_at).toLocaleDateString()}</p>
              )}
              {!c.passed && (
                <a
                  href={`/worker/certifications?take=${c.task_type}`}
                  class="mt-3 block text-center text-sm text-violet-600 hover:underline font-medium"
                >
                  Retake →
                </a>
              )}
              <p class="text-xs text-gray-400 mt-1">{c.attempt_count} attempt{c.attempt_count !== 1 ? "s" : ""} • Best: {c.best_score}%</p>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Available Certifications -->
    {!certDetail && (
      <div>
        <h2 class="text-xl font-bold text-white mb-4">Available Certifications</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {certifications.map((cert: any) => {
            const my = myMap[cert.task_type];
            return (
              <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 hover:border-gray-700 transition-colors">
                <div class="flex items-start justify-between mb-4">
                  <div class="text-4xl">{cert.badge_icon || "🏅"}</div>
                  {my?.passed && (
                    <span class="bg-emerald-900/40 text-emerald-300 text-xs font-bold px-2 py-1 rounded-full">✓ Certified</span>
                  )}
                  {my && !my.passed && (
                    <span class="bg-orange-900/40 text-orange-300 text-xs font-bold px-2 py-1 rounded-full">Best: {my.best_score}%</span>
                  )}
                </div>
                <h3 class="font-bold text-white mb-1">{cert.name}</h3>
                <p class="text-sm text-gray-400 mb-3">{cert.description}</p>
                <div class="flex items-center justify-between text-xs text-gray-400 mb-4">
                  <span>📋 {cert.question_count} questions</span>
                  <span>🎯 Pass at {cert.passing_score}%</span>
                </div>
                <a
                  href={`/worker/certifications?take=${cert.task_type}`}
                  class={`block text-center py-2 rounded-xl text-sm font-medium transition ${
                    my?.passed
                      ? "bg-emerald-900/30 text-emerald-300 border border-emerald-800 hover:bg-emerald-900/50"
                      : "bg-violet-600 hover:bg-violet-700 text-white"
                  }`}
                >
                  {my?.passed ? "✓ View Details" : my ? "Retake Test" : "Take Test"}
                </a>
              </div>
            );
          })}
        </div>

        {certifications.length === 0 && (
          <div class="bg-gray-900 border border-gray-800 rounded-2xl p-12 text-center text-gray-400">
            <div class="text-5xl mb-4">🎓</div>
            <p class="text-lg font-medium">No certifications available yet</p>
          </div>
        )}
      </div>
    )}
  </div>

  <script>
    function updateAnswers() {
      const answers: Array<{question_id: string|null, answer: string|string[]}> = [];
      const questions = document.querySelectorAll("[data-question-id]");
      for (const qEl of questions) {
        const qId = qEl.getAttribute("data-question-id");
        const singles = qEl.querySelectorAll("input[type=radio]:checked");
        const multis = qEl.querySelectorAll("input[type=checkbox]:checked");
        if (singles.length > 0) {
          // @ts-ignore — querySelectorAll returns Element but these are HTMLInputElements
          answers.push({ question_id: qId, answer: singles[0].value });
        } else if (multis.length > 0) {
          // @ts-ignore — same as above
          answers.push({ question_id: qId, answer: Array.from(multis).map((m) => m.value) });
        }
      }
      const hiddenEl = document.getElementById("answers-json");
      // @ts-ignore — hiddenEl is an <input type="hidden"> so .value exists
      if (hiddenEl) hiddenEl.value = JSON.stringify(answers);

      // Update progress bar
      const total = questions.length;
      const answered = answers.length;
      const pct = total > 0 ? Math.round((answered / total) * 100) : 0;
      const bar = document.getElementById("quiz-progress-bar");
      const txt = document.getElementById("quiz-progress-text");
      if (bar) (bar as HTMLElement).style.width = pct + "%";
      if (txt) txt.textContent = answered + " of " + total + " answered";
    }

    function submitCert() {
      updateAnswers();
      const hiddenEl = document.getElementById("answers-json");
      // @ts-ignore — hiddenEl is an <input type="hidden"> so .value exists
      const answers = JSON.parse(hiddenEl ? hiddenEl.value : "[]");
      const questions = document.querySelectorAll("[data-question-id]");

      // Validate all questions answered
      const missing = [];
      for (const qEl of questions) {
        const qId = qEl.getAttribute("data-question-id");
        // @ts-ignore — answers is any[]
        const answered = answers.some((a) => a.question_id === qId);
        if (!answered) missing.push(qId);
      }

      if (missing.length > 0) {
        const errEl = document.getElementById("quiz-submit-error");
        if (errEl) {
          errEl.textContent = `Please answer all ${questions.length} questions before submitting.`;
          errEl.classList.remove("hidden");
          errEl.scrollIntoView({ behavior: "smooth", block: "nearest" });
        }
        return false;
      }
      // Clear error on valid submission
      document.getElementById("quiz-submit-error")?.classList.add("hidden");

      return true;
    }
    window.submitCert = submitCert;
  </script>
</Layout>
