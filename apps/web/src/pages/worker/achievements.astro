---
/**
 * Worker Achievements / Badges page.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);

if (!token) {
  return Astro.redirect("/login?next=/worker/achievements");
}

let badges: any = null;
let error: string | null = null;

try {
  badges = await apiFetch("/v1/worker/badges", { token });
} catch (e: any) {
  error = e.message ?? "Failed to load badges";
}

const totalBadges = badges ? badges.earned.length + badges.locked.length : 0;
const progress = badges ? Math.round((badges.earned.length / totalBadges) * 100) : 0;
---

<Layout title="Achievements — CrowdSorcerer">
  <div class="max-w-4xl mx-auto px-6 py-10">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold">🏅 Achievements</h1>
        <p class="text-gray-400 text-sm mt-0.5">Badges earned by completing milestones</p>
      </div>
      <a href="/worker" class="text-sm text-gray-400 hover:text-white transition-colors">
        ← Back to Earn
      </a>
    </div>

    {error ? (
      <div class="text-red-400 bg-red-900/20 border border-red-800/40 rounded-xl p-6 text-center">
        {error === "Not enrolled as a worker." ? (
          <div>
            <p class="mb-4">You need to enroll as a worker to earn badges.</p>
            <a href="/worker" class="text-emerald-400 hover:text-emerald-300">Enroll now →</a>
          </div>
        ) : error}
      </div>
    ) : badges && (
      <div>
        <!-- Progress overview -->
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 mb-8">
          <div class="flex items-center justify-between mb-3">
            <div>
              <div class="text-sm text-gray-400">Badges earned</div>
              <div class="text-3xl font-bold mt-0.5">
                {badges.total_earned}
                <span class="text-base text-gray-500 font-normal">/ {totalBadges}</span>
              </div>
            </div>
            <div class="text-right">
              <div class="text-4xl font-bold text-amber-400">{progress}%</div>
              <div class="text-xs text-gray-500">complete</div>
            </div>
          </div>
          <div class="h-2.5 bg-gray-800 rounded-full overflow-hidden">
            <div
              class="h-full bg-gradient-to-r from-amber-600 to-amber-400 rounded-full transition-all"
              style={`width: ${progress}%`}
            ></div>
          </div>
        </div>

        <!-- Earned badges -->
        {badges.earned.length > 0 && (
          <div class="mb-10">
            <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
              <span class="text-amber-400">✦</span>
              Earned ({badges.earned.length})
            </h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
              {badges.earned.map((badge: any) => (
                <div class="bg-gradient-to-b from-amber-900/20 to-gray-900 border border-amber-700/40 rounded-2xl p-5 text-center hover:border-amber-600/60 transition-colors">
                  <div class="text-4xl mb-3">{badge.icon}</div>
                  <div class="font-semibold text-amber-200 text-sm mb-1">{badge.name}</div>
                  <div class="text-xs text-gray-400 leading-relaxed">{badge.description}</div>
                  {badge.rarity != null && (
                    <div class="mt-2 text-xs text-amber-500/70">
                      {badge.rarity <= 5 ? "💎 " : badge.rarity <= 20 ? "✦ " : ""}{badge.rarity}% of workers
                    </div>
                  )}
                  {badge.earned_at && (
                    <div class="mt-1 text-xs text-gray-500">
                      {new Date(badge.earned_at).toLocaleDateString()}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Locked badges -->
        {badges.locked.length > 0 && (
          <div>
            <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
              <span class="text-gray-500">🔒</span>
              Locked ({badges.locked.length})
            </h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
              {badges.locked.map((badge: any) => (
                <div class="bg-gray-900/60 border border-gray-800 rounded-2xl p-5 text-center opacity-60 hover:opacity-80 transition-opacity">
                  <div class="text-4xl mb-3 grayscale">{badge.icon}</div>
                  <div class="font-semibold text-gray-400 text-sm mb-1">{badge.name}</div>
                  <div class="text-xs text-gray-500 leading-relaxed">{badge.description}</div>
                  {badge.rarity != null && badge.rarity > 0 && (
                    <div class="mt-2 text-xs text-gray-500">
                      {badge.rarity <= 5 ? "💎 " : badge.rarity <= 20 ? "✦ " : ""}{badge.rarity}% of workers
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    )}
  </div>
</Layout>
