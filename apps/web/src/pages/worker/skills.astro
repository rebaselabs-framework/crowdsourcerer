---
/**
 * Worker Skill Profile — per-task-type proficiency breakdown + recommended tasks.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";
import { TASK_METADATA } from "@crowdsourcerer/types";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login?next=/worker/skills");

let skillsData: any = null;
let recommended: any = null;
let interestsData: any = null;
let error: string | null = null;

try {
  [skillsData, recommended, interestsData] = await Promise.all([
    apiFetch<any>("/v1/workers/me/skills", { token }),
    apiFetch<any>("/v1/workers/me/recommended?limit=6", { token }),
    apiFetch<any>("/v1/worker/interests", { token }).catch(() => null),
  ]);
} catch (e: any) {
  error = e.message ?? "Failed to load skill data.";
}

const skills: any[] = skillsData?.skills ?? [];
const recTasks: any[] = recommended?.items ?? [];
const topSkill: string | null = skillsData?.top_skill ?? null;
const verifiedCount: number = skillsData?.verified_count ?? 0;
const verifiedSkills = skills.filter((s: any) => s.verified);
const currentInterests: string[] = interestsData?.interests ?? [];

const HUMAN_TYPES = [
  "label_image", "label_text", "rate_quality", "verify_fact",
  "moderate_content", "compare_rank", "answer_question", "transcription_review",
];

const HUMAN_TYPE_META: Record<string, { label: string; icon: string; desc: string }> = {
  label_image:          { label: "Label Image",         icon: "🖼️", desc: "Tag objects and scenes in photos" },
  label_text:           { label: "Classify Text",       icon: "📝", desc: "Categorise text snippets" },
  rate_quality:         { label: "Rate Quality",        icon: "⭐", desc: "Score AI or human outputs" },
  verify_fact:          { label: "Verify Fact",         icon: "✅", desc: "Check factual claims" },
  moderate_content:     { label: "Moderate Content",    icon: "🛡️", desc: "Review for policy violations" },
  compare_rank:         { label: "A/B Compare",         icon: "⚖️", desc: "Pick the better option" },
  answer_question:      { label: "Answer Question",     icon: "💬", desc: "Short-form factual answers" },
  transcription_review: { label: "Review Transcript",  icon: "🎙️", desc: "Fix audio transcription errors" },
};

const radarData = HUMAN_TYPES.map((t) => {
  const s = skills.find((sk: any) => sk.task_type === t);
  return s ? s.proficiency_level * 20 : 0;
});
const radarLabels = HUMAN_TYPES.map((t) =>
  t.replace(/_/g, " ").replace(/\b\w/g, (c) => c.toUpperCase())
);

const BADGE_STYLE: Record<number, string> = {
  1: "bg-gray-800 text-gray-400 border-gray-700",
  2: "bg-blue-900/40 text-blue-300 border-blue-700",
  3: "bg-green-900/40 text-green-300 border-green-700",
  4: "bg-purple-900/40 text-purple-300 border-purple-700",
  5: "bg-amber-900/40 text-amber-300 border-amber-700",
};

const taskIcon = (type: string): string =>
  TASK_METADATA[type as keyof typeof TASK_METADATA]?.icon ?? "🔧";
---

<Layout title="My Skills — CrowdSorcerer">
  <div class="max-w-5xl mx-auto px-6 py-10">

    <!-- Header -->
    <div class="flex items-start justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold">🎯 My Skills</h1>
        <p class="text-gray-400 text-sm mt-0.5">
          Your task proficiency profile
          {topSkill && (
            <> — top skill: <span class="text-violet-400">{topSkill.replace(/_/g, " ")}</span></>
          )}
        </p>
      </div>
      <div class="flex items-center gap-4">
        <a href="/worker/recommendations" class="text-sm text-violet-400 hover:text-violet-300 transition-colors">
          💡 Recommendations →
        </a>
        <a href="/worker" class="text-sm text-gray-400 hover:text-white transition-colors">
          ← Worker hub
        </a>
      </div>
    </div>

    {/* Verified skills banner */}
    {verifiedCount > 0 && (
      <div class="bg-amber-900/20 border border-amber-700/50 rounded-xl p-4 mb-6 flex items-center gap-3">
        <span class="text-2xl">🏅</span>
        <div>
          <p class="text-sm font-semibold text-amber-300">
            {verifiedCount} Verified {verifiedCount === 1 ? "Skill" : "Skills"}
          </p>
          <p class="text-xs text-amber-500 mt-0.5">
            You've achieved Proficient+ status with 90%+ accuracy on:
            {verifiedSkills.map((s: any, i: number) => (
              <span>
                {i > 0 && ", "}
                <span class="font-medium text-amber-300">{s.task_type.replace(/_/g, " ")}</span>
              </span>
            ))}
          </p>
        </div>
      </div>
    )}

    {/* Verification progress hint for near-threshold skills */}
    {skills.some((s: any) => !s.verified && s.proficiency_level >= 3 && s.tasks_completed >= 8) && (
      <div class="bg-blue-900/20 border border-blue-700/50 rounded-xl p-4 mb-6">
        <p class="text-xs text-blue-300">
          💡 <strong>Earn a Verified badge</strong> — reach Proficient (level 4) with ≥90% accuracy
          and ≥15 completions on any skill. Verified skills appear on your public profile.
        </p>
      </div>
    )}

    {error && (
      <div class="text-red-400 bg-red-900/20 border border-red-800/40 rounded-xl p-6 mb-6 text-center">
        {error}
      </div>
    )}

    {skills.length === 0 && !error ? (
      <!-- Empty state with interest picker -->
      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8">
        <div class="text-center mb-8">
          <div class="text-5xl mb-3">🎯</div>
          <h2 class="text-xl font-bold mb-2">Tell us what you're good at</h2>
          <p class="text-gray-400 text-sm max-w-md mx-auto">
            Select the task types you're interested in. We'll prioritise matching tasks to your preferences while you build your skill history.
          </p>
        </div>

        <!-- Interest picker grid -->
        <div id="interest-grid" class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
          {HUMAN_TYPES.map((type) => {
            const meta = HUMAN_TYPE_META[type];
            const selected = currentInterests.includes(type);
            return (
              <button
                type="button"
                data-type={type}
                class:list={[
                  "interest-btn flex flex-col items-center gap-1.5 p-4 rounded-xl border-2 transition-all text-center",
                  selected
                    ? "border-violet-500 bg-violet-900/30 text-violet-300"
                    : "border-gray-700 bg-gray-800/50 text-gray-400 hover:border-gray-600 hover:text-gray-300"
                ]}
              >
                <span class="text-2xl">{meta.icon}</span>
                <span class="text-xs font-semibold leading-tight">{meta.label}</span>
                <span class="text-[11px] text-gray-500 leading-tight hidden sm:block">{meta.desc}</span>
              </button>
            );
          })}
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div id="interest-status" class="text-sm text-gray-500">
            {currentInterests.length > 0
              ? `${currentInterests.length} interest${currentInterests.length !== 1 ? "s" : ""} selected`
              : "Select at least one interest"}
          </div>
          <div class="flex gap-3">
            <button
              id="save-interests-btn"
              class="px-5 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-semibold rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Save interests
            </button>
            <a href="/worker/marketplace"
               class="px-5 py-2 bg-gray-800 hover:bg-gray-700 border border-gray-700 text-gray-300 text-sm font-medium rounded-lg transition-colors">
              Browse tasks
            </a>
          </div>
        </div>
        <div id="interest-msg" class="mt-3 text-sm hidden"></div>
      </div>
    ) : (
      <>
        <!-- Skills grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
          {skills.map((skill: any) => (
            <div class="bg-gray-900 border border-gray-800 hover:border-violet-700 rounded-xl p-5 transition-colors">
              <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-2">
                  <span class="text-2xl">{taskIcon(skill.task_type)}</span>
                  <div class="text-sm font-semibold capitalize">
                    {skill.task_type.replace(/_/g, " ")}
                    {skill.verified && (
                      <span class="ml-1 text-amber-400" title={`Verified ${skill.verified_at ? new Date(skill.verified_at).toLocaleDateString() : ''}`}>🏅</span>
                    )}
                  </div>
                </div>
                <span class={`text-xs px-2 py-0.5 rounded-full border font-medium ${BADGE_STYLE[skill.proficiency_level] ?? BADGE_STYLE[1]}`}>
                  {skill.proficiency_label}
                </span>
              </div>

              <!-- Progress bar -->
              <div class="w-full bg-gray-800 rounded-full h-1.5 mb-3">
                <div
                  class="bg-violet-500 h-1.5 rounded-full transition-all"
                  style={`width: ${skill.proficiency_level * 20}%`}
                />
              </div>

              <div class="grid grid-cols-3 gap-2 text-xs">
                <div class="text-center">
                  <div class="font-bold text-white">{skill.tasks_completed}</div>
                  <div class="text-gray-500">Done</div>
                </div>
                <div class="text-center">
                  <div class={`font-bold ${skill.accuracy != null && skill.accuracy >= 0.8 ? "text-green-400" : "text-gray-300"}`}>
                    {skill.accuracy != null ? `${(skill.accuracy * 100).toFixed(0)}%` : "—"}
                  </div>
                  <div class="text-gray-500">Accuracy</div>
                </div>
                <div class="text-center">
                  <div class="font-bold text-amber-400">{skill.credits_earned}</div>
                  <div class="text-gray-500">Credits</div>
                </div>
              </div>

              {skill.avg_response_minutes != null && (
                <div class="mt-2 text-xs text-gray-500 text-center">
                  Avg {skill.avg_response_minutes.toFixed(1)} min/task
                </div>
              )}
            </div>
          ))}
        </div>

        <!-- Radar chart -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 mb-10">
          <h2 class="font-semibold text-gray-300 mb-4">Skill Radar (Human Tasks)</h2>
          <div class="max-w-sm mx-auto">
            <canvas id="radarChart"></canvas>
          </div>
        </div>

        <!-- Recommended Tasks -->
        {recTasks.length > 0 && (
          <section>
            <div class="flex items-center justify-between mb-4">
              <div>
                <h2 class="text-lg font-bold">✨ Recommended For You</h2>
                <p class="text-gray-400 text-sm">Tasks matched to your strengths</p>
              </div>
              <a href="/worker/marketplace" class="text-sm text-violet-400 hover:text-violet-300">
                All tasks →
              </a>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {recTasks.map((task: any) => (
                <div class="bg-gray-900 border border-violet-800/40 hover:border-violet-600 rounded-xl p-4 transition-colors">
                  <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center gap-1.5">
                      <span class="text-lg">{taskIcon(task.type)}</span>
                      <span class="text-xs font-medium text-violet-400 uppercase tracking-wide">
                        {task.type.replace(/_/g, " ")}
                      </span>
                    </div>
                    <span class="text-sm font-bold text-emerald-400">+{task.reward_credits} cr</span>
                  </div>
                  <div class="font-medium text-sm mb-1 line-clamp-2">{task.title}</div>
                  {task.description && (
                    <div class="text-xs text-gray-500 mb-3 line-clamp-2">{task.description}</div>
                  )}
                  <div class="flex items-center justify-between">
                    <span class="text-xs text-gray-500">{task.slots_remaining} slot{task.slots_remaining !== 1 ? "s" : ""}</span>
                    <a
                      href={`/worker/tasks/${task.id}`}
                      class="text-xs px-3 py-1 bg-violet-600 hover:bg-violet-500 text-white rounded-full transition-colors"
                    >
                      Claim
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Interest manager for workers who already have skills -->
        <div class="mt-10 bg-gray-900 border border-gray-800 rounded-xl p-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="text-base font-semibold text-gray-200">🎯 Task Interests</h2>
              <p class="text-xs text-gray-500 mt-0.5">
                Declare what you want to work on. Affects your personalised feed before you've built proficiency.
              </p>
            </div>
            <div id="interests-saved-badge" class="text-xs text-emerald-400 hidden">✓ Saved</div>
          </div>
          <div id="interest-grid" class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-4">
            {HUMAN_TYPES.map((type) => {
              const meta = HUMAN_TYPE_META[type];
              const selected = currentInterests.includes(type);
              return (
                <button
                  type="button"
                  data-type={type}
                  class:list={[
                    "interest-btn flex items-center gap-2 p-2.5 rounded-lg border text-left transition-all",
                    selected
                      ? "border-violet-500 bg-violet-900/30 text-violet-300"
                      : "border-gray-700 bg-gray-800/40 text-gray-400 hover:border-gray-600 hover:text-gray-300"
                  ]}
                >
                  <span class="text-lg shrink-0">{meta.icon}</span>
                  <span class="text-xs font-medium leading-tight">{meta.label}</span>
                </button>
              );
            })}
          </div>
          <div class="flex items-center justify-between gap-4">
            <div id="interest-status" class="text-xs text-gray-500">
              {currentInterests.length > 0
                ? `${currentInterests.length} selected`
                : "None selected"}
            </div>
            <button
              id="save-interests-btn"
              class="px-4 py-1.5 bg-violet-600 hover:bg-violet-500 text-white text-xs font-semibold rounded-lg transition-colors"
            >
              Save
            </button>
          </div>
          <div id="interest-msg" class="mt-2 text-xs hidden"></div>
        </div>
      </>
    )}
  </div>
</Layout>

<script is:inline define:vars={{ radarData, radarLabels, currentInterests }}>
// ── Radar chart ──────────────────────────────────────────────────────────────
  const s = document.createElement("script");
  s.src = "https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js";
  s.onload = function() {
    var ctx = document.getElementById("radarChart");
    if (!ctx) return;
    new Chart(ctx, {
      type: "radar",
      data: {
        labels: radarLabels,
        datasets: [{
          label: "Skill Level",
          data: radarData,
          backgroundColor: "rgba(139, 92, 246, 0.15)",
          borderColor: "rgba(139, 92, 246, 0.8)",
          pointBackgroundColor: "rgba(139, 92, 246, 1)",
          pointBorderColor: "#fff",
          borderWidth: 2,
        }],
      },
      options: {
        responsive: true,
        scales: {
          r: {
            min: 0, max: 100,
            ticks: { stepSize: 20, display: false },
            grid: { color: "rgba(255,255,255,0.06)" },
            angleLines: { color: "rgba(255,255,255,0.06)" },
            pointLabels: { color: "#9ca3af", font: { size: 11 } },
          },
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(ctx) {
                var level = Math.round(ctx.raw / 20);
                var names = ["", "Novice", "Learner", "Competent", "Proficient", "Expert"];
                return "Level " + level + " — " + (names[level] || "");
              },
            },
          },
        },
      },
    });
  };
  document.head.appendChild(s);

// ── Interest picker ──────────────────────────────────────────────────────────
  (function() {
    // /api/worker/interests proxy handles auth via httpOnly cookie — no token needed client-side

    // selected starts from SSR-rendered state
    var selected = new Set(currentInterests || []);

    // Wire up toggle buttons
    document.addEventListener("click", function(e) {
      var btn = e.target.closest(".interest-btn");
      if (!btn) return;
      var type = btn.dataset.type;
      if (!type) return;

      if (selected.has(type)) {
        selected.delete(type);
        btn.className = btn.className
          .replace("border-violet-500 bg-violet-900/30 text-violet-300", "border-gray-700 bg-gray-800/50 text-gray-400 hover:border-gray-600 hover:text-gray-300")
          // compact variant
          .replace("border-violet-500 bg-violet-900/30 text-violet-300", "border-gray-700 bg-gray-800/40 text-gray-400 hover:border-gray-600 hover:text-gray-300");
      } else {
        selected.add(type);
        btn.className = btn.className
          .replace("border-gray-700 bg-gray-800/50 text-gray-400 hover:border-gray-600 hover:text-gray-300", "border-violet-500 bg-violet-900/30 text-violet-300")
          .replace("border-gray-700 bg-gray-800/40 text-gray-400 hover:border-gray-600 hover:text-gray-300", "border-violet-500 bg-violet-900/30 text-violet-300");
      }

      // Update status counter
      var statusEls = document.querySelectorAll("#interest-status");
      var count = selected.size;
      var label = count > 0 ? count + " interest" + (count !== 1 ? "s" : "") + " selected" : "Select at least one interest";
      statusEls.forEach(function(el) { el.textContent = label; });
    });

    // Save button handler (works for both empty-state picker and skills-page manager)
    document.addEventListener("click", async function(e) {
      var btn = e.target.closest("#save-interests-btn");
      if (!btn) return;  // TOKEN check removed — /api/worker/interests proxy handles auth

      btn.disabled = true;
      btn.textContent = "Saving…";

      try {
        var r = await fetch("/api/worker/interests", {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ interests: Array.from(selected) }),
        });
        // Check res.ok before parsing JSON — error responses may not be JSON
        var d = r.ok ? await r.json() : await r.json().catch(function() { return {}; });
        var result = { ok: r.ok, data: d };
        if (result.ok) {
          btn.textContent = "Saved!";
          setTimeout(function() { btn.textContent = btn.closest("#interest-grid") ? "Save interests" : "Save"; btn.disabled = false; }, 1500);

          // Show saved badge if it exists (skills page variant)
          var badge = document.getElementById("interests-saved-badge");
          if (badge) {
            badge.classList.remove("hidden");
            setTimeout(function() { badge.classList.add("hidden"); }, 3000);
          }

          // If empty-state → redirect to marketplace after save
          var msgEl = document.getElementById("interest-msg");
          if (msgEl && btn.textContent === "Saved!") {
            var isEmpty = !document.getElementById("radarChart");
            if (isEmpty) {
              setTimeout(function() { window.location.href = "/worker/marketplace"; }, 800);
            }
          }
        } else {
          btn.textContent = "Error — retry";
          btn.disabled = false;
          var msgEl = document.getElementById("interest-msg");
          if (msgEl) { msgEl.textContent = result.data.detail || "Failed to save."; msgEl.className = "mt-2 text-xs text-red-400"; msgEl.classList.remove("hidden"); }
        }
      } catch(err) {
        btn.textContent = "Error — retry";
        btn.disabled = false;
      }
    });
  })();
</script>
