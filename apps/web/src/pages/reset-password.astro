---
import Layout from "@/layouts/Layout.astro";

const token = Astro.url.searchParams.get("token") ?? "";

let success = false;
let error = "";

// If no token in URL, redirect to forgot-password
if (!token) {
  return Astro.redirect("/forgot-password");
}

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const newPassword = form.get("new_password") as string;
  const confirmPassword = form.get("confirm_password") as string;

  if (newPassword !== confirmPassword) {
    error = "Passwords do not match.";
  } else if (newPassword.length < 8) {
    error = "Password must be at least 8 characters.";
  } else {
    try {
      const res = await fetch(
        `${import.meta.env.PUBLIC_API_URL ?? "http://api:8100"}/v1/auth/reset-password`,
        {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ token, new_password: newPassword }),
        }
      );

      if (res.ok) {
        success = true;
      } else {
        const data = await res.json();
        error = data.detail ?? "Failed to reset password. The link may have expired.";
      }
    } catch (e) {
      error = "Network error — please try again";
    }
  }
}
---

<Layout title="Reset password — CrowdSorcerer">
  <div class="min-h-screen flex items-center justify-center px-6">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <div class="text-4xl mb-3">🔑</div>
        <h1 class="text-2xl font-bold">
          {success ? "Password updated!" : "Set a new password"}
        </h1>
        {!success && (
          <p class="text-gray-400 mt-1 text-sm">Choose a strong password — at least 8 characters.</p>
        )}
      </div>

      {success ? (
        <div class="bg-green-950/40 border border-green-700/50 rounded-xl px-5 py-6 text-center">
          <div class="text-3xl mb-3">✅</div>
          <p class="text-green-300 font-semibold mb-2">Password updated successfully</p>
          <p class="text-sm text-gray-400 mb-5">
            Your password has been changed. You can now sign in with your new credentials.
          </p>
          <a
            href="/login"
            class="inline-block bg-violet-600 hover:bg-violet-500 text-white font-semibold px-6 py-2.5 rounded-lg transition-colors"
          >
            Sign in →
          </a>
        </div>
      ) : (
        <>
          {error && (
            <div class="bg-red-950/50 border border-red-800 rounded-xl px-4 py-3 text-sm text-red-300 mb-6 flex items-start gap-2">
              <span class="mt-0.5 flex-shrink-0">⚠️</span>
              <span>{error}</span>
            </div>
          )}

          <!-- Show expired link message if error mentions expired/invalid -->
          {error && (error.includes("expired") || error.includes("Invalid")) && (
            <div class="text-center mb-6">
              <a
                href="/forgot-password"
                class="text-sm text-violet-400 hover:text-violet-300 underline"
              >
                Request a new reset link →
              </a>
            </div>
          )}

          <form method="POST" class="space-y-4">
            <input type="hidden" name="token" value={token} />

            <div>
              <label class="block text-sm text-gray-400 mb-1">New password</label>
              <input
                name="new_password"
                type="password"
                required
                minlength="8"
                autofocus
                class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2.5 text-gray-100 placeholder-gray-600 focus:outline-none focus:border-violet-500 transition-colors"
                placeholder="8+ characters"
              />
            </div>

            <div>
              <label class="block text-sm text-gray-400 mb-1">Confirm password</label>
              <input
                name="confirm_password"
                type="password"
                required
                minlength="8"
                class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2.5 text-gray-100 placeholder-gray-600 focus:outline-none focus:border-violet-500 transition-colors"
                placeholder="Same password again"
              />
            </div>

            <!-- Client-side password match indicator -->
            <p id="match-msg" class="text-xs hidden"></p>

            <button
              type="submit"
              class="w-full bg-violet-600 hover:bg-violet-500 text-white font-semibold py-3 rounded-lg transition-colors"
            >
              Update password
            </button>
          </form>
        </>
      )}

      <p class="text-center text-sm text-gray-500 mt-6">
        <a href="/login" class="text-violet-400 hover:text-violet-300">Back to sign in</a>
      </p>
    </div>
  </div>
</Layout>

<script>
  // Live password match feedback
  const pw1 = document.querySelector('input[name="new_password"]') as HTMLInputElement | null;
  const pw2 = document.querySelector('input[name="confirm_password"]') as HTMLInputElement | null;
  const msg = document.getElementById("match-msg");

  function checkMatch() {
    if (!pw1 || !pw2 || !msg || !pw2.value) { return; }
    msg.classList.remove("hidden");
    if (pw1.value === pw2.value) {
      msg.textContent = "✓ Passwords match";
      msg.className = "text-xs text-green-400";
    } else {
      msg.textContent = "✗ Passwords do not match";
      msg.className = "text-xs text-red-400";
    }
  }

  pw1?.addEventListener("input", checkMatch);
  pw2?.addEventListener("input", checkMatch);
</script>
