---
/**
 * 2FA verification page — /login-2fa
 * Shown after successful password login when TOTP is enabled.
 */
import Layout from "@/layouts/Layout.astro";

// The pending_token is passed as a query param from the login flow
const pendingToken = Astro.url.searchParams.get("pt") ?? "";
---

<Layout title="Two-Factor Authentication — CrowdSorcerer">
  <div class="min-h-[80vh] flex items-center justify-center px-4">
    <div class="w-full max-w-sm">
      <div class="text-center mb-8">
        <div class="text-5xl mb-3">🔐</div>
        <h1 class="text-2xl font-bold text-white">Two-Factor Auth</h1>
        <p class="text-gray-400 text-sm mt-2">
          Enter the 6-digit code from your authenticator app.
        </p>
      </div>

      <div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
        <div id="error-msg" class="hidden mb-4 p-3 rounded-lg bg-red-900/30 border border-red-700 text-red-300 text-sm" />

        <form id="verify-form" class="space-y-4">
          <div>
            <label for="code-input" class="block text-xs font-medium text-gray-400 mb-2">
              Authentication Code
            </label>
            <input
              id="code-input"
              type="text"
              inputmode="numeric"
              maxlength="8"
              autofocus
              placeholder="000000"
              class="w-full bg-gray-700 border border-gray-600 rounded-lg px-4 py-3 text-white text-xl font-mono text-center tracking-widest focus:ring-2 focus:ring-indigo-500 focus:outline-none"
            />
            <p class="text-xs text-gray-500 mt-1 text-center">
              Or enter one of your 8-character backup codes
            </p>
          </div>

          <button
            type="submit"
            id="btn-verify"
            class="w-full bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors"
          >
            Verify
          </button>
        </form>

        <p class="text-xs text-gray-500 text-center mt-4">
          <a href="/login" class="text-indigo-400 hover:underline">← Back to login</a>
        </p>
      </div>
    </div>
  </div>
</Layout>

<script is:inline define:vars={{ pendingToken }}>
  const form     = document.getElementById("verify-form");
  const codeInput = document.getElementById("code-input");
  const btnVerify = document.getElementById("btn-verify");
  const errorEl   = document.getElementById("error-msg");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const code = codeInput?.value.trim();
    if (!code) return;

    btnVerify?.setAttribute("disabled", "true");
    btnVerify.textContent = "Verifying…";
    errorEl?.classList.add("hidden");

    try {
      const res = await fetch("/api/auth/2fa/verify", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ pending_token: pendingToken, code }),
      });
      const data = await res.json().catch(() => ({}));

      if (!res.ok) {
        throw new Error(data.detail ?? "Invalid code");
      }

      // Success — cookie is set by the API route; redirect to dashboard
      window.location.href = "/dashboard";
    } catch (err) {
      if (errorEl) errorEl.textContent = err?.message ?? "Verification failed";
      errorEl?.classList.remove("hidden");
      btnVerify?.removeAttribute("disabled");
      btnVerify.textContent = "Verify";
    }
  });

  // Auto-submit when 6 digits entered
  codeInput?.addEventListener("input", () => {
    const val = codeInput.value;
    if (val.length === 6 || val.length === 8) {
      form?.dispatchEvent(new Event("submit"));
    }
  });
</script>
