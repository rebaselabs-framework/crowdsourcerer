---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Page Not Found — CrowdSorcerer">
  <div class="min-h-[60vh] flex flex-col items-center justify-center px-6 text-center">
    <div class="text-6xl mb-6">🔮</div>
    <h1 class="text-4xl font-bold mb-3">
      <span class="text-violet-400">404</span> — Page not found
    </h1>
    <p class="text-gray-400 max-w-md mb-8">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href="/"
        class="px-6 py-3 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold transition-colors"
      >
        Back to home
      </a>
      <a
        href="/docs"
        class="px-6 py-3 rounded-xl border border-gray-700 hover:border-gray-500 text-gray-300 transition-colors"
      >
        Read the docs
      </a>
    </div>
  </div>
</Layout>
