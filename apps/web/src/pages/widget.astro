---
/**
 * Widget documentation & live demo page.
 * Shows how to embed the CrowdSorcerer task feed widget.
 */
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Embeddable Widget — CrowdSorcerer" description="Embed a live CrowdSorcerer task feed on any website with a single script tag.">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <div class="text-center mb-12">
      <span class="bg-violet-900/30 text-violet-300 text-xs font-semibold px-3 py-1.5 rounded-full border border-violet-800/50 mb-4 inline-block">
        Embeddable Widget
      </span>
      <h1 class="text-3xl sm:text-4xl font-bold mt-3 mb-4">Add a task feed to your website</h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto leading-relaxed">
        A single script tag shows live open tasks from CrowdSorcerer on any webpage.
        Your visitors can start earning credits in one click.
      </p>
    </div>

    <!-- Live demo -->
    <div class="grid md:grid-cols-2 gap-8 mb-14">
      <div>
        <h2 class="text-lg font-semibold mb-4">Live Preview</h2>
        <div id="cs-widget-demo"></div>
      </div>

      <div>
        <h2 class="text-lg font-semibold mb-4">Light Theme</h2>
        <div id="cs-widget-light"></div>
      </div>
    </div>

    <!-- Installation -->
    <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden mb-8">
      <div class="px-6 py-4 border-b border-gray-800 flex items-center gap-3">
        <span class="w-3 h-3 rounded-full bg-red-500"></span>
        <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
        <span class="w-3 h-3 rounded-full bg-green-500"></span>
        <span class="text-sm text-gray-400 ml-2">Minimal embed (copy & paste)</span>
      </div>
      <div class="p-6">
        <pre class="text-sm text-gray-300 overflow-x-auto whitespace-pre-wrap"><code id="code-minimal">&lt;div id="cs-widget"&gt;&lt;/div&gt;
&lt;script src="https://crowdsourcerer.rebaselabs.online/widget.js"&gt;&lt;/script&gt;</code></pre>
        <button
          onclick="copyCode('code-minimal', this)"
          class="mt-4 px-4 py-2 bg-gray-800 hover:bg-gray-700 text-sm text-gray-300 rounded-lg transition-colors"
        >
          📋 Copy
        </button>
      </div>
    </div>

    <!-- Full config example -->
    <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden mb-12">
      <div class="px-6 py-4 border-b border-gray-800 flex items-center gap-3">
        <span class="w-3 h-3 rounded-full bg-red-500"></span>
        <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
        <span class="w-3 h-3 rounded-full bg-green-500"></span>
        <span class="text-sm text-gray-400 ml-2">Full configuration options</span>
      </div>
      <div class="p-6">
        <pre class="text-sm text-gray-300 overflow-x-auto whitespace-pre-wrap"><code id="code-full">&lt;div id="cs-widget"&gt;&lt;/div&gt;
&lt;script
  src="https://crowdsourcerer.rebaselabs.online/widget.js"
  data-container="#cs-widget"
  data-limit="6"
  data-type=""
  data-theme="dark"
  data-title="Open Tasks — Earn Credits"
  data-cta-url="https://crowdsourcerer.rebaselabs.online/register"
  data-auto-refresh="60"&gt;
&lt;/script&gt;</code></pre>
        <button
          onclick="copyCode('code-full', this)"
          class="mt-4 px-4 py-2 bg-gray-800 hover:bg-gray-700 text-sm text-gray-300 rounded-lg transition-colors"
        >
          📋 Copy
        </button>
      </div>
    </div>

    <!-- Options table -->
    <h2 class="text-xl font-semibold mb-4">Configuration options</h2>
    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-12">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-800">
            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Attribute</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Default</th>
            <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          {[
            { attr: "data-container", def: "#cs-widget", desc: "CSS selector of the container element" },
            { attr: "data-limit", def: "6", desc: "Number of tasks to show (max 12)" },
            { attr: "data-type", def: "(all)", desc: "Filter by task type (e.g. label_image, verify_fact)" },
            { attr: "data-theme", def: "dark", desc: "\"dark\" or \"light\"" },
            { attr: "data-title", def: "Open Tasks — Earn Credits", desc: "Widget header title" },
            { attr: "data-cta-url", def: "/register", desc: "Where the CTA button links to" },
            { attr: "data-auto-refresh", def: "60", desc: "Auto-refresh interval in seconds (0 = off)" },
          ].map(({ attr, def, desc }) => (
            <tr>
              <td class="px-5 py-3 font-mono text-violet-300 text-xs">{attr}</td>
              <td class="px-5 py-3 text-gray-400 text-xs font-mono">{def}</td>
              <td class="px-5 py-3 text-gray-300 text-xs">{desc}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Task types reference -->
    <h2 class="text-xl font-semibold mb-4">Available task types for filtering</h2>
    <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-3 mb-12">
      {[
        { type: "label_image", icon: "🖼️", label: "Label Image" },
        { type: "label_text", icon: "📝", label: "Classify Text" },
        { type: "rate_quality", icon: "⭐", label: "Rate Quality" },
        { type: "verify_fact", icon: "✅", label: "Verify Fact" },
        { type: "moderate_content", icon: "🛡️", label: "Moderate Content" },
        { type: "compare_rank", icon: "⚖️", label: "A/B Compare" },
        { type: "answer_question", icon: "💬", label: "Answer Question" },
        { type: "transcription_review", icon: "🎙️", label: "Review Transcript" },
      ].map(({ type, icon, label }) => (
        <div class="bg-gray-900 border border-gray-800 rounded-lg px-4 py-3 flex items-center gap-3">
          <span class="text-xl">{icon}</span>
          <div>
            <div class="text-xs font-semibold text-gray-200">{label}</div>
            <code class="text-[11px] text-violet-400">{type}</code>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center bg-gradient-to-br from-violet-950/50 to-indigo-950/50 border border-violet-800/30 rounded-2xl p-10">
      <h3 class="text-2xl font-bold mb-3">Ready to earn?</h3>
      <p class="text-gray-400 mb-6">Create a free account and start completing tasks today.</p>
      <a href="/register" class="inline-block px-8 py-3 bg-violet-600 hover:bg-violet-500 text-white font-semibold rounded-xl transition-colors">
        Get started free →
      </a>
    </div>
  </div>
</Layout>

<!-- Load the widget for live demos -->
<div id="cs-widget-light-inner"></div>
<script is:inline>
  // Dark demo
  (function() {
    var s = document.createElement("script");
    s.src = "/widget.js";
    s.setAttribute("data-container", "#cs-widget-demo");
    s.setAttribute("data-limit", "5");
    s.setAttribute("data-theme", "dark");
    s.setAttribute("data-title", "Open Tasks");
    s.setAttribute("data-auto-refresh", "0");
    document.body.appendChild(s);
  })();

  // Light demo - initialize manually after the dark one loads
  setTimeout(function() {
    if (window.CrowdSorcerer && window.CrowdSorcerer.initWidget) {
      // Manually create light widget
    }
    var el = document.getElementById("cs-widget-light");
    if (!el) return;

    // Inline the light widget since we can't load the script tag twice easily
    var API_URL = "https://crowdsourcerer.rebaselabs.online";
    fetch(API_URL + "/api/widget/tasks?limit=5")
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var TASK_META = {
          label_image: { label: "Label Image", icon: "🖼️", est: "2" },
          label_text: { label: "Classify Text", icon: "📝", est: "2" },
          rate_quality: { label: "Rate Quality", icon: "⭐", est: "1" },
          verify_fact: { label: "Verify Fact", icon: "✅", est: "2" },
          moderate_content: { label: "Moderate Content", icon: "🛡️", est: "3" },
          compare_rank: { label: "A/B Compare", icon: "⚖️", est: "1" },
          answer_question: { label: "Answer Question", icon: "💬", est: "3" },
          transcription_review: { label: "Review Transcript", icon: "🎙️", est: "5" },
        };
        var items = (data.items || []).slice(0, 5);
        var taskHtml = items.length === 0
          ? '<div style="text-align:center;padding:20px;color:#6b7280;font-size:13px;">🔮 No open tasks right now.</div>'
          : items.map(function(task) {
              var meta = TASK_META[task.type] || { label: task.type, icon: "🔮", est: "?" };
              var reward = task.reward || task.worker_reward_credits || "?";
              return [
                '<a href="https://crowdsourcerer.rebaselabs.online/tasks" target="_blank" rel="noopener" style="display:flex;align-items:center;gap:12px;background:#fff;border:1px solid #e5e7eb;border-radius:8px;padding:10px 12px;text-decoration:none;color:inherit;transition:background 0.15s;margin-bottom:8px;cursor:pointer;">',
                '<span style="font-size:20px;line-height:1;">' + meta.icon + '</span>',
                '<div style="flex:1;min-width:0;">',
                '<div style="font-size:13px;font-weight:600;color:#111827;">' + meta.label + '</div>',
                '<div style="font-size:11px;color:#6b7280;margin-top:2px;">~' + meta.est + ' min</div>',
                '</div>',
                '<span style="font-size:14px;font-weight:700;color:#059669;background:rgba(5,150,105,0.1);padding:4px 8px;border-radius:6px;">+' + reward + ' cr</span>',
                '</a>',
              ].join("");
            }).join("");

        el.innerHTML = [
          '<div style="font-family:-apple-system,BlinkMacSystemFont,\'Segoe UI\',Roboto,sans-serif;background:#fafafa;border:1px solid #e5e7eb;border-radius:12px;padding:16px;">',
          '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">',
          '<span style="font-size:13px;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;">Open Tasks</span>',
          data.total > 0 ? '<span style="font-size:11px;background:#7c3aed22;color:#7c3aed;padding:2px 8px;border-radius:99px;font-weight:600;">' + data.total + ' tasks</span>' : "",
          '</div>',
          taskHtml,
          '<div style="margin-top:14px;text-align:center;">',
          '<a href="https://crowdsourcerer.rebaselabs.online/register" target="_blank" rel="noopener" style="display:inline-block;background:#7c3aed;color:#fff;font-size:13px;font-weight:600;padding:9px 20px;border-radius:8px;text-decoration:none;">Start earning →</a>',
          '<div style="font-size:10px;color:#9ca3af;margin-top:8px;">Powered by <a href="https://crowdsourcerer.rebaselabs.online" target="_blank" style="color:#7c3aed;text-decoration:none;">CrowdSorcerer</a></div>',
          '</div>',
          '</div>',
        ].join("");
      })
      .catch(function() {
        el.innerHTML = '<div style="padding:20px;text-align:center;color:#6b7280;font-size:12px;border:1px solid #e5e7eb;border-radius:12px;">Widget preview unavailable</div>';
      });
  }, 500);

  function copyCode(id, btn) {
    var code = document.getElementById(id)?.textContent || "";
    navigator.clipboard.writeText(code).then(function() {
      btn.textContent = "✓ Copied!";
      setTimeout(function() { btn.textContent = "📋 Copy"; }, 2000);
    }).catch(function() {
      btn.textContent = "Copy failed";
    });
  }
</script>
