---
import Layout from "@/layouts/Layout.astro";
import { CONTACT_EMAIL, mailto } from "@/lib/contact";

const taskTypes = [
  {
    id: "web-research",
    name: "Web Research",
    slug: "web_research",
    credits: 10,
    description: "Scrape and summarize any URL. Supports JavaScript-rendered pages, table extraction, and link discovery.",
    fields: [
      { name: "url", type: "string", required: true, desc: "URL to scrape" },
      { name: "instruction", type: "string", required: false, desc: "What to extract (default: main content)" },
      { name: "extract_tables", type: "boolean", required: false, desc: "Extract tables (default: false)" },
      { name: "extract_links", type: "boolean", required: false, desc: "Extract links (default: false)" },
      { name: "wait_for_selector", type: "string", required: false, desc: "CSS selector to wait for before scraping" },
    ],
    example: `{
  "type": "web_research",
  "input": {
    "url": "https://news.ycombinator.com",
    "instruction": "List the top 5 story titles and their scores"
  }
}`,
  },
  {
    id: "entity-lookup",
    name: "Entity Lookup",
    slug: "entity_lookup",
    credits: 5,
    description: "Enrich company or person data: description, tech stack, headcount, funding, social profiles.",
    fields: [
      { name: "entity_type", type: "\"company\" | \"person\"", required: true, desc: "Type of entity to enrich" },
      { name: "name", type: "string", required: false, desc: "Company or person name" },
      { name: "domain", type: "string", required: false, desc: "Company domain (e.g. stripe.com)" },
      { name: "linkedin_url", type: "string", required: false, desc: "LinkedIn profile URL" },
      { name: "enrich_fields", type: "string[]", required: false, desc: "Specific fields to include" },
    ],
    example: `{
  "type": "entity_lookup",
  "input": {
    "entity_type": "company",
    "domain": "stripe.com"
  }
}`,
  },
  {
    id: "document-parse",
    name: "Document Parse",
    slug: "document_parse",
    credits: 3,
    description: "Extract text, tables, and metadata from PDFs, Word docs, images, and other documents.",
    fields: [
      { name: "url", type: "string", required: false, desc: "URL to a document file" },
      { name: "base64_content", type: "string", required: false, desc: "Base64-encoded file content" },
      { name: "mime_type", type: "string", required: false, desc: "MIME type when using base64 (e.g. application/pdf)" },
      { name: "extract_tables", type: "boolean", required: false, desc: "Extract tables (default: true)" },
      { name: "extract_images", type: "boolean", required: false, desc: "Extract images (default: false)" },
    ],
    example: `{
  "type": "document_parse",
  "input": {
    "url": "https://example.com/report.pdf",
    "extract_tables": true
  }
}`,
  },
  {
    id: "data-transform",
    name: "Data Transform",
    slug: "data_transform",
    credits: 2,
    description: "Transform data between formats: CSV↔JSON, clean/normalize, filter, reshape.",
    fields: [
      { name: "data", type: "any", required: true, desc: "Input data (JSON, CSV string, array, etc.)" },
      { name: "transform", type: "string", required: true, desc: "Natural language description of the transformation" },
      { name: "output_format", type: "string", required: false, desc: "Desired output format: json, csv, markdown (default: json)" },
    ],
    example: `{
  "type": "data_transform",
  "input": {
    "data": [{"name": "Alice", "score": "87"}, {"name": "Bob", "score": "92"}],
    "transform": "Sort by score descending and add a rank column",
    "output_format": "json"
  }
}`,
  },
  {
    id: "llm-generate",
    name: "LLM Generate",
    slug: "llm_generate",
    credits: 1,
    description: "Route to the best LLM for the job. Supports Claude, GPT-4, Gemini, Mistral, and more via the RebaseKit LLM router.",
    fields: [
      { name: "messages", type: "Message[]", required: true, desc: "Array of {role, content} messages" },
      { name: "system_prompt", type: "string", required: false, desc: "System prompt (prepended if no system message in messages)" },
      { name: "model", type: "string", required: false, desc: "Model ID (default: claude-3-5-haiku-20241022)" },
      { name: "temperature", type: "number", required: false, desc: "Temperature 0–2 (default: 0.7)" },
      { name: "max_tokens", type: "number", required: false, desc: "Max output tokens (default: 2048)" },
    ],
    example: `{
  "type": "llm_generate",
  "input": {
    "messages": [{"role": "user", "content": "Summarize the pros and cons of microservices in 3 bullet points each."}],
    "model": "claude-3-5-haiku-20241022"
  }
}`,
  },
  {
    id: "screenshot",
    name: "Screenshot",
    slug: "screenshot",
    credits: 2,
    description: "Capture a full-page or viewport screenshot of any URL. Returns a base64-encoded image.",
    fields: [
      { name: "url", type: "string", required: true, desc: "URL to screenshot" },
      { name: "width", type: "number", required: false, desc: "Viewport width in px (default: 1280)" },
      { name: "height", type: "number", required: false, desc: "Viewport height in px (default: 800)" },
      { name: "full_page", type: "boolean", required: false, desc: "Capture full scrollable page (default: false)" },
      { name: "format", type: "\"png\" | \"jpeg\"", required: false, desc: "Image format (default: png)" },
      { name: "wait_for_selector", type: "string", required: false, desc: "CSS selector to wait for before capturing" },
    ],
    example: `{
  "type": "screenshot",
  "input": {
    "url": "https://example.com",
    "full_page": true,
    "format": "jpeg"
  }
}`,
  },
  {
    id: "audio-transcribe",
    name: "Audio Transcribe",
    slug: "audio_transcribe",
    credits: 8,
    description: "Transcribe audio files with speaker diarization. Supports MP3, WAV, M4A, and more.",
    fields: [
      { name: "url", type: "string", required: false, desc: "URL to an audio file" },
      { name: "base64_audio", type: "string", required: false, desc: "Base64-encoded audio content" },
      { name: "language", type: "string", required: false, desc: "BCP-47 language code (auto-detected if omitted)" },
      { name: "diarize", type: "boolean", required: false, desc: "Speaker diarization (default: false)" },
    ],
    example: `{
  "type": "audio_transcribe",
  "input": {
    "url": "https://example.com/interview.mp3",
    "diarize": true
  }
}`,
  },
  {
    id: "pii-detect",
    name: "PII Detect",
    slug: "pii_detect",
    credits: 2,
    description: "Detect, mask, or vault 30+ PII types (names, emails, SSNs, credit cards, etc.).",
    fields: [
      { name: "text", type: "string", required: true, desc: "Text to analyze" },
      { name: "entities", type: "string[]", required: false, desc: "Specific PII types to detect (default: all)" },
      { name: "mask", type: "boolean", required: false, desc: "Replace PII with [TYPE] tokens (default: false)" },
      { name: "vault", type: "boolean", required: false, desc: "Store PII in vault, return placeholder tokens (default: false)" },
    ],
    example: `{
  "type": "pii_detect",
  "input": {
    "text": "Call John Smith at john@example.com or 555-123-4567",
    "mask": true
  }
}`,
  },
  {
    id: "code-execute",
    name: "Code Execute",
    slug: "code_execute",
    credits: 3,
    description: "Run Python, JavaScript, TypeScript, or Bash code in a sandboxed environment.",
    fields: [
      { name: "code", type: "string", required: true, desc: "Code to execute" },
      { name: "language", type: "\"python\" | \"javascript\" | \"typescript\" | \"bash\"", required: false, desc: "Language (default: python)" },
      { name: "timeout_seconds", type: "number", required: false, desc: "Execution timeout (default: 30)" },
      { name: "stdin", type: "string", required: false, desc: "Standard input to pass to the program" },
    ],
    example: `{
  "type": "code_execute",
  "input": {
    "code": "import json\\ndata = [1, 2, 3, 4, 5]\\nprint(json.dumps({'sum': sum(data), 'mean': sum(data)/len(data)}))",
    "language": "python"
  }
}`,
  },
  {
    id: "web-intel",
    name: "Web Intel",
    slug: "web_intel",
    credits: 5,
    description: "AI-powered web intelligence gathering. Search the web and synthesize results into structured insights.",
    fields: [
      { name: "query", type: "string", required: true, desc: "Research query or question" },
      { name: "sources", type: "string[]", required: false, desc: "Specific domains or URLs to prioritize" },
      { name: "max_results", type: "number", required: false, desc: "Max search results to process (default: 10)" },
    ],
    example: `{
  "type": "web_intel",
  "input": {
    "query": "Latest AI coding assistants launched in 2025 — compare features and pricing",
    "max_results": 15
  }
}`,
  },
];

const humanTaskTypes = [
  {
    id: "label-image",
    name: "Label Image",
    slug: "label_image",
    credits: 3,
    description: "Workers classify images by selecting from a set of predefined labels.",
    fields: [
      { name: "image_url", type: "string", required: true, desc: "URL of the image to label" },
      { name: "labels", type: "string[]", required: true, desc: "Array of possible labels to choose from" },
      { name: "description", type: "string", required: false, desc: "Additional context for workers" },
    ],
    example: `{
  "type": "label_image",
  "input": {
    "image_url": "https://example.com/photo.jpg",
    "labels": ["cat", "dog", "bird", "other"],
    "description": "Select the animal in this photo"
  }
}`,
  },
  {
    id: "label-text",
    name: "Label Text",
    slug: "label_text",
    credits: 2,
    description: "Workers categorize text into one of the provided categories.",
    fields: [
      { name: "text", type: "string", required: true, desc: "Text to categorize" },
      { name: "categories", type: "string[]", required: true, desc: "Array of possible categories" },
    ],
    example: `{
  "type": "label_text",
  "input": {
    "text": "The new iPhone has amazing battery life and a great camera",
    "categories": ["positive", "negative", "neutral"]
  }
}`,
  },
  {
    id: "rate-quality",
    name: "Rate Quality",
    slug: "rate_quality",
    credits: 2,
    description: "Workers rate content quality on a 1\u20135 scale based on specified criteria.",
    fields: [
      { name: "title", type: "string", required: true, desc: "Title of the content to rate" },
      { name: "content", type: "string", required: true, desc: "The content to evaluate" },
      { name: "criteria", type: "string", required: false, desc: "What to evaluate (e.g. clarity, accuracy)" },
    ],
    example: `{
  "type": "rate_quality",
  "input": {
    "title": "Introduction to Machine Learning",
    "content": "Machine learning is a subset of AI...",
    "criteria": "Rate the accuracy and clarity of this explanation"
  }
}`,
  },
  {
    id: "verify-fact",
    name: "Verify Fact",
    slug: "verify_fact",
    credits: 3,
    description: "Workers verify whether a claim is true, false, or indeterminate given the provided context.",
    fields: [
      { name: "claim", type: "string", required: true, desc: "The factual claim to verify" },
      { name: "context", type: "string", required: true, desc: "Supporting context or evidence" },
    ],
    example: `{
  "type": "verify_fact",
  "input": {
    "claim": "Python was created by Guido van Rossum in 1991",
    "context": "Python is a high-level programming language first released in 1991 by Guido van Rossum."
  }
}`,
  },
  {
    id: "moderate-content",
    name: "Moderate Content",
    slug: "moderate_content",
    credits: 2,
    description: "Workers review content against a policy and decide to approve, reject, or escalate.",
    fields: [
      { name: "content", type: "string", required: true, desc: "The content to moderate" },
      { name: "content_type", type: "string", required: false, desc: "Type of content (e.g. comment, review, post)" },
      { name: "policy_context", type: "string", required: false, desc: "Moderation policy or guidelines" },
    ],
    example: `{
  "type": "moderate_content",
  "input": {
    "content": "This product is absolutely terrible, worst purchase ever!",
    "content_type": "product_review",
    "policy_context": "Reject spam, hate speech, and threats. Allow negative opinions."
  }
}`,
  },
  {
    id: "compare-rank",
    name: "Compare & Rank",
    slug: "compare_rank",
    credits: 2,
    description: "Workers compare two options and select the better one based on given criteria.",
    fields: [
      { name: "option_a", type: "string", required: true, desc: "First option to compare" },
      { name: "option_b", type: "string", required: true, desc: "Second option to compare" },
      { name: "criteria", type: "string", required: false, desc: "What to compare on (e.g. readability, accuracy)" },
    ],
    example: `{
  "type": "compare_rank",
  "input": {
    "option_a": "Machine learning uses algorithms to learn from data.",
    "option_b": "ML is when computers figure stuff out from examples.",
    "criteria": "Which explanation is clearer and more professional?"
  }
}`,
  },
  {
    id: "answer-question",
    name: "Answer Question",
    slug: "answer_question",
    credits: 4,
    description: "Workers read content and answer a question about it. Supports free-text and multiple-choice formats.",
    fields: [
      { name: "content", type: "string", required: true, desc: "Source content to read" },
      { name: "question", type: "string", required: true, desc: "Question to answer" },
      { name: "answer_format", type: "\"free_text\" | \"multiple_choice\"", required: false, desc: "Answer format (default: free_text)" },
      { name: "choices", type: "string[]", required: false, desc: "Options for multiple-choice format" },
    ],
    example: `{
  "type": "answer_question",
  "input": {
    "content": "The Eiffel Tower was built in 1889 for the World's Fair...",
    "question": "When was the Eiffel Tower built?",
    "answer_format": "multiple_choice",
    "choices": ["1876", "1889", "1901", "1912"]
  }
}`,
  },
  {
    id: "transcription-review",
    name: "Transcription Review",
    slug: "transcription_review",
    credits: 5,
    description: "Workers review and correct an AI-generated transcript against the original audio.",
    fields: [
      { name: "audio_url", type: "string", required: true, desc: "URL of the audio file" },
      { name: "ai_transcript", type: "string", required: true, desc: "AI-generated transcript to review" },
      { name: "language", type: "string", required: false, desc: "Language of the audio (e.g. en, es)" },
    ],
    example: `{
  "type": "transcription_review",
  "input": {
    "audio_url": "https://example.com/recording.mp3",
    "ai_transcript": "Welcome to the podast about artifical inteligence...",
    "language": "en"
  }
}`,
  },
];
---

<Layout title="Docs — CrowdSorcerer">
  <div class="max-w-5xl mx-auto px-6 py-20">
    <h1 class="text-4xl font-bold mb-3">Documentation</h1>
    <p class="text-gray-400 mb-12">Everything you need to integrate CrowdSorcerer.</p>

    <div class="grid md:grid-cols-4 gap-8">
      <!-- Sidebar -->
      <nav class="text-sm space-y-1 md:sticky md:top-8 self-start min-w-0">
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Get started</div>
        <a href="#quickstart" class="block py-1 text-gray-400 hover:text-gray-200 transition-colors">Quickstart</a>
        <a href="#authentication" class="block py-1 text-gray-400 hover:text-gray-200 transition-colors">Authentication</a>
        <a href="#tasks" class="block py-1 text-gray-400 hover:text-gray-200 transition-colors">Task lifecycle</a>
        <a href="#sdk" class="block py-1 text-gray-400 hover:text-gray-200 transition-colors">TypeScript SDK</a>
        <a href="#python-sdk" class="block py-1 text-gray-400 hover:text-gray-200 transition-colors">Python SDK</a>
        <a href="#webhooks" class="block py-1 text-gray-400 hover:text-gray-200 transition-colors">Webhooks</a>
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mt-4 mb-2">AI task types</div>
        {taskTypes.map((t) => (
          <a href={`#${t.id}`} class="block py-1 text-gray-400 hover:text-gray-200 transition-colors">
            {t.name} <span class="text-gray-500 text-xs">{t.credits}cr</span>
          </a>
        ))}
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mt-4 mb-2">Human task types</div>
        {humanTaskTypes.map((t) => (
          <a href={`#${t.id}`} class="block py-1 text-gray-400 hover:text-gray-200 transition-colors">
            {t.name} <span class="text-gray-500 text-xs">{t.credits}cr</span>
          </a>
        ))}
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mt-4 mb-2">Reference</div>
        <a href="/docs/api-reference" class="block py-1 text-gray-400 hover:text-gray-200 transition-colors">
          📖 API Reference
        </a>
      </nav>

      <!-- Content (min-w-0 prevents code blocks from stretching the grid) -->
      <div class="md:col-span-3 space-y-16 text-gray-300 min-w-0">

        <!-- Quickstart -->
        <section id="quickstart">
          <h2 class="text-2xl font-bold text-gray-100 mb-4">Quickstart</h2>
          <p class="mb-4">Get your first task result in under 2 minutes.</p>
          <ol class="list-decimal list-inside space-y-2 text-sm mb-6">
            <li><a href={mailto(CONTACT_EMAIL, "CrowdSorcerer early access")} class="text-violet-400 hover:text-violet-300">Request early access</a> — we're in closed beta and onboarding one cohort at a time</li>
            <li>Generate an API key from the <a href="/dashboard/api-keys" class="text-violet-400 hover:text-violet-300">API Keys page</a></li>
            <li>Submit your first task via the REST API or SDK</li>
          </ol>
          <div class="space-y-3">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">TypeScript / Node.js</p>
            <pre class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-sm font-mono overflow-x-auto"><code class="text-gray-300">{`npm install @crowdsourcerer/sdk`}</code></pre>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Python</p>
            <pre class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-sm font-mono overflow-x-auto"><code class="text-gray-300">{`pip install crowdsourcerer-sdk`}</code></pre>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">cURL</p>
            <pre class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-sm font-mono overflow-x-auto"><code class="text-gray-300">{`curl -X POST https://crowdsourcerer.rebaselabs.online/v1/tasks \\
  -H "Authorization: Bearer csk_YOUR_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "type": "web_research",
    "input": {
      "url": "https://example.com",
      "instruction": "Extract the main heading and description"
    }
  }'`}</code></pre>
          </div>
        </section>

        <!-- Authentication -->
        <section id="authentication">
          <h2 class="text-2xl font-bold text-gray-100 mb-4">Authentication</h2>
          <p class="mb-4">
            All API requests require a Bearer token in the <code class="text-violet-300 bg-gray-900 px-1 rounded">Authorization</code> header.
          </p>
          <pre class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4">Authorization: Bearer csk_YOUR_API_KEY</pre>
          <p class="text-sm mb-4">Two token types are accepted:</p>
          <ul class="list-disc list-inside space-y-2 text-sm">
            <li>
              <strong class="text-gray-200">API Keys</strong> (<code class="text-violet-300">csk_...</code>) —
              recommended for production. Create in the <a href="/dashboard/api-keys" class="text-violet-400 hover:text-violet-300">dashboard</a>.
            </li>
            <li>
              <strong class="text-gray-200">JWT tokens</strong> —
              returned from <code class="text-violet-300">POST /v1/auth/login</code>. Use for short-lived user sessions.
            </li>
          </ul>
        </section>

        <!-- Task lifecycle -->
        <section id="tasks">
          <h2 class="text-2xl font-bold text-gray-100 mb-4">Task lifecycle</h2>
          <p class="mb-4 text-sm">Tasks execute asynchronously. States:</p>
          <div class="flex items-center gap-2 text-sm mb-6 flex-wrap">
            {["queued", "running", "completed", "failed", "cancelled"].map((s, i, arr) => (
              <>
                <span class:list={[
                  "px-2 py-1 rounded-full font-mono text-xs",
                  s === "completed" ? "bg-green-950 text-green-400" :
                  s === "failed" ? "bg-red-950 text-red-400" :
                  s === "running" ? "bg-yellow-950 text-yellow-400" :
                  "bg-gray-800 text-gray-300"
                ]}>{s}</span>
                {i < arr.length - 1 && <span class="text-gray-500">→</span>}
              </>
            ))}
          </div>
          <p class="text-sm mb-4">
            Submit a task → get a <code class="text-violet-300">task_id</code> →
            poll <code class="text-violet-300">GET /v1/tasks/{"{task_id}"}</code> or use webhooks.
            Credits are charged immediately on submission (refunded automatically if the task fails).
          </p>

          <h3 class="text-lg font-semibold text-gray-200 mb-3 mt-6">Submit a task</h3>
          <pre class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code>POST /v1/tasks
{`{
  "type": "web_research",
  "input": { "url": "https://example.com" },
  "priority": "normal",           // optional: low | normal | high
  "webhook_url": "https://..."    // optional
}`}</code></pre>

          <h3 class="text-lg font-semibold text-gray-200 mb-3 mt-6">Poll for result</h3>
          <pre class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-sm font-mono overflow-x-auto"><code>GET /v1/tasks/{"{task_id}"}

// Response when completed:
{`{
  "id": "uuid",
  "type": "web_research",
  "status": "completed",
  "output": { "summary": "...", "raw": {...} },
  "credits_used": 10,
  "duration_ms": 3420,
  "created_at": "2025-01-01T00:00:00Z",
  "completed_at": "2025-01-01T00:00:03Z"
}`}</code></pre>
        </section>

        <!-- SDK -->
        <section id="sdk">
          <h2 class="text-2xl font-bold text-gray-100 mb-4">TypeScript SDK</h2>
          <pre class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-sm font-mono overflow-x-auto mb-6"><code>npm install @crowdsourcerer/sdk</code></pre>
          <pre class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-sm font-mono overflow-x-auto"><code class="text-gray-300">{`import { CrowdSorcerer } from "@crowdsourcerer/sdk";

const crowd = new CrowdSorcerer({ apiKey: process.env.CROWDSOURCERER_API_KEY! });

// Typed helpers — submit + wait for result
const result = await crowd.webResearch({ url: "https://news.ycombinator.com" });
const entity = await crowd.entityLookup({ entity_type: "company", name: "Stripe" });
const llm    = await crowd.llmGenerate({ messages: [{ role: "user", content: "Hello!" }] });

// Or submit async + poll manually
const { task_id } = await crowd.submitTask({ type: "screenshot", input: { url: "..." } });
const task = await crowd.getTask(task_id);

// Credits
const balance = await crowd.getCredits();
console.log(balance.available); // → 87`}</code></pre>
        </section>

        <!-- Python SDK -->
        <section id="python-sdk">
          <h2 class="text-2xl font-bold text-gray-100 mb-4">Python SDK</h2>
