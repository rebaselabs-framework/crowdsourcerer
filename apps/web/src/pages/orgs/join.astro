---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect(`/login?redirect=${Astro.url.pathname}${Astro.url.search}`);

const inviteToken = Astro.url.searchParams.get("token");
if (!inviteToken) return Astro.redirect("/dashboard");

let org: any = null;
let error: string | null = null;
let success = false;

if (Astro.request.method === "POST") {
  try {
    org = await apiFetch<any>(`/v1/orgs/join?token=${inviteToken}`, {
      method: "POST",
      token,
    });
    success = true;
  } catch (e: any) {
    error = e.message ?? "Failed to accept invite";
  }
} else {
  // Preview: just show a welcome page (we don't have a "preview invite" endpoint,
  // but we can try to accept on form submit)
}
---

<Layout title="Join Team — CrowdSorcerer">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 w-full max-w-md">

      {success ? (
        <div class="text-center">
          <div class="text-5xl mb-4">🎉</div>
          <h1 class="text-2xl font-bold text-white mb-2">You've joined!</h1>
          <p class="text-gray-400 mb-6">
            Welcome to <strong>{org?.name}</strong>. You can now create tasks
            using your team's shared credit pool.
          </p>
          <a
            href="/dashboard/team"
            class="block w-full py-3 bg-violet-600 hover:bg-violet-500 text-white font-semibold rounded-xl text-center transition"
          >
            Go to Team Dashboard
          </a>
        </div>
      ) : (
        <>
          <div class="text-center mb-6">
            <div class="text-4xl mb-2">🏢</div>
            <h1 class="text-2xl font-bold text-white">You've been invited!</h1>
            <p class="text-gray-400 mt-2">
              Accept this invitation to join a team and collaborate with shared credits.
            </p>
          </div>

          {error && (
            <div class="bg-red-900/30 border border-red-700 text-red-300 rounded-xl p-3 mb-4 text-sm">
              {error}
            </div>
          )}

          <form method="POST" class="space-y-4">
            <button
              type="submit"
              class="w-full py-3 bg-violet-600 hover:bg-violet-500 text-white font-semibold rounded-xl transition"
            >
              Accept Invitation
            </button>
            <a
              href="/dashboard"
              class="block w-full py-3 border border-gray-700 text-gray-300 font-medium rounded-xl text-center hover:bg-gray-800 transition"
            >
              Decline
            </a>
          </form>
        </>
      )}
    </div>
  </div>
</Layout>
