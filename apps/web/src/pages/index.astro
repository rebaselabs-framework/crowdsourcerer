---
import Layout from "@/layouts/Layout.astro";
import { TASK_CREDITS } from "@crowdsourcerer/types";

function taskIcon(type: string): string {
  const icons: Record<string, string> = {
    web_research: "🌐",
    entity_lookup: "🏢",
    document_parse: "📄",
    data_transform: "🔄",
    llm_generate: "🤖",
    screenshot: "📸",
    audio_transcribe: "🎙️",
    pii_detect: "🔒",
    code_execute: "⚡",
    web_intel: "🕵️",
  };
  return icons[type] ?? "🔮";
}

function taskLabel(type: string): string {
  const labels: Record<string, string> = {
    web_research: "Web Research",
    entity_lookup: "Entity Lookup",
    document_parse: "Doc Parse",
    data_transform: "Data Transform",
    llm_generate: "LLM Generate",
    screenshot: "Screenshot",
    audio_transcribe: "Transcribe",
    pii_detect: "PII Detect",
    code_execute: "Code Execute",
    web_intel: "Web Intel",
  };
  return labels[type] ?? type;
}
---

<Layout title="CrowdSorcerer — AI Task Platform">
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 py-24 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-violet-800 bg-violet-950/50 text-violet-300 text-sm mb-8">
      <span class="w-2 h-2 rounded-full bg-violet-400 animate-pulse"></span>
      Powered by RebaseKit · 10 AI worker types
    </div>

    <h1 class="text-5xl sm:text-6xl font-bold tracking-tight mb-6">
      Submit any task.<br />
      <span class="text-violet-400">We conjure the result.</span>
    </h1>

    <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10">
      CrowdSorcerer routes your tasks to the right AI workers — web research,
      entity lookups, document parsing, code execution, and more.
      No API juggling. Just results.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href="/register"
        class="px-6 py-3 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold transition-colors"
      >
        Start free — 100 credits
      </a>
      <a
        href="/tasks"
        class="px-6 py-3 rounded-xl border border-violet-700 hover:border-violet-500 text-violet-300 font-semibold transition-colors"
      >
        Browse open tasks →
      </a>
      <a
        href="/docs"
        class="px-6 py-3 rounded-xl border border-gray-700 hover:border-gray-500 text-gray-300 font-semibold transition-colors"
      >
        View docs
      </a>
    </div>
  </section>

  <!-- Task types grid -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <h2 class="text-2xl font-bold text-center mb-10 text-gray-300">10 task types. One API.</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      {Object.entries(TASK_CREDITS).map(([type, credits]) => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 hover:border-violet-800 transition-colors">
          <div class="text-2xl mb-2">{taskIcon(type)}</div>
          <div class="text-sm font-medium text-gray-200">{taskLabel(type)}</div>
          <div class="text-xs text-gray-500 mt-1">{credits} credits</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Code example -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="grid md:grid-cols-2 gap-8 items-center">
      <div>
        <h2 class="text-3xl font-bold mb-4">Simple API. Powerful results.</h2>
        <p class="text-gray-400 mb-6">
          Submit a task with a single POST request. Poll for the result, or use webhooks.
          Our TypeScript SDK makes it even easier.
        </p>
        <a href="/docs" class="text-violet-400 hover:text-violet-300 font-medium">
          Read the full docs →
        </a>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 font-mono text-sm overflow-x-auto">
        <pre class="text-gray-300"><span class="text-violet-400">import</span> {"{ CrowdSorcerer }"} <span class="text-violet-400">from</span> <span class="text-green-400">"@crowdsourcerer/sdk"</span>;

<span class="text-violet-400">const</span> crowd = <span class="text-violet-400">new</span> <span class="text-yellow-400">CrowdSorcerer</span>({"{"}<span class="text-orange-400"> apiKey</span>: <span class="text-green-400">"csk_..."</span> {"}"});

<span class="text-gray-500">// Research a company</span>
<span class="text-violet-400">const</span> task = <span class="text-violet-400">await</span> crowd.<span class="text-yellow-400">entityLookup</span>({"{"}<span class="text-orange-400">
  entity_type</span>: <span class="text-green-400">"company"</span>,<span class="text-orange-400">
  name</span>: <span class="text-green-400">"OpenAI"</span>,
{"}"});

console.<span class="text-yellow-400">log</span>(task.output.summary);
<span class="text-gray-500">// → "OpenAI: AI safety company..."</span></pre>
      </div>
    </div>
  </section>

  <!-- Pricing preview -->
  <section class="max-w-5xl mx-auto px-6 pb-20 text-center">
    <h2 class="text-3xl font-bold mb-3">Pay as you go</h2>
    <p class="text-gray-400 mb-10">100 credits free on signup. $1 = 100 credits.</p>
    <div class="grid md:grid-cols-3 gap-6">
      {[
        { plan: "Free", credits: 100, price: "$0", note: "On signup, no card required" },
        { plan: "Starter", credits: 1000, price: "$10", note: "Best for prototypes" },
        { plan: "Pro", credits: 10000, price: "$90", note: "10% volume discount" },
      ].map(({ plan, credits, price, note }) => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 text-left">
          <div class="text-sm text-gray-500 mb-1">{plan}</div>
          <div class="text-3xl font-bold mb-1">{price}</div>
          <div class="text-violet-300 font-medium mb-3">{credits.toLocaleString()} credits</div>
          <div class="text-sm text-gray-500">{note}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Pricing Calculator -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="bg-gradient-to-br from-gray-900 to-gray-950 border border-gray-800 rounded-2xl p-8 md:p-10">
      <h2 class="text-2xl font-bold mb-2">Calculate your cost</h2>
      <p class="text-gray-400 text-sm mb-8">Estimate credits for your typical workflow. $1 = 100 credits.</p>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Inputs -->
        <div class="space-y-5">
          <div>
            <label class="block text-sm text-gray-400 mb-2">Task type</label>
            <select id="calc-type" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-gray-200 text-sm focus:outline-none focus:border-violet-500">
              <option value="1">LLM Generate (1 cr)</option>
              <option value="2">Data Transform (2 cr)</option>
              <option value="2">PII Detect (2 cr)</option>
              <option value="3">Document Parse (3 cr)</option>
              <option value="3">Code Execute (3 cr)</option>
              <option value="5">Entity Lookup (5 cr)</option>
              <option value="5">Web Intel (5 cr)</option>
              <option value="8">Audio Transcribe (8 cr)</option>
              <option value="10">Web Research (10 cr)</option>
              <option value="2">Screenshot (2 cr)</option>
            </select>
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-2">Number of tasks per month</label>
            <input
              type="range"
              id="calc-tasks"
              min="10"
              max="10000"
              step="10"
              value="500"
              class="w-full accent-violet-500"
            />
            <div class="flex justify-between text-xs text-gray-500 mt-1">
              <span>10</span>
              <span id="calc-tasks-val" class="text-violet-300 font-medium">500</span>
              <span>10,000</span>
            </div>
          </div>
        </div>

        <!-- Result -->
        <div class="flex flex-col justify-center bg-gray-800/50 rounded-xl p-6 border border-gray-700">
          <div class="text-xs text-gray-500 uppercase tracking-wider mb-1">Estimated monthly cost</div>
          <div class="text-5xl font-bold text-violet-300 mb-1" id="calc-result">$5.00</div>
          <div class="text-sm text-gray-400 mb-4" id="calc-credits">500 credits needed</div>
          <div class="text-xs text-gray-500" id="calc-plan">Covered by Starter plan ($10/mo)</div>
          <a href="/pricing" class="mt-4 text-sm text-violet-400 hover:text-violet-300 transition-colors">
            See all plans →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Comparison -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <h2 class="text-2xl font-bold text-center mb-10 text-gray-300">Why CrowdSorcerer?</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-800">
            <th class="text-left px-4 py-3 text-gray-400 font-medium w-1/3">Feature</th>
            <th class="text-center px-4 py-3 font-semibold text-violet-300">CrowdSorcerer</th>
            <th class="text-center px-4 py-3 text-gray-500">DIY Integration</th>
            <th class="text-center px-4 py-3 text-gray-500">Zapier/n8n</th>
          </tr>
        </thead>
        <tbody>
          {[
            ["10+ AI task types, one API", "✅", "❌ Build each", "⚠️ Limited"],
            ["Human-in-the-loop workforce", "✅", "❌", "❌"],
            ["Task pipelines & chaining", "✅", "❌ Custom code", "⚠️ Basic"],
            ["Real-time webhooks", "✅", "⚠️ DIY", "✅"],
            ["Credits system (pay per task)", "✅", "❌ Per-provider billing", "⚠️ Subscription"],
            ["Worker reputation + quality control", "✅", "❌", "❌"],
            ["Python + TypeScript SDKs", "✅", "❌", "⚠️ Limited"],
            ["Setup time", "⚡ Minutes", "🕒 Weeks", "🕐 Hours"],
          ].map(([feature, us, diy, zap], i) => (
            <tr class:list={["border-b border-gray-800/50", i % 2 === 0 ? "" : "bg-gray-900/30"]}>
              <td class="px-4 py-3 text-gray-300">{feature}</td>
              <td class="px-4 py-3 text-center font-medium text-green-400">{us}</td>
              <td class="px-4 py-3 text-center text-gray-500">{diy}</td>
              <td class="px-4 py-3 text-center text-gray-500">{zap}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Social Proof -->
  <section class="max-w-5xl mx-auto px-6 pb-24">
    <!-- Stats bar -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      {[
        { value: "10+", label: "Task types" },
        { value: "18", label: "AI & human worker types" },
        { value: "1¢", label: "Per LLM task" },
        { value: "100%", label: "API-first" },
      ].map(({ value, label }) => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 text-center">
          <div class="text-3xl font-bold text-violet-300 mb-1">{value}</div>
          <div class="text-sm text-gray-400">{label}</div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center bg-gradient-to-br from-violet-950/50 to-gray-950 border border-violet-800/40 rounded-2xl p-12">
      <div class="text-4xl mb-4">🔮</div>
      <h2 class="text-3xl font-bold mb-4">Ready to conjure results?</h2>
      <p class="text-gray-400 mb-8 max-w-lg mx-auto">
        Start with 100 free credits. No credit card required.
        Scale from prototype to production with one API.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/register"
          class="px-8 py-3 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold transition-colors"
        >
          Start free
        </a>
        <a
          href="/docs/api-reference"
          class="px-8 py-3 rounded-xl border border-gray-700 hover:border-gray-500 text-gray-300 font-semibold transition-colors"
        >
          API Reference
        </a>
      </div>
    </div>
  </section>

  <script>
    const typeEl = document.getElementById("calc-type") as HTMLSelectElement;
    const tasksEl = document.getElementById("calc-tasks") as HTMLInputElement;
    const tasksValEl = document.getElementById("calc-tasks-val")!;
    const resultEl = document.getElementById("calc-result")!;
    const creditsEl = document.getElementById("calc-credits")!;
    const planEl = document.getElementById("calc-plan")!;

    function update() {
      const creditPerTask = Number(typeEl?.value ?? 1);
      const taskCount = Number(tasksEl?.value ?? 500);
      const totalCredits = creditPerTask * taskCount;
      const usd = totalCredits / 100;

      tasksValEl.textContent = taskCount.toLocaleString();
      resultEl.textContent = `$${usd.toFixed(2)}`;
      creditsEl.textContent = `${totalCredits.toLocaleString()} credits needed`;

      let planText = "";
      if (totalCredits <= 100) planText = "Covered by Free plan";
      else if (totalCredits <= 1000) planText = "Covered by Starter plan ($10/mo)";
      else if (totalCredits <= 10000) planText = "Covered by Pro plan ($90/mo — 10% savings)";
      else planText = "Contact us for Enterprise pricing";
      planEl.textContent = planText;
    }

    typeEl?.addEventListener("change", update);
    tasksEl?.addEventListener("input", update);
    update();
  </script>
</Layout>
