---
import Layout from "@/layouts/Layout.astro";
import { CONTACT_EMAIL, mailto } from "@/lib/contact";

const HUMAN_TASKS = [
  { type: "label_text",          icon: "🏷️", label: "Label Text",        desc: "Sentiment, categories, spam detection" },
  { type: "label_image",         icon: "🖼️", label: "Label Image",       desc: "Bounding boxes, object tags, content flags" },
  { type: "rate_quality",        icon: "⭐", label: "Rate Quality",      desc: "Score AI output on a 1–5 or custom scale" },
  { type: "verify_fact",         icon: "✅", label: "Verify Fact",       desc: "Check a claim against sources" },
  { type: "moderate_content",    icon: "🛡️", label: "Moderate",          desc: "Approve, reject, or escalate user content" },
  { type: "compare_rank",        icon: "📊", label: "Compare & Rank",    desc: "Pick A vs B on any criterion" },
  { type: "answer_question",     icon: "💬", label: "Answer Question",   desc: "Open-ended Q&A with optional context" },
  { type: "transcription_review",icon: "📝", label: "Review Transcript", desc: "Correct an AI-generated transcript" },
];
---

<Layout title="CrowdSorcerer — A human work API" description="Post labeling, moderation, ranking, and QA tasks. Real workers claim them, submit results, and you pull structured JSON. Pay per task in credits. Hybrid human+AI pipelines included.">
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-24 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-violet-800 bg-violet-950/50 text-violet-300 text-sm mb-8">
      <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
      Closed beta — launching soon
    </div>

    <h1 class="text-5xl sm:text-6xl font-bold tracking-tight mb-6">
      A REST API for<br />
      <span class="text-violet-400">human work.</span>
    </h1>

    <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-4">
      Post a task. A real worker claims it, does the work, and submits a
      structured answer. You get it back as typed JSON or a webhook.
      Label, moderate, rank, verify, review — same flow every time.
    </p>
    <p class="text-sm text-gray-500 max-w-xl mx-auto mb-10">
      Need an LLM summary or a PDF parse in between two human steps?
      Chain them as a pipeline. One balance, one audit trail, one webhook.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href="/docs"
        class="px-6 py-3 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold transition-colors"
      >
        Read the docs
      </a>
      <a
        href="/pricing"
        class="px-6 py-3 rounded-xl border border-gray-700 hover:border-gray-500 text-gray-300 font-semibold transition-colors"
      >
        See pricing
      </a>
    </div>
  </section>

  <!-- How it works -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <h2 class="text-2xl font-bold text-center mb-12 text-gray-300">How it works</h2>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="w-14 h-14 rounded-2xl bg-violet-950/60 border border-violet-800/50 flex items-center justify-center text-2xl mx-auto mb-4">1</div>
        <h3 class="text-lg font-semibold text-gray-200 mb-2">Post a task</h3>
        <p class="text-gray-400 text-sm">POST to <code class="text-violet-400 text-xs">/v1/tasks</code> with the task type, the input, and how many workers should touch it. Credits are reserved up front.</p>
      </div>
      <div class="text-center">
        <div class="w-14 h-14 rounded-2xl bg-violet-950/60 border border-violet-800/50 flex items-center justify-center text-2xl mx-auto mb-4">2</div>
        <h3 class="text-lg font-semibold text-gray-200 mb-2">A worker claims it</h3>
        <p class="text-gray-400 text-sm">The task shows up in the worker marketplace. A skill-matched worker claims it, does the work, and submits a structured answer within the timeout you set.</p>
      </div>
      <div class="text-center">
        <div class="w-14 h-14 rounded-2xl bg-violet-950/60 border border-violet-800/50 flex items-center justify-center text-2xl mx-auto mb-4">3</div>
        <h3 class="text-lg font-semibold text-gray-200 mb-2">Get structured results</h3>
        <p class="text-gray-400 text-sm">Poll for completion, or receive a webhook. Every submission is typed JSON — ready for your downstream pipeline. Failed tasks auto-refund.</p>
      </div>
    </div>
  </section>

  <!-- Task types grid -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <h2 class="text-2xl font-bold text-center mb-3 text-gray-300">Eight task types. One endpoint.</h2>
    <p class="text-gray-500 text-sm text-center mb-10">Each task type has a strict input schema and a matching worker response schema — so you never have to parse free-text.</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {HUMAN_TASKS.map(({ icon, label, desc }) => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 hover:border-violet-800 transition-colors">
          <div class="text-2xl mb-2">{icon}</div>
          <div class="text-sm font-medium text-gray-200">{label}</div>
          <div class="text-xs text-gray-500 mt-1">{desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Code example -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="grid md:grid-cols-2 gap-8 items-center">
      <div>
        <h2 class="text-3xl font-bold mb-4">A few lines to your first task.</h2>
        <p class="text-gray-400 mb-4">
          Install the SDK. Create a client. Post a task.
          The SDK polls until the worker submits — or you subscribe to a webhook and move on.
        </p>
        <ul class="text-gray-400 text-sm space-y-2 mb-6">
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> TypeScript + Python SDKs</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Webhook delivery with HMAC signatures</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Pipelines — chain human steps with LLM / parse / exec primitives</li>
          <li class="flex items-start gap-2"><span class="text-emerald-400 mt-0.5">✓</span> Org-level billing, API keys, and RBAC</li>
        </ul>
        <a href="/docs" class="text-violet-400 hover:text-violet-300 font-medium">
          Read the full docs →
        </a>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 font-mono text-sm overflow-x-auto">
        <pre class="text-gray-300"><span class="text-violet-400">import</span> {"{ CrowdSorcerer }"} <span class="text-violet-400">from</span> <span class="text-green-400">"@crowdsourcerer/sdk"</span>;

<span class="text-violet-400">const</span> crowd = <span class="text-violet-400">new</span> <span class="text-yellow-400">CrowdSorcerer</span>({"{"}<span class="text-orange-400"> apiKey</span>: <span class="text-green-400">"csk_..."</span> {"}"});

<span class="text-gray-500">// Ask workers to classify a review</span>
<span class="text-violet-400">const</span> task = <span class="text-violet-400">await</span> crowd.<span class="text-yellow-400">runTask</span>({"{"}<span class="text-orange-400">
  type</span>: <span class="text-green-400">"label_text"</span>,<span class="text-orange-400">
  input</span>: {"{"}<span class="text-orange-400">
    text</span>: <span class="text-green-400">"The new iPhone is great!"</span>,<span class="text-orange-400">
    categories</span>: [<span class="text-green-400">"positive"</span>, <span class="text-green-400">"negative"</span>],<span class="text-orange-400">
    question</span>: <span class="text-green-400">"Sentiment?"</span>,
  {"}"},<span class="text-orange-400">
  assignments_required</span>: <span class="text-orange-400">3</span>,
{"}"});

console.<span class="text-yellow-400">log</span>(task.output.summary);
<span class="text-gray-500">// → "positive (3/3 workers agree)"</span></pre>
      </div>
    </div>
  </section>

  <!-- For Workers — gamification differentiator -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="bg-gradient-to-br from-emerald-950/30 to-gray-950 border border-emerald-800/30 rounded-2xl p-8 md:p-10">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-emerald-800 bg-emerald-950/50 text-emerald-300 text-xs mb-4">
            For workers
          </div>
          <h2 class="text-3xl font-bold mb-4">Earn credits.<br /><span class="text-emerald-400">Level up.</span></h2>
          <p class="text-gray-400 mb-4">
            CrowdSorcerer isn't just an API — it's a marketplace.
            Complete labeling, moderation, and QA tasks to earn credits and climb the leaderboard.
          </p>
          <p class="text-gray-400 text-sm mb-6">
            Think Duolingo for data work: daily streaks, weekly leagues, quests, and badges
            keep you engaged while you build real skills.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/register" class="px-5 py-2.5 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white font-semibold text-sm transition-colors">
              Start earning →
            </a>
            <a href="/worker" class="px-5 py-2.5 rounded-xl border border-emerald-700 hover:border-emerald-500 text-emerald-300 font-semibold text-sm transition-colors">
              Learn more
            </a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          {[
            { icon: "🔥", label: "Daily Streaks", desc: "Keep your streak alive" },
            { icon: "🏆", label: "Weekly Leagues", desc: "Compete for promotion" },
            { icon: "🎯", label: "Quests", desc: "Complete weekly challenges" },
            { icon: "🏅", label: "Badges", desc: "Unlock achievements" },
          ].map(({ icon, label, desc }) => (
            <div class="bg-gray-900/60 border border-gray-800 rounded-xl p-4">
              <div class="text-2xl mb-2">{icon}</div>
              <div class="text-sm font-medium text-gray-200">{label}</div>
              <div class="text-xs text-gray-500 mt-1">{desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing preview -->
  <section class="max-w-5xl mx-auto px-6 pb-20 text-center">
    <h2 class="text-3xl font-bold mb-3">Pay per task</h2>
    <p class="text-gray-400 mb-10">No subscription. Buy credits once, spend them over time. $1 = 100 credits.</p>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 text-left">
        <div class="text-sm text-gray-500 mb-1">Starter</div>
        <div class="text-3xl font-bold mb-1">$10</div>
        <div class="text-violet-300 font-medium mb-3">1,000 credits</div>
        <div class="text-sm text-gray-500">For prototypes and small projects. ~300–500 labeling tasks at 3 assignments each.</div>
      </div>
      <div class="bg-gradient-to-br from-violet-950/60 to-gray-900 border-2 border-violet-600 rounded-xl p-6 text-left relative overflow-hidden">
        <div class="absolute top-3 right-3">
          <span class="text-[10px] font-bold uppercase tracking-widest bg-violet-600 text-white px-2 py-0.5 rounded-full">Most popular</span>
        </div>
        <div class="text-sm text-violet-400 font-semibold mb-1">Pro</div>
        <div class="text-3xl font-bold mb-1">$90</div>
        <div class="text-violet-300 font-medium mb-3">10,000 credits</div>
        <div class="text-sm text-gray-400 mb-4">10% volume discount. Production datasets and recurring pipelines.</div>
        <a href="/pricing" class="inline-block w-full text-center py-2.5 rounded-lg bg-violet-600 hover:bg-violet-500 text-white text-sm font-semibold transition-colors">
          See all plans →
        </a>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 text-left">
        <div class="text-sm text-gray-500 mb-1">Enterprise</div>
        <div class="text-3xl font-bold mb-1">Talk to us</div>
        <div class="text-violet-300 font-medium mb-3">Custom volume</div>
        <div class="text-sm text-gray-500">Dedicated workers, SLAs, private workforces, and procurement-friendly invoicing.</div>
      </div>
    </div>
  </section>

  <!-- Why CrowdSorcerer — honest comparison -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <h2 class="text-2xl font-bold text-center mb-3 text-gray-300">Why CrowdSorcerer over the alternatives</h2>
    <p class="text-gray-500 text-sm text-center mb-10 max-w-2xl mx-auto">You could wire up MTurk, stitch together a few Fiverr contractors, or build an internal tool. Here's what you get instead.</p>
    <div class="grid md:grid-cols-2 gap-6">
      {[
        {
          title: "Typed input → typed output",
          desc: "Every task type has a strict JSON schema both sides. No free-text parsing, no 'did they read the instructions?' debugging.",
          icon: "📐",
        },
        {
          title: "Pipelines, not one-off tasks",
          desc: "Chain human steps with LLM summarization, PDF parsing, and code execution. One API, one credit balance, one audit trail.",
          icon: "🔀",
        },
        {
          title: "Built-in quality control",
          desc: "Gold-standard checks, consensus across N workers, automatic disagreement review, per-worker reputation scores.",
          icon: "✅",
        },
        {
          title: "Skill certification + gamification",
          desc: "Workers level up through tiered certs, unlock higher-paying tasks, and stay engaged through leagues, quests, and streaks.",
          icon: "🎯",
        },
        {
          title: "Credits, not subscriptions",
          desc: "Pay per assignment. Scale to zero when you're not running a batch. No seat fees, no 'enterprise sales call to get a quote'.",
          icon: "💰",
        },
        {
          title: "Typed SDKs + webhooks",
          desc: "TypeScript and Python SDKs with full autocomplete. HMAC-signed webhooks with replay protection. Org-level API keys with scopes.",
          icon: "🔧",
        },
      ].map(({ title, desc, icon }) => (
        <div class="flex gap-4 p-4 rounded-xl bg-gray-900/50 border border-gray-800/50">
          <div class="text-2xl flex-shrink-0">{icon}</div>
          <div>
            <h3 class="text-sm font-semibold text-gray-200 mb-1">{title}</h3>
            <p class="text-sm text-gray-500">{desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Stats -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {[
        { value: "8", label: "Human task types" },
        { value: "3", label: "Consensus strategies" },
        { value: "1¢", label: "Cheapest assignment" },
        { value: "2", label: "SDKs (TS + Python)" },
      ].map(({ value, label }) => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 text-center">
          <div class="text-3xl font-bold text-violet-300 mb-1">{value}</div>
          <div class="text-sm text-gray-400">{label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Final CTA -->
  <section class="max-w-5xl mx-auto px-6 pb-24">
    <div class="text-center bg-gradient-to-br from-violet-950/50 to-gray-950 border border-violet-800/40 rounded-2xl p-12">
      <h2 class="text-3xl font-bold mb-4">Closed beta.</h2>
      <p class="text-gray-400 mb-8 max-w-lg mx-auto">
        We're onboarding a small cohort before the public launch. Email us with what you want to build and we'll get you an account.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href={mailto(CONTACT_EMAIL, "CrowdSorcerer early access")}
          class="px-8 py-3 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold transition-colors"
        >
          Request early access
        </a>
        <a
          href="/docs"
          class="px-8 py-3 rounded-xl border border-gray-700 hover:border-gray-500 text-gray-300 font-semibold transition-colors"
        >
          Read the docs
        </a>
      </div>
    </div>
  </section>

</Layout>
