      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 text-left">
        <div class="text-sm text-gray-500 mb-1">Starter</div>
        <div class="text-3xl font-bold mb-1">$10</div>
        <div class="text-violet-300 font-medium mb-3">1,000 credits</div>
