---
import Layout from "@/layouts/Layout.astro";
import { TASK_CREDITS } from "@crowdsourcerer/types";

function taskIcon(type: string): string {
  const icons: Record<string, string> = {
    web_research: "🌐", entity_lookup: "🏢", document_parse: "📄",
    data_transform: "🔄", llm_generate: "🤖", screenshot: "📸",
    audio_transcribe: "🎙️", pii_detect: "🔒", code_execute: "⚡",
    web_intel: "🕵️",
  };
  return icons[type] ?? "🔮";
}

function taskLabel(type: string): string {
  const labels: Record<string, string> = {
    web_research: "Web Research", entity_lookup: "Entity Lookup",
    document_parse: "Doc Parse", data_transform: "Data Transform",
    llm_generate: "LLM Generate", screenshot: "Screenshot",
    audio_transcribe: "Transcribe", pii_detect: "PII Detect",
    code_execute: "Code Execute", web_intel: "Web Intel",
  };
  return labels[type] ?? type;
}
---

<Layout title="CrowdSorcerer — AI-Powered Task API" description="One API for web research, entity lookup, document parsing, code execution, and 6 more task types. Plus a gamified human workforce for labeling and QA. Start free.">
