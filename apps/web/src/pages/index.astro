---
import Layout from "@/layouts/Layout.astro";
import { TASK_CREDITS } from "@crowdsourcerer/types";

function taskIcon(type: string): string {
  const icons: Record<string, string> = {
    web_research: "🌐",
    entity_lookup: "🏢",
    document_parse: "📄",
    data_transform: "🔄",
    llm_generate: "🤖",
    screenshot: "📸",
    audio_transcribe: "🎙️",
    pii_detect: "🔒",
    code_execute: "⚡",
    web_intel: "🕵️",
  };
  return icons[type] ?? "🔮";
}

function taskLabel(type: string): string {
  const labels: Record<string, string> = {
    web_research: "Web Research",
    entity_lookup: "Entity Lookup",
    document_parse: "Doc Parse",
    data_transform: "Data Transform",
    llm_generate: "LLM Generate",
    screenshot: "Screenshot",
    audio_transcribe: "Transcribe",
    pii_detect: "PII Detect",
    code_execute: "Code Execute",
    web_intel: "Web Intel",
  };
  return labels[type] ?? type;
}
---

<Layout title="CrowdSorcerer — AI Task Platform">
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 py-24 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-violet-800 bg-violet-950/50 text-violet-300 text-sm mb-8">
      <span class="w-2 h-2 rounded-full bg-violet-400 animate-pulse"></span>
      Powered by RebaseKit · 10 AI worker types
    </div>

    <h1 class="text-5xl sm:text-6xl font-bold tracking-tight mb-6">
      Submit any task.<br />
      <span class="text-violet-400">We conjure the result.</span>
    </h1>

    <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10">
      CrowdSorcerer routes your tasks to the right AI workers — web research,
      entity lookups, document parsing, code execution, and more.
      No API juggling. Just results.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href="/register"
        class="px-6 py-3 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold transition-colors"
      >
        Start free — 100 credits
      </a>
      <a
        href="/tasks"
        class="px-6 py-3 rounded-xl border border-violet-700 hover:border-violet-500 text-violet-300 font-semibold transition-colors"
      >
        Browse open tasks →
      </a>
      <a
        href="/docs"
        class="px-6 py-3 rounded-xl border border-gray-700 hover:border-gray-500 text-gray-300 font-semibold transition-colors"
      >
        View docs
      </a>
    </div>
  </section>

  <!-- Interactive API Demo -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="text-center mb-8">
      <h2 class="text-2xl font-bold text-gray-200 mb-2">See it in action</h2>
      <p class="text-gray-400 text-sm">Submit a task. Get results. Pick your scenario:</p>
    </div>

    <!-- Demo terminal window -->
    <div class="rounded-2xl overflow-hidden border border-gray-700 bg-gray-900 shadow-2xl">
      <!-- Window chrome -->
      <div class="flex items-center gap-2 px-4 py-3 bg-gray-800/80 border-b border-gray-700">
        <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
        <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
        <span class="ml-3 text-xs text-gray-500 font-mono">CrowdSorcerer API</span>
        <!-- Scenario tabs -->
        <div class="ml-auto flex gap-1">
          <button class="demo-tab active-tab px-3 py-1 rounded text-xs font-medium transition-colors" data-demo="0">🌐 Web Research</button>
          <button class="demo-tab px-3 py-1 rounded text-xs font-medium transition-colors" data-demo="1">🤖 LLM Generate</button>
          <button class="demo-tab px-3 py-1 rounded text-xs font-medium transition-colors" data-demo="2">🏢 Entity Lookup</button>
        </div>
      </div>

      <!-- Split pane: request + response -->
      <div class="grid md:grid-cols-2 gap-0 divide-y md:divide-y-0 md:divide-x divide-gray-800">
        <!-- Request pane -->
        <div class="p-5">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-[10px] font-bold uppercase tracking-widest text-violet-400 bg-violet-950/40 border border-violet-800/50 px-2 py-0.5 rounded">POST</span>
            <span class="text-xs text-gray-500 font-mono">/v1/tasks</span>
          </div>
          <pre id="demo-request" class="text-sm font-mono text-gray-300 leading-relaxed overflow-x-auto whitespace-pre-wrap min-h-[160px]"></pre>
        </div>

        <!-- Response pane -->
        <div class="p-5">
          <div class="flex items-center gap-2 mb-3">
            <span id="demo-status-badge" class="text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded border text-gray-400 bg-gray-800 border-gray-700">Waiting…</span>
            <span id="demo-status-label" class="text-xs text-gray-500">Submit a task to see results</span>
          </div>
          <pre id="demo-response" class="text-sm font-mono text-gray-500 leading-relaxed overflow-x-auto whitespace-pre-wrap min-h-[160px]"></pre>
        </div>
      </div>

      <!-- Progress bar + action -->
      <div class="px-5 py-4 bg-gray-950/50 border-t border-gray-800 flex items-center justify-between gap-4">
        <div class="flex-1 bg-gray-800 rounded-full h-1.5 overflow-hidden">
          <div id="demo-progress" class="h-full bg-violet-500 rounded-full transition-all duration-300" style="width: 0%"></div>
        </div>
        <button id="demo-run-btn" class="flex-shrink-0 px-4 py-1.5 bg-violet-600 hover:bg-violet-500 text-white text-xs font-semibold rounded-lg transition-colors">
          ▶ Run demo
        </button>
      </div>
    </div>
  </section>

  <!-- Task types grid -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <h2 class="text-2xl font-bold text-center mb-10 text-gray-300">10 task types. One API.</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      {Object.entries(TASK_CREDITS).map(([type, credits]) => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 hover:border-violet-800 transition-colors">
          <div class="text-2xl mb-2">{taskIcon(type)}</div>
          <div class="text-sm font-medium text-gray-200">{taskLabel(type)}</div>
          <div class="text-xs text-gray-500 mt-1">{credits} credits</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Code example -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="grid md:grid-cols-2 gap-8 items-center">
      <div>
        <h2 class="text-3xl font-bold mb-4">Simple API. Powerful results.</h2>
        <p class="text-gray-400 mb-6">
