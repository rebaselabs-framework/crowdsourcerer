          icon: "🤝",
        },
        {
          title: "Built-in quality control",
          desc: "Worker reputation scores, consensus checks, and automatic re-routing on failures.",
          icon: "✅",
        },
        {
          title: "Credits, not subscriptions",
          desc: "Pay per task, not per seat or per month. Scale to zero when you're not using it.",
          icon: "💰",
        },
        {
          title: "Typed SDKs + webhooks",
          desc: "TypeScript and Python SDKs with full autocomplete. HMAC-signed webhook delivery.",
          icon: "🔧",
        },
      ].map(({ title, desc, icon }) => (
        <div class="flex gap-4 p-4 rounded-xl bg-gray-900/50 border border-gray-800/50">
          <div class="text-2xl flex-shrink-0">{icon}</div>
