  </section>

  <!-- Open source + transparency -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {[
        { value: "10", label: "AI task types" },
        { value: "8", label: "Human task types" },
        { value: "1¢", label: "Cheapest task" },
        { value: "2", label: "SDKs (TS + Python)" },
