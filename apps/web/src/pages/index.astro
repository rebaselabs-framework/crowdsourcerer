        <div class="text-violet-300 font-medium mb-3">10,000 credits</div>
        <div class="text-sm text-gray-500">10% volume discount. Production-ready.</div>
      </div>
    </div>
  </section>

  <!-- Pricing Calculator -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
