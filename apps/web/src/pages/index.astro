          </div>
        </div>

        <!-- Result -->
        <div class="flex flex-col justify-center bg-gray-800/50 rounded-xl p-6 border border-gray-700">
          <div class="text-xs text-gray-500 uppercase tracking-wider mb-1">Estimated monthly cost</div>
          <div class="text-5xl font-bold text-violet-300 mb-1" id="calc-result">$5.00</div>
          <div class="text-sm text-gray-400 mb-4" id="calc-credits">500 credits needed</div>
          <div class="text-xs text-gray-500" id="calc-plan">Covered by Starter plan ($10/mo)</div>
          <a href="/pricing" class="mt-4 text-sm text-violet-400 hover:text-violet-300 transition-colors">
            See all plans →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Comparison -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <h2 class="text-2xl font-bold text-center mb-10 text-gray-300">Why CrowdSorcerer?</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-800">
            <th class="text-left px-4 py-3 text-gray-400 font-medium w-1/3">Feature</th>
            <th class="text-center px-4 py-3 font-semibold text-violet-300">CrowdSorcerer</th>
            <th class="text-center px-4 py-3 text-gray-500">DIY Integration</th>
            <th class="text-center px-4 py-3 text-gray-500">Zapier/n8n</th>
          </tr>
        </thead>
        <tbody>
          {[
            ["10+ AI task types, one API", "✅", "❌ Build each", "⚠️ Limited"],
            ["Human-in-the-loop workforce", "✅", "❌", "❌"],
            ["Task pipelines & chaining", "✅", "❌ Custom code", "⚠️ Basic"],
            ["Real-time webhooks", "✅", "⚠️ DIY", "✅"],
            ["Credits system (pay per task)", "✅", "❌ Per-provider billing", "⚠️ Subscription"],
            ["Worker reputation + quality control", "✅", "❌", "❌"],
            ["Python + TypeScript SDKs", "✅", "❌", "⚠️ Limited"],
            ["Setup time", "⚡ Minutes", "🕒 Weeks", "🕐 Hours"],
          ].map(([feature, us, diy, zap], i) => (
            <tr class:list={["border-b border-gray-800/50", i % 2 === 0 ? "" : "bg-gray-900/30"]}>
              <td class="px-4 py-3 text-gray-300">{feature}</td>
              <td class="px-4 py-3 text-center font-medium text-green-400">{us}</td>
              <td class="px-4 py-3 text-center text-gray-500">{diy}</td>
              <td class="px-4 py-3 text-center text-gray-500">{zap}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <h2 class="text-2xl font-bold text-center mb-3 text-gray-200">What people are saying</h2>
    <p class="text-center text-gray-500 text-sm mb-10">Trusted by ML teams and freelancers alike</p>
    <div class="grid md:grid-cols-3 gap-6">
      {[
        {
          quote: "CrowdSorcerer cut our data labeling costs by 60%. The quality control system is incredible.",
          name: "Sarah K.",
          role: "ML Engineer at TechCorp",
          avatar: "SK",
          color: "violet",
        },
        {
          quote: "I've earned over $800 in my first month completing tasks in my spare time. Highly recommend!",
          name: "Marcus T.",
          role: "Freelance Worker",
          avatar: "MT",
          color: "emerald",
        },
        {
          quote: "The pipeline feature lets us chain AI and human tasks seamlessly. Game changer for our workflow.",
          name: "David L.",
          role: "Product Manager",
          avatar: "DL",
          color: "blue",
        },
      ].map(({ quote, name, role, avatar, color }) => (
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 flex flex-col gap-4">
          <div class="text-2xl text-gray-600 leading-none">&ldquo;</div>
          <p class="text-gray-300 text-sm leading-relaxed flex-1">{quote}</p>
          <div class="flex items-center gap-3 pt-2 border-t border-gray-800">
            <div class:list={[
              "w-9 h-9 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0",
              color === "violet" ? "bg-violet-900/60 text-violet-300" :
              color === "emerald" ? "bg-emerald-900/60 text-emerald-300" :
              "bg-blue-900/60 text-blue-300"
            ]}>
              {avatar}
            </div>
            <div>
              <div class="text-sm font-semibold text-gray-200">{name}</div>
              <div class="text-xs text-gray-500">{role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Social Proof -->
  <section class="max-w-5xl mx-auto px-6 pb-24">
    <!-- Stats bar -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      {[
        { value: "10+", label: "Task types" },
        { value: "18", label: "AI & human worker types" },
        { value: "1¢", label: "Per LLM task" },
        { value: "100%", label: "API-first" },
      ].map(({ value, label }) => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 text-center">
          <div class="text-3xl font-bold text-violet-300 mb-1">{value}</div>
          <div class="text-sm text-gray-400">{label}</div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center bg-gradient-to-br from-violet-950/50 to-gray-950 border border-violet-800/40 rounded-2xl p-12">
      <div class="text-4xl mb-4">🔮</div>
      <h2 class="text-3xl font-bold mb-4">Ready to conjure results?</h2>
      <p class="text-gray-400 mb-8 max-w-lg mx-auto">
        Start with 100 free credits. No credit card required.
        Scale from prototype to production with one API.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/register"
          class="px-8 py-3 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold transition-colors"
        >
          Start free — 100 credits, no credit card required
        </a>
        <a
          href="/docs/api-reference"
          class="px-8 py-3 rounded-xl border border-gray-700 hover:border-gray-500 text-gray-300 font-semibold transition-colors"
        >
          API Reference
        </a>
      </div>
    </div>
  </section>

  <script>
    const typeEl = document.getElementById("calc-type") as HTMLSelectElement;
    const tasksEl = document.getElementById("calc-tasks") as HTMLInputElement;
    const tasksValEl = document.getElementById("calc-tasks-val")!;
    const resultEl = document.getElementById("calc-result")!;
    const creditsEl = document.getElementById("calc-credits")!;
    const planEl = document.getElementById("calc-plan")!;

    function update() {
      const creditPerTask = Number(typeEl?.value ?? 1);
      const taskCount = Number(tasksEl?.value ?? 500);
      const totalCredits = creditPerTask * taskCount;
      const usd = totalCredits / 100;

      tasksValEl.textContent = taskCount.toLocaleString();
      resultEl.textContent = `$${usd.toFixed(2)}`;
      creditsEl.textContent = `${totalCredits.toLocaleString()} credits needed`;

      let planText = "";
      if (totalCredits <= 100) planText = "Covered by Free plan";
      else if (totalCredits <= 1000) planText = "Covered by Starter plan ($10/mo)";
      else if (totalCredits <= 10000) planText = "Covered by Pro plan ($90/mo — 10% savings)";
      else planText = "Contact us for Enterprise pricing";
      planEl.textContent = planText;
    }

    typeEl?.addEventListener("change", update);
    tasksEl?.addEventListener("input", update);
    update();
  </script>

  <script>
    // ── Interactive API Demo ──────────────────────────────────────────────────
    const DEMOS = [
      {
        request: `{
  "type": "web_research",
  "input": {
    "url": "https://news.ycombinator.com",
    "instruction": "List the top 5 story titles"
  },
  "priority": "normal"
}`,
        response: `{
  "id": "task_8f3a2c1d",
  "status": "completed",
  "type": "web_research",
  "output": {
    "summary": "Hacker News front page features stories
about AI safety research, a new Rust HTTP
library, PostgreSQL 17 benchmarks, and a
discussion on distributed systems.",
    "key_facts": [
      "Top story: AI alignment paper by Anthropic",
      "PostgreSQL 17 shows 40% query speedup",
      "New Rust async HTTP client: 2M req/sec"
    ],
    "sources": ["https://news.ycombinator.com"]
  },
  "credits_used": 10,
  "completed_at": "2026-03-24T14:02:11Z"
}`,
      },
      {
        request: `{
  "type": "llm_generate",
  "input": {
    "messages": [{
      "role": "user",
      "content": "Write 3 taglines for a
crowdsourcing + AI task API platform"
    }],
    "model": "claude-3-5-haiku-20241022"
  }
}`,
        response: `{
  "id": "task_2e9b1f4a",
  "status": "completed",
  "type": "llm_generate",
  "output": {
    "text": "**1.** Route any task. Get results instantly.

**2.** 10 AI workers. One API. Zero setup.

**3.** From prompt to production — in minutes,
not months.",
    "model": "claude-3-5-haiku-20241022",
    "tokens": 84
  },
  "credits_used": 1,
  "completed_at": "2026-03-24T14:02:04Z"
}`,
      },
      {
        request: `{
  "type": "entity_lookup",
  "input": {
    "entity_type": "company",
    "domain": "stripe.com",
    "enrich_fields": [
      "description",
      "headcount",
      "funding"
    ]
  }
}`,
        response: `{
  "id": "task_7c4d8e2b",
  "status": "completed",
  "type": "entity_lookup",
  "output": {
    "name": "Stripe",
    "description": "Online payment processing
for internet businesses.",
    "headcount": "~8,000 employees",
    "funding": "$2.2B raised",
    "founded": 2010,
    "hq": "South San Francisco, CA"
  },
  "credits_used": 5,
  "completed_at": "2026-03-24T14:02:07Z"
}`,
      },
    ];

    let currentDemo = 0;
    let running = false;

    const reqEl    = document.getElementById("demo-request");
    const resEl    = document.getElementById("demo-response");
    const progEl   = document.getElementById("demo-progress") as HTMLElement | null;
    const statusBadge = document.getElementById("demo-status-badge");
    const statusLabel = document.getElementById("demo-status-label");
    const runBtn   = document.getElementById("demo-run-btn") as HTMLButtonElement | null;
    const tabs     = document.querySelectorAll(".demo-tab");

    function setTab(idx: number) {
      currentDemo = idx;
      tabs.forEach((t, i) => {
        if (i === idx) {
          t.classList.add("active-tab");
        } else {
          t.classList.remove("active-tab");
        }
      });
      // Reset display
      if (reqEl) reqEl.textContent = DEMOS[idx].request;
      if (resEl) { resEl.textContent = ""; resEl.classList.add("text-gray-500"); resEl.classList.remove("text-green-300"); }
      setStatus("idle", "Click ▶ Run demo to execute");
      if (progEl) progEl.style.width = "0%";
    }

    function setStatus(state: string, label: string) {
      if (!statusBadge || !statusLabel) return;
      statusLabel.textContent = label;
      if (state === "idle") {
        statusBadge.textContent = "Ready";
        statusBadge.className = "text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded border text-gray-400 bg-gray-800 border-gray-700";
      } else if (state === "running") {
        statusBadge.textContent = "Processing";
        statusBadge.className = "text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded border text-yellow-300 bg-yellow-950/40 border-yellow-800/50 animate-pulse";
      } else if (state === "done") {
        statusBadge.textContent = "200 OK";
        statusBadge.className = "text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded border text-green-300 bg-green-950/40 border-green-800/50";
      }
    }

    async function runDemo() {
      if (running) return;
      running = true;
      if (runBtn) { runBtn.textContent = "⏳ Running…"; runBtn.disabled = true; }

      const demo = DEMOS[currentDemo];
      if (reqEl) reqEl.textContent = demo.request;
      if (resEl) { resEl.textContent = ""; resEl.classList.remove("text-green-300"); resEl.classList.add("text-gray-500"); }
      setStatus("running", "Routing task to AI worker…");

      // Animate progress bar from 0 → 85%
      if (progEl) progEl.style.width = "0%";
      await new Promise(r => setTimeout(r, 50));
      if (progEl) { progEl.style.transition = "width 1.4s ease-out"; progEl.style.width = "85%"; }

      await new Promise(r => setTimeout(r, 1500));
      setStatus("running", "Worker processing…");
      await new Promise(r => setTimeout(r, 900));

      // Complete: flash to 100%
      if (progEl) { progEl.style.transition = "width 0.25s ease-out"; progEl.style.width = "100%"; }
      setStatus("done", "Task completed ✓");

      // Type out the response
      if (resEl) {
        const outputEl = resEl;
        outputEl.classList.remove("text-gray-500");
        outputEl.classList.add("text-green-300");
        const text = demo.response;
        let i = 0;
        function typeNext() {
          if (i < text.length) {
            outputEl.textContent += text[i++];
            setTimeout(typeNext, i < 50 ? 12 : 4);
          } else {
            running = false;
            if (runBtn) { runBtn.textContent = "▶ Run again"; runBtn.disabled = false; }
            if (progEl) setTimeout(() => { progEl.style.transition = "width 0.6s"; progEl.style.width = "0%"; }, 2000);
          }
        }
        typeNext();
      }
    }

    // Tab clicks
    tabs.forEach((tab, i) => {
      tab.addEventListener("click", () => {
        if (!running) setTab(i);
      });
    });

    // Run button
    runBtn?.addEventListener("click", runDemo);

    // Init
    setTab(0);

    // Auto-run once after 1.5s to grab attention
    setTimeout(() => { if (!running) runDemo(); }, 1500);
  </script>

  <style is:global>
    .demo-tab {
      background: transparent;
      color: #6b7280;
      border: 1px solid transparent;
    }
    .demo-tab:hover {
      color: #d1d5db;
      background: #1f2937;
    }
    .demo-tab.active-tab {
      background: #1f2937;
      color: #e5e7eb;
      border-color: #374151;
    }
  </style>
</Layout>
