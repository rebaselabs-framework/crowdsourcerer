---
import Layout from "@/layouts/Layout.astro";
import { CONTACT_EMAIL, mailto } from "@/lib/contact";

// Public registration is closed while we're in closed beta. This page
// used to render a full signup form with role selection, name/email/
// password fields, and Google OAuth buttons — but every path ended in
// a 403 at /v1/auth/register or /v1/auth/google because the REGISTRATION_ENABLED
// gate fires on both the direct and the OAuth new-user branch. Rather
// than letting prospects fill out a form and bounce on an error, we
// just tell them up front and point them at a mailto.
---

<Layout title="Request early access — CrowdSorcerer">
  <div class="min-h-screen flex items-center justify-center px-6 py-10">
    <div class="w-full max-w-md text-center">
      <div class="text-4xl mb-4">🔮</div>
      <h1 class="text-2xl font-bold mb-3">CrowdSorcerer is in closed beta</h1>
      <p class="text-gray-400 text-sm mb-8 leading-relaxed">
        We're onboarding early users one cohort at a time — small enough
        that each account gets real attention. Tell us what you want to
        build and we'll set you up with a scoped API key and credits.
      </p>

      <a
        href={mailto(CONTACT_EMAIL, "CrowdSorcerer early access")}
        class="inline-block w-full px-6 py-3 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold transition-colors mb-3"
      >
        Request early access
      </a>
      <p class="text-xs text-gray-500 mb-10">
        Or email <a href={mailto(CONTACT_EMAIL)} class="text-violet-400 hover:text-violet-300">{CONTACT_EMAIL}</a> directly
      </p>

      <div class="border-t border-gray-800 pt-6 space-y-3">
        <p class="text-sm text-gray-500">
          Already have an account?
          <a href="/login" class="text-violet-400 hover:text-violet-300 ml-1">Sign in →</a>
        </p>
        <p class="text-xs text-gray-600">
          Want to know what the product does first? <a href="/" class="text-gray-400 hover:text-gray-200">Back to the landing page →</a>
        </p>
      </div>
    </div>
  </div>
</Layout>
