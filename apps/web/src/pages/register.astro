---
import Layout from "@/layouts/Layout.astro";

let error = "";

// Read referral code from query string (GET) or form (POST)
const urlParams = new URL(Astro.request.url).searchParams;
const refCode = urlParams.get("ref") ?? "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const email = form.get("email") as string;
  const password = form.get("password") as string;
  const name = form.get("name") as string;
  const ref = (form.get("ref") as string) ?? "";
  const role = (form.get("role") as string) === "worker" ? "worker" : "requester";

  // Pass referral code as query param to the API
  const registerUrl = `${import.meta.env.PUBLIC_API_URL ?? "http://api:8100"}/v1/auth/register${ref ? `?ref=${encodeURIComponent(ref)}` : ""}`;

  try {
    const res = await fetch(registerUrl, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email, password, name, role }),
    });

    if (!res.ok) {
      const data = await res.json();
      error = data.detail ?? "Registration failed";
    } else {
      const { access_token } = await res.json();
      Astro.cookies.set("cs_token", access_token, {
        httpOnly: true,
        secure: true,
        sameSite: "lax",
        maxAge: 60 * 60 * 24 * 7,
        path: "/",
      });
      // Redirect to the appropriate onboarding flow
      return Astro.redirect(
        role === "worker" ? "/worker/onboarding" : "/dashboard/requester-onboarding"
      );
    }
  } catch (e) {
    error = "Network error — please try again";
  }
}
---

<Layout title="Register — CrowdSorcerer">
  <div class="min-h-screen flex items-center justify-center px-6 py-10">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <div class="text-4xl mb-3">🔮</div>
        <h1 class="text-2xl font-bold">Create your account</h1>
        <p class="text-gray-400 mt-1 text-sm">
          {refCode ? "You were invited!" : "Start with 100 free credits"}
        </p>
      </div>

      {refCode && (
        <div class="bg-emerald-900/30 border border-emerald-700/40 rounded-xl px-4 py-3 text-sm text-emerald-300 mb-6 flex items-center gap-2">
          <span>🎁</span>
          <span>Referral bonus: sign up now to get <strong>150 credits</strong> (50 bonus) to start.</span>
        </div>
      )}

      {error && (
        <div class="bg-red-950/50 border border-red-800 rounded-xl px-4 py-3 text-sm text-red-300 mb-6">
          {error}
        </div>
      )}

      <form method="POST" class="space-y-5">
        {refCode && <input type="hidden" name="ref" value={refCode} />}

        <!-- Role selection -->
        <div>
          <label class="block text-sm text-gray-400 mb-2">I want to…</label>
          <div class="grid grid-cols-2 gap-3" id="role-cards">
            <label class="relative cursor-pointer">
              <input type="radio" name="role" value="requester" class="sr-only peer" checked />
              <div class="peer-checked:border-violet-500 peer-checked:bg-violet-950/30 border border-gray-700 rounded-xl p-4 text-center hover:border-gray-500 transition-colors">
                <div class="text-2xl mb-1">📋</div>
                <div class="text-sm font-semibold text-gray-200">Hire Workers</div>
                <div class="text-xs text-gray-500 mt-0.5">Post tasks, get results</div>
              </div>
            </label>
            <label class="relative cursor-pointer">
              <input type="radio" name="role" value="worker" class="sr-only peer" />
              <div class="peer-checked:border-violet-500 peer-checked:bg-violet-950/30 border border-gray-700 rounded-xl p-4 text-center hover:border-gray-500 transition-colors">
                <div class="text-2xl mb-1">💼</div>
                <div class="text-sm font-semibold text-gray-200">Earn Credits</div>
                <div class="text-xs text-gray-500 mt-0.5">Complete tasks, get paid</div>
              </div>
            </label>
          </div>
        </div>

        <div>
          <label class="block text-sm text-gray-400 mb-1">Name <span class="text-gray-600">(optional)</span></label>
          <input
            name="name"
            type="text"
            class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2.5 text-gray-100 placeholder-gray-600 focus:outline-none focus:border-violet-500 transition-colors"
            placeholder="Your name"
          />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1">Email</label>
          <input
            name="email"
            type="email"
            required
            class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2.5 text-gray-100 placeholder-gray-600 focus:outline-none focus:border-violet-500 transition-colors"
            placeholder="you@example.com"
          />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1">Password</label>
          <input
            name="password"
            type="password"
            required
            minlength="8"
            class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2.5 text-gray-100 placeholder-gray-600 focus:outline-none focus:border-violet-500 transition-colors"
            placeholder="8+ characters"
          />
        </div>

        <button
          type="submit"
          class="w-full bg-violet-600 hover:bg-violet-500 text-white font-semibold py-3 rounded-lg transition-colors"
        >
          Create account →
        </button>
      </form>

      <p class="text-center text-sm text-gray-500 mt-6">
        Already have an account?
        <a href="/login" class="text-violet-400 hover:text-violet-300 ml-1">Sign in</a>
      </p>
    </div>
  </div>
</Layout>
