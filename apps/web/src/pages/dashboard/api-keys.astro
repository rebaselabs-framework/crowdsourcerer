---
/**
 * API Keys — list, create, revoke, configure per-key rate limits, and view usage analytics.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login");

let apiKeys: any[] = [];
let usageOverview: any = null;
let scopesCatalogue: any[] = [];
let error = "";
let successMsg = "";
let newKey: string | null = null;
let newKeyScopes: string[] = [];
const selectedKeyId = Astro.url.searchParams.get("key") ?? null;
let selectedKeyUsage: any = null;
let selectedKeyRateStatus: any = null;

// Handle POST (create / delete / set-rate-limits)
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("action") as string;

  if (action === "create") {
    const name = form.get("name") as string;
    const scopeValues = form.getAll("scopes") as string[];
    try {
      const result = await apiFetch<any>("/v1/api-keys", {
        method: "POST",
        body: JSON.stringify({ name, scopes: scopeValues }),
        token,
      });
      newKey = result.key; // only shown once
      newKeyScopes = result.scopes || [];
    } catch (e: any) {
      error = e.message ?? "Failed to create API key";
    }
  } else if (action === "delete") {
    const keyId = form.get("key_id") as string;
    try {
      await apiFetch<any>(`/v1/api-keys/${keyId}`, { method: "DELETE", token });
    } catch (e: any) {
      error = e.message ?? "Failed to revoke key";
    }
  } else if (action === "set_rate_limits") {
    const keyId = form.get("key_id") as string;
    const rpmRaw = form.get("rate_limit_rpm") as string;
    const dailyRaw = form.get("rate_limit_daily") as string;
    try {
      await apiFetch<any>(`/v1/api-keys/${keyId}/rate-limits`, {
        method: "PATCH",
        body: JSON.stringify({
          rate_limit_rpm: rpmRaw ? parseInt(rpmRaw) : null,
          rate_limit_daily: dailyRaw ? parseInt(dailyRaw) : null,
        }),
        token,
      });
      successMsg = "Rate limits updated successfully";
    } catch (e: any) {
      error = e.message ?? "Failed to update rate limits";
    }
  }
}

// Load keys + usage overview + scopes catalogue in parallel
try {
  [apiKeys, usageOverview, scopesCatalogue] = await Promise.all([
    apiFetch<any[]>("/v1/api-keys", { token }),
    apiFetch<any>("/v1/api-keys/usage/overview?days=30", { token }).catch(() => null),
    apiFetch<any[]>("/v1/scopes", { token }).catch(() => []),
  ]);
} catch (e: any) {
  // Only redirect to login for actual authentication failures.
  if (e.message?.includes("401") || e.message?.includes("403")) {
    return Astro.redirect("/login");
  }
  apiKeys = [];
}

// If a specific key is selected, load its detail usage + rate status
if (selectedKeyId) {
  try {
    [selectedKeyUsage, selectedKeyRateStatus] = await Promise.all([
      apiFetch<any>(`/v1/api-keys/${selectedKeyId}/usage?days=30`, { token }).catch(() => null),
      apiFetch<any>(`/v1/api-keys/${selectedKeyId}/rate-status`, { token }).catch(() => null),
    ]);
  } catch (_) {}
}

function fmt(d: string) {
  return new Date(d).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}

// Build a map of keyId -> overview stats
const keyStats: Record<string, any> = {};
if (usageOverview?.keys) {
  for (const k of usageOverview.keys) {
    keyStats[k.id] = k;
  }
}

// Build a map of keyId -> key detail for rate limit display
const keyMap: Record<string, any> = {};
for (const k of apiKeys) {
  keyMap[k.id] = k;
}
const selectedKey = selectedKeyId ? keyMap[selectedKeyId] : null;

// Simple sparkline: compute bar heights (0-100%) for last 7 days from selectedKeyUsage
function buildSparkline(daily: any[]): number[] {
  const last7 = daily.slice(-7);
  const max = Math.max(...last7.map((d: any) => d.requests), 1);
  return last7.map((d: any) => Math.round((d.requests / max) * 100));
}

// Rate status helpers
const rpm = selectedKeyRateStatus?.rpm;
const daily = selectedKeyRateStatus?.daily;
const rpmPct = rpm && !rpm.unlimited ? Math.min(100, Math.round((rpm.used / rpm.limit) * 100)) : 0;
const dailyPct = daily && !daily.unlimited ? Math.min(100, Math.round((daily.used / daily.limit) * 100)) : 0;
---

<Layout title="API Keys — CrowdSorcerer">
  <div class="max-w-4xl mx-auto px-6 py-10">
    <!-- Breadcrumb -->
    <div class="text-sm text-gray-500 mb-6">
      <a href="/dashboard" class="hover:text-gray-300 transition-colors">Dashboard</a>
      <span class="mx-2">›</span>
      <span>API Keys</span>
    </div>

    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold">API Keys</h1>
        <p class="text-gray-400 text-sm mt-0.5">
          Authenticate with the CrowdSorcerer API.
          Keys start with <code class="text-violet-300 bg-gray-900 px-1 rounded">csk_</code>.
        </p>
      </div>
    </div>

    {error && (
      <div class="bg-red-900/30 border border-red-700/50 rounded-xl p-4 mb-6 text-red-300 text-sm">{error}</div>
    )}
    {successMsg && (
      <div class="bg-emerald-900/30 border border-emerald-700/50 rounded-xl p-4 mb-6 text-emerald-300 text-sm">✅ {successMsg}</div>
    )}

    {newKey && (
      <div class="bg-emerald-900/30 border border-emerald-700/50 rounded-xl p-5 mb-6">
        <div class="text-sm font-medium text-emerald-300 mb-2">Key created — copy it now, it won't be shown again</div>
        <div class="flex gap-2 mb-3">
          <input id="new-key-input" type="text" readonly value={newKey}
            class="flex-1 bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm font-mono text-emerald-300 focus:outline-none" />
          <button id="copy-new-key"
            class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition-colors">
            Copy
          </button>
        </div>
        {newKeyScopes.length > 0 ? (
          <div class="flex flex-wrap gap-1.5">
            <span class="text-xs text-gray-400 mr-1">Scopes:</span>
            {newKeyScopes.map((s) => (
              <span class="text-xs bg-violet-900/40 text-violet-300 px-2 py-0.5 rounded border border-violet-700/40">{s}</span>
            ))}
          </div>
        ) : (
          <p class="text-xs text-gray-400">Full access (no scope restriction)</p>
        )}
      </div>
    )}

    <!-- Usage Overview (30-day) -->
    {usageOverview && (
      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5 mb-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-gray-300">Last 30 Days — All Keys</h2>
          <span class="text-xs text-gray-500">API Usage</span>
        </div>
        <div class="grid grid-cols-3 gap-4">
          <div class="text-center">
            <div class="text-2xl font-bold text-white">{usageOverview.total_requests.toLocaleString()}</div>
            <div class="text-xs text-gray-400 mt-0.5">Total requests</div>
          </div>
          <div class="text-center">
            <div class={`text-2xl font-bold ${usageOverview.total_errors > 0 ? "text-red-400" : "text-gray-300"}`}>
              {usageOverview.total_errors.toLocaleString()}
            </div>
            <div class="text-xs text-gray-400 mt-0.5">Errors</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-violet-300">{usageOverview.total_credits_used.toLocaleString()}</div>
            <div class="text-xs text-gray-400 mt-0.5">Credits used</div>
          </div>
        </div>
      </div>
    )}

    <!-- Key Detail Panel (usage + rate limits) -->
    {selectedKeyId && selectedKey && (
      <div class="bg-gray-900 border border-violet-800/40 rounded-2xl p-6 mb-8 space-y-6">
        <!-- Header -->
        <div class="flex items-center justify-between">
          <div>
            <h2 class="text-base font-semibold">{selectedKey.name}</h2>
            <code class="text-xs text-violet-300">{selectedKey.key_prefix}…</code>
          </div>
          <a href="/dashboard/api-keys" class="text-xs text-gray-400 hover:text-gray-200">✕ Close</a>
        </div>

        <!-- ── Rate Limit Configuration ─────────────────────────────────── -->
        <div>
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-sm font-semibold text-gray-300">Rate Limits</h3>
            <span class="text-xs text-gray-500">Null = plan default</span>
          </div>

          <!-- Current live usage meters -->
          {selectedKeyRateStatus && (
            <div class="grid sm:grid-cols-2 gap-3 mb-4">
              <div class="bg-gray-800/60 rounded-xl p-3">
                <div class="flex justify-between text-xs mb-1.5">
                  <span class="text-gray-400">Requests / minute</span>
                  {rpm?.unlimited ? (
                    <span class="text-emerald-400">Unlimited</span>
                  ) : (
                    <span class={rpmPct >= 90 ? "text-red-400" : rpmPct >= 70 ? "text-yellow-400" : "text-gray-300"}>
                      {rpm?.used ?? 0} / {rpm?.limit ?? "—"}
                    </span>
                  )}
                </div>
                {!rpm?.unlimited && (
                  <div class="bg-gray-700 rounded-full h-1.5">
                    <div class={`h-1.5 rounded-full transition-all ${rpmPct >= 90 ? "bg-red-500" : rpmPct >= 70 ? "bg-yellow-500" : "bg-violet-500"}`}
                         style={`width:${rpmPct}%`}></div>
                  </div>
                )}
              </div>
              <div class="bg-gray-800/60 rounded-xl p-3">
                <div class="flex justify-between text-xs mb-1.5">
                  <span class="text-gray-400">Requests / day</span>
                  {daily?.unlimited ? (
                    <span class="text-emerald-400">Unlimited</span>
                  ) : (
                    <span class={dailyPct >= 90 ? "text-red-400" : dailyPct >= 70 ? "text-yellow-400" : "text-gray-300"}>
                      {daily?.used ?? 0} / {daily?.limit ?? "—"}
                    </span>
                  )}
                </div>
                {!daily?.unlimited && (
                  <div class="bg-gray-700 rounded-full h-1.5">
                    <div class={`h-1.5 rounded-full transition-all ${dailyPct >= 90 ? "bg-red-500" : dailyPct >= 70 ? "bg-yellow-500" : "bg-violet-500"}`}
                         style={`width:${dailyPct}%`}></div>
                  </div>
                )}
              </div>
            </div>
          )}

          <!-- Set limits form -->
          <form method="POST" class="grid sm:grid-cols-3 gap-3 items-end">
            <input type="hidden" name="action" value="set_rate_limits" />
            <input type="hidden" name="key_id" value={selectedKeyId} />
            <div>
              <label class="block text-xs text-gray-400 mb-1.5">Requests / minute (RPM)</label>
              <input type="number" name="rate_limit_rpm" min="1" max="10000"
                placeholder={`Plan default (${selectedKeyRateStatus?.rpm?.limit ?? "—"})`}
                value={selectedKey.rate_limit_rpm ?? ""}
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-violet-500 placeholder-gray-600" />
              <p class="text-xs text-gray-600 mt-1">Leave blank to use plan default</p>
            </div>
            <div>
              <label class="block text-xs text-gray-400 mb-1.5">Requests / day</label>
              <input type="number" name="rate_limit_daily" min="1" max="1000000"
                placeholder={`Plan default (${selectedKeyRateStatus?.daily?.limit ?? "—"})`}
                value={selectedKey.rate_limit_daily ?? ""}
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-violet-500 placeholder-gray-600" />
              <p class="text-xs text-gray-600 mt-1">Leave blank to use plan default</p>
            </div>
            <div>
              <button type="submit" class="w-full px-4 py-2 bg-violet-700 hover:bg-violet-600 text-white text-sm font-medium rounded-lg transition-colors">
                Save Limits
              </button>
            </div>
          </form>
        </div>

        <!-- ── Usage Statistics ───────────────────────────────────────────── -->
        {selectedKeyUsage && (
          <div>
            <h3 class="text-sm font-semibold text-gray-300 mb-3">30-Day Usage</h3>
            <div class="grid grid-cols-3 gap-4 mb-4">
              <div class="bg-gray-800/60 rounded-xl p-4 text-center">
                <div class="text-xl font-bold">{selectedKeyUsage.total_requests.toLocaleString()}</div>
                <div class="text-xs text-gray-400">Requests</div>
              </div>
              <div class="bg-gray-800/60 rounded-xl p-4 text-center">
                <div class={`text-xl font-bold ${selectedKeyUsage.total_errors > 0 ? "text-red-400" : ""}`}>
                  {selectedKeyUsage.total_errors.toLocaleString()}
                </div>
                <div class="text-xs text-gray-400">Errors</div>
              </div>
              <div class="bg-gray-800/60 rounded-xl p-4 text-center">
                <div class="text-xl font-bold text-violet-300">{selectedKeyUsage.total_credits_used.toLocaleString()}</div>
                <div class="text-xs text-gray-400">Credits used</div>
              </div>
            </div>

            <!-- Sparkline bar chart (last 7 days) -->
            {selectedKeyUsage.daily?.length > 0 && (
              <div class="mb-4">
                <div class="text-xs text-gray-500 mb-2">Daily requests (last {Math.min(selectedKeyUsage.daily.length, 7)} days)</div>
                <div class="flex items-end gap-1 h-16">
                  {buildSparkline(selectedKeyUsage.daily).map((h: number, i: number) => (
                    <div class="flex-1 bg-violet-600/70 rounded-sm transition-all hover:bg-violet-500"
                      style={`height: ${Math.max(h, 4)}%`}
                      title={`Day ${i+1}: ${selectedKeyUsage.daily.slice(-7)[i]?.requests ?? 0} req`}>
                    </div>
                  ))}
                </div>
              </div>
            )}

            <!-- Top endpoints -->
            {selectedKeyUsage.top_endpoints?.length > 0 && (
              <div>
                <div class="text-xs text-gray-500 mb-2">Top endpoints</div>
                <div class="space-y-1">
                  {selectedKeyUsage.top_endpoints.slice(0, 5).map((ep: any) => (
                    <div class="flex items-center gap-3 text-xs">
                      <span class={`px-1.5 py-0.5 rounded font-mono ${
                        ep.method === "POST" ? "bg-green-900/40 text-green-400" :
                        ep.method === "DELETE" ? "bg-red-900/40 text-red-400" :
                        "bg-blue-900/40 text-blue-400"
                      }`}>{ep.method}</span>
                      <span class="text-gray-300 font-mono flex-1 truncate">{ep.endpoint}</span>
                      <span class="text-gray-400">{ep.requests.toLocaleString()} req</span>
                      {ep.avg_response_ms && (
                        <span class="text-gray-500">{ep.avg_response_ms}ms</span>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}
      </div>
    )}

    <!-- Keys list -->
    <div class="space-y-3 mb-8">
      {apiKeys.length === 0 ? (
        <div class="text-center py-12 text-gray-500">
          <div class="text-4xl mb-3">🔑</div>
          <p>No API keys yet. Create one below.</p>
        </div>
      ) : (
        apiKeys.map((key: any) => {
          const stats = keyStats[key.id];
          const isSelected = selectedKeyId === key.id;
          return (
            <div class={`bg-gray-900 border rounded-xl p-5 ${isSelected ? "border-violet-600/60" : "border-gray-800"}`}>
              <div class="flex items-start justify-between">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="font-medium text-sm">{key.name}</span>
                    <code class="text-xs bg-gray-800 px-2 py-0.5 rounded text-violet-300 font-mono">
                      {key.key_prefix}…
                    </code>
                    {(key.rate_limit_rpm || key.rate_limit_daily) && (
                      <span class="text-xs bg-orange-900/40 text-orange-300 px-2 py-0.5 rounded border border-orange-700/40">
                        Custom limits
                      </span>
                    )}
                  </div>
                  <div class="flex items-center gap-4 text-xs text-gray-500">
                    <span>Created {fmt(key.created_at)}</span>
                    {key.last_used_at && <span>Last used {fmt(key.last_used_at)}</span>}
                    {stats && (
                      <>
                        <span class="text-gray-400">{(stats.requests || 0).toLocaleString()} req/30d</span>
                        {stats.errors > 0 && (
                          <span class="text-red-400">{stats.errors} errors</span>
                        )}
                      </>
                    )}
                    {key.rate_limit_rpm && (
                      <span class="text-orange-400">{key.rate_limit_rpm} rpm</span>
                    )}
                    {key.rate_limit_daily && (
                      <span class="text-orange-400">{key.rate_limit_daily.toLocaleString()}/day</span>
                    )}
                  </div>
                  {/* Scope badges */}
                  {key.scopes && key.scopes.length > 0 ? (
                    <div class="flex flex-wrap gap-1 mt-1.5">
                      {key.scopes.map((s: string) => (
                        <span class="text-xs bg-violet-900/30 text-violet-400 px-1.5 py-0.5 rounded border border-violet-800/40">{s}</span>
                      ))}
                    </div>
                  ) : (
                    <div class="text-xs text-gray-600 mt-1">Full access</div>
                  )}
                </div>
                <div class="flex items-center gap-2 ml-4">
                  <a
                    href={isSelected ? "/dashboard/api-keys" : `/dashboard/api-keys?key=${key.id}`}
                    class={`text-xs px-3 py-1.5 rounded-lg border transition-colors ${
                      isSelected
                        ? "bg-violet-900/40 border-violet-700 text-violet-300"
                        : "border-gray-700 text-gray-400 hover:border-gray-500 hover:text-gray-200"
                    }`}
                  >
                    {isSelected ? "Hide" : "Details"}
                  </a>
                  <form method="POST" data-confirm="Revoke this API key?">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="key_id" value={key.id} />
                    <button type="submit"
                      class="text-xs px-3 py-1.5 rounded-lg border border-red-900/50 text-red-400 hover:border-red-700 hover:text-red-300 transition-colors">
                      Revoke
                    </button>
                  </form>
                </div>
              </div>
            </div>
          );
        })
      )}
    </div>

    <!-- Create new key -->
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
      <h2 class="text-sm font-semibold mb-4">Create new key</h2>
      <form method="POST" class="space-y-4">
        <input type="hidden" name="action" value="create" />
        <div class="flex gap-3">
          <input
            type="text"
            name="name"
            placeholder="Key name (e.g. Production, Testing)"
            required
            maxlength="80"
            class="flex-1 bg-gray-800 border border-gray-700 focus:border-violet-600 rounded-lg px-4 py-2 text-sm text-gray-200 placeholder-gray-600 focus:outline-none transition-colors"
          />
          <button type="submit"
            class="px-5 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors whitespace-nowrap">
            Create Key
          </button>
        </div>

        <!-- Scope selection -->
        <div>
          <div class="flex items-center justify-between mb-2">
            <label class="text-xs font-medium text-gray-400">Scopes <span class="text-gray-600">(leave all unchecked = full access)</span></label>
            <button type="button" id="toggle-scopes" class="text-xs text-violet-400 hover:text-violet-300">
              Show scopes ▾
            </button>
          </div>
          <div id="scopes-panel" class="hidden">
            <div class="grid sm:grid-cols-2 gap-2 p-4 bg-gray-800/60 rounded-xl border border-gray-700/50">
              {scopesCatalogue.map((item: any) => (
                <label class="flex items-start gap-2 cursor-pointer group">
                  <input type="checkbox" name="scopes" value={item.scope}
                    class="mt-0.5 rounded border-gray-600 bg-gray-700 text-violet-500 focus:ring-violet-500 focus:ring-offset-gray-900" />
                  <div>
                    <span class="text-xs font-mono text-violet-300 group-hover:text-violet-200">{item.scope}</span>
                    <p class="text-xs text-gray-500">{item.description}</p>
                  </div>
                </label>
              ))}
            </div>
            <p class="text-xs text-gray-600 mt-2">
              Tip: Use scoped keys for third-party integrations to limit their access.
            </p>
          </div>
        </div>

        <p class="text-xs text-gray-600">Store the key securely — it won't be shown again.</p>
      </form>
    </div>

    <!-- Docs link -->
    <div class="mt-6 text-center text-sm text-gray-500">
      See <a href="/docs" class="text-violet-400 hover:text-violet-300 transition-colors">API Docs</a>
      for endpoint reference and SDK examples.
    </div>
  </div>
</Layout>

<script>
  // Copy new key — fall back to selecting text if clipboard API unavailable
  const newKeyInput = document.getElementById("new-key-input") as HTMLInputElement | null;
  const copyNewKeyBtn = document.getElementById("copy-new-key");
  copyNewKeyBtn?.addEventListener("click", async () => {
    if (newKeyInput) {
      try {
        await navigator.clipboard.writeText(newKeyInput.value);
        copyNewKeyBtn.textContent = "Copied!";
        setTimeout(() => { copyNewKeyBtn.textContent = "Copy"; }, 2000);
      } catch {
        // Clipboard API blocked — select text so user can copy manually
        newKeyInput.select();
        copyNewKeyBtn.textContent = "Select all ↑";
        setTimeout(() => { copyNewKeyBtn.textContent = "Copy"; }, 3000);
      }
    }
  });

  // Two-step confirm for revoke forms
  document.querySelectorAll<HTMLFormElement>("form[data-confirm]").forEach(form => {
    const btn = form.querySelector<HTMLButtonElement>("button[type='submit']");
    if (!btn) return;
    form.addEventListener("submit", e => {
      if (btn.dataset.pending !== "true") {
        e.preventDefault();
        const orig = btn.textContent!;
        btn.dataset.pending = "true";
        btn.textContent = "Sure?";
        btn.classList.add("!text-red-400", "!border-red-600");
        setTimeout(() => {
          btn.dataset.pending = "";
          btn.textContent = orig;
          btn.classList.remove("!text-red-400", "!border-red-600");
        }, 3000);
      }
    });
  });

  // Toggle scopes panel
  const toggleBtn = document.getElementById("toggle-scopes");
  const scopesPanel = document.getElementById("scopes-panel");
  toggleBtn?.addEventListener("click", () => {
    const hidden = scopesPanel?.classList.toggle("hidden");
    if (toggleBtn) toggleBtn.textContent = hidden ? "Show scopes ▾" : "Hide scopes ▲";
  });
</script>
