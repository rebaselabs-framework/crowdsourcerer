---
/**
 * Notification Center — grouped, searchable, real-time badge, mark-all-read,
 * clear-all, per-notification delete.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Object.fromEntries(
  Astro.cookies.getAll().map((c) => [c.name, c.value])
));
if (!token) return Astro.redirect("/login");

interface NotifItem {
  id: string;
  type: string;
  title: string;
  body: string;
  link?: string | null;
  is_read: boolean;
  created_at: string;
}
interface Group {
  type: string;
  label: string;
  unread_count: number;
  items: NotifItem[];
}
interface GroupedResponse { groups: Group[]; total_unread: number; }

let grouped: Group[] = [];
let totalUnread = 0;
let error = "";

try {
  const data = await apiFetch<GroupedResponse>("/v1/notifications/grouped?limit=200", { token });
  grouped = data.groups ?? [];
  totalUnread = data.total_unread ?? 0;
} catch (e: any) {
  error = (e as Error).message ?? "Failed to load notifications";
}

const GROUP_ICONS: Record<string, string> = {
  task_event:   "⚡",
  submission:   "📬",
  payout:       "💸",
  gamification: "🏆",
  system:       "🔔",
};

const TYPE_ICON: Record<string, string> = {
  TASK_COMPLETED:       "✅",
  TASK_FAILED:          "❌",
  TASK_CREATED:         "📋",
  TASK_ASSIGNED:        "🤝",
  SLA_BREACH:           "⏰",
  SUBMISSION_RECEIVED:  "📬",
  WORKER_APPROVED:      "🎉",
  WORKER_REJECTED:      "⚠️",
  PAYOUT_INITIATED:     "⏳",
  PAYOUT_COMPLETED:     "💸",
  PAYOUT_FAILED:        "❌",
  BADGE_EARNED:         "🏅",
  LEVEL_UP:             "🚀",
  CHALLENGE_COMPLETED:  "🏆",
  LEADERBOARD_RANK:     "📊",
  REFERRAL_BONUS:       "🎁",
};

function notifIcon(type: string) {
  return TYPE_ICON[type.toUpperCase()] ?? "🔔";
}

function timeAgo(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return "just now";
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  return `${days}d ago`;
}

const totalNotifications = grouped.reduce((s, g) => s + g.items.length, 0);
---

<Layout title="Notification Center — CrowdSorcerer">
  <div class="max-w-4xl mx-auto px-4 py-8">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
      <div>
        <h1 class="text-2xl font-bold flex items-center gap-2">
          🔔 Notification Center
          {totalUnread > 0 && (
            <span id="header-badge"
              class="inline-flex items-center justify-center h-6 min-w-6 px-1.5 rounded-full bg-violet-600 text-white text-xs font-bold">
              {totalUnread > 99 ? "99+" : totalUnread}
            </span>
          )}
        </h1>
        <p class="text-gray-400 text-sm mt-1" id="header-subtitle">
          {totalUnread > 0
            ? `${totalUnread} unread across ${grouped.length} categories`
            : totalNotifications > 0
              ? "All caught up! ✓"
              : "No notifications yet"}
        </p>
      </div>
      <div class="flex items-center gap-2 flex-wrap">
        <a
          href="/dashboard/notification-preferences"
          class="px-3 py-1.5 rounded-lg border border-gray-700 text-sm text-gray-400 hover:border-violet-500 hover:text-violet-300 transition-colors"
        >
          ⚙️ Preferences
        </a>
        {totalUnread > 0 && (
          <button
            id="mark-all-btn"
            class="px-3 py-1.5 rounded-lg border border-gray-700 text-sm text-gray-300 hover:border-violet-500 hover:text-violet-300 transition-colors"
          >
            ✓ Mark all read
          </button>
        )}
        {totalNotifications > 0 && (
          <button
            id="clear-all-btn"
            class="px-3 py-1.5 rounded-lg border border-gray-700 text-sm text-gray-400 hover:border-red-500 hover:text-red-400 transition-colors"
          >
            🗑 Clear all
          </button>
        )}
      </div>
    </div>

    {error && (
      <div class="rounded-lg bg-red-900/30 border border-red-700 p-4 text-red-300 mb-6">
        {error}
      </div>
    )}

    {totalNotifications === 0 && !error ? (
      <div class="text-center py-24">
        <div class="text-6xl mb-4">🔔</div>
        <p class="text-xl font-semibold text-gray-300 mb-2">No notifications yet</p>
        <p class="text-sm text-gray-500">You'll see task events, submissions, payouts, and achievements here.</p>
      </div>
    ) : (
      <>
        <!-- Tab bar -->
        <div class="flex items-center gap-1 overflow-x-auto pb-1 mb-6 border-b border-gray-800" id="tab-bar">
          <button
            class="tab-btn px-4 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap active"
            data-group="all"
          >
            All
            {totalUnread > 0 && (
              <span class="ml-1.5 px-1.5 py-0.5 rounded-full bg-violet-600 text-white text-xs">
                {totalUnread}
              </span>
            )}
          </button>
          {grouped.map((g) => (
            <button
              class="tab-btn px-4 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap"
              data-group={g.type}
            >
              {GROUP_ICONS[g.type] ?? "🔔"} {g.label}
              {g.unread_count > 0 && (
                <span class="ml-1.5 px-1.5 py-0.5 rounded-full bg-violet-600/70 text-white text-xs">
                  {g.unread_count}
                </span>
              )}
            </button>
          ))}
        </div>

        <!-- Search input -->
        <div class="relative mb-4">
          <input
            id="notif-search"
            type="search"
            placeholder="Search notifications…"
            class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-2.5 pl-9 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:border-violet-500 transition-colors"
          />
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-sm">🔍</span>
        </div>

        <!-- Notification groups -->
        <div id="notif-container">
          {grouped.map((g) => (
            <div class="notif-group mb-6" data-group={g.type}>
              <!-- Group header -->
              <div class="flex items-center justify-between mb-3">
                <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide flex items-center gap-2">
                  <span>{GROUP_ICONS[g.type] ?? "🔔"}</span>
                  <span>{g.label}</span>
                  <span class="text-gray-600 font-normal normal-case tracking-normal">
                    ({g.items.length})
                  </span>
                </h2>
                {g.unread_count > 0 && (
                  <span class="text-xs text-violet-400">{g.unread_count} unread</span>
                )}
              </div>

              <!-- Items -->
              <div class="space-y-2">
                {g.items.map((n) => (
                  <div
                    class={`notif-card rounded-xl border p-4 transition-all group ${
                      n.is_read
                        ? "border-gray-800 bg-gray-900/30"
                        : "border-violet-700/40 bg-gray-900/60"
                    }`}
                    data-id={n.id}
                    data-read={n.is_read ? "true" : "false"}
                    data-title={n.title.toLowerCase()}
                    data-body={n.body.toLowerCase()}
                    data-group={g.type}
                  >
                    <div class="flex items-start gap-3">
                      <!-- Icon -->
                      <span class="text-xl flex-shrink-0 mt-0.5">{notifIcon(n.type)}</span>

                      <!-- Content -->
                      <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between gap-2">
                          <div class="flex-1 min-w-0">
                            <p class={`font-semibold text-sm ${n.is_read ? "text-gray-300" : "text-white"}`}>
                              {!n.is_read && (
                                <span class="inline-block h-2 w-2 rounded-full bg-violet-500 mr-1.5 mb-0.5 align-middle unread-dot"></span>
                              )}
                              {n.title}
                            </p>
                            {n.type === "task_completed" && n.body.includes(" — ") ? (() => {
                              const sepIdx = n.body.indexOf(" — ");
                              const meta    = n.body.slice(0, sepIdx);
                              const preview = n.body.slice(sepIdx + 3);
                              return (
                                <>
                                  <p class="text-sm text-gray-400 mt-0.5">{meta}</p>
                                  <blockquote class="mt-1.5 pl-3 border-l-2 border-emerald-700/60 text-xs text-gray-300 italic leading-relaxed line-clamp-3">
                                    {preview}
                                  </blockquote>
                                </>
                              );
                            })() : (
                              <p class="text-sm text-gray-400 mt-0.5 leading-relaxed">{n.body}</p>
                            )}
                          </div>
                          <div class="flex items-center gap-1 flex-shrink-0 ml-2">
                            <span class="text-xs text-gray-500 whitespace-nowrap">{timeAgo(n.created_at)}</span>
                          </div>
                        </div>
                        <div class="flex items-center gap-3 mt-2">
                          {n.link && (
                            <a
                              href={n.link}
                              class="text-xs text-violet-400 hover:text-violet-300 transition-colors"
                              data-notif-id={n.id}
                            >
                              View →
                            </a>
                          )}
                        </div>
                      </div>

                      <!-- Actions (visible on hover) -->
                      <div class="flex items-center gap-1 flex-shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">
                        {!n.is_read && (
                          <button
                            class="mark-read-btn p-1.5 rounded-lg text-xs text-gray-500 hover:text-emerald-400 hover:bg-emerald-900/20 transition-colors"
                            data-id={n.id}
                            title="Mark as read"
                          >
                            ✓
                          </button>
                        )}
                        <button
                          class="delete-btn p-1.5 rounded-lg text-xs text-gray-600 hover:text-red-400 hover:bg-red-900/20 transition-colors"
                          data-id={n.id}
                          title="Delete"
                        >
                          ✕
                        </button>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </>
    )}

  </div>

  <style>
    .tab-btn {
      color: theme('colors.gray.400');
      background: transparent;
    }
    .tab-btn:hover {
      color: theme('colors.gray.200');
      background: theme('colors.gray.800');
    }
    .tab-btn.active {
      color: theme('colors.violet.300');
      background: theme('colors.violet.900' / 30%);
    }
    .notif-card[data-read="true"] { opacity: 0.75; }
    .notif-card[data-read="false"] { opacity: 1; }
  </style>

  <script>
    // ── Tabs ──────────────────────────────────────────────────────────────────
    const tabBtns = document.querySelectorAll<HTMLButtonElement>(".tab-btn");
    const groups = document.querySelectorAll<HTMLElement>(".notif-group");

    function showGroup(key: string) {
      tabBtns.forEach((b) => {
        b.classList.toggle("active", b.dataset.group === key);
      });
      groups.forEach((g) => {
        if (key === "all") {
          g.style.display = "";
        } else {
          g.style.display = g.dataset.group === key ? "" : "none";
        }
      });
    }

    tabBtns.forEach((btn) => {
      btn.addEventListener("click", () => showGroup(btn.dataset.group ?? "all"));
    });

    // ── Search ─────────────────────────────────────────────────────────────────
    const searchInput = document.getElementById("notif-search") as HTMLInputElement | null;
    searchInput?.addEventListener("input", () => {
      const q = searchInput.value.toLowerCase().trim();
      document.querySelectorAll<HTMLElement>(".notif-card").forEach((card) => {
        const title = card.dataset.title ?? "";
        const body = card.dataset.body ?? "";
        card.style.display = !q || title.includes(q) || body.includes(q) ? "" : "none";
      });
    });

    // ── Mark single as read ─────────────────────────────────────────────────
    function markCardRead(id: string) {
      const card = document.querySelector<HTMLElement>(`.notif-card[data-id="${id}"]`);
      if (!card || card.dataset.read === "true") return;
      card.dataset.read = "true";
      card.classList.remove("border-violet-700/40", "bg-gray-900/60");
      card.classList.add("border-gray-800", "bg-gray-900/30");
      card.querySelector(".unread-dot")?.remove();
      card.querySelector(".mark-read-btn")?.remove();
      const title = card.querySelector("p.font-semibold");
      if (title) {
        title.classList.remove("text-white");
        title.classList.add("text-gray-300");
      }
      updateBadge(-1);
    }

    document.querySelectorAll<HTMLElement>(".mark-read-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.dataset.id!;
        try {
          await fetch(`/api/notifications/${id}/read`, { method: "POST" });
          markCardRead(id);
        } catch { /* ignore */ }
      });
    });

    // ── Delete single ───────────────────────────────────────────────────────
    document.querySelectorAll<HTMLElement>(".delete-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.dataset.id!;
        try {
          await fetch(`/api/notifications/${id}`, { method: "DELETE" });
          const card = document.querySelector<HTMLElement>(`.notif-card[data-id="${id}"]`);
          if (card) {
            if (card.dataset.read === "false") updateBadge(-1);
            card.remove();
          }
        } catch { /* ignore */ }
      });
    });

    // ── Mark all read ───────────────────────────────────────────────────────
    document.getElementById("mark-all-btn")?.addEventListener("click", async () => {
      try {
        await fetch("/api/notifications/read-all", { method: "POST" });
        document.querySelectorAll<HTMLElement>(".notif-card[data-read='false']").forEach((card) => {
          markCardRead(card.dataset.id ?? "");
        });
        document.getElementById("mark-all-btn")?.remove();
        // remove all unread group badges
        document.querySelectorAll(".tab-btn span.bg-violet-600\\/70, .tab-btn span.bg-violet-600").forEach((s) => {
          // keep the "All" badge
        });
        const badge = document.getElementById("header-badge");
        if (badge) badge.remove();
        const subtitle = document.getElementById("header-subtitle");
        if (subtitle) subtitle.textContent = "All caught up! ✓";
      } catch { /* ignore */ }
    });

    // ── Clear all ───────────────────────────────────────────────────────────
    document.getElementById("clear-all-btn")?.addEventListener("click", async () => {
      if (!confirm("Delete all notifications? This cannot be undone.")) return;
      try {
        await fetch("/api/notifications/delete-all", { method: "DELETE" });
        window.location.reload();
      } catch { /* ignore */ }
    });

    // ── Badge helper ────────────────────────────────────────────────────────
    function updateBadge(delta: number) {
      const badge = document.getElementById("header-badge");
      if (!badge) return;
      const current = parseInt(badge.textContent ?? "0", 10);
      const next = Math.max(0, current + delta);
      if (next === 0) {
        badge.remove();
        const subtitle = document.getElementById("header-subtitle");
        if (subtitle) subtitle.textContent = "All caught up! ✓";
        document.getElementById("mark-all-btn")?.remove();
      } else {
        badge.textContent = next > 99 ? "99+" : String(next);
      }
    }

    // ── Auto-read on "View →" click ─────────────────────────────────────────
    document.querySelectorAll<HTMLAnchorElement>("a[data-notif-id]").forEach((link) => {
      link.addEventListener("click", async () => {
        const id = link.dataset.notifId!;
        try {
          await fetch(`/api/notifications/${id}/read`, { method: "POST" });
        } catch { /* ignore */ }
      });
    });

    // ── Poll unread count and refresh badge every 30s ───────────────────────
    async function pollUnreadCount() {
      try {
        const res = await fetch("/api/notifications/unread-count");
        const data = await res.json();
        const count: number = data.unread_count ?? 0;
        // Update nav badge if present (Layout.astro)
        const navBadge = document.getElementById("nav-notif-badge");
        if (navBadge) {
          navBadge.textContent = count > 99 ? "99+" : String(count);
          navBadge.style.display = count > 0 ? "" : "none";
        }
      } catch { /* ignore */ }
    }
    setInterval(pollUnreadCount, 30_000);
  </script>
</Layout>
