---
/**
 * Scheduled Tasks — view and manage tasks that are waiting to run at a future time.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Object.fromEntries(
  Astro.cookies.getAll().map((c) => [c.name, c.value])
));
if (!token) return Astro.redirect("/login?next=/dashboard/scheduled");

let tasks: any = { items: [], total: 0, has_next: false };
let error: string | null = null;

try {
  // All pending tasks that have a scheduled_at set
  tasks = await apiFetch<any>("/v1/tasks?status=pending&page_size=50", { token });
  // Filter locally for scheduled_at tasks (API does not have a dedicated filter yet)
  tasks.items = tasks.items.filter((t: any) => t.scheduled_at);
  tasks.total = tasks.items.length;
} catch (e: any) {
  if (e.message?.includes("401")) return Astro.redirect("/login");
  error = e.message ?? "Failed to load scheduled tasks.";
}

// Group by date
function fmtDate(iso: string) {
  return new Date(iso).toLocaleDateString(undefined, { weekday: "short", month: "short", day: "numeric" });
}
function fmtTime(iso: string) {
  return new Date(iso).toLocaleTimeString(undefined, { hour: "2-digit", minute: "2-digit" });
}

const groups: Record<string, any[]> = {};
for (const task of tasks.items) {
  const key = fmtDate(task.scheduled_at);
  if (!groups[key]) groups[key] = [];
  groups[key].push(task);
}
// Sort keys chronologically
const sortedDates = Object.keys(groups).sort((a, b) =>
  new Date(groups[a][0].scheduled_at).getTime() - new Date(groups[b][0].scheduled_at).getTime()
);
---

<Layout title="Scheduled Tasks — CrowdSorcerer">
  <div class="max-w-4xl mx-auto px-6 py-10">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <div class="text-sm text-gray-500 mb-1">
          <a href="/dashboard" class="hover:text-gray-300 transition-colors">Dashboard</a>
          <span class="mx-2">›</span>
          <span>Scheduled Tasks</span>
        </div>
        <h1 class="text-2xl font-bold">Scheduled Tasks</h1>
        <p class="text-sm text-gray-400 mt-1">
          Tasks waiting to run at a future time. The sweeper checks every minute.
        </p>
      </div>
      <a href="/dashboard/tasks/new"
        class="px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors">
        + Schedule a task
      </a>
    </div>

    {error ? (
      <div class="bg-red-900/30 border border-red-800 text-red-300 p-4 rounded-lg mb-6">{error}</div>
    ) : tasks.items.length === 0 ? (
      <div class="bg-gray-900 border border-gray-800 rounded-xl px-6 py-16 text-center">
        <div class="text-4xl mb-3">⏰</div>
        <div class="text-gray-300 font-medium mb-1">No scheduled tasks</div>
        <p class="text-sm text-gray-500 mb-4">
          Schedule a task to run at any future time — perfect for recurring reports, off-hours processing, or delayed execution.
        </p>
        <a href="/dashboard/tasks/new"
          class="px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors inline-block">
          Create a scheduled task →
        </a>
      </div>
    ) : (
      <div class="space-y-6">
        {sortedDates.map(date => (
          <div>
            <h2 class="text-sm font-semibold text-gray-400 mb-3 flex items-center gap-2">
              <span class="text-lg">📅</span>
              {date}
              <span class="text-gray-600 font-normal">({groups[date].length} task{groups[date].length !== 1 ? "s" : ""})</span>
            </h2>
            <div class="bg-gray-900 border border-gray-800 rounded-xl divide-y divide-gray-800">
              {groups[date].sort((a: any, b: any) =>
                new Date(a.scheduled_at).getTime() - new Date(b.scheduled_at).getTime()
              ).map((t: any) => (
                <div class="flex items-center gap-4 px-5 py-4">
                  <!-- Time -->
                  <div class="text-amber-400 font-mono text-sm font-medium w-16 shrink-0">
                    {fmtTime(t.scheduled_at)}
                  </div>

                  <!-- Type + tags -->
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                      <a href={`/dashboard/tasks/${t.id}`}
                        class="font-mono text-sm text-violet-300 hover:text-violet-200 transition-colors">
                        {t.type}
                      </a>
                      <span class="text-xs px-2 py-0.5 rounded-full bg-gray-800 text-gray-400">
                        {t.execution_mode}
                      </span>
                      <span class="text-xs px-2 py-0.5 rounded-full bg-gray-800 text-gray-400">
                        {t.priority}
                      </span>
                    </div>
                    {t.tags && t.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1 mt-1.5">
                        {(t.tags as string[]).map((tg: string) => (
                          <span class="px-1.5 py-0.5 bg-gray-800 text-gray-500 text-xs rounded">🏷️ {tg}</span>
                        ))}
                      </div>
                    )}
                  </div>

                  <!-- Created at -->
                  <div class="text-xs text-gray-600 shrink-0 hidden sm:block">
                    Created {new Date(t.created_at).toLocaleString()}
                  </div>

                  <!-- Actions -->
                  <div class="flex gap-2 shrink-0">
                    <a href={`/dashboard/tasks/${t.id}`}
                      class="px-3 py-1.5 bg-gray-800 hover:bg-gray-700 text-gray-300 text-xs rounded-lg transition-colors">
                      View
                    </a>
                    <button
                      class="cancel-btn px-3 py-1.5 bg-red-900/40 hover:bg-red-900/60 text-red-400 text-xs rounded-lg transition-colors"
                      data-id={t.id}>
                      Cancel
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}

        <p class="text-xs text-gray-600 text-center pt-2">
          Showing {tasks.items.length} scheduled task{tasks.items.length !== 1 ? "s" : ""}.
          <a href="/dashboard/tasks?status=pending" class="text-gray-500 hover:text-gray-400 ml-1">View all pending →</a>
        </p>
      </div>
    )}
  </div>
</Layout>

<script define:vars={{ apiBase: import.meta.env.PUBLIC_API_URL ?? "" }}>
  // Cancel button handler
  document.querySelectorAll(".cancel-btn").forEach(btn => {
    btn.addEventListener("click", async () => {
      const taskId = btn.dataset.id;
      if (!confirm("Cancel this scheduled task?")) return;
      try {
        const res = await fetch(`/api/tasks/${taskId}/cancel`, { method: "POST" });
        if (res.ok || res.status === 204) {
          btn.closest(".flex.items-center")?.remove();
          // Reload if no items left
          const remaining = document.querySelectorAll(".cancel-btn").length;
          if (remaining === 0) window.location.reload();
        } else {
          alert("Failed to cancel task.");
        }
      } catch {
        alert("Network error.");
      }
    });
  });
</script>
