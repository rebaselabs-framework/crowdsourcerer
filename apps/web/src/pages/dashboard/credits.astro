---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";
import { CONTACT_EMAIL, mailto } from "@/lib/contact";

const token = getToken(Astro.cookies);

if (!token) {
  return Astro.redirect("/login");
}

let credits: any = null;
let transactions: any = null;
let creditsError: string | null = null;

try {
  [credits, transactions] = await Promise.all([
    apiFetch("/v1/credits", { token }),
    apiFetch("/v1/credits/transactions?page_size=50", { token }),
  ]);
} catch (e: any) {
  // Only redirect to login for actual authentication failures.
  // Network errors, 500s, etc. show an in-page error so users aren't
  // unexpectedly kicked to login when the API is temporarily unavailable.
  if (e.message?.includes("401") || e.message?.includes("403")) {
    return Astro.redirect("/login");
  }
  creditsError = "Failed to load credit balance. Please refresh to try again.";
}

const PACKS = [
  { credits: 500, price: 5, label: "Starter", note: "Good for 50 web researches" },
  { credits: 1000, price: 10, label: "Developer", note: "Most popular" },
  { credits: 5000, price: 45, label: "Team", note: "10% discount" },
  { credits: 10000, price: 80, label: "Pro", note: "20% discount" },
];

// Check if Stripe is configured (hides buy buttons if not)
let paymentsEnabled = false;
try {
  const cfgRes = await fetch(`${import.meta.env.PUBLIC_API_URL ?? "http://api:8100"}/v1/config`).catch(() => null);
  if (cfgRes?.ok) {
    const cfg = await cfgRes.json();
    paymentsEnabled = !!cfg.payments_enabled;
  }
} catch {
  paymentsEnabled = false;
}
---

<Layout title="Credits — CrowdSorcerer">
  <div class="max-w-4xl mx-auto px-6 py-10">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold">Credits</h1>
        <p class="text-gray-400 text-sm mt-0.5">Manage your balance and purchase history</p>
      </div>
      <a href="/dashboard" class="text-sm text-gray-400 hover:text-gray-200">← Back to dashboard</a>
    </div>

    {creditsError && (
      <div class="mb-6 p-4 bg-red-950/40 border border-red-700 rounded-xl flex items-center gap-3 text-sm text-red-300">
        <span>⚠️</span>
        <span>{creditsError}</span>
      </div>
    )}

    <!-- Balance -->
    <div class="grid grid-cols-3 gap-4 mb-10">
      <div class="bg-gray-900 border border-violet-800/50 rounded-xl p-5">
        <div class="text-sm text-gray-400 mb-1">Available</div>
        <div class="text-3xl font-bold text-violet-300">{credits?.available?.toLocaleString() ?? 0}</div>
        <div class="text-xs text-gray-500 mt-1">≈ ${((credits?.available ?? 0) / 100).toFixed(2)} USD</div>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="text-sm text-gray-400 mb-1">Credits used</div>
        <div class="text-3xl font-bold">{credits?.total_used?.toLocaleString() ?? 0}</div>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="text-sm text-gray-400 mb-1">Plan</div>
        <div class="text-2xl font-bold capitalize">{credits?.plan ?? "free"}</div>
      </div>
    </div>

    <!-- Buy credits -->
    <h2 class="text-xl font-bold mb-4">Buy credits</h2>
    {!paymentsEnabled && (
      <div class="mb-6 p-4 bg-gray-900 border border-gray-700 rounded-xl text-sm text-gray-400">
        💳 Credit purchases are not yet available. Contact <a href={mailto(CONTACT_EMAIL)} class="text-violet-400">{CONTACT_EMAIL}</a> for bulk credit purchases.
      </div>
    )}
    <div id="checkout-error" class="hidden text-sm text-red-400 bg-red-950/20 border border-red-800 rounded-lg px-4 py-3 mb-4"></div>
    {paymentsEnabled && (
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-10" id="packs">
        {PACKS.map(({ credits: cr, price, label, note }) => (
          <button
            class="buy-pack bg-gray-900 border border-gray-800 hover:border-violet-600 rounded-xl p-5 text-left transition-colors cursor-pointer"
            data-credits={cr}
            data-price={price}
          >
            <div class="buy-pack-label text-sm text-gray-400 mb-1">{label}</div>
            <div class="buy-pack-price text-2xl font-bold mb-1">${price}</div>
            <div class="buy-pack-credits text-violet-300 font-medium text-sm mb-2">{cr.toLocaleString()} credits</div>
            <div class="buy-pack-note text-xs text-gray-500">{note}</div>
          </button>
        ))}
      </div>
    )}

    <!-- Crypto option -->
    <div class="bg-gray-900/50 border border-gray-800 rounded-xl p-5 mb-10">
      <div class="flex items-start gap-3">
        <span class="text-xl">💎</span>
        <div>
          <h3 class="font-medium mb-1">Pay with crypto</h3>
          <p class="text-sm text-gray-400 mb-3">
            Send to any of the wallets below, then email
            <a href={mailto(CONTACT_EMAIL)} class="text-violet-400">{CONTACT_EMAIL}</a>
            with your transaction hash and account email. Credits added within 24h.
          </p>
          <div class="grid sm:grid-cols-3 gap-3 text-xs font-mono">
            <div>
              <div class="text-gray-500 mb-0.5">Bitcoin</div>
              <div class="text-gray-300 break-all">bc1qvzvwjcvpcztwcuv5ef42frzlq2xn46g7usxfcm</div>
            </div>
            <div>
              <div class="text-gray-500 mb-0.5">Solana</div>
              <div class="text-gray-300 break-all">8tGVz7wUr89bVQVR4MbiUQPfnEHeGPzSgjWqjorsZ91o</div>
            </div>
            <div>
              <div class="text-gray-500 mb-0.5">EVM (ETH/Base)</div>
              <div class="text-gray-300 break-all">0x16F086e2292eA895B0eC3a4DeBb255e3d6fD9E01</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Transaction history -->
    <h2 class="text-xl font-bold mb-4">
      Transaction history
      {transactions?.total > 0 && (
        <span class="text-sm font-normal text-gray-500 ml-2">{transactions.total} total</span>
      )}
    </h2>
    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
      {!transactions?.items?.length ? (
        <div class="px-6 py-10 text-center text-gray-500 text-sm">No transactions yet.</div>
      ) : (
        <>
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-800 text-left">
                <th class="px-6 py-3 text-gray-400 font-medium">Description</th>
                <th class="px-6 py-3 text-gray-400 font-medium text-right">Amount</th>
                <th class="px-6 py-3 text-gray-400 font-medium text-right">Date</th>
              </tr>
            </thead>
            <tbody id="txn-tbody">
              {transactions.items.map((t: any) => (
                <tr class="border-b border-gray-800/50 hover:bg-gray-800/20 transition-colors">
                  <td class="px-6 py-3 text-gray-300">{t.description}</td>
                  <td class:list={[
                    "px-6 py-3 text-right font-mono font-medium",
                    t.amount > 0 ? "text-green-400" : "text-red-400"
                  ]}>
                    {t.amount > 0 ? "+" : ""}{t.amount}
                  </td>
                  <td class="px-6 py-3 text-right text-gray-500">
                    {new Date(t.created_at).toLocaleDateString()}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          {transactions.total > transactions.items.length && (
            <div class="px-6 py-4 border-t border-gray-800 text-center">
              <button
                id="load-more-txn"
                data-page="2"
                data-total={transactions.total}
                class="text-sm text-indigo-400 hover:underline"
              >
                Load more ({transactions.total - transactions.items.length} remaining)
              </button>
            </div>
          )}
        </>
      )}
    </div>
  </div>
</Layout>

<script>
  function showCheckoutError(msg: string) {
    const el = document.getElementById("checkout-error");
    if (!el) return;
    el.textContent = msg;
    el.classList.remove("hidden");
    el.scrollIntoView({ behavior: "smooth", block: "nearest" });
  }

  function toast(msg: string, ok = true) {
    const t = document.createElement("div");
    t.className = `fixed bottom-4 right-4 px-4 py-2 rounded-lg text-white text-sm z-50 ${ok ? "bg-emerald-600" : "bg-red-600"}`;
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(() => t.remove(), 4000);
  }

  // ── Buy credits ────────────────────────────────────────────────────────────
  // Use /api/credits/checkout proxy — cs_token is httpOnly so client JS
  // cannot read it directly from document.cookie.
  document.querySelectorAll(".buy-pack").forEach((btn) => {
    const button = btn as HTMLButtonElement;
    button.addEventListener("click", async () => {
      const credits = Number(button.dataset.credits);
      // Clear any previous checkout error
      const errEl = document.getElementById("checkout-error");
      if (errEl) errEl.classList.add("hidden");
      // Show loading without destroying child elements
      button.classList.add("opacity-50", "pointer-events-none");
      const noteEl = button.querySelector(".buy-pack-note");
      const origNote = noteEl?.textContent ?? "";
      if (noteEl) noteEl.textContent = "Redirecting…";
      button.disabled = true;

      try {
        const res = await fetch("/api/credits/checkout", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            credits,
            success_url: `${window.location.origin}/dashboard/credits?success=1`,
            cancel_url: `${window.location.origin}/dashboard/credits`,
          }),
        });

        if (res.status === 401) {
          window.location.href = "/login";
          return;
        }
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          showCheckoutError(err.detail ?? "Checkout failed. Please try again.");
          button.classList.remove("opacity-50", "pointer-events-none");
          if (noteEl) noteEl.textContent = origNote;
          button.disabled = false;
          return;
        }

        const { checkout_url } = await res.json();
        window.location.href = checkout_url;
      } catch {
        showCheckoutError("Failed to create checkout session. Please try again.");
        button.classList.remove("opacity-50", "pointer-events-none");
        if (noteEl) noteEl.textContent = origNote;
        button.disabled = false;
      }
    });
  });

  // ── Load more transactions ─────────────────────────────────────────────────
  const loadMoreBtn = document.getElementById("load-more-txn") as HTMLButtonElement | null;
  const tbody = document.getElementById("txn-tbody");

  loadMoreBtn?.addEventListener("click", async () => {
    const page = Number(loadMoreBtn.dataset.page ?? 2);
    const total = Number(loadMoreBtn.dataset.total ?? 0);
    const originalText = loadMoreBtn.textContent ?? "Load more";
    loadMoreBtn.textContent = "Loading…";
    loadMoreBtn.disabled = true;

    try {
      const res = await fetch(`/api/credits/transactions?page=${page}&page_size=50`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const items: any[] = data.items ?? [];

      items.forEach((t) => {
        const tr = document.createElement("tr");
        tr.className = "border-b border-gray-800/50 hover:bg-gray-800/20 transition-colors";
        const amt = Number(t.amount);
        const amtClass = amt > 0 ? "text-green-400" : "text-red-400";
        tr.innerHTML = `
          <td class="px-6 py-3 text-gray-300">${t.description ?? ""}</td>
          <td class="px-6 py-3 text-right font-mono font-medium ${amtClass}">${amt > 0 ? "+" : ""}${amt}</td>
          <td class="px-6 py-3 text-right text-gray-500">${new Date(t.created_at).toLocaleDateString()}</td>
        `;
        tbody?.appendChild(tr);
      });

      const loaded = page * 50;
      if (loaded < total) {
        loadMoreBtn.dataset.page = String(page + 1);
        loadMoreBtn.textContent = `Load more (${total - loaded} remaining)`;
        loadMoreBtn.disabled = false;
      } else {
        loadMoreBtn.parentElement?.remove(); // hide the button row
      }
    } catch {
      loadMoreBtn.textContent = originalText;
      loadMoreBtn.disabled = false;
      toast("Failed to load transactions — please try again", false);
    }
  });

  // ── Success banner ─────────────────────────────────────────────────────────
  const params = new URLSearchParams(window.location.search);
  if (params.get("success") === "1") {
    const banner = document.createElement("div");
    banner.className = "fixed top-4 right-4 bg-green-900 border border-green-700 text-green-300 px-4 py-3 rounded-lg text-sm z-50";
    banner.textContent = "✅ Payment successful! Credits have been added to your account.";
    document.body.appendChild(banner);
    setTimeout(() => banner.remove(), 5000);
  }
</script>
