---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Object.fromEntries(
  Astro.cookies.getAll().map((c) => [c.name, c.value])
));
if (!token) return Astro.redirect("/login");

// Load: quality report + human tasks (potential gold standards)
let report: any[] = [];
let humanTasks: any = { items: [], total: 0 };
let error: string | null = null;

try {
  [report, humanTasks] = await Promise.all([
    apiFetch<any[]>("/v1/quality/report", { token }),
    apiFetch<any>("/v1/tasks?page_size=50", { token }),
  ]);
} catch (e: any) {
  if (e.message?.includes("401") || e.message?.includes("403")) {
    return Astro.redirect("/login");
  }
  error = "Failed to load quality data";
}

// Filter to only human tasks
const human = (humanTasks?.items ?? []).filter((t: any) => t.execution_mode === "human");
const goldTasks = human.filter((t: any) => t.is_gold_standard);
const nonGoldHuman = human.filter((t: any) => !t.is_gold_standard);

function pct(val: number): string {
  return `${Math.round(val * 100)}%`;
}

function levelColor(acc: number): string {
  if (acc >= 0.95) return "text-green-400";
  if (acc >= 0.80) return "text-yellow-400";
  return "text-red-400";
}
---

<Layout title="Quality Control — CrowdSorcerer">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <!-- Breadcrumb -->
    <div class="text-sm text-gray-500 mb-6">
      <a href="/dashboard" class="hover:text-gray-300 transition-colors">Dashboard</a>
      <span class="mx-2">›</span>
      <span>Quality Control</span>
    </div>

    <div class="flex items-start justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold">Quality Control</h1>
        <p class="text-gray-400 text-sm mt-1">
          Mark tasks as gold standards and track worker accuracy.
        </p>
      </div>
    </div>

    {error && (
      <div class="bg-red-950/30 border border-red-800 rounded-xl p-4 mb-6 text-red-300 text-sm">
        {error}
      </div>
    )}

    <!-- Overview cards -->
    <div class="grid grid-cols-3 gap-4 mb-8">
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="text-sm text-gray-400 mb-1">Gold standard tasks</div>
        <div class="text-3xl font-bold text-violet-300">{goldTasks.length}</div>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="text-sm text-gray-400 mb-1">Workers evaluated</div>
        <div class="text-3xl font-bold">{report.length}</div>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="text-sm text-gray-400 mb-1">Avg accuracy</div>
        <div class="text-3xl font-bold text-green-400">
          {report.length > 0
            ? pct(report.reduce((s: number, r: any) => s + r.accuracy, 0) / report.length)
            : "—"}
        </div>
      </div>
    </div>

    <!-- Worker Quality Report -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl mb-8">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-800">
        <div>
          <h2 class="font-semibold">Worker accuracy report</h2>
          <p class="text-xs text-gray-500 mt-0.5">Ranked by accuracy on your gold standard tasks</p>
        </div>
      </div>

      {report.length === 0 ? (
        <div class="px-6 py-12 text-center text-gray-500 text-sm">
          <div class="text-3xl mb-3">🎯</div>
          <p class="font-medium mb-1">No quality data yet</p>
          <p>Mark some tasks as gold standards and evaluate worker submissions to see accuracy scores.</p>
        </div>
      ) : (
        <div class="divide-y divide-gray-800">
          {report.map((r: any, i: number) => (
            <div class="flex items-center justify-between px-6 py-4">
              <div class="flex items-center gap-4">
                <div class="w-7 h-7 rounded-full bg-gray-800 flex items-center justify-center text-xs font-bold text-gray-400">
                  {i + 1}
                </div>
                <div>
                  <div class="font-medium text-sm">{r.name ?? "Anonymous"}</div>
                  <div class="text-xs text-gray-500">Lv.{r.worker_level} · {r.worker_xp} XP</div>
                </div>
              </div>
              <div class="flex items-center gap-8 text-sm">
                <div class="text-right">
                  <div class="text-xs text-gray-500 mb-0.5">Accuracy</div>
                  <div class:list={["font-bold", levelColor(r.accuracy)]}>
                    {pct(r.accuracy)}
                  </div>
                </div>
                <div class="text-right">
                  <div class="text-xs text-gray-500 mb-0.5">Reliability</div>
                  <div class="font-medium">
                    {r.reliability != null ? pct(r.reliability) : "—"}
                  </div>
                </div>
                <div class="text-right">
                  <div class="text-xs text-gray-500 mb-0.5">Evaluated</div>
                  <div class="font-medium">{r.tasks_correct}/{r.tasks_evaluated}</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Gold Standard Tasks -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl mb-8">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-800">
        <div>
          <h2 class="font-semibold">Gold standard tasks</h2>
          <p class="text-xs text-gray-500 mt-0.5">Tasks with known correct answers used for QC</p>
        </div>
      </div>

      {goldTasks.length === 0 ? (
        <div class="px-6 py-10 text-center text-gray-500 text-sm">
          No gold standard tasks yet.
          <a href="/dashboard/tasks" class="text-violet-400 ml-1">Mark a human task as gold standard →</a>
        </div>
      ) : (
        <div class="divide-y divide-gray-800">
          {goldTasks.map((t: any) => (
            <div class="flex items-center justify-between px-6 py-4">
              <div class="flex items-center gap-3">
                <span class="text-amber-400 text-lg">⭐</span>
                <div>
                  <a href={`/dashboard/tasks/${t.id}`} class="font-mono text-sm text-violet-300 hover:text-violet-200">
                    {t.type}
                  </a>
                  <div class="text-xs text-gray-500 font-mono">{t.id.slice(0, 8)}…</div>
                </div>
              </div>
              <div class="flex items-center gap-6 text-sm text-gray-400">
                <span>{t.assignments_completed}/{t.assignments_required} submissions</span>
                <a
                  href={`/dashboard/quality/evaluate/${t.id}`}
                  class="px-3 py-1 bg-violet-600 hover:bg-violet-500 text-white text-xs rounded-lg transition-colors"
                >
                  Evaluate
                </a>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Non-gold human tasks — can be marked -->
    {nonGoldHuman.length > 0 && (
      <div class="bg-gray-900 border border-gray-800 rounded-xl">
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-800">
          <div>
            <h2 class="font-semibold">Mark as gold standard</h2>
            <p class="text-xs text-gray-500 mt-0.5">
              Select a human task and provide the correct answer to use for quality control
            </p>
          </div>
        </div>
        <div class="divide-y divide-gray-800">
          {nonGoldHuman.slice(0, 20).map((t: any) => (
            <div class="flex items-center justify-between px-6 py-4">
              <div class="flex items-center gap-3">
                <div>
                  <a href={`/dashboard/tasks/${t.id}`} class="font-mono text-sm text-violet-300 hover:text-violet-200">
                    {t.type}
                  </a>
                  <div class="text-xs text-gray-500 font-mono">{t.id.slice(0, 8)}… · {t.status}</div>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <span class="text-xs text-gray-500">
                  {t.assignments_completed}/{t.assignments_required} workers
                </span>
                <a
                  href={`/dashboard/quality/mark/${t.id}`}
                  class="px-3 py-1 bg-amber-600 hover:bg-amber-500 text-white text-xs rounded-lg transition-colors"
                >
                  Set gold answer
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</Layout>
