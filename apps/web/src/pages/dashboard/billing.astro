---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Object.fromEntries(
  Astro.cookies.getAll().map((c) => [c.name, c.value])
));
if (!token) return Astro.redirect("/login");

let user: any = null;
let transactions: any[] = [];

try {
  user = await apiFetch<any>("/v1/users/me", { token });
} catch (_) {
  return Astro.redirect("/login");
}

try {
  const txRes = await apiFetch<any>("/v1/credits/history?limit=20", { token });
  transactions = txRes?.transactions ?? txRes ?? [];
} catch (_) {
  transactions = [];
}

const PLAN_FEATURES: Record<string, string[]> = {
  free: ["100 credits/month", "10 tasks/day", "2 pipelines", "Community support"],
  starter: ["2,000 credits/month", "100 tasks/day", "10 pipelines", "Email support"],
  pro: ["10,000 credits/month", "500 tasks/day", "Unlimited pipelines", "Priority support"],
  enterprise: ["Unlimited credits", "Unlimited tasks", "Unlimited pipelines", "Dedicated support"],
};

const PLAN_PRICES: Record<string, string> = {
  free: "Free",
  starter: "$9/mo",
  pro: "$29/mo",
  enterprise: "Custom",
};

const PLAN_COLORS: Record<string, string> = {
  free: "border-gray-700",
  starter: "border-violet-700",
  pro: "border-indigo-500",
  enterprise: "border-amber-600",
};

const currentPlan = user?.plan ?? "free";
---

<Layout title="Billing & Plan — CrowdSorcerer">
  <div class="max-w-4xl mx-auto px-6 py-10">
    <div class="text-sm text-gray-500 mb-6">
      <a href="/dashboard" class="hover:text-gray-300 transition-colors">Dashboard</a>
      <span class="mx-2">›</span>
      <span>Billing & Plan</span>
    </div>

    <h1 class="text-2xl font-bold mb-2">Billing & Plan</h1>
    <p class="text-gray-400 text-sm mb-8">Manage your subscription, credits, and payment history.</p>

    <!-- Current plan banner -->
    <div class={`bg-gray-900 border-2 rounded-xl p-6 mb-8 ${PLAN_COLORS[currentPlan] ?? "border-gray-700"}`}>
      <div class="flex items-start justify-between flex-wrap gap-4">
        <div>
          <div class="flex items-center gap-3 mb-2">
            <span class="text-lg font-bold capitalize text-white">{currentPlan} Plan</span>
            {currentPlan !== "free" && (
              <span class="bg-violet-600 text-white text-xs px-2 py-0.5 rounded-full font-medium">Active</span>
            )}
          </div>
          <p class="text-gray-400 text-sm">{PLAN_PRICES[currentPlan]}</p>
          <ul class="mt-3 space-y-1">
            {(PLAN_FEATURES[currentPlan] ?? []).map((f: string) => (
              <li class="text-sm text-gray-300 flex items-center gap-2">
                <span class="text-green-400">✓</span> {f}
              </li>
            ))}
          </ul>
        </div>
        <div class="flex flex-col items-end gap-3">
          <div class="text-right">
            <div class="text-3xl font-bold text-white">{user?.credits?.toLocaleString()}</div>
            <div class="text-sm text-gray-400">credits remaining</div>
          </div>
          <a
            href="/dashboard/credits"
            class="px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors"
          >
            Buy Credits →
          </a>
        </div>
      </div>
    </div>

    <!-- Plan comparison -->
    <h2 class="text-lg font-semibold mb-4">Upgrade Your Plan</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
      {(["free", "starter", "pro", "enterprise"] as const).map((plan) => (
        <div class={`bg-gray-900 border rounded-xl p-5 flex flex-col ${plan === currentPlan ? "border-violet-500 ring-1 ring-violet-500/30" : "border-gray-800"}`}>
          <div class="flex items-center justify-between mb-1">
            <span class="font-bold capitalize text-white">{plan}</span>
            {plan === currentPlan && (
              <span class="text-xs text-violet-400 bg-violet-900/30 px-2 py-0.5 rounded-full">current</span>
            )}
          </div>
          <div class="text-2xl font-bold text-white mb-3">{PLAN_PRICES[plan]}</div>
          <ul class="space-y-1.5 flex-1 mb-4">
            {(PLAN_FEATURES[plan] ?? []).map((f: string) => (
              <li class="text-xs text-gray-400 flex items-start gap-1.5">
                <span class="text-green-500 mt-0.5">✓</span> {f}
              </li>
            ))}
          </ul>
          {plan !== currentPlan && plan !== "free" && plan !== "enterprise" && (
            <a
              href={`/api/billing/checkout?plan=${plan}`}
              class="w-full text-center px-3 py-2 bg-violet-600 hover:bg-violet-500 text-white text-xs font-medium rounded-lg transition-colors"
            >
              Upgrade to {plan.charAt(0).toUpperCase() + plan.slice(1)}
            </a>
          )}
          {plan === "enterprise" && (
            <a
              href="mailto:support@rebaselabs.online?subject=Enterprise Plan Inquiry"
              class="w-full text-center px-3 py-2 border border-amber-700 text-amber-400 text-xs font-medium rounded-lg hover:bg-amber-900/20 transition-colors"
            >
              Contact Sales
            </a>
          )}
          {plan === currentPlan && (
            <div class="text-center text-xs text-gray-600 py-2">Current plan</div>
          )}
          {plan === "free" && plan !== currentPlan && (
            <div class="text-center text-xs text-gray-600 py-2">Downgrade on cancellation</div>
          )}
        </div>
      ))}
    </div>

    <!-- Stripe portal link -->
    {currentPlan !== "free" && (
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mb-8 flex items-center justify-between">
        <div>
          <div class="font-medium text-gray-200 mb-1">Manage Subscription</div>
          <p class="text-sm text-gray-400">Update payment method, view invoices, or cancel subscription.</p>
        </div>
        <a
          href="https://billing.stripe.com/p/login/test_00g000000000000"
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 border border-gray-600 text-gray-300 text-sm rounded-lg hover:border-gray-400 hover:text-white transition-colors whitespace-nowrap"
        >
          Stripe Portal →
        </a>
      </div>
    )}

    <!-- Transaction history -->
    <h2 class="text-lg font-semibold mb-4">Recent Transactions</h2>
    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
      {transactions.length === 0 ? (
        <div class="px-6 py-10 text-center text-gray-500 text-sm">
          No transactions yet. Buy credits to get started.
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-800 text-left">
              <th class="px-4 py-3 text-gray-500 font-medium">Description</th>
              <th class="px-4 py-3 text-gray-500 font-medium text-right">Amount</th>
              <th class="px-4 py-3 text-gray-500 font-medium text-right hidden sm:table-cell">Balance</th>
              <th class="px-4 py-3 text-gray-500 font-medium text-right hidden md:table-cell">Date</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800/60">
            {transactions.map((txn: any) => (
              <tr class="hover:bg-gray-800/30 transition-colors">
                <td class="px-4 py-3 text-gray-300">
                  {txn.description ?? txn.reference_type ?? "Transaction"}
                </td>
                <td class:list={[
                  "px-4 py-3 text-right font-mono font-medium",
                  txn.amount >= 0 ? "text-green-400" : "text-red-400"
                ]}>
                  {txn.amount >= 0 ? "+" : ""}{txn.amount} cr
                </td>
                <td class="px-4 py-3 text-right text-gray-500 font-mono hidden sm:table-cell">
                  {txn.balance_after ?? "—"} cr
                </td>
                <td class="px-4 py-3 text-right text-gray-500 hidden md:table-cell">
                  {txn.created_at ? new Date(txn.created_at).toLocaleDateString() : "—"}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>

    <div class="mt-6 text-center">
      <a href="/dashboard/credits" class="text-violet-400 hover:text-violet-300 text-sm transition-colors">
        View full transaction history →
      </a>
    </div>
  </div>
</Layout>
