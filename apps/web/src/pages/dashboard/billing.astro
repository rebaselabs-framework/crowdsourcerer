---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login");

let user: any = null;
let transactions: any[] = [];
let creditAlert: any = null;
let alertSuccess = "";
let alertError = "";

// Handle POST (update credit alert threshold)
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("action") as string;
  if (action === "set_credit_alert") {
    const rawThreshold = form.get("threshold") as string;
    const threshold = rawThreshold ? parseInt(rawThreshold) : null;
    try {
      await apiFetch<any>("/v1/users/credit-alert", {
        method: "PATCH",
        body: JSON.stringify({ threshold }),
        token,
      });
      alertSuccess = threshold
        ? `Alert set: you'll be notified when balance drops below ${threshold.toLocaleString()} credits.`
        : "Credit alert disabled.";
    } catch (e: any) {
      if (e.message?.includes("401") || e.message?.includes("403")) return Astro.redirect("/login");
      alertError = e.message ?? "Failed to update alert";
    }
  }
}

try {
  user = await apiFetch<any>("/v1/users/me", { token });
} catch (e: any) {
  // Only redirect to login for actual authentication failures.
  if (e.message?.includes("401") || e.message?.includes("403")) {
    return Astro.redirect("/login");
  }
}

try {
  const txRes = await apiFetch<any>("/v1/credits/history?limit=20", { token });
  transactions = txRes?.transactions ?? txRes ?? [];
} catch (_) {
  transactions = [];
}

try {
  creditAlert = await apiFetch<any>("/v1/users/credit-alert", { token });
} catch (_) {
  creditAlert = null;
}

const PLAN_FEATURES: Record<string, string[]> = {
  free: ["1,000 credits on signup", "10 tasks/day", "2 pipelines", "Community support"],
  starter: ["2,000 credits/month", "100 tasks/day", "10 pipelines", "Email support"],
  pro: ["10,000 credits/month", "500 tasks/day", "Unlimited pipelines", "Priority support"],
  enterprise: ["Unlimited credits", "Unlimited tasks", "Unlimited pipelines", "Dedicated support"],
};

const PLAN_PRICES: Record<string, string> = {
  free: "Free",
  starter: "$9/mo",
  pro: "$29/mo",
  enterprise: "Custom",
};

const PLAN_COLORS: Record<string, string> = {
  free: "border-gray-700",
  starter: "border-violet-700",
  pro: "border-indigo-500",
  enterprise: "border-amber-600",
};

const currentPlan = user?.plan ?? "free";
---

<Layout title="Billing & Plan — CrowdSorcerer">
  <div class="max-w-4xl mx-auto px-6 py-10">
    <div class="text-sm text-gray-500 mb-6">
      <a href="/dashboard" class="hover:text-gray-300 transition-colors">Dashboard</a>
      <span class="mx-2">›</span>
      <span>Billing & Plan</span>
    </div>

    <h1 class="text-2xl font-bold mb-2">Billing & Plan</h1>
    <p class="text-gray-400 text-sm mb-8">Manage your subscription, credits, and payment history.</p>

    <!-- Current plan banner -->
    <div class={`bg-gray-900 border-2 rounded-xl p-6 mb-8 ${PLAN_COLORS[currentPlan] ?? "border-gray-700"}`}>
      <div class="flex items-start justify-between flex-wrap gap-4">
        <div>
          <div class="flex items-center gap-3 mb-2">
            <span class="text-lg font-bold capitalize text-white">{currentPlan} Plan</span>
            {currentPlan !== "free" && (
              <span class="bg-violet-600 text-white text-xs px-2 py-0.5 rounded-full font-medium">Active</span>
            )}
          </div>
          <p class="text-gray-400 text-sm">{PLAN_PRICES[currentPlan]}</p>
          <ul class="mt-3 space-y-1">
            {(PLAN_FEATURES[currentPlan] ?? []).map((f: string) => (
              <li class="text-sm text-gray-300 flex items-center gap-2">
                <span class="text-green-400">✓</span> {f}
              </li>
            ))}
          </ul>
        </div>
        <div class="flex flex-col items-end gap-3">
          <div class="text-right">
            <div class="text-3xl font-bold text-white">{user?.credits?.toLocaleString()}</div>
            <div class="text-sm text-gray-400">credits remaining</div>
          </div>
          <a
            href="/dashboard/credits"
            class="px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors"
          >
            Buy Credits →
          </a>
        </div>
      </div>
    </div>

    <!-- ⚡ Quick Buy Credits -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 mb-8">
      <div class="flex items-center justify-between mb-1">
        <h2 class="text-sm font-semibold text-gray-200">⚡ Quick Buy Credits</h2>
        <span class="text-xs text-gray-500">1 credit = $0.01 USD</span>
      </div>
      <p class="text-xs text-gray-400 mb-5">One-click credit top-ups — no subscription needed.</p>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3" id="qb-grid">
        {[
          { credits: 500,    label: "Starter",  price: "$5",  bonus: "" },
          { credits: 1000,   label: "Popular",  price: "$10", bonus: "" },
          { credits: 2500,   label: "Value",    price: "$25", bonus: "+50 bonus" },
          { credits: 5000,   label: "Pro",      price: "$50", bonus: "+150 bonus" },
          { credits: 10000,  label: "Power",    price: "$100", bonus: "+500 bonus" },
        ].map(({ credits, label, price, bonus }) => (
          <button
            type="button"
            class="qb-btn relative flex flex-col items-center justify-center gap-1 p-4 rounded-xl border border-gray-700 hover:border-violet-500 hover:bg-violet-900/10 transition-all group focus:outline-none focus:ring-2 focus:ring-violet-500/50"
            data-credits={credits}
          >
            <span class="text-xs font-medium text-gray-400 group-hover:text-violet-300 transition-colors">{label}</span>
            <span class="text-xl font-bold text-white">{credits.toLocaleString()}</span>
            <span class="text-xs text-gray-500">credits</span>
            <span class="text-sm font-semibold text-violet-400">{price}</span>
            {bonus && (
              <span class="absolute -top-2 -right-2 text-[10px] bg-emerald-700 text-white px-1.5 py-0.5 rounded-full font-bold shadow">{bonus}</span>
            )}
          </button>
        ))}
      </div>

      <p id="qb-error" class="hidden text-xs text-red-400 mt-3"></p>
      <p id="qb-info" class="hidden text-xs text-gray-400 mt-3">Redirecting to Stripe checkout…</p>
    </div>

    <!-- Credit Burn-Rate Alert -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 mb-8">
      <div class="flex items-start justify-between mb-4">
        <div>
          <h2 class="text-sm font-semibold text-gray-200">🔔 Low Credit Alert</h2>
          <p class="text-xs text-gray-400 mt-1">
            Get notified when your balance drops below a threshold so you never run out unexpectedly.
          </p>
        </div>
        {creditAlert?.alert_fired && (
          <span class="text-xs bg-red-900/40 text-red-300 border border-red-700/40 px-2 py-1 rounded-full flex-shrink-0">
            ⚠️ Alert has fired
          </span>
        )}
        {creditAlert?.threshold && !creditAlert.alert_fired && (
          <span class="text-xs bg-emerald-900/40 text-emerald-300 border border-emerald-700/40 px-2 py-1 rounded-full flex-shrink-0">
            ✅ Active at {creditAlert.threshold.toLocaleString()} cr
          </span>
        )}
      </div>

      {alertSuccess && (
        <div class="bg-emerald-900/30 border border-emerald-700/50 rounded-lg p-3 mb-4 text-emerald-300 text-xs">{alertSuccess}</div>
      )}
      {alertError && (
        <div class="bg-red-900/30 border border-red-700/50 rounded-lg p-3 mb-4 text-red-300 text-xs">{alertError}</div>
      )}

      <form method="POST" class="flex gap-3 items-end">
        <input type="hidden" name="action" value="set_credit_alert" />
        <div class="flex-1">
          <label class="block text-xs text-gray-400 mb-1.5">Alert threshold (credits)</label>
          <input
            type="number"
            name="threshold"
            min="0"
            max="1000000"
            step="100"
            placeholder="e.g. 500 — leave blank to disable"
            value={creditAlert?.threshold ?? ""}
            class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-violet-500 placeholder-gray-600"
          />
          <p class="text-xs text-gray-600 mt-1">
            Current balance: <span class="text-white">{user?.credits?.toLocaleString() ?? 0}</span> credits
            {creditAlert?.threshold && (
              <> · Alert at <span class="text-orange-400">{creditAlert.threshold.toLocaleString()}</span></>
            )}
          </p>
        </div>
        <button type="submit" class="px-4 py-2 bg-violet-700 hover:bg-violet-600 text-white text-sm font-medium rounded-lg transition-colors whitespace-nowrap">
          Save Alert
        </button>
      </form>
    </div>

    <!-- Plan comparison -->
    <h2 class="text-lg font-semibold mb-4">Upgrade Your Plan</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
      {(["free", "starter", "pro", "enterprise"] as const).map((plan) => (
        <div class={`bg-gray-900 border rounded-xl p-5 flex flex-col ${plan === currentPlan ? "border-violet-500 ring-1 ring-violet-500/30" : "border-gray-800"}`}>
          <div class="flex items-center justify-between mb-1">
            <span class="font-bold capitalize text-white">{plan}</span>
            {plan === currentPlan && (
              <span class="text-xs text-violet-400 bg-violet-900/30 px-2 py-0.5 rounded-full">current</span>
            )}
          </div>
          <div class="text-2xl font-bold text-white mb-3">{PLAN_PRICES[plan]}</div>
          <ul class="space-y-1.5 flex-1 mb-4">
            {(PLAN_FEATURES[plan] ?? []).map((f: string) => (
              <li class="text-xs text-gray-400 flex items-start gap-1.5">
                <span class="text-green-500 mt-0.5">✓</span> {f}
              </li>
            ))}
          </ul>
          {plan !== currentPlan && plan !== "free" && plan !== "enterprise" && (
            <a
              href={`/api/billing/checkout?plan=${plan}`}
              class="w-full text-center px-3 py-2 bg-violet-600 hover:bg-violet-500 text-white text-xs font-medium rounded-lg transition-colors"
            >
              Upgrade to {plan.charAt(0).toUpperCase() + plan.slice(1)}
            </a>
          )}
          {plan === "enterprise" && (
            <a
              href="mailto:support@rebaselabs.online?subject=Enterprise Plan Inquiry"
              class="w-full text-center px-3 py-2 border border-amber-700 text-amber-400 text-xs font-medium rounded-lg hover:bg-amber-900/20 transition-colors"
            >
              Contact Sales
            </a>
          )}
          {plan === currentPlan && (
            <div class="text-center text-xs text-gray-600 py-2">Current plan</div>
          )}
          {plan === "free" && plan !== currentPlan && (
            <div class="text-center text-xs text-gray-600 py-2">Downgrade on cancellation</div>
          )}
        </div>
      ))}
    </div>

    <!-- Stripe portal link -->
    {currentPlan !== "free" && (
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mb-8 flex items-center justify-between">
        <div>
          <div class="font-medium text-gray-200 mb-1">Manage Subscription</div>
          <p class="text-sm text-gray-400">Update payment method, view invoices, or cancel subscription.</p>
        </div>
        <a
          href="https://billing.stripe.com/p/login/test_00g000000000000"
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 border border-gray-600 text-gray-300 text-sm rounded-lg hover:border-gray-400 hover:text-white transition-colors whitespace-nowrap"
        >
          Stripe Portal →
        </a>
      </div>
    )}

    <!-- Transaction history -->
    <h2 class="text-lg font-semibold mb-4">Recent Transactions</h2>
    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
      {transactions.length === 0 ? (
        <div class="px-6 py-10 text-center text-gray-500 text-sm">
          No transactions yet. Buy credits to get started.
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-800 text-left">
              <th class="px-4 py-3 text-gray-500 font-medium">Description</th>
              <th class="px-4 py-3 text-gray-500 font-medium text-right">Amount</th>
              <th class="px-4 py-3 text-gray-500 font-medium text-right hidden sm:table-cell">Balance</th>
              <th class="px-4 py-3 text-gray-500 font-medium text-right hidden md:table-cell">Date</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800/60">
            {transactions.map((txn: any) => (
              <tr class="hover:bg-gray-800/30 transition-colors">
                <td class="px-4 py-3 text-gray-300">
                  {txn.description ?? txn.reference_type ?? "Transaction"}
                </td>
                <td class:list={[
                  "px-4 py-3 text-right font-mono font-medium",
                  txn.amount >= 0 ? "text-green-400" : "text-red-400"
                ]}>
                  {txn.amount >= 0 ? "+" : ""}{txn.amount} cr
                </td>
                <td class="px-4 py-3 text-right text-gray-500 font-mono hidden sm:table-cell">
                  {txn.balance_after ?? "—"} cr
                </td>
                <td class="px-4 py-3 text-right text-gray-500 hidden md:table-cell">
                  {txn.created_at ? new Date(txn.created_at).toLocaleDateString() : "—"}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>

    <div class="mt-6 text-center">
      <a href="/dashboard/credits" class="text-violet-400 hover:text-violet-300 text-sm transition-colors">
        View full transaction history →
      </a>
    </div>
  </div>
</Layout>

<script>
  // Quick-buy credit bundles — client-side Stripe checkout redirect
  document.querySelectorAll<HTMLButtonElement>(".qb-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const credits = parseInt(btn.dataset.credits ?? "0", 10);
      if (!credits) return;

      const errorEl  = document.getElementById("qb-error")  as HTMLParagraphElement;
      const infoEl   = document.getElementById("qb-info")   as HTMLParagraphElement;
      const grid     = document.getElementById("qb-grid")   as HTMLDivElement;

      // UI: disable all buttons, show loading
      grid.querySelectorAll<HTMLButtonElement>(".qb-btn").forEach((b) => b.disabled = true);
      infoEl.classList.remove("hidden");
      errorEl.classList.add("hidden");
      btn.classList.add("ring-2", "ring-violet-500");
      btn.innerHTML += `<span class="absolute inset-0 flex items-center justify-center bg-gray-900/70 rounded-xl text-sm">⏳</span>`;

      try {
        const origin = window.location.origin;
        const res = await fetch("/api/credits/checkout", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            credits,
            success_url: `${origin}/dashboard/billing?bought=${credits}`,
            cancel_url:  `${origin}/dashboard/billing`,
          }),
        });
        const data = await res.json();

        if (!res.ok) {
          throw new Error(data.detail ?? `Error ${res.status}`);
        }
        if (data.checkout_url) {
          window.location.href = data.checkout_url;
        } else {
          throw new Error("No checkout URL returned");
        }
      } catch (err: any) {
        errorEl.textContent = `Checkout failed: ${err.message}`;
        errorEl.classList.remove("hidden");
        infoEl.classList.add("hidden");
        grid.querySelectorAll<HTMLButtonElement>(".qb-btn").forEach((b) => {
          b.disabled = false;
          b.classList.remove("ring-2", "ring-violet-500");
        });
        // Remove the spinner span we appended
        btn.querySelector("span.absolute.inset-0")?.remove();
      }
    });
  });

  // Show success banner if redirected back with ?bought=N
  const params = new URLSearchParams(window.location.search);
  const bought = parseInt(params.get("bought") ?? "0", 10);
  if (bought > 0) {
    const banner = document.createElement("div");
    banner.className = "fixed top-4 right-4 z-50 bg-emerald-800 border border-emerald-600 text-white text-sm font-medium px-5 py-3 rounded-xl shadow-lg flex items-center gap-3";
    banner.innerHTML = `<span>🎉 ${bought.toLocaleString()} credits added to your account!</span><button onclick="this.parentElement.remove()" class="ml-2 text-emerald-300 hover:text-white">✕</button>`;
    document.body.appendChild(banner);
    // Auto-dismiss after 6s
    setTimeout(() => banner.remove(), 6000);
    // Remove query param without reload
    history.replaceState({}, "", window.location.pathname);
  }
</script>
