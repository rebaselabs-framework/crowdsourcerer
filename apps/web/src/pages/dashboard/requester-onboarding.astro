---
/**
 * Requester Onboarding — guided 5-step tutorial for new requesters.
 * Mirrors the worker onboarding flow but focused on posting tasks, not earning.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Object.fromEntries(
  Astro.cookies.getAll().map((c) => [c.name, c.value])
));
if (!token) return Astro.redirect("/login?next=/dashboard/requester-onboarding");

// Handle POST actions
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("action") as string;
  const step = form.get("step") as string;

  try {
    if (action === "complete_step" && step) {
      await apiFetch(`/v1/requester-onboarding/steps/${step}/complete`, { method: "POST", token });
    } else if (action === "skip_step" && step) {
      await apiFetch(`/v1/requester-onboarding/steps/${step}/skip`, { method: "POST", token });
    } else if (action === "reset") {
      await apiFetch("/v1/requester-onboarding/reset", { method: "POST", token });
    }
  } catch (_) {}
  return Astro.redirect("/dashboard/requester-onboarding");
}

let progress: any = null;
let error: string | null = null;

try {
  progress = await apiFetch<any>("/v1/requester-onboarding/status", { token });
} catch (e: any) {
  if (e.message?.includes("401")) return Astro.redirect("/login");
  error = e.message ?? "Failed to load onboarding status.";
}

const skippable = new Set(["set_webhook", "invite_team"]);
---

<Layout title="Get Started — CrowdSorcerer">
  <div class="max-w-2xl mx-auto px-6 py-10">

    <!-- Header -->
    <div class="mb-8 text-center">
      <div class="text-5xl mb-4">🚀</div>
      <h1 class="text-2xl font-bold mb-2">Get Started with CrowdSorcerer</h1>
      <p class="text-gray-400 text-sm">Complete these steps to unlock the full power of the platform.</p>

      {progress?.bonus_claimed ? (
        <div class="mt-3 inline-flex items-center gap-2 px-4 py-2 bg-green-900/20 border border-green-800/40 text-green-400 rounded-full text-sm">
          ✅ Onboarding complete — you earned your bonus!
        </div>
      ) : progress?.all_complete ? (
        <div class="mt-3 inline-flex items-center gap-2 px-4 py-2 bg-green-900/20 border border-green-800/40 text-green-400 rounded-full text-sm">
          ✅ All steps complete!
        </div>
      ) : null}
    </div>

    {error ? (
      <div class="bg-red-900/30 border border-red-800 text-red-300 p-4 rounded-lg">{error}</div>
    ) : progress && (
      <>
        <!-- Progress bar -->
        <div class="mb-8">
          <div class="flex justify-between text-sm text-gray-400 mb-2">
            <span>{progress.completed_count} of {progress.total_steps} steps completed</span>
            <span class="text-violet-400 font-medium">{Math.round((progress.completed_count / progress.total_steps) * 100)}%</span>
          </div>
          <div class="w-full bg-gray-800 rounded-full h-3">
            <div
              class="bg-gradient-to-r from-violet-600 to-indigo-500 h-3 rounded-full transition-all duration-500"
              style={`width:${Math.round((progress.completed_count / progress.total_steps) * 100)}%`}
            ></div>
          </div>
        </div>

        <!-- Bonus callout -->
        {!progress.all_complete && (
          <div class="mb-6 p-4 bg-amber-900/20 border border-amber-800/40 rounded-xl">
            <div class="flex items-center gap-3">
              <div class="text-2xl">🎁</div>
              <div>
                <div class="font-medium text-amber-300 text-sm">
                  Complete all steps to earn +{progress.bonus_credits} bonus credits!
                </div>
                <div class="text-xs text-gray-400 mt-0.5">
                  That's ${(progress.bonus_credits / 100).toFixed(2)} in free task credits — no strings attached.
                </div>
              </div>
            </div>
          </div>
        )}

        <!-- Steps -->
        <div class="space-y-3 mb-8">
          {progress.steps.map((step: any, idx: number) => (
            <div class={`border rounded-xl p-5 transition-all ${
              step.completed
                ? "bg-green-900/10 border-green-800/40 opacity-75"
                : "bg-gray-900 border-gray-800"
            }`}>
              <div class="flex items-center gap-4">
                <!-- Step icon / check -->
                <div class={`w-10 h-10 rounded-full flex items-center justify-center text-lg shrink-0 ${
                  step.completed
                    ? "bg-green-900/40 text-green-400"
                    : "bg-gray-800 text-gray-400"
                }`}>
                  {step.completed ? "✓" : step.icon}
                </div>

                <!-- Content -->
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <h3 class={`font-medium text-sm ${step.completed ? "text-green-300 line-through opacity-60" : "text-white"}`}>
                      {step.title}
                    </h3>
                    {step.completed && (
                      <span class="text-xs text-green-500">Done!</span>
                    )}
                    {skippable.has(step.key) && !step.completed && (
                      <span class="text-xs text-gray-600 italic">optional</span>
                    )}
                  </div>
                  <p class="text-xs text-gray-400 mt-0.5">{step.description}</p>
                </div>

                <!-- CTAs -->
                {!step.completed && (
                  <div class="flex gap-2 shrink-0 flex-wrap">
                    <a href={step.cta_url}
                      class="px-3 py-1.5 bg-violet-600 hover:bg-violet-700 text-white rounded-lg text-xs font-medium transition-colors whitespace-nowrap">
                      {step.cta}
                    </a>

                    <!-- Manual mark-as-done -->
                    <form method="POST">
                      <input type="hidden" name="action" value="complete_step" />
                      <input type="hidden" name="step" value={step.key} />
                      <button
                        class="px-3 py-1.5 bg-gray-700 hover:bg-gray-600 text-gray-300 rounded-lg text-xs transition-colors"
                        title="Mark as done">
                        ✓ Done
                      </button>
                    </form>

                    <!-- Skip (only for skippable steps) -->
                    {skippable.has(step.key) && (
                      <form method="POST">
                        <input type="hidden" name="action" value="skip_step" />
                        <input type="hidden" name="step" value={step.key} />
                        <button
                          class="px-3 py-1.5 bg-gray-800 hover:bg-gray-700 text-gray-500 hover:text-gray-400 rounded-lg text-xs transition-colors"
                          title="Skip this step">
                          Skip
                        </button>
                      </form>
                    )}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>

        <!-- Navigation -->
        <div class="flex items-center justify-between">
          <a href="/dashboard"
            class="text-sm text-gray-500 hover:text-gray-400 transition-colors">
            ← Back to dashboard
          </a>
          {progress.all_complete && (
            <a href="/dashboard/requester"
              class="px-4 py-2 bg-violet-600 hover:bg-violet-700 text-white rounded-lg text-sm font-medium transition-colors">
              Go to Requester Hub →
            </a>
          )}
        </div>

        <!-- Completion celebration -->
        {progress.all_complete && (
          <div class="mt-8 p-6 bg-gradient-to-br from-violet-900/30 to-indigo-900/20 border border-violet-800/40 rounded-xl text-center">
            <div class="text-4xl mb-3">🏆</div>
            <h2 class="text-lg font-bold text-violet-300 mb-1">You're fully set up!</h2>
            <p class="text-sm text-gray-400 mb-4">
              You've completed all onboarding steps.
              {progress.bonus_claimed
                ? " Your bonus credits have been added to your account."
                : " Claim your completion bonus now!"}
            </p>
            <div class="flex gap-3 justify-center">
              <a href="/dashboard/tasks/new"
                class="px-4 py-2 bg-violet-600 hover:bg-violet-700 text-white rounded-lg text-sm font-medium transition-colors">
                Create a Task
              </a>
              <a href="/dashboard/requester"
                class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-lg text-sm transition-colors">
                Requester Hub
              </a>
            </div>
          </div>
        )}
      </>
    )}
  </div>
</Layout>
