---
/**
 * My Profile — /dashboard/profile
 * Workers can edit their public profile (name, bio, avatar, location, website, visibility).
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken, withTimeout } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login");

let me: any = null;
let status: any = null;
let myCerts: any[] = [];
let error = "";

try {
  [me, status] = await Promise.all([
    apiFetch<any>("/v1/users/me", { token }),
    apiFetch<any>("/v1/users/me/profile-status", { token }),
  ]);
} catch (e: any) {
  if (e.message?.includes("401") || e.message?.includes("403")) {
    return Astro.redirect("/login");
  }
  error = e.message ?? "Failed to load profile";
}

const isWorker = me?.role === "worker" || me?.role === "both";

// Fetch earned certifications for workers only (non-critical — use withTimeout)
if (isWorker) {
  try {
    myCerts = await withTimeout(
      apiFetch<any>("/v1/certifications/me/earned", { token }),
      3000,
      [],
    );
    myCerts = myCerts ?? [];
  } catch {
    myCerts = [];
  }
}

// Completeness items — mirrors the server-side score breakdown
const completenessItems = [
  { key: "has_name",     label: "Name",     done: status?.has_name },
  { key: "has_bio",      label: "Bio",      done: status?.has_bio },
  { key: "has_avatar",   label: "Avatar",   done: status?.has_avatar },
  { key: "has_location", label: "Location", done: status?.has_location },
  { key: "has_website",  label: "Website",  done: status?.has_website },
  ...(isWorker ? [
    { key: "has_skills", label: "Skills",   done: (status?.skill_count ?? 0) > 0 },
    { key: "has_cert",   label: "Certified", done: (status?.cert_count ?? 0) > 0 },
  ] : []),
];

const earnedCerts = myCerts.filter((c: any) => c.passed);
---

<Layout title="My Profile — CrowdSorcerer">
  <div class="max-w-2xl mx-auto px-6 py-10">
    <h1 class="text-2xl font-bold text-white mb-2">My Profile</h1>
    <p class="text-gray-400 text-sm mb-8">
      Manage your public profile visible to requesters and other workers.
    </p>

    {error && (
      <div class="bg-red-900/30 border border-red-700 text-red-300 rounded-lg p-4 mb-6 text-sm">{error}</div>
    )}

    {me && (
      <div class="space-y-6">

        {/* ── Completeness bar ─────────────────────────── */}
        <div class="bg-gray-800 border border-gray-700 rounded-xl p-5">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-medium text-gray-300">Profile completeness</span>
            <span class="text-sm font-bold text-white">{status?.completeness_pct ?? 0}%</span>
          </div>
          <div class="w-full bg-gray-700 rounded-full h-2">
            <div
              class="bg-indigo-500 h-2 rounded-full transition-all"
              style={`width: ${status?.completeness_pct ?? 0}%`}
            />
          </div>
          <div class="mt-3 flex flex-wrap gap-2 text-xs">
            {completenessItems.map(f => (
              <span class={`px-2 py-0.5 rounded-full border ${f.done ? "border-green-700 bg-green-900/30 text-green-400" : "border-gray-600 bg-gray-700/30 text-gray-400"}`}>
                {f.done ? "✓" : "○"} {f.label}
              </span>
            ))}
          </div>
          {isWorker && (status?.skill_count ?? 0) === 0 && (
            <p class="mt-3 text-xs text-amber-400">
              💡 Add skills to unlock the worker marketplace and earn the full completeness score.{" "}
              <a href="/worker/skills" class="underline hover:text-amber-300">Add skills →</a>
            </p>
          )}
        </div>

        {/* ── Edit form ─────────────────────────────────── */}
        <div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
          <h2 class="text-base font-semibold text-white mb-5">Edit Profile</h2>

          <div id="save-result" class="hidden mb-4 p-3 rounded-lg text-sm"></div>

          <form id="profile-form" class="space-y-5">
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Display Name</label>
              <input
                type="text"
                name="name"
                value={me.name ?? ""}
                maxlength="255"
                class="w-full bg-gray-700 border border-gray-600 rounded-lg px-3 py-2 text-white text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none"
                placeholder="Your name"
              />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Bio</label>
              <textarea
                name="bio"
                maxlength="500"
                rows="3"
                class="w-full bg-gray-700 border border-gray-600 rounded-lg px-3 py-2 text-white text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none resize-none"
                placeholder="A short intro about yourself (max 500 chars)"
              >{me.bio ?? ""}</textarea>
              <p class="text-xs text-gray-500 mt-1">Max 500 characters</p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1">Avatar URL</label>
              <input
                type="url"
                name="avatar_url"
                value={me.avatar_url ?? ""}
                maxlength="512"
                class="w-full bg-gray-700 border border-gray-600 rounded-lg px-3 py-2 text-white text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none"
                placeholder="https://example.com/avatar.jpg"
              />
              <p class="text-xs text-gray-500 mt-1">Link to a publicly accessible image</p>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Location</label>
                <input
                  type="text"
                  name="location"
                  value={me.location ?? ""}
                  maxlength="128"
                  class="w-full bg-gray-700 border border-gray-600 rounded-lg px-3 py-2 text-white text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none"
                  placeholder="City, Country"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Website</label>
                <input
                  type="url"
                  name="website_url"
                  value={me.website_url ?? ""}
                  maxlength="512"
                  class="w-full bg-gray-700 border border-gray-600 rounded-lg px-3 py-2 text-white text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none"
                  placeholder="https://yoursite.com"
                />
              </div>
            </div>

            <div class="flex items-center justify-between p-4 bg-gray-700/50 rounded-lg border border-gray-600">
              <div>
                <p class="text-sm font-medium text-gray-200">Public profile</p>
                <p class="text-xs text-gray-400 mt-0.5">Allow others to view your profile page</p>
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input
                  type="checkbox"
                  name="profile_public"
                  id="profile_public_toggle"
                  class="sr-only peer"
                  checked={me.profile_public !== false}
                />
                <div class="w-11 h-6 bg-gray-600 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600" />
              </label>
            </div>

            <div class="flex gap-3">
              <button
                type="submit"
                class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2 rounded-lg text-sm font-medium transition-colors"
              >
                Save Profile
              </button>
              {isWorker && (
                <a
                  href={`/workers/${me.id}`}
                  target="_blank"
                  class="bg-gray-700 hover:bg-gray-600 text-gray-200 px-5 py-2 rounded-lg text-sm font-medium transition-colors"
                >
                  View Public Profile ↗
                </a>
              )}
            </div>
          </form>
        </div>

        {/* ── Certifications (workers only) ──────────────── */}
        {isWorker && (
          <div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-base font-semibold text-white">Certifications</h2>
              <a href="/worker/certifications" class="text-sm text-indigo-400 hover:underline">
                {earnedCerts.length > 0 ? "Manage" : "Earn your first"} →
              </a>
            </div>

            {earnedCerts.length === 0 ? (
              <div class="text-center py-6 text-gray-400">
                <div class="text-4xl mb-2">🎓</div>
                <p class="text-sm">No certifications yet.</p>
                <p class="text-xs mt-1">
                  Certifications unlock higher-paying tasks and show requesters you're qualified.
                </p>
                <a
                  href="/worker/certifications"
                  class="inline-block mt-3 text-xs text-indigo-400 hover:underline"
                >
                  Browse certifications →
                </a>
              </div>
            ) : (
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {earnedCerts.map((cert: any) => (
                  <div class="flex items-center gap-3 p-3 bg-gray-700/50 border border-gray-600 rounded-xl">
                    <div class="text-3xl flex-shrink-0 w-10 h-10 flex items-center justify-center">
                      {cert.badge_icon || "🏅"}
                    </div>
                    <div class="min-w-0">
                      <p class="text-sm font-medium text-white truncate">{cert.cert_name}</p>
                      <p class="text-xs text-gray-400">
                        Score: <span class="text-green-400 font-medium">{cert.best_score}%</span>
                        {cert.certified_at && (
                          <span class="ml-2 text-gray-500">
                            · {new Date(cert.certified_at).toLocaleDateString("en-US", { month: "short", year: "numeric" })}
                          </span>
                        )}
                      </p>
                    </div>
                    <div class="ml-auto flex-shrink-0">
                      <span class="text-xs px-2 py-0.5 rounded-full border border-green-700 bg-green-900/30 text-green-400">✓ Certified</span>
                    </div>
                  </div>
                ))}
              </div>
            )}

            {myCerts.filter((c: any) => !c.passed).length > 0 && (
              <div class="mt-4 pt-4 border-t border-gray-700">
                <p class="text-xs text-gray-500 mb-2">In progress</p>
                <div class="flex flex-wrap gap-2">
                  {myCerts.filter((c: any) => !c.passed).map((cert: any) => (
                    <a
                      href={`/worker/certifications?type=${cert.task_type}`}
                      class="flex items-center gap-1.5 px-3 py-1.5 bg-gray-700/30 border border-gray-600 rounded-lg text-xs text-gray-400 hover:border-indigo-600 hover:text-indigo-400 transition-colors"
                    >
                      <span>{cert.badge_icon || "🎯"}</span>
                      <span>{cert.cert_name}</span>
                      <span class="text-gray-500">({cert.best_score}%)</span>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

        {/* ── Security shortcuts ─────────────────────────── */}
        <div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
          <h2 class="text-base font-semibold text-white mb-4">Security</h2>
          <div class="space-y-3">
            <div class="flex items-center justify-between p-3 bg-gray-700/30 rounded-lg border border-gray-600">
              <div>
                <p class="text-sm font-medium text-gray-200">Two-Factor Authentication</p>
                <p class="text-xs text-gray-400 mt-0.5">
                  {status?.totp_enabled ? "✅ Enabled — your account is protected" : "⚠️ Not enabled"}
                </p>
              </div>
              <a
                href="/dashboard/security"
                class="text-sm text-indigo-400 hover:underline"
              >
                {status?.totp_enabled ? "Manage" : "Enable"} →
              </a>
            </div>
          </div>
        </div>

      </div>
    )}
  </div>
</Layout>

<script>
  const form = document.getElementById("profile-form") as HTMLFormElement;
  const result = document.getElementById("save-result") as HTMLElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const fd = new FormData(form);

    const payload: Record<string, any> = {
      name: (fd.get("name") as string).trim() || null,
      bio: (fd.get("bio") as string).trim() || null,
      avatar_url: (fd.get("avatar_url") as string).trim() || null,
      location: (fd.get("location") as string).trim() || null,
      website_url: (fd.get("website_url") as string).trim() || null,
      profile_public: (document.getElementById("profile_public_toggle") as HTMLInputElement)?.checked ?? true,
    };

    try {
      const res = await fetch("/api/users/profile", {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.detail ?? `HTTP ${res.status}`);
      }
      result.className = "mb-4 p-3 rounded-lg text-sm bg-green-900/30 border border-green-700 text-green-300";
      result.textContent = "✓ Profile saved";
      setTimeout(() => { result.className = "hidden mb-4 p-3 rounded-lg text-sm"; }, 3000);
    } catch (err: any) {
      result.className = "mb-4 p-3 rounded-lg text-sm bg-red-900/30 border border-red-700 text-red-300";
      result.textContent = err.message ?? "Failed to save";
    }
  });
</script>
