---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";
import { TASK_CREDITS } from "@crowdsourcerer/types";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login");

let error = "";
let submittedTaskId = "";
let templates: any[] = [];
let savedTemplates: any[] = [];

try {
  const tplRes = await apiFetch<any>("/v1/tasks/templates", { token });
  templates = tplRes?.templates ?? [];
} catch {
  // non-fatal
}

try {
  const savedRes = await apiFetch<any>("/v1/task-templates?page_size=50", { token });
  savedTemplates = savedRes?.templates ?? [];
} catch {
  // non-fatal
}

// Duplicate pre-fill: check if ?duplicate=<task_id> is in URL
const urlParams = new URL(Astro.request.url).searchParams;
const duplicateTaskId = urlParams.get("duplicate") ?? "";
const savedTplId = urlParams.get("tpl") ?? "";
let duplicateParams: any = null;
let duplicateTitle = "";
let savedTplParams: any = null;

if (duplicateTaskId) {
  try {
    duplicateParams = await apiFetch<any>(`/v1/tasks/${duplicateTaskId}/duplicate-params`, { token });
    duplicateTitle = duplicateParams?.type
      ? `${duplicateParams.type} (${duplicateTaskId.slice(0, 8)}…)`
      : duplicateTaskId.slice(0, 8) + "…";
  } catch {
    // non-fatal — duplicate params load failed, just proceed as normal new task
    duplicateParams = null;
  }
}

if (savedTplId) {
  try {
    savedTplParams = await apiFetch<any>(`/v1/task-templates/${savedTplId}`, { token });
    // Increment use count (fire-and-forget)
    apiFetch(`/v1/task-templates/${savedTplId}/use`, { token, method: "POST" }).catch(() => {});
  } catch {
    savedTplParams = null;
  }
}

const AI_TASK_TYPES = [
  { type: "web_research", label: "Web Research", icon: "🌐", placeholder: '{\n  "url": "https://example.com/article",\n  "instruction": "Extract the main content and key points"\n}' },
  { type: "entity_lookup", label: "Entity Lookup", icon: "🏢", placeholder: '{\n  "entity_type": "company",\n  "name": "OpenAI",\n  "domain": "openai.com"\n}' },
  { type: "document_parse", label: "Doc Parse", icon: "📄", placeholder: '{\n  "url": "https://example.com/doc.pdf",\n  "extract_tables": true\n}' },
  { type: "data_transform", label: "Data Transform", icon: "🔄", placeholder: '{\n  "data": {"name": "Alice", "age": 30},\n  "transform": "Convert to CSV format",\n  "output_format": "csv"\n}' },
  { type: "llm_generate", label: "LLM Generate", icon: "🤖", placeholder: '{\n  "messages": [{"role": "user", "content": "Write a haiku about AI"}],\n  "model": "claude-3-5-haiku-20241022"\n}' },
  { type: "screenshot", label: "Screenshot", icon: "📸", placeholder: '{\n  "url": "https://example.com",\n  "full_page": true,\n  "format": "png"\n}' },
  { type: "audio_transcribe", label: "Transcribe", icon: "🎙️", placeholder: '{\n  "url": "https://example.com/audio.mp3",\n  "language": "en",\n  "diarize": false\n}' },
  { type: "pii_detect", label: "PII Detect", icon: "🔒", placeholder: '{\n  "text": "My name is John Doe, email: john@example.com",\n  "mask": true\n}' },
  { type: "code_execute", label: "Code Execute", icon: "⚡", placeholder: '{\n  "language": "python",\n  "code": "print(sum(range(100)))"\n}' },
  { type: "web_intel", label: "Web Intel", icon: "🕵️", placeholder: '{\n  "query": "OpenAI funding history",\n  "max_results": 10\n}' },
];

const HUMAN_TASK_TYPE_LIST = [
  { type: "label_image",         label: "Label Image",    icon: "🖼️", placeholder: '{\n  "image_url": "https://example.com/image.jpg",\n  "labels": ["cat", "dog", "bird"],\n  "question": "What animal is in this image?"\n}' },
  { type: "label_text",          label: "Label Text",     icon: "🏷️", placeholder: '{\n  "text": "The new iPhone 15 is amazing!",\n  "categories": ["positive", "negative", "neutral"],\n  "question": "What is the sentiment of this text?"\n}' },
  { type: "rate_quality",        label: "Rate Quality",   icon: "⭐", placeholder: '{\n  "content": "AI-generated summary text here...",\n  "scale": [1, 2, 3, 4, 5],\n  "criteria": "Rate the overall quality of this summary"\n}' },
  { type: "verify_fact",         label: "Verify Fact",    icon: "✅", placeholder: '{\n  "claim": "The Eiffel Tower is 330 meters tall.",\n  "context": "Optional supporting context here"\n}' },
  { type: "moderate_content",    label: "Moderate",       icon: "🛡️", placeholder: '{\n  "content": "User-submitted text or image URL",\n  "guidelines": "Mark as safe/unsafe based on community guidelines"\n}' },
  { type: "compare_rank",        label: "Compare & Rank", icon: "📊", placeholder: '{\n  "items": ["Option A description", "Option B description"],\n  "criteria": "Which option is more creative?"\n}' },
  { type: "answer_question",     label: "Answer Q",       icon: "💬", placeholder: '{\n  "question": "What year was the French Revolution?",\n  "context": "Optional background information"\n}' },
  { type: "transcription_review","label": "Review Transcript", icon: "📝", placeholder: '{\n  "audio_url": "https://example.com/audio.mp3",\n  "draft_transcript": "Auto-generated transcript to review and correct"\n}' },
];

// Keep backwards compat alias
const TASK_TYPES = AI_TASK_TYPES;

const HUMAN_TASK_TYPES = new Set([
  "label_image","label_text","rate_quality","verify_fact",
  "moderate_content","compare_rank","answer_question","transcription_review"
]);

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const type = form.get("type") as string;
  const inputRaw = form.get("input") as string;
  const priority = form.get("priority") as string || "normal";
  const webhookUrl = form.get("webhook_url") as string;
  const webhookEventsRaw = form.getAll("webhook_events") as string[];

  try {
    const input = JSON.parse(inputRaw);
    const body: any = { type, input, priority };
    if (webhookUrl) {
      body.webhook_url = webhookUrl;
      body.webhook_events = webhookEventsRaw.length > 0 ? webhookEventsRaw : ["task.completed"];
    }

    // Tags
    const tagsRaw = form.get("tags") as string;
    if (tagsRaw?.trim()) {
      body.tags = tagsRaw.split(",").map((t: string) => t.trim()).filter(Boolean).slice(0, 20);
    }

    // Scheduled execution
    const scheduledAt = form.get("scheduled_at") as string;
    if (scheduledAt) {
      body.scheduled_at = new Date(scheduledAt).toISOString();
    }

    if (HUMAN_TASK_TYPES.has(type)) {
      const workerReward = Number(form.get("worker_reward_credits") || 0);
      const assignmentsRequired = Number(form.get("assignments_required") || 1);
      const claimTimeout = Number(form.get("claim_timeout_minutes") || 30);
      const instructions = form.get("task_instructions") as string;
      const consensusStrategy = form.get("consensus_strategy") as string || "any_first";
      const minSkillLevelRaw = form.get("min_skill_level") as string;
      const minSkillLevel = minSkillLevelRaw ? Number(minSkillLevelRaw) : null;
      if (workerReward > 0) body.worker_reward_credits = workerReward;
      body.assignments_required = Math.max(1, Math.min(10, assignmentsRequired));
      body.claim_timeout_minutes = Math.max(5, Math.min(480, claimTimeout));
      if (instructions) body.task_instructions = instructions;
      body.consensus_strategy = consensusStrategy;
      if (minSkillLevel && minSkillLevel >= 1 && minSkillLevel <= 5) body.min_skill_level = minSkillLevel;
    }

    const task = await apiFetch<any>("/v1/tasks", {
      method: "POST",
      body: JSON.stringify(body),
      token,
    });
    return Astro.redirect(`/dashboard/tasks/${task.task_id}`);
  } catch (e: any) {
    error = e.message ?? "Failed to submit task";
  }
}
---

<Layout title="New Task — CrowdSorcerer">
  <div class="max-w-3xl mx-auto px-6 py-10">
    <div class="flex items-center gap-3 mb-8">
      <a href="/dashboard" class="text-gray-500 hover:text-gray-300 transition-colors text-sm">← Dashboard</a>
    </div>

    <div class="flex items-start justify-between mb-1">
      <h1 class="text-2xl font-bold">Submit a new task</h1>
      <a href="/dashboard/batch-upload"
         class="text-sm px-3 py-1.5 bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-lg transition-colors flex items-center gap-1.5">
        📤 Batch upload
      </a>
    </div>
    <p class="text-gray-400 text-sm mb-6">Select a task type, provide JSON input, and get results.</p>

    {/* Duplication banner */}
    {duplicateParams && (
      <div class="bg-blue-950/30 border border-blue-800 rounded-xl px-5 py-3 mb-6 flex items-center justify-between gap-4">
        <div class="flex items-center gap-2 text-blue-300 text-sm">
          <span class="text-base">📋</span>
          <span>Duplicating task: <strong class="font-mono">{duplicateTitle}</strong> — form is pre-filled and fully editable.</span>
        </div>
        <a href="/dashboard/new-task" class="text-xs text-blue-400 hover:text-blue-300 transition-colors whitespace-nowrap">
          Start fresh →
        </a>
      </div>
    )}

    {/* Saved template banner */}
    {savedTplParams && (
      <div class="bg-violet-950/30 border border-violet-700 rounded-xl px-5 py-3 mb-6 flex items-center justify-between gap-4">
        <div class="flex items-center gap-2 text-violet-300 text-sm">
          <span class="text-base">📋</span>
          <span>Using template: <strong>{savedTplParams.name}</strong> — form is pre-filled and fully editable.</span>
        </div>
        <a href="/dashboard/new-task" class="text-xs text-violet-400 hover:text-violet-300 transition-colors whitespace-nowrap">
          Start fresh →
        </a>
      </div>
    )}

    <!-- Saved Templates quick-start (personal) -->
    {savedTemplates.length > 0 && (
      <div class="mb-6">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-medium text-gray-400">📋 My Templates</h2>
          <a href="/dashboard/task-templates" class="text-xs text-violet-400 hover:text-violet-300">Manage →</a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
          {savedTemplates.slice(0, 8).map((tpl: any) => (
            <button
              type="button"
              class="saved-tpl-btn text-left bg-gray-900 border border-gray-700 hover:border-violet-500 rounded-lg p-3 transition-colors group"
              data-type={tpl.task_type}
              data-input={JSON.stringify(tpl.task_input, null, 2)}
              data-config={JSON.stringify(tpl.task_config ?? {})}
              data-id={tpl.id}
            >
              <div class="text-lg mb-1">{tpl.icon || "📋"}</div>
              <div class="font-medium text-xs group-hover:text-violet-300 transition-colors line-clamp-2">{tpl.name}</div>
            </button>
          ))}
        </div>
      </div>
    )}

    <!-- Templates quick-start (marketplace) -->
    {templates.length > 0 && (
      <div class="mb-8">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-medium text-gray-400">🚀 Quick start with a template</h2>
          <span class="text-xs text-gray-600">Click to pre-fill the form</span>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          {templates.slice(0, 6).map((tpl: any) => (
            <button
              type="button"
              class="template-btn text-left bg-gray-900 border border-gray-800 hover:border-violet-600/60 rounded-xl p-4 transition-colors group"
              data-type={tpl.type}
              data-input={JSON.stringify(tpl.default_input, null, 2)}
              data-settings={JSON.stringify(tpl.default_settings ?? {})}
            >
              <div class="text-xl mb-2">{tpl.icon}</div>
              <div class="font-medium text-sm group-hover:text-violet-300 transition-colors">{tpl.name}</div>
              <div class="text-xs text-gray-500 mt-1 line-clamp-2">{tpl.description}</div>
              <div class="mt-2 flex items-center gap-1.5">
                <span class:list={["text-[10px] px-1.5 py-0.5 rounded font-medium", tpl.category === "ai" ? "bg-cyan-900/40 text-cyan-400" : "bg-violet-900/40 text-violet-400"]}>
                  {tpl.category === "ai" ? "AI" : "Human"}
                </span>
                <span class="text-[10px] text-gray-600">~{tpl.estimated_credits} cr</span>
              </div>
            </button>
          ))}
        </div>
      </div>
    )}

    {error && (
      <div class="bg-red-950/50 border border-red-800 rounded-lg px-4 py-3 text-sm text-red-300 mb-6">
        {error}
      </div>
    )}

    <form method="POST" class="space-y-6">
      <!-- Task type picker -->
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-3">
          AI Task Types <span class="text-xs text-gray-500">(executed instantly by AI)</span>
        </label>
        <div class="grid grid-cols-2 sm:grid-cols-5 gap-2">
          {AI_TASK_TYPES.map(({ type, label, icon }) => (
            <label class="cursor-pointer">
              <input type="radio" name="type" value={type} required class="peer sr-only"
                checked={type === "web_research"} />
              <div class="bg-gray-900 border border-gray-800 rounded-lg p-3 text-center
                peer-checked:border-violet-500 peer-checked:bg-violet-950/30 hover:border-gray-600 transition-colors">
                <div class="text-xl mb-1">{icon}</div>
                <div class="text-xs font-medium text-gray-300">{label}</div>
                <div class="text-xs text-gray-500 mt-0.5">{(TASK_CREDITS as any)[type]}cr</div>
              </div>
            </label>
          ))}
        </div>
      </div>

      <!-- Human task type picker -->
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-3">
          Human Task Types <span class="text-xs text-gray-500">(completed by workers in the marketplace)</span>
        </label>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
          {HUMAN_TASK_TYPE_LIST.map(({ type, label, icon }) => (
            <label class="cursor-pointer">
              <input type="radio" name="type" value={type} required class="peer sr-only" />
              <div class="bg-gray-900 border border-gray-800 rounded-lg p-3 text-center
                peer-checked:border-violet-500 peer-checked:bg-violet-950/30 hover:border-gray-600 transition-colors">
                <div class="text-xl mb-1">{icon}</div>
                <div class="text-xs font-medium text-gray-300">{label}</div>
                <div class="text-xs text-indigo-400 mt-0.5">👥 Human</div>
              </div>
            </label>
          ))}
        </div>
      </div>

      <!-- JSON input -->
      <div>
        <label for="input" class="block text-sm font-medium text-gray-300 mb-2">
          Input <span class="text-gray-500">(JSON)</span>
        </label>
        <textarea
          id="input"
          name="input"
          required
          rows="6"
          class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-3 font-mono text-sm text-gray-100
            focus:outline-none focus:border-violet-500 transition-colors resize-y"
          placeholder='{"query": "latest AI research 2025"}'
        ></textarea>
      </div>

      <!-- Priority + webhook -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Priority</label>
          <select name="priority" class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2.5 text-sm text-gray-100 focus:outline-none focus:border-violet-500">
            <option value="low">Low</option>
            <option value="normal" selected>Normal</option>
            <option value="high">High (+20%)</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">
            Webhook URL <span class="text-gray-500">(optional)</span>
          </label>
          <input
            type="url"
            name="webhook_url"
            class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2.5 text-sm text-gray-100 focus:outline-none focus:border-violet-500 transition-colors"
            placeholder="https://your-app.com/webhook"
          />
          <p class="text-xs text-gray-500 mt-1.5">
            Choose which events to receive:
          </p>
          <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1.5">
            {[
              ["task.created","Created"],["task.assigned","Assigned"],
              ["task.submission_received","Submitted"],["task.completed","Completed"],
              ["task.failed","Failed"],["task.approved","Approved"],
              ["task.rejected","Rejected"],["sla.breach","SLA Breach"],
            ].map(([val, label]) => (
              <label class="flex items-center gap-1.5 text-xs text-gray-400 cursor-pointer select-none">
                <input
                  type="checkbox"
                  name="webhook_events"
                  value={val}
                  checked={val === "task.completed"}
                  class="rounded border-gray-600 bg-gray-800 text-violet-500 focus:ring-0"
                />
                {label}
              </label>
            ))}
          </div>
        </div>
      </div>

      <!-- Human task options (shown/hidden by JS based on selected type) -->
      <div id="human-task-options" class="hidden bg-gray-900 border border-gray-700 rounded-xl p-5 space-y-4">
        <h3 class="text-sm font-semibold text-gray-300 border-b border-gray-700 pb-2">
          👥 Human Task Options
        </h3>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Worker Reward (credits)</label>
            <input
              type="number"
              name="worker_reward_credits"
              min="1"
              max="10000"
              placeholder="auto"
              class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-100 focus:outline-none focus:border-violet-500"
            />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Workers Required</label>
            <input
              type="number"
              name="assignments_required"
              min="1"
              max="10"
              value="1"
              class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-100 focus:outline-none focus:border-violet-500"
            />
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Timeout (minutes)</label>
            <input
              type="number"
              name="claim_timeout_minutes"
              min="5"
              max="480"
              value="30"
              class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-100 focus:outline-none focus:border-violet-500"
            />
          </div>
        </div>

        <div id="consensus-section">
          <label class="block text-xs font-medium text-gray-400 mb-1.5">
            Consensus Strategy
            <span class="text-gray-600">(for multiple workers)</span>
          </label>
          <select
            name="consensus_strategy"
            class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-100 focus:outline-none focus:border-violet-500"
          >
            <option value="any_first">First Wins — first submission completes the task</option>
            <option value="majority_vote">Majority Vote — &gt;50% must agree (for 3+ workers)</option>
            <option value="unanimous">Unanimous — all workers must agree</option>
            <option value="requester_review">Your Review — you always pick the best answer</option>
          </select>
          <p class="text-xs text-gray-500 mt-1">
            With Majority Vote or Unanimous, disagreements are flagged for your resolution.
          </p>
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1.5">
            Minimum Skill Level
            <span class="text-gray-600">(optional, 1–5)</span>
          </label>
          <select
            name="min_skill_level"
            class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-100 focus:outline-none focus:border-violet-500"
          >
            <option value="">Any skill level</option>
            <option value="1">1 — Novice (default)</option>
            <option value="2">2 — Beginner</option>
            <option value="3">3 — Intermediate</option>
            <option value="4">4 — Advanced</option>
            <option value="5">5 — Expert only</option>
          </select>
          <p class="text-xs text-gray-500 mt-1">
            Only workers who have reached this proficiency in {"{task type}"} can claim this task.
          </p>
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1.5">Task Instructions</label>
          <textarea
            name="task_instructions"
            rows={3}
            placeholder="Optional guidance for workers: what to look for, format of answer, etc."
            class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-100 focus:outline-none focus:border-violet-500 resize-y"
          />
        </div>
      </div>

      <!-- ── Tags / Labels ─────────────────────────────────────── -->
      <div class="pt-4 border-t border-gray-800">
        <h3 class="text-sm font-semibold text-gray-300 mb-3">Labels & Scheduling</h3>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">
              Tags
              <span class="text-gray-600">(comma-separated, optional)</span>
            </label>
            <input
              type="text"
              name="tags"
              placeholder="e.g. billing, v2, prod"
              class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-100 focus:outline-none focus:border-violet-500"
            />
            <p class="text-xs text-gray-600 mt-1">Up to 20 tags to organise and filter your tasks.</p>
          </div>

          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">
              Schedule for later
              <span class="text-gray-600">(optional)</span>
            </label>
            <input
              type="datetime-local"
              name="scheduled_at"
              class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-100 focus:outline-none focus:border-violet-500"
            />
            <p class="text-xs text-gray-600 mt-1">Leave blank to run immediately.</p>
          </div>
        </div>
      </div>

      <div class="flex gap-3">
        <button
          type="submit"
          class="flex-1 bg-violet-600 hover:bg-violet-500 text-white font-semibold py-3 rounded-lg transition-colors"
        >
          Submit task →
        </button>
        <button
          type="button"
          id="save-tpl-btn"
          class="px-4 py-3 bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm font-medium rounded-lg transition-colors whitespace-nowrap"
          title="Save current form as a reusable template"
        >
          💾 Save as Template
        </button>
      </div>
    </form>
  </div>

  <!-- Save-as-template modal -->
  <div id="save-tpl-modal" class="fixed inset-0 bg-black/60 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-gray-950 border border-gray-700 rounded-2xl shadow-2xl w-full max-w-sm p-6">
      <h2 class="text-lg font-semibold mb-1 text-white">Save as Template</h2>
      <p class="text-sm text-gray-400 mb-4">Give this template a name so you can reuse it later.</p>
      <input
        id="save-tpl-name"
        type="text"
        maxlength="255"
        placeholder="Template name…"
        class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-violet-500 mb-3"
      />
      <input
        id="save-tpl-desc"
        type="text"
        maxlength="500"
        placeholder="Short description (optional)…"
        class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-violet-500 mb-4"
      />
      <div id="save-tpl-error" class="hidden bg-red-950/60 border border-red-800 text-red-300 rounded-lg px-3 py-2 text-xs mb-3"></div>
      <div class="flex justify-end gap-3">
        <button id="save-tpl-cancel" class="px-4 py-2 text-sm border border-gray-600 rounded-lg text-gray-300 hover:bg-gray-800">Cancel</button>
        <button id="save-tpl-confirm" class="px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg">Save</button>
      </div>
    </div>
  </div>
</Layout>

{savedTplParams && (
  <script
    define:vars={{ savedTplData: savedTplParams }}
    is:inline
  >
    // Pre-fill form with saved template data (SSR-injected)
    window.__savedTplData = savedTplData;
  </script>
)}

<script>
  // Human task options toggle
  const HUMAN_TYPES = new Set([
    "label_image","label_text","rate_quality","verify_fact",
    "moderate_content","compare_rank","answer_question","transcription_review"
  ]);
  const humanOptions = document.getElementById("human-task-options");
  const assignmentsInput = document.querySelector<HTMLInputElement>('[name="assignments_required"]');
  const consensusSection = document.getElementById("consensus-section");

  function updateHumanOptions() {
    const checked = document.querySelector<HTMLInputElement>('input[name="type"]:checked');
    if (!checked) return;
    const isHuman = HUMAN_TYPES.has(checked.value);
    humanOptions?.classList.toggle("hidden", !isHuman);
  }

  function updateConsensusVisibility() {
    const count = Number(assignmentsInput?.value ?? 1);
    consensusSection?.classList.toggle("hidden", count <= 1);
  }

  document.querySelectorAll('input[name="type"]').forEach((radio) => {
    radio.addEventListener("change", updateHumanOptions);
  });

  assignmentsInput?.addEventListener("input", updateConsensusVisibility);

  // Run on load
  updateHumanOptions();
  updateConsensusVisibility();

  // Pre-fill from saved template (SSR data)
  const savedTplData = (window as any).__savedTplData;
  if (savedTplData) {
    const type = savedTplData.task_type;
    const radio = document.querySelector<HTMLInputElement>(`input[name="type"][value="${type}"]`);
    if (radio) {
      radio.checked = true;
      radio.dispatchEvent(new Event("change", { bubbles: true }));
    }
    const inputTA = document.getElementById("input") as HTMLTextAreaElement;
    if (inputTA && savedTplData.task_input) {
      try { inputTA.value = JSON.stringify(savedTplData.task_input, null, 2); } catch {}
    }
    const cfg = savedTplData.task_config ?? {};
    if (cfg.priority) {
      const sel = document.querySelector<HTMLSelectElement>(`select[name="priority"]`);
      if (sel) sel.value = cfg.priority;
    }
    if (cfg.tags && Array.isArray(cfg.tags)) {
      const el = document.querySelector<HTMLInputElement>(`input[name="tags"]`);
      if (el) el.value = cfg.tags.join(", ");
    }
  }

  // Template pre-fill
  document.querySelectorAll<HTMLButtonElement>(".template-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const type = btn.dataset.type!;
      const input = btn.dataset.input!;

      // Select radio
      const radio = document.querySelector<HTMLInputElement>(`input[name="type"][value="${type}"]`);
      if (radio) {
        radio.checked = true;
        radio.dispatchEvent(new Event("change", { bubbles: true }));
      }

      // Fill input textarea
      const textarea = document.getElementById("input") as HTMLTextAreaElement;
      if (textarea) textarea.value = input;

      // Highlight selected template
      document.querySelectorAll(".template-btn").forEach((b) => {
        b.classList.remove("border-violet-500", "bg-violet-950/20");
        b.classList.add("border-gray-800");
      });
      btn.classList.add("border-violet-500", "bg-violet-950/20");
      btn.classList.remove("border-gray-800");

      // Scroll to form
      document.querySelector("form")?.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });
</script>

<script>
  // Duplicate task pre-fill from URL query params
  (function () {
    const params = new URLSearchParams(window.location.search);
    const duplicateId = params.get("duplicate");
    if (!duplicateId) return;

    const type = params.get("type");
    const inputStr = params.get("input");
    const priority = params.get("priority");
    const tags = params.get("tags");
    const scheduledAt = params.get("scheduled_at");
    const webhookUrl = params.get("webhook_url");
    const workerReward = params.get("worker_reward_credits");
    const assignmentsRequired = params.get("assignments_required");
    const taskInstructions = params.get("task_instructions");

    // Select task type radio
    if (type) {
      const radio = document.querySelector<HTMLInputElement>(`input[name="type"][value="${type}"]`);
      if (radio) {
        radio.checked = true;
        radio.dispatchEvent(new Event("change", { bubbles: true }));
      }
    }

    // Fill JSON input
    if (inputStr) {
      try {
        const parsed = JSON.parse(inputStr);
        const textarea = document.getElementById("input") as HTMLTextAreaElement;
        if (textarea) textarea.value = JSON.stringify(parsed, null, 2);
      } catch {}
    }

    // Fill priority
    if (priority) {
      const sel = document.querySelector<HTMLSelectElement>(`select[name="priority"]`);
      if (sel) sel.value = priority;
    }

    // Fill tags
    if (tags) {
      const tagInput = document.querySelector<HTMLInputElement>(`input[name="tags"]`);
      if (tagInput) tagInput.value = tags;
    }

    // Fill scheduled_at
    if (scheduledAt) {
      const schedInput = document.querySelector<HTMLInputElement>(`input[name="scheduled_at"]`);
      if (schedInput) {
        // Convert ISO string to datetime-local format
        try {
          const dt = new Date(scheduledAt);
          const local = dt.toISOString().slice(0, 16);
          schedInput.value = local;
        } catch {}
      }
    }

    // Fill webhook URL
    if (webhookUrl) {
      const wh = document.querySelector<HTMLInputElement>(`input[name="webhook_url"]`);
      if (wh) wh.value = webhookUrl;
    }

    // Fill human task fields
    if (workerReward) {
      const el = document.querySelector<HTMLInputElement>(`input[name="worker_reward_credits"]`);
      if (el) el.value = workerReward;
    }
    if (assignmentsRequired) {
      const el = document.querySelector<HTMLInputElement>(`input[name="assignments_required"]`);
      if (el) { el.value = assignmentsRequired; el.dispatchEvent(new Event("input")); }
    }
    if (taskInstructions) {
      const el = document.querySelector<HTMLTextAreaElement>(`textarea[name="task_instructions"]`);
      if (el) el.value = taskInstructions;
    }
  })();
</script>

<script>
  // ── Saved templates (personal) pre-fill ───────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>(".saved-tpl-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const type = btn.dataset.type!;
      const input = btn.dataset.input!;
      const config = btn.dataset.config ? JSON.parse(btn.dataset.config) : {};

      // Select radio
      const radio = document.querySelector<HTMLInputElement>(`input[name="type"][value="${type}"]`);
      if (radio) {
        radio.checked = true;
        radio.dispatchEvent(new Event("change", { bubbles: true }));
      }
      // Fill input
      const textarea = document.getElementById("input") as HTMLTextAreaElement;
      if (textarea) textarea.value = input;
      // Fill config fields
      if (config.priority) {
        const sel = document.querySelector<HTMLSelectElement>(`select[name="priority"]`);
        if (sel) sel.value = config.priority;
      }
      if (config.tags && Array.isArray(config.tags)) {
        const el = document.querySelector<HTMLInputElement>(`input[name="tags"]`);
        if (el) el.value = config.tags.join(", ");
      }
      // Highlight
      document.querySelectorAll(".saved-tpl-btn").forEach((b) => {
        b.classList.remove("border-violet-500", "bg-violet-950/20");
        b.classList.add("border-gray-700");
      });
      btn.classList.add("border-violet-500", "bg-violet-950/20");
      btn.classList.remove("border-gray-700");

      document.querySelector("form")?.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });

  // ── Save as Template button ───────────────────────────────────────────────
  const saveTplModal = document.getElementById("save-tpl-modal")!;
  const saveTplError = document.getElementById("save-tpl-error")!;

  document.getElementById("save-tpl-btn")?.addEventListener("click", () => {
    (document.getElementById("save-tpl-name") as HTMLInputElement).value = "";
    (document.getElementById("save-tpl-desc") as HTMLInputElement).value = "";
    saveTplError.classList.add("hidden");
    saveTplModal.classList.remove("hidden");
    (document.getElementById("save-tpl-name") as HTMLInputElement).focus();
  });
  document.getElementById("save-tpl-cancel")?.addEventListener("click", () => saveTplModal.classList.add("hidden"));
  saveTplModal.addEventListener("click", (e) => { if (e.target === saveTplModal) saveTplModal.classList.add("hidden"); });

  document.getElementById("save-tpl-confirm")?.addEventListener("click", async () => {
    const name = (document.getElementById("save-tpl-name") as HTMLInputElement).value.trim();
    if (!name) {
      saveTplError.textContent = "Template name is required.";
      saveTplError.classList.remove("hidden");
      return;
    }
    // Collect current form state
    const typeRadio = document.querySelector<HTMLInputElement>(`input[name="type"]:checked`);
    const task_type = typeRadio?.value ?? "";
    const inputTA = document.getElementById("input") as HTMLTextAreaElement;
    let task_input: object;
    try { task_input = JSON.parse(inputTA.value || "{}"); } catch { task_input = {}; }

    const prioritySel = document.querySelector<HTMLSelectElement>(`select[name="priority"]`);
    const tagsEl = document.querySelector<HTMLInputElement>(`input[name="tags"]`);
    const task_config: Record<string, unknown> = {};
    if (prioritySel?.value) task_config.priority = prioritySel.value;
    if (tagsEl?.value) task_config.tags = tagsEl.value.split(",").map((t: string) => t.trim()).filter(Boolean);

    const description = (document.getElementById("save-tpl-desc") as HTMLInputElement).value.trim() || null;

    const confirmBtn = document.getElementById("save-tpl-confirm")!;
    confirmBtn.textContent = "Saving…";
    (confirmBtn as HTMLButtonElement).disabled = true;

    const res = await fetch("/api/task-templates", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ name, description, task_type, task_input, task_config }),
    });
    if (res.ok) {
      saveTplModal.classList.add("hidden");
      // Show success toast
      const toast = document.createElement("div");
      toast.className = "fixed bottom-4 right-4 bg-emerald-600 text-white text-sm px-4 py-2.5 rounded-lg shadow-lg z-50";
      toast.textContent = `Template "${name}" saved!`;
      document.body.appendChild(toast);
      setTimeout(() => toast.remove(), 3000);
    } else {
      const err = await res.json().catch(() => ({}));
      saveTplError.textContent = err.detail || "Failed to save template.";
      saveTplError.classList.remove("hidden");
    }
    confirmBtn.textContent = "Save";
    (confirmBtn as HTMLButtonElement).disabled = false;
  });
</script>
