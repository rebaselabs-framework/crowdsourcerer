---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";
import { TASK_CREDITS } from "@crowdsourcerer/types";

const token = getToken(Object.fromEntries(
  Astro.cookies.getAll().map((c) => [c.name, c.value])
));
if (!token) return Astro.redirect("/login");

let error = "";
let submittedTaskId = "";

const TASK_TYPES = [
  { type: "web_research", label: "Web Research", icon: "🌐", placeholder: '{"query": "latest AI research 2025", "max_results": 5}' },
  { type: "entity_lookup", label: "Entity Lookup", icon: "🏢", placeholder: '{"entity_type": "company", "name": "OpenAI"}' },
  { type: "document_parse", label: "Doc Parse", icon: "📄", placeholder: '{"url": "https://example.com/doc.pdf", "extract": ["text", "tables"]}' },
  { type: "data_transform", label: "Data Transform", icon: "🔄", placeholder: '{"input": {"key": "value"}, "instructions": "convert to CSV"}' },
  { type: "llm_generate", label: "LLM Generate", icon: "🤖", placeholder: '{"messages": [{"role": "user", "content": "Hello!"}]}' },
  { type: "screenshot", label: "Screenshot", icon: "📸", placeholder: '{"url": "https://example.com", "full_page": true}' },
  { type: "audio_transcribe", label: "Transcribe", icon: "🎙️", placeholder: '{"url": "https://example.com/audio.mp3"}' },
  { type: "pii_detect", label: "PII Detect", icon: "🔒", placeholder: '{"text": "My name is John Doe, email: john@example.com"}' },
  { type: "code_execute", label: "Code Execute", icon: "⚡", placeholder: '{"language": "python", "code": "print(\"Hello, World!\")"}' },
  { type: "web_intel", label: "Web Intel", icon: "🕵️", placeholder: '{"target": "openai.com", "types": ["whois", "headers"]}' },
];

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const type = form.get("type") as string;
  const inputRaw = form.get("input") as string;
  const priority = form.get("priority") as string || "normal";
  const webhookUrl = form.get("webhook_url") as string;

  try {
    const input = JSON.parse(inputRaw);
    const body: any = { type, input, priority };
    if (webhookUrl) body.webhook_url = webhookUrl;

    const task = await apiFetch<any>("/v1/tasks", {
      method: "POST",
      body: JSON.stringify(body),
      token,
    });
    return Astro.redirect(`/dashboard/tasks/${task.task_id}`);
  } catch (e: any) {
    error = e.message ?? "Failed to submit task";
  }
}
---

<Layout title="New Task — CrowdSorcerer">
  <div class="max-w-3xl mx-auto px-6 py-10">
    <div class="flex items-center gap-3 mb-8">
      <a href="/dashboard" class="text-gray-500 hover:text-gray-300 transition-colors text-sm">← Dashboard</a>
    </div>

    <h1 class="text-2xl font-bold mb-1">Submit a new task</h1>
    <p class="text-gray-400 text-sm mb-8">Select a task type, provide JSON input, and get results.</p>

    {error && (
      <div class="bg-red-950/50 border border-red-800 rounded-lg px-4 py-3 text-sm text-red-300 mb-6">
        {error}
      </div>
    )}

    <form method="POST" class="space-y-6">
      <!-- Task type picker -->
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-3">Task type</label>
        <div class="grid grid-cols-2 sm:grid-cols-5 gap-2">
          {TASK_TYPES.map(({ type, label, icon }) => (
            <label class="cursor-pointer">
              <input type="radio" name="type" value={type} required class="peer sr-only"
                checked={type === "web_research"} />
              <div class="bg-gray-900 border border-gray-800 rounded-lg p-3 text-center
                peer-checked:border-violet-500 peer-checked:bg-violet-950/30 hover:border-gray-600 transition-colors">
                <div class="text-xl mb-1">{icon}</div>
                <div class="text-xs font-medium text-gray-300">{label}</div>
                <div class="text-xs text-gray-500 mt-0.5">{(TASK_CREDITS as any)[type]}cr</div>
              </div>
            </label>
          ))}
        </div>
      </div>

      <!-- JSON input -->
      <div>
        <label for="input" class="block text-sm font-medium text-gray-300 mb-2">
          Input <span class="text-gray-500">(JSON)</span>
        </label>
        <textarea
          id="input"
          name="input"
          required
          rows="6"
          class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-3 font-mono text-sm text-gray-100
            focus:outline-none focus:border-violet-500 transition-colors resize-y"
          placeholder='{"query": "latest AI research 2025"}'
        ></textarea>
      </div>

      <!-- Priority + webhook -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">Priority</label>
          <select name="priority" class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2.5 text-sm text-gray-100 focus:outline-none focus:border-violet-500">
            <option value="low">Low</option>
            <option value="normal" selected>Normal</option>
            <option value="high">High (+20%)</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-2">
            Webhook URL <span class="text-gray-500">(optional)</span>
          </label>
          <input
            type="url"
            name="webhook_url"
            class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2.5 text-sm text-gray-100 focus:outline-none focus:border-violet-500 transition-colors"
            placeholder="https://your-app.com/webhook"
          />
        </div>
      </div>

      <button
        type="submit"
        class="w-full bg-violet-600 hover:bg-violet-500 text-white font-semibold py-3 rounded-lg transition-colors"
      >
        Submit task →
      </button>
    </form>
  </div>
</Layout>
