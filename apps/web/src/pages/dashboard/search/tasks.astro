---
/**
 * Advanced Task Search — full-text search across task type, instructions,
 * input JSON, and output JSON. Supports tag filtering + saved filters.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login?next=/dashboard/search/tasks");

const q          = Astro.url.searchParams.get("q") ?? "";
const status     = Astro.url.searchParams.get("status") ?? "";
const taskType   = Astro.url.searchParams.get("task_type") ?? "";
const execMode   = Astro.url.searchParams.get("execution_mode") ?? "";
const fromDate   = Astro.url.searchParams.get("from_date") ?? "";
const toDate     = Astro.url.searchParams.get("to_date") ?? "";
const tagsParam  = Astro.url.searchParams.get("tags") ?? "";
const page       = parseInt(Astro.url.searchParams.get("page") ?? "1", 10);
const pageSize   = 20;

let results: any = null;
let error: string | null = null;
let userTags: string[] = [];

// Load user's tag list for suggestions
try {
  const tagData = await apiFetch<any[]>("/v1/tasks/tags", { token }).catch(() => []);
  userTags = (tagData ?? []).map((t: any) => (typeof t === "string" ? t : t.tag ?? t.name ?? "")).filter(Boolean);
} catch (_) {}

const shouldSearch = q.length >= 2 || status || taskType || execMode || fromDate || toDate || tagsParam;

if (shouldSearch) {
  try {
    const qs = new URLSearchParams({ page: String(page), page_size: String(pageSize) });
    if (q)         qs.set("q", q);
    if (status)    qs.set("status", status);
    if (taskType)  qs.set("task_type", taskType);
    if (execMode)  qs.set("execution_mode", execMode);
    if (fromDate)  qs.set("from_date", fromDate);
    if (toDate)    qs.set("to_date", toDate);
    if (tagsParam) qs.set("tags", tagsParam);
    results = await apiFetch<any>(`/v1/search/tasks?${qs}`, { token });
  } catch (e: any) {
    if (e.message?.includes("401") || e.message?.includes("403")) return Astro.redirect("/login");
    error = e.message ?? "Search failed.";
  }
}

const fieldLabels: Record<string, string> = {
  output: "📤 output",
  input: "📥 input",
  instructions: "📝 instructions",
  type: "🏷️ type",
};

const fieldColors: Record<string, string> = {
  output: "text-green-400",
  input: "text-blue-400",
  instructions: "text-yellow-400",
  type: "text-gray-400",
};

// Active tags as array
const activeTags = tagsParam ? tagsParam.split(",").map(t => t.trim()).filter(Boolean) : [];

// Build current filter URL params (without page) for pagination
function filterQs(extra: Record<string, string> = {}): string {
  const p: Record<string, string> = {};
  if (q)         p.q = q;
  if (status)    p.status = status;
  if (taskType)  p.task_type = taskType;
  if (execMode)  p.execution_mode = execMode;
  if (fromDate)  p.from_date = fromDate;
  if (toDate)    p.to_date = toDate;
  if (tagsParam) p.tags = tagsParam;
  return new URLSearchParams({ ...p, ...extra }).toString();
}
---

<Layout title="Task Search — CrowdSorcerer">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <!-- Header -->
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-1">
        <a href="/dashboard/search" class="text-gray-500 hover:text-gray-300 text-sm transition-colors">← Search</a>
      </div>
      <h1 class="text-2xl font-bold">🔍 Task Search</h1>
      <p class="text-gray-400 text-sm mt-1">
        Full-text search across task type, instructions, and JSON input/output content.
      </p>
    </div>

    <!-- Search form -->
    <form method="GET" id="search-form" class="mb-8 space-y-3">
      <!-- Main query + submit -->
      <div class="flex gap-3">
        <input
          name="q"
          value={q}
          autofocus
          placeholder="Search inside tasks… (e.g. Paris, sentiment, true)"
          class="flex-1 bg-gray-900 border border-gray-700 rounded-xl px-5 py-3 text-base focus:outline-none focus:ring-2 focus:ring-violet-600/40 focus:border-violet-600 transition-colors"
        />
        <button
          type="submit"
          class="px-6 py-3 bg-violet-700 hover:bg-violet-600 text-white rounded-xl font-medium text-sm transition-colors"
        >
          Search
        </button>
      </div>

      <!-- Filters row -->
      <div class="flex flex-wrap gap-3">
        <select
          name="status"
          class="bg-gray-900 border border-gray-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-violet-600/40 focus:border-violet-600"
        >
          <option value="">Any status</option>
          {["pending","running","completed","failed","cancelled","open","assigned","submitted","approved","rejected"].map((s) => (
            <option value={s} selected={status === s}>{s}</option>
          ))}
        </select>

        <select
          name="task_type"
          class="bg-gray-900 border border-gray-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-violet-600/40 focus:border-violet-600"
        >
          <option value="">Any type</option>
          {[
            // Human
            "label_image","label_text","rate_quality","verify_fact",
            "moderate_content","compare_rank","answer_question","transcription_review",
            // Pipeline AI primitives
            "web_research","document_parse","data_transform",
            "llm_generate","pii_detect","code_execute",
          ].map((t) => (
            <option value={t} selected={taskType === t}>{t.replace(/_/g, " ")}</option>
          ))}
        </select>

        <select
          name="execution_mode"
          class="bg-gray-900 border border-gray-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-violet-600/40 focus:border-violet-600"
        >
          <option value="">Any mode</option>
          <option value="ai" selected={execMode === "ai"}>AI</option>
          <option value="human" selected={execMode === "human"}>Human</option>
        </select>

        <input
          type="date"
          name="from_date"
          value={fromDate}
          title="From date"
          class="bg-gray-900 border border-gray-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-violet-600/40 focus:border-violet-600 text-gray-400"
        />
        <input
          type="date"
          name="to_date"
          value={toDate}
          title="To date"
          class="bg-gray-900 border border-gray-700 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-violet-600/40 focus:border-violet-600 text-gray-400"
        />

        {(q || status || taskType || execMode || fromDate || toDate || tagsParam) && (
          <a
            href="/dashboard/search/tasks"
            class="px-4 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-gray-200 rounded-lg text-sm transition-colors"
          >
            Clear
          </a>
        )}
      </div>

      <!-- Tag filter row -->
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-xs text-gray-500 shrink-0">🏷️ Tags:</span>
        <!-- Hidden input carries tag value -->
        <input type="hidden" name="tags" id="tags-hidden" value={tagsParam} />

        <!-- Active tags as removable chips -->
        {activeTags.map(tag => (
          <button
            type="button"
            data-tag={tag}
            class="tag-chip-active inline-flex items-center gap-1 px-2.5 py-1 bg-violet-900/50 border border-violet-700 text-violet-300 text-xs rounded-full hover:bg-red-900/40 hover:border-red-700 hover:text-red-300 transition-colors"
            title="Click to remove"
          >
            {tag}
            <span class="text-[10px] opacity-60">✕</span>
          </button>
        ))}

        <!-- Tag suggestion pills from user's tags -->
        {userTags.filter(t => !activeTags.includes(t)).slice(0, 12).map(tag => (
          <button
            type="button"
            data-tag={tag}
            class="tag-chip-add inline-flex items-center gap-1 px-2.5 py-1 bg-gray-800 border border-gray-700 text-gray-400 text-xs rounded-full hover:bg-violet-900/40 hover:border-violet-700 hover:text-violet-300 transition-colors"
            title="Click to filter by this tag"
          >
            + {tag}
          </button>
        ))}

        {userTags.length === 0 && activeTags.length === 0 && (
          <span class="text-xs text-gray-500 italic">No tags used yet</span>
        )}
      </div>
    </form>

    <!-- Saved Filters bar -->
    <div id="saved-filters-bar" class="mb-6 hidden">
      <div class="flex items-center gap-3 flex-wrap">
        <span class="text-xs text-gray-500 shrink-0">💾 Saved:</span>
        <div id="saved-filter-chips" class="flex flex-wrap gap-2"></div>
        <button
          id="save-filter-btn"
          class="text-xs px-3 py-1.5 bg-gray-800 border border-gray-700 text-gray-400 hover:text-white hover:border-gray-500 rounded-lg transition-colors"
        >
          + Save current filters
        </button>
      </div>
    </div>

    {error && (
      <div class="bg-red-950/30 border border-red-800 rounded-xl p-4 text-red-300 text-sm mb-6">{error}</div>
    )}

    {results ? (
      <div>
        <!-- Result count -->
        <div class="flex items-center justify-between mb-4">
          <p class="text-sm text-gray-400">
            {results.total === 0
              ? "No tasks found"
              : <><strong class="text-white">{results.total}</strong> task{results.total !== 1 ? "s" : ""} found{q ? <> matching <strong class="text-white">"{q}"</strong></> : ""}</>
            }
            {activeTags.length > 0 && (
              <> · tagged <strong class="text-violet-300">{activeTags.join(", ")}</strong></>
            )}
          </p>
          {results.total > 0 && (
            <p class="text-xs text-gray-500">
              Page {page} of {Math.ceil(results.total / pageSize)}
            </p>
          )}
        </div>

        {results.items?.length === 0 ? (
          <div class="text-center py-16">
            <div class="text-5xl mb-4">🔍</div>
            <h2 class="text-lg font-semibold mb-2">No matching tasks</h2>
            <p class="text-gray-400 text-sm">Try changing your query or removing filters.</p>
          </div>
        ) : (
          <div class="space-y-3">
            {results.items?.map((task: any) => (
              <a
                href={task.url ?? `/dashboard/tasks/${task.id}`}
                class="block p-5 bg-gray-900 border border-gray-800 hover:border-gray-600 rounded-xl transition-colors group"
              >
                <div class="flex items-start gap-4">
                  <!-- Icon -->
                  <div class="text-2xl shrink-0 mt-0.5">📋</div>

                  <!-- Main content -->
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 flex-wrap">
                      <span class="font-medium text-white group-hover:text-violet-300 transition-colors truncate">
                        {task.title ?? task.type?.replace(/_/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase()) + " Task"}
                      </span>
                      <span class:list={[
                        "text-xs px-2 py-0.5 rounded-full border shrink-0",
                        task.status === "completed" ? "text-green-400 bg-green-900/20 border-green-800/40" :
                        task.status === "failed" ? "text-red-400 bg-red-900/20 border-red-800/40" :
                        task.status === "running" ? "text-blue-400 bg-blue-900/20 border-blue-800/40" :
                        "text-gray-400 bg-gray-800/50 border-gray-700/50"
                      ]}>{task.status}</span>
                      <span class="text-xs text-gray-500 shrink-0">
                        {task.execution_mode === "ai" ? "🤖 AI" : "👤 Human"}
                      </span>
                    </div>

                    <!-- Tag chips -->
                    {task.tags?.length > 0 && (
                      <div class="flex flex-wrap gap-1.5 mt-2">
                        {task.tags.map((tag: string) => (
                          <span class:list={[
                            "inline-flex items-center px-2 py-0.5 text-[10px] rounded-full border",
                            activeTags.includes(tag)
                              ? "bg-violet-900/50 border-violet-700 text-violet-300"
                              : "bg-gray-800/60 border-gray-700/60 text-gray-400"
                          ]}>
                            🏷️ {tag}
                          </span>
                        ))}
                      </div>
                    )}

                    <!-- Match context snippet -->
                    {task.match_context && task.match_context.field !== "type" && (
                      <div class="mt-2 text-xs bg-gray-800/60 border border-gray-700/40 rounded-lg px-3 py-2 font-mono leading-relaxed">
                        <span class:list={["font-sans font-semibold mr-2 not-italic", fieldColors[task.match_context.field] ?? "text-gray-400"]}>
                          {fieldLabels[task.match_context.field] ?? task.match_context.field}
                        </span>
                        <span class="text-gray-400">{task.match_context.snippet}</span>
                      </div>
                    )}

                    <!-- Meta -->
                    <div class="flex items-center gap-3 mt-2 text-xs text-gray-500">
                      <span>{new Date(task.created_at).toLocaleDateString()}</span>
                      {task.completed_at && (
                        <span>Completed {new Date(task.completed_at).toLocaleDateString()}</span>
                      )}
                      {task.credits_used > 0 && (
                        <span>{task.credits_used} cr</span>
                      )}
                      {task.has_output && (
                        <span class="text-green-600">Has output</span>
                      )}
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}

        <!-- Pagination -->
        {results.total > pageSize && (
          <div class="flex items-center justify-between mt-8">
            {page > 1 ? (
              <a
                href={`?${filterQs({ page: String(page - 1) })}`}
                class="px-5 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-lg text-sm transition-colors"
              >
                ← Previous
              </a>
            ) : <div />}

            {results.has_next && (
              <a
                href={`?${filterQs({ page: String(page + 1) })}`}
                class="px-5 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-lg text-sm transition-colors"
              >
                Next →
              </a>
            )}
          </div>
        )}
      </div>
    ) : !shouldSearch ? (
      <div class="text-center py-16 text-gray-500">
        <div class="text-5xl mb-4">🔍</div>
        <p class="text-base font-medium mb-2">Search inside your tasks</p>
        <p class="text-sm max-w-sm mx-auto">
          Find tasks by content — search through task types, instructions, input data, and AI output results.
        </p>
        <div class="mt-8 grid grid-cols-2 gap-3 max-w-sm mx-auto text-left">
          {[
            { icon: "📥", label: "Input search", desc: "Find tasks by their input data" },
            { icon: "📤", label: "Output search", desc: "Search AI results and outputs" },
            { icon: "📝", label: "Instructions", desc: "Search task instructions text" },
            { icon: "🏷️", label: "Tag filters", desc: "Filter by task tags instantly" },
          ].map(({ icon, label, desc }) => (
            <div class="p-3 bg-gray-900 border border-gray-800 rounded-xl">
              <div class="text-lg mb-1">{icon}</div>
              <div class="text-xs font-medium text-gray-300">{label}</div>
              <div class="text-xs text-gray-500 mt-0.5">{desc}</div>
            </div>
          ))}
        </div>
      </div>
    ) : null}
  </div>

  <script>
    // ── Tag chip interactions ──────────────────────────────────────────────────
    const tagsHidden = document.getElementById("tags-hidden") as HTMLInputElement | null;
    const searchForm = document.getElementById("search-form") as HTMLFormElement | null;

    function getActiveTags(): string[] {
      const v = tagsHidden?.value ?? "";
      return v ? v.split(",").map(t => t.trim()).filter(Boolean) : [];
    }

    function setActiveTags(tags: string[]) {
      if (tagsHidden) tagsHidden.value = tags.join(",");
    }

    // Remove active tag
    document.querySelectorAll(".tag-chip-active").forEach(chip => {
      chip.addEventListener("click", () => {
        const tag = chip.getAttribute("data-tag") ?? "";
        const tags = getActiveTags().filter(t => t !== tag);
        setActiveTags(tags);
        searchForm?.submit();
      });
    });

    // Add inactive tag
    document.querySelectorAll(".tag-chip-add").forEach(chip => {
      chip.addEventListener("click", () => {
        const tag = chip.getAttribute("data-tag") ?? "";
        const tags = [...getActiveTags(), tag];
        setActiveTags(tags);
        searchForm?.submit();
      });
    });

    // ── Saved filters (localStorage) ──────────────────────────────────────────
    const STORAGE_KEY = "cs_saved_task_filters";
    const savedBar = document.getElementById("saved-filters-bar");
    const savedChips = document.getElementById("saved-filter-chips");
    const saveBtn = document.getElementById("save-filter-btn");

    function loadSavedFilters(): Array<{ name: string; qs: string }> {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) ?? "[]");
      } catch { return []; }
    }

    function saveSavedFilters(filters: Array<{ name: string; qs: string }>) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(filters.slice(0, 10)));
    }

    function renderSavedChips() {
      const filters = loadSavedFilters();
      if (!savedBar || !savedChips) return;
      if (filters.length > 0) {
        savedBar.classList.remove("hidden");
      }
      savedChips.innerHTML = filters.map((f, i) =>
        `<span class="inline-flex items-center gap-0.5">
          <a href="/dashboard/search/tasks?${f.qs}"
            class="text-xs px-2.5 py-1 bg-gray-800 border border-gray-700 text-gray-300 hover:text-white hover:border-gray-500 rounded-l-lg transition-colors">
            ${f.name}
          </a>
          <button data-idx="${i}" class="saved-del text-xs px-1.5 py-1 bg-gray-800 border border-gray-700 border-l-0 text-gray-500 hover:text-red-400 hover:border-red-800 rounded-r-lg transition-colors" title="Delete saved filter">✕</button>
        </span>`
      ).join("");

      savedChips.querySelectorAll(".saved-del").forEach(btn => {
        btn.addEventListener("click", () => {
          const idx = parseInt(btn.getAttribute("data-idx") ?? "0", 10);
          const filters = loadSavedFilters();
          filters.splice(idx, 1);
          saveSavedFilters(filters);
          renderSavedChips();
        });
      });
    }

    saveBtn?.addEventListener("click", () => {
      const url = new URL(window.location.href);
      url.searchParams.delete("page");
      const qs = url.searchParams.toString();
      if (!qs) {
        const btn = saveBtn as HTMLButtonElement;
        const orig = btn.textContent;
        btn.textContent = "⚠ Set filters first";
        btn.classList.add("text-amber-400");
        setTimeout(() => { btn.textContent = orig; btn.classList.remove("text-amber-400"); }, 2500);
        return;
      }
      // Inline name input — replaces prompt()
      const origBtn = saveBtn as HTMLButtonElement;
      const input = document.createElement("input");
      input.type = "text";
      input.value = "My filters";
      input.maxLength = 30;
      input.placeholder = "Filter name…";
      input.className = "text-xs px-2 py-1 bg-gray-800 border border-violet-600 rounded text-white focus:outline-none focus:ring-2 focus:ring-violet-400/40 focus:border-violet-400 w-28";
      const confirmBtn = document.createElement("button");
      confirmBtn.type = "button";
      confirmBtn.textContent = "Save";
      confirmBtn.className = "text-xs px-2 py-1 bg-violet-600 hover:bg-violet-700 text-white rounded ml-1 transition-colors";
      const cancelBtn = document.createElement("button");
      cancelBtn.type = "button";
      cancelBtn.textContent = "✕";
      cancelBtn.className = "text-xs px-1.5 py-1 text-gray-500 hover:text-gray-300 ml-1";
      const wrapper = document.createElement("span");
      wrapper.className = "inline-flex items-center";
      wrapper.append(input, confirmBtn, cancelBtn);
      origBtn.replaceWith(wrapper);
      input.focus();
      input.select();

      const restore = () => wrapper.replaceWith(origBtn);
      const doSave = () => {
        const name = input.value.trim();
        if (!name) { input.focus(); return; }
        const filters = loadSavedFilters();
        filters.unshift({ name: name.slice(0, 30), qs });
        saveSavedFilters(filters);
        savedBar?.classList.remove("hidden");
        renderSavedChips();
        restore();
      };
      confirmBtn.addEventListener("click", doSave);
      cancelBtn.addEventListener("click", restore);
      input.addEventListener("keydown", (e) => {
        if (e.key === "Enter") doSave();
        if (e.key === "Escape") restore();
      });
    });

    // Init
    renderSavedChips();
  </script>
</Layout>
