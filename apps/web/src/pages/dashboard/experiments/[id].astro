---
/**
 * A/B Experiment Results — statistical analysis for a single experiment.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login");

const { id } = Astro.params;

let experiment: any = null;
let results: any = null;
let error: string | null = null;

try {
  [experiment, results] = await Promise.all([
    apiFetch<any>(`/v1/experiments/${id}`, { token }),
    apiFetch<any>(`/v1/experiments/${id}/results`, { token }),
  ]);
} catch (e: any) {
  if (e.message?.includes("401") || e.message?.includes("403")) return Astro.redirect("/login");
  if (e.message?.includes("404")) return Astro.redirect("/dashboard/experiments");
  error = e.message ?? "Failed to load experiment.";
}

const metricLabels: Record<string, string> = {
  completion_rate: "Completion Rate",
  accuracy:        "Accuracy",
  avg_time:        "Avg. Time (ms)",
  credits_used:    "Credits Used",
};

---

<Layout title={`Experiment: ${experiment?.name ?? id} — CrowdSorcerer`}>
  <div class="max-w-5xl mx-auto px-6 py-10">
    <div class="flex items-center gap-3 mb-2">
      <a href="/dashboard/experiments" class="text-gray-400 hover:text-white text-sm">← Experiments</a>
    </div>

    {error ? (
      <div class="bg-red-900/30 border border-red-800 text-red-300 p-4 rounded-lg">{error}</div>
    ) : experiment && (
      <>
        <div class="mb-8">
          <div class="flex items-center gap-3 mb-2">
            <h1 class="text-2xl font-bold">🧪 {experiment.name}</h1>
            <span class={`px-2 py-0.5 rounded-full text-xs font-medium ${
              experiment.status === "running" ? "bg-green-900/40 text-green-400" :
              experiment.status === "completed" ? "bg-blue-900/40 text-blue-400" :
              experiment.status === "paused" ? "bg-yellow-900/40 text-yellow-400" :
              "bg-gray-700 text-gray-300"
            }`}>
              {experiment.status}
            </span>
          </div>
          {experiment.description && <p class="text-gray-400 text-sm mb-1">{experiment.description}</p>}
          {experiment.hypothesis && (
            <p class="text-gray-500 text-sm italic">💡 Hypothesis: {experiment.hypothesis}</p>
          )}
        </div>

        <!-- KPI Cards -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
            <div class="text-2xl font-bold text-white">{results?.total_participants ?? 0}</div>
            <div class="text-xs text-gray-400 mt-1">Total Participants</div>
          </div>
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
            <div class="text-2xl font-bold text-white">{experiment.variants?.length ?? 0}</div>
            <div class="text-xs text-gray-400 mt-1">Variants</div>
          </div>
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
            <div class={`text-2xl font-bold ${
              results?.statistical_significance != null && results.statistical_significance < 0.05
                ? "text-green-400" : "text-gray-400"
            }`}>
              {results?.statistical_significance != null
                ? `p=${results.statistical_significance}`
                : "N/A"}
            </div>
            <div class="text-xs text-gray-400 mt-1">Significance (p-value)</div>
          </div>
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
            <div class="text-sm font-medium text-gray-300">
              {metricLabels[experiment.primary_metric] ?? experiment.primary_metric}
            </div>
            <div class="text-xs text-gray-400 mt-1">Primary Metric</div>
          </div>
        </div>

        <!-- Recommendation banner -->
        {results?.recommendation && (
          <div class={`p-4 rounded-xl border mb-8 ${
            results.statistical_significance != null && results.statistical_significance < 0.05
              ? "bg-green-900/20 border-green-800/40 text-green-300"
              : "bg-gray-800 border-gray-700 text-gray-300"
          }`}>
            <span class="font-medium">📊 Recommendation: </span>{results.recommendation}
          </div>
        )}

        <!-- Variant comparison table -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-8">
          <div class="px-6 py-4 border-b border-gray-800">
            <h2 class="font-semibold">Variant Comparison</h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-gray-800/50">
                <tr>
                  <th class="px-4 py-3 text-left text-xs text-gray-400 font-medium">Variant</th>
                  <th class="px-4 py-3 text-right text-xs text-gray-400 font-medium">Traffic %</th>
                  <th class="px-4 py-3 text-right text-xs text-gray-400 font-medium">Participants</th>
                  <th class="px-4 py-3 text-right text-xs text-gray-400 font-medium">Completions</th>
                  <th class="px-4 py-3 text-right text-xs text-gray-400 font-medium">Failures</th>
                  <th class="px-4 py-3 text-right text-xs text-gray-400 font-medium">Completion Rate</th>
                  <th class="px-4 py-3 text-right text-xs text-gray-400 font-medium">Avg Accuracy</th>
                  <th class="px-4 py-3 text-right text-xs text-gray-400 font-medium">Avg Duration</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-800">
                {results?.variants?.map((v: any) => {
                  const isWinner = v.id === results.winner_variant_id;
                  return (
                    <tr class={isWinner ? "bg-violet-900/10" : ""}>
                      <td class="px-4 py-3">
                        <div class="flex items-center gap-2">
                          {v.is_control && <span class="text-xs bg-gray-700 text-gray-300 px-1.5 py-0.5 rounded">Control</span>}
                          {isWinner && <span class="text-xs bg-violet-800 text-violet-300 px-1.5 py-0.5 rounded">🏆 Winner</span>}
                          <span class="text-gray-200 font-medium">{v.name}</span>
                        </div>
                      </td>
                      <td class="px-4 py-3 text-right text-gray-400">{v.traffic_pct}%</td>
                      <td class="px-4 py-3 text-right text-gray-300">{v.participant_count}</td>
                      <td class="px-4 py-3 text-right text-green-400">{v.completion_count}</td>
                      <td class="px-4 py-3 text-right text-red-400">{v.failure_count}</td>
                      <td class={`px-4 py-3 text-right font-medium ${isWinner ? "text-violet-300" : "text-gray-200"}`}>
                        {v.completion_rate}%
                      </td>
                      <td class="px-4 py-3 text-right text-gray-300">
                        {v.avg_accuracy != null ? `${(v.avg_accuracy * 100).toFixed(1)}%` : "—"}
                      </td>
                      <td class="px-4 py-3 text-right text-gray-300">
                        {v.avg_duration_ms != null ? `${Math.round(v.avg_duration_ms)}ms` : "—"}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Enroll a task section (for running experiments) -->
        {experiment.status === "running" && (
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
            <h2 class="font-semibold mb-4">Enroll a Task</h2>
            <p class="text-sm text-gray-400 mb-4">
              Enroll an existing task into this experiment to track its outcome against a variant.
            </p>
            <form id="enroll-form" class="flex gap-3">
              <input id="enroll-task-id" placeholder="Task ID (UUID)"
                class="flex-1 bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/40 focus:border-violet-500" />
              <button type="submit"
                class="px-4 py-2 bg-violet-600 hover:bg-violet-700 text-white rounded-lg text-sm font-medium transition-colors">
                Enroll
              </button>
            </form>
            <div id="enroll-result" class="mt-3 text-sm hidden"></div>
          </div>
        )}
      </>
    )}
  </div>

  <script is:inline define:vars={{ expId: id }}>
    document.getElementById("enroll-form")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const taskEl = document.getElementById("enroll-task-id");
      const taskId = taskEl ? taskEl.value.trim() : "";
      if (!taskId) return;
      const resultEl = document.getElementById("enroll-result");
      const submitBtn = e.currentTarget.querySelector("button[type='submit']");
      resultEl.className = "mt-3 text-sm hidden";
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = "Enrolling…"; }
      try {
        const res = await fetch(`/api/experiments/${expId}/enroll`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ task_id: taskId, experiment_id: expId }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.detail ?? "Failed");
        resultEl.textContent = `✅ Enrolled in variant: ${data.variant_name}`;
        resultEl.className = "mt-3 text-sm text-green-400";
      } catch (err) {
        resultEl.textContent = `❌ ${err?.message ?? "Error"}`;
        resultEl.className = "mt-3 text-sm text-red-400";
      } finally {
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = "Enroll"; }
      }
    });
  </script>
</Layout>
