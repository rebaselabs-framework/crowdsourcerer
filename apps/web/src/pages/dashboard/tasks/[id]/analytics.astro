---
/**
 * Per-task Analytics — response distribution, accuracy, worker breakdown.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login");

const { id } = Astro.params;

let analytics: any = null;
let error: string | null = null;

try {
  analytics = await apiFetch(`/v1/tasks/${id}/analytics`, { token });
} catch (e: any) {
  error = e.message ?? "Failed to load analytics.";
}

const a = analytics;

const statusLabels = ["Approved", "Rejected", "Pending"];
const statusData = a ? [a.approved_count, a.rejected_count, a.pending_count] : [0, 0, 0];
const statusColors = ["#10b981", "#ef4444", "#f59e0b"];

const distLabels: string[] = a ? Object.keys(a.response_distribution) : [];
const distData: number[] = a ? Object.values(a.response_distribution) : [];
---

<Layout title={`Analytics — ${a?.title ?? "Task"}`}>
  <div class="max-w-5xl mx-auto px-6 py-10">

    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6 flex items-center gap-2">
      <a href="/dashboard" class="hover:text-gray-300">Dashboard</a>
      <span>/</span>
      <a href="/dashboard/tasks" class="hover:text-gray-300">Tasks</a>
      <span>/</span>
      <a href={`/dashboard/tasks/${id}`} class="hover:text-gray-300 truncate max-w-[160px]">
        {a?.title ?? id?.slice(0,8)}
      </a>
      <span>/</span>
      <span class="text-gray-300">Analytics</span>
    </nav>

    {error && (
      <div class="text-red-400 bg-red-900/20 border border-red-800/40 rounded-xl p-6 mb-6 text-center">
        {error}
      </div>
    )}

    {a && (
      <>
        <!-- Header -->
        <div class="flex items-start justify-between mb-8">
          <div>
            <h1 class="text-2xl font-bold">{a.title}</h1>
            <div class="flex items-center gap-3 mt-1">
              <span class="text-sm text-gray-400 capitalize">{a.task_type.replace(/_/g, " ")}</span>
              <span class:list={[
                "text-xs px-2 py-0.5 rounded-full font-medium",
                a.status === "completed" ? "bg-green-900/40 text-green-300 border border-green-800" :
                a.status === "open" ? "bg-blue-900/40 text-blue-300 border border-blue-800" :
                "bg-gray-800 text-gray-400 border border-gray-700",
              ]}>{a.status}</span>
              {a.is_gold_standard && (
                <span class="text-xs px-2 py-0.5 rounded-full bg-amber-900/40 text-amber-300 border border-amber-800 font-medium">
                  🏅 Gold Standard
                </span>
              )}
            </div>
          </div>
          <a href={`/dashboard/tasks/${id}`} class="text-sm text-gray-400 hover:text-white transition-colors">
            ← Back to task
          </a>
        </div>

        <!-- KPI cards -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 text-center">
            <div class="text-3xl font-bold text-white">{a.total_assignments}</div>
            <div class="text-xs text-gray-500 mt-1">Total Submissions</div>
          </div>
          <div class="bg-gray-900 border border-green-800/40 rounded-xl p-4 text-center">
            <div class="text-3xl font-bold text-green-400">{a.approved_count}</div>
            <div class="text-xs text-gray-500 mt-1">Approved</div>
          </div>
          <div class="bg-gray-900 border border-amber-800/40 rounded-xl p-4 text-center">
            <div class="text-3xl font-bold text-amber-400">{a.total_credits_paid}</div>
            <div class="text-xs text-gray-500 mt-1">Credits Paid</div>
          </div>
          {a.accuracy_rate != null ? (
            <div class="bg-gray-900 border border-violet-800/40 rounded-xl p-4 text-center">
              <div class="text-3xl font-bold text-violet-400">{(a.accuracy_rate * 100).toFixed(0)}%</div>
              <div class="text-xs text-gray-500 mt-1">Accuracy Rate</div>
            </div>
          ) : (
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 text-center">
              <div class="text-3xl font-bold text-gray-400">
                {a.avg_response_minutes != null
                  ? `${a.avg_response_minutes.toFixed(1)}m`
                  : "—"}
              </div>
              <div class="text-xs text-gray-500 mt-1">Avg Response Time</div>
            </div>
          )}
        </div>

        <!-- Charts row -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <!-- Status doughnut -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <h2 class="font-semibold text-gray-300 mb-4">Submission Status</h2>
            {statusData.some((v) => v > 0) ? (
              <canvas id="statusChart" height="220"></canvas>
            ) : (
              <div class="flex items-center justify-center h-32 text-gray-500 text-sm">
                No submissions yet
              </div>
            )}
          </div>

          <!-- Response distribution -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <h2 class="font-semibold text-gray-300 mb-4">Response Distribution</h2>
            {distLabels.length > 0 ? (
              <canvas id="distChart" height="220"></canvas>
            ) : (
              <div class="flex items-center justify-center h-32 text-gray-500 text-sm">
                No structured responses yet
              </div>
            )}
          </div>
        </div>

        <!-- Assignment table -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
          <div class="px-5 py-4 border-b border-gray-800 flex items-center justify-between">
            <h2 class="font-semibold text-gray-300">Submission Details</h2>
            <span class="text-xs text-gray-500">{a.assignments.length} submission{a.assignments.length !== 1 ? "s" : ""}</span>
          </div>
          {a.assignments.length === 0 ? (
            <div class="p-8 text-center text-gray-500 text-sm">No submissions yet.</div>
          ) : (
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead class="bg-gray-800/60">
                  <tr>
                    {["Worker", "Status", "Response Time", "Credits", "Accurate"].map((col) => (
                      <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wide">{col}</th>
                    ))}
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-800">
                  {a.assignments.map((row: any) => (
                    <tr class="hover:bg-gray-800/40">
                      <td class="px-4 py-3 font-medium text-gray-200">
                        {row.worker_name ?? (row.worker_id?.slice(0, 8) + "…")}
                      </td>
                      <td class="px-4 py-3">
                        <span class:list={[
                          "inline-block px-2 py-0.5 rounded-full text-xs font-medium border",
                          row.status === "approved" ? "bg-green-900/40 text-green-300 border-green-800" :
                          row.status === "rejected" ? "bg-red-900/40 text-red-300 border-red-800" :
                          row.status === "submitted" ? "bg-blue-900/40 text-blue-300 border-blue-800" :
                          "bg-gray-800 text-gray-400 border-gray-700",
                        ]}>{row.status}</span>
                      </td>
                      <td class="px-4 py-3 text-gray-400">
                        {row.response_minutes != null ? `${row.response_minutes.toFixed(1)} min` : "—"}
                      </td>
                      <td class="px-4 py-3 text-amber-400 font-medium">{row.earnings_credits}</td>
                      <td class="px-4 py-3">
                        {row.is_accurate == null ? (
                          <span class="text-gray-600">—</span>
                        ) : row.is_accurate ? (
                          <span class="text-green-400 font-medium">✓ Yes</span>
                        ) : (
                          <span class="text-red-400 font-medium">✗ No</span>
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </>
    )}
  </div>
</Layout>

<script define:vars={{ statusLabels, statusData, statusColors, distLabels, distData }}>
  const s = document.createElement("script");
  s.src = "https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js";
  s.onload = () => {
    const statusCtx = document.getElementById("statusChart");
    if (statusCtx && statusData.some((v) => v > 0)) {
      new Chart(statusCtx, {
        type: "doughnut",
        data: {
          labels: statusLabels,
          datasets: [{
            data: statusData,
            backgroundColor: statusColors,
            borderWidth: 0,
            hoverOffset: 4,
          }],
        },
        options: {
          responsive: true,
          plugins: {
            legend: {
              position: "bottom",
              labels: { color: "#9ca3af", padding: 12 },
            },
          },
        },
      });
    }

    const distCtx = document.getElementById("distChart");
    if (distCtx && distLabels.length > 0) {
      new Chart(distCtx, {
        type: "bar",
        data: {
          labels: distLabels,
          datasets: [{
            label: "Count",
            data: distData,
            backgroundColor: "rgba(139, 92, 246, 0.7)",
            borderRadius: 4,
            borderSkipped: false,
          }],
        },
        options: {
          responsive: true,
          plugins: { legend: { display: false } },
          scales: {
            x: { ticks: { color: "#9ca3af" }, grid: { color: "rgba(255,255,255,0.04)" } },
            y: { beginAtZero: true, ticks: { stepSize: 1, color: "#9ca3af" }, grid: { color: "rgba(255,255,255,0.04)" } },
          },
        },
      });
    }
  };
  document.head.appendChild(s);
</script>
