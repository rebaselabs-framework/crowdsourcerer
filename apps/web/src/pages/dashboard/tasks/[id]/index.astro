---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Object.fromEntries(
  Astro.cookies.getAll().map((c) => [c.name, c.value])
));
if (!token) return Astro.redirect("/login");

const { id } = Astro.params;

// Handle approve/reject/rerun POST actions
let rerunError = "";
let rerunTaskId: string | null = null;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("action") as string;

  if (action === "rerun") {
    try {
      const result = await apiFetch<any>(`/v1/tasks/${id}/rerun`, {
        method: "POST",
        token,
      });
      // Redirect to the new task
      return Astro.redirect(`/dashboard/tasks/${result.task_id}`);
    } catch (e: any) {
      rerunError = e.message ?? "Failed to rerun task";
    }
  } else {
    const assignmentId = form.get("assignment_id") as string;
    const reason = form.get("reason") as string | undefined;

    try {
      await apiFetch(`/v1/tasks/${id}/submissions/${assignmentId}/${action}`, {
        method: "POST",
        token,
        body: JSON.stringify({ reason: reason || null }),
      });
    } catch (_) {
      // Fall through — errors shown on reload
    }
    return Astro.redirect(`/dashboard/tasks/${id}`);
  }
}

let task: any = null;
let submissions: any[] = [];
let comments: any[] = [];
let notFound = false;

try {
  task = await apiFetch<any>(`/v1/tasks/${id}`, { token });
} catch (e: any) {
  if (e.message?.includes("404") || e.message?.includes("not found")) {
    notFound = true;
  } else {
    return Astro.redirect("/login");
  }
}

// Load submissions for human tasks
if (task?.execution_mode === "human") {
  try {
    submissions = await apiFetch<any[]>(`/v1/tasks/${id}/submissions`, { token });
  } catch (_) {
    submissions = [];
  }
}

// Load comments
try {
  const commentData = await apiFetch<any>(`/v1/tasks/${id}/comments?per_page=100`, { token });
  comments = commentData?.comments ?? [];
} catch (_) {
  comments = [];
}

// Load task dependencies (upstream) + dependents (downstream)
let dependencies: any[] = [];
let dependents: any[] = [];
try {
  [dependencies, dependents] = await Promise.all([
    apiFetch<any[]>(`/v1/tasks/${id}/dependencies`, { token }),
    apiFetch<any[]>(`/v1/tasks/${id}/dependents`, { token }),
  ]);
} catch (_) {}

// Advance requester onboarding: view_results step (fire-and-forget, non-blocking)
if (task?.status === "completed") {
  apiFetch("/v1/requester-onboarding/steps/view_results/complete", {
    method: "POST", token
  }).catch(() => {});
}

const STATUS_COLORS: Record<string, string> = {
  completed: "bg-green-950/50 border-green-800 text-green-300",
  failed:    "bg-red-950/50 border-red-800 text-red-300",
  running:   "bg-yellow-950/50 border-yellow-800 text-yellow-300",
  queued:    "bg-blue-950/50 border-blue-800 text-blue-300",
  pending:   "bg-gray-800/50 border-gray-700 text-gray-300",
  open:      "bg-violet-950/50 border-violet-800 text-violet-300",
  assigned:  "bg-amber-950/50 border-amber-800 text-amber-300",
  cancelled: "bg-gray-800/50 border-gray-700 text-gray-500",
  archived:  "bg-gray-900/50 border-gray-800 text-gray-600",
};

const SUB_STATUS_COLORS: Record<string, string> = {
  submitted: "bg-yellow-950/40 border-yellow-800 text-yellow-300",
  approved:  "bg-green-950/40 border-green-800 text-green-300",
  rejected:  "bg-red-950/40 border-red-800 text-red-300",
  active:    "bg-blue-950/40 border-blue-800 text-blue-300",
};

const duration = task?.completed_at && task?.created_at
  ? Math.round((new Date(task.completed_at).getTime() - new Date(task.created_at).getTime()) / 1000)
  : null;

const isLive = task && ["running", "queued", "pending", "open", "assigned"].includes(task.status);
const pendingSubmissions = submissions.filter((s: any) => s.status === "submitted").length;

// ── Rich output helpers ───────────────────────────────────────────────────────
type RichOutput =
  | { kind: "web_research"; summary: string; sources?: string[]; key_facts?: string[] }
  | { kind: "web_intel"; report: string; entities?: string[]; sources?: string[] }
  | { kind: "entity_lookup"; fields: Record<string, any> }
  | { kind: "document_parse"; sections?: Array<{ title?: string; content: string }>; tables?: any[][]; raw_text?: string }
  | { kind: "llm_generate"; text: string; model?: string; tokens?: number }
  | { kind: "audio_transcribe"; transcript: string; language?: string; confidence?: number }
  | { kind: "pii_detect"; findings: Array<{ type: string; value: string; redacted: string; start: number; end: number }>; redacted_text?: string }
  | { kind: "code_execute"; stdout?: string; stderr?: string; exit_code?: number; output?: any }
  | { kind: "screenshot"; url?: string; image_url?: string; image_base64?: string }
  | { kind: "data_transform"; result: any; rows_processed?: number; rows_output?: number }
  | { kind: "moderate_content"; verdict: string; confidence?: number; violations?: Array<{ policy: string; confidence: number; excerpt?: string }>; recommended_action?: string }
  | { kind: "raw"; data: any };

function parseRichOutput(type: string, output: any): RichOutput {
  if (!output) return { kind: "raw", data: output };
  const o = typeof output === "string" ? (() => { try { return JSON.parse(output); } catch { return { text: output }; } })() : output;

  if (type === "web_research") {
    return {
      kind: "web_research",
      summary: o.summary ?? o.result ?? o.content ?? JSON.stringify(o),
      sources: Array.isArray(o.sources) ? o.sources : (o.source ? [o.source] : undefined),
      key_facts: Array.isArray(o.key_facts) ? o.key_facts : undefined,
    };
  }
  if (type === "web_intel") {
    return {
      kind: "web_intel",
      report: o.report ?? o.summary ?? o.content ?? JSON.stringify(o),
      entities: Array.isArray(o.entities) ? o.entities : undefined,
      sources: Array.isArray(o.sources) ? o.sources : undefined,
    };
  }
  if (type === "entity_lookup") {
    const { type: _t, ...fields } = o;
    return { kind: "entity_lookup", fields };
  }
  if (type === "document_parse") {
    return {
      kind: "document_parse",
      sections: Array.isArray(o.sections) ? o.sections : undefined,
      tables: Array.isArray(o.tables) ? o.tables : undefined,
      raw_text: o.raw_text ?? o.text ?? (typeof o === "string" ? o : undefined),
    };
  }
  if (type === "llm_generate") {
    return {
      kind: "llm_generate",
      text: o.text ?? o.content ?? o.result ?? JSON.stringify(o),
      model: o.model,
      tokens: o.tokens ?? o.usage?.total_tokens,
    };
  }
  if (type === "audio_transcribe") {
    return {
      kind: "audio_transcribe",
      transcript: o.transcript ?? o.text ?? o.result ?? JSON.stringify(o),
      language: o.language ?? o.detected_language,
      confidence: o.confidence,
    };
  }
  if (type === "pii_detect") {
    return {
      kind: "pii_detect",
      findings: Array.isArray(o.findings) ? o.findings : (Array.isArray(o.pii) ? o.pii : []),
      redacted_text: o.redacted_text ?? o.redacted,
    };
  }
  if (type === "code_execute") {
    return {
      kind: "code_execute",
      stdout: o.stdout,
      stderr: o.stderr,
      exit_code: o.exit_code ?? o.returncode,
      output: o.output ?? o.result,
    };
  }
  if (type === "screenshot") {
    return {
      kind: "screenshot",
      url: o.url,
      image_url: o.image_url ?? o.screenshot_url,
      image_base64: o.image_base64,
    };
  }
  if (type === "data_transform") {
    return {
      kind: "data_transform",
      result: o.result ?? o.data ?? o,
      rows_processed: o.rows_processed ?? o.input_count,
      rows_output: o.rows_output ?? o.output_count,
    };
  }
  if (type === "moderate_content") {
    return {
      kind: "moderate_content",
      verdict: o.verdict ?? (o.safe ? "safe" : "flag"),
      confidence: o.confidence,
      violations: Array.isArray(o.violations) ? o.violations : undefined,
      recommended_action: o.recommended_action ?? o.action,
    };
  }
  return { kind: "raw", data: o };
}

const richOutput: RichOutput | null = task?.output ? parseRichOutput(task.type, task.output) : null;
---

<Layout title={task ? `Task ${task.id.slice(0,8)}… — CrowdSorcerer` : "Task Not Found"}>
  <div class="max-w-4xl mx-auto px-6 py-10">
    <div class="text-sm text-gray-500 mb-6">
      <a href="/dashboard" class="hover:text-gray-300 transition-colors">Dashboard</a>
      <span class="mx-2">›</span>
      <a href="/dashboard/tasks" class="hover:text-gray-300 transition-colors">Tasks</a>
      <span class="mx-2">›</span>
      <span class="font-mono">{id?.slice(0, 8)}…</span>
    </div>

    {rerunError && (
      <div class="bg-red-900/30 border border-red-700/50 rounded-xl px-5 py-3 mb-4 text-red-300 text-sm">
        ⚠️ Rerun failed: {rerunError}
      </div>
    )}

    {notFound ? (
      <div class="text-center py-20">
        <div class="text-4xl mb-4">🔍</div>
        <h1 class="text-xl font-bold mb-2">Task not found</h1>
        <p class="text-gray-400 text-sm mb-6">This task doesn't exist or doesn't belong to you.</p>
        <a href="/dashboard/tasks" class="text-violet-400 hover:text-violet-300">← Back to tasks</a>
      </div>
    ) : task ? (
      <div>
        <div class="flex items-start justify-between mb-8">
          <div>
            <h1 class="text-2xl font-bold font-mono text-violet-300">{task.type}</h1>
            <p class="text-gray-500 text-sm mt-1 font-mono">{task.id}</p>
          </div>
          <div class="flex items-center gap-3">
            {/* Analytics link */}
            <a
              href={`/dashboard/tasks/${id}/analytics`}
              class="px-3 py-1.5 rounded-lg border border-gray-700 text-sm text-gray-300 hover:bg-gray-800 hover:text-white transition-colors"
            >
              📊 Analytics
            </a>
            {/* Rerun button — shown once task is in a terminal state */}
            {["completed", "failed", "cancelled", "archived"].includes(task.status) && (
              <form method="POST">
                <input type="hidden" name="action" value="rerun" />
                <button type="submit"
                  class="px-3 py-1.5 rounded-lg border border-emerald-700/60 text-sm text-emerald-300 hover:bg-emerald-900/30 hover:text-emerald-200 transition-colors"
                  title="Clone this task and queue a fresh run">
                  ↺ Rerun
                </button>
              </form>
            )}
            {/* Duplicate button — pre-fills new-task form, does NOT auto-execute */}
            <button
              id="duplicate-task-btn"
              data-task-id={task.id}
              class="px-3 py-1.5 rounded-lg border border-blue-700/60 text-sm text-blue-300 hover:bg-blue-900/30 hover:text-blue-200 transition-colors"
              title="Open a pre-filled new-task form (does not execute immediately)"
            >
              📋 Duplicate
            </button>
            {/* Live status badge — updated via SSE */}
            <div
              id="status-badge"
              class:list={[
                "px-4 py-1.5 rounded-full border text-sm font-medium transition-all",
                STATUS_COLORS[task.status] ?? "bg-gray-800 border-gray-700 text-gray-300"
              ]}
              data-status={task.status}
            >
              {task.status}
            </div>
            {isLive && (
              <span id="live-dot" class="flex items-center gap-1.5 text-xs text-gray-400">
                <span class="w-1.5 h-1.5 rounded-full bg-yellow-400 animate-pulse"></span>
                live
              </span>
            )}
          </div>
        </div>

        <!-- Priority auto-escalation banner -->
        {task.priority_escalated_at && (
          <div class="bg-orange-950/30 border border-orange-700 rounded-xl px-5 py-3 mb-6 flex items-center gap-2 text-orange-300 text-sm">
            <span class="text-base">⬆️</span>
            <span>
              This task's priority was auto-escalated at{" "}
              <strong>{new Date(task.priority_escalated_at).toLocaleString()}</strong>
            </span>
          </div>
        )}

        <!-- Pending submissions alert -->
        {pendingSubmissions > 0 && (
          <div class="bg-amber-950/30 border border-amber-700 rounded-xl px-5 py-3 mb-6 flex items-center justify-between">
            <div class="flex items-center gap-2 text-amber-300 text-sm">
              <span class="text-base">⏳</span>
              <span>
                <strong>{pendingSubmissions}</strong> submission{pendingSubmissions > 1 ? "s" : ""} awaiting your review
              </span>
            </div>
            <a
              href="/dashboard/review"
              class="text-xs text-amber-400 hover:text-amber-300 transition-colors"
            >
              Review all →
            </a>
          </div>
        )}

        <!-- Metadata grid -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
          {[
            {
              label: task.execution_mode === "human" ? "Workers progress" : "Credits used",
              value: task.execution_mode === "human"
                ? `${task.assignments_completed}/${task.assignments_required} done`
                : (task.credits_used != null ? `${task.credits_used} cr` : "—"),
            },
            { label: "Priority", value: task.priority ?? "normal" },
            {
              label: "Duration",
              value: duration != null ? `${duration}s` : "—",
              id: "meta-duration",
            },
            { label: "Submitted", value: new Date(task.created_at).toLocaleString() },
          ].map(({ label, value, id: elId }) => (
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
              <div class="text-xs text-gray-500 mb-1">{label}</div>
              <div class="font-medium text-sm" id={elId ?? undefined}>{value}</div>
            </div>
          ))}
        </div>

        <!-- Tags + Scheduled -->
        <div class="flex flex-wrap items-center gap-3 mb-6">
          {/* Scheduled badge */}
          {task.scheduled_at && (
            <div class="flex items-center gap-2 px-3 py-1.5 bg-amber-900/20 border border-amber-800/40 rounded-lg text-xs text-amber-300">
              <span>⏰</span>
              <span>Scheduled: {new Date(task.scheduled_at).toLocaleString()}</span>
            </div>
          )}
          {/* Tags section */}
          {task.tags && (task.tags as string[]).length > 0 && (
            <div class="flex flex-wrap gap-1.5 items-center">
              {(task.tags as string[]).map((tg: string) => (
                <a
                  href={`/dashboard/tasks?tag=${encodeURIComponent(tg)}`}
                  class="px-2 py-0.5 bg-gray-800 hover:bg-gray-700 text-gray-400 text-xs rounded transition-colors"
                >
                  🏷️ {tg}
                </a>
              ))}
            </div>
          )}
          {/* Tag editor button */}
          <button
            id="edit-tags-btn"
            class="text-xs text-gray-600 hover:text-gray-400 transition-colors px-2 py-1 rounded border border-gray-800 hover:border-gray-600"
          >
            {task.tags?.length ? "✏️ Edit tags" : "🏷️ Add tags"}
          </button>
        </div>

        <!-- Inline tag editor (hidden by default) -->
        <div id="tag-editor" class="hidden mb-6 bg-gray-900 border border-gray-800 rounded-xl p-4">
          <h3 class="text-xs font-semibold text-gray-400 mb-2">Edit labels / tags</h3>
          <div class="flex gap-2">
            <input
              type="text"
              id="tag-input"
              placeholder="e.g. billing, v2, prod (comma-separated)"
              value={(task.tags as string[] | null)?.join(", ") ?? ""}
              class="flex-1 bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-100 focus:outline-none focus:border-violet-500"
            />
            <button
              id="save-tags-btn"
              class="px-4 py-2 bg-violet-600 hover:bg-violet-700 text-white text-sm rounded-lg transition-colors"
            >Save</button>
            <button
              id="cancel-tags-btn"
              class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm rounded-lg transition-colors"
            >Cancel</button>
          </div>
          <p id="tag-save-msg" class="text-xs mt-2 text-gray-600"></p>
        </div>

        <!-- Input -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl mb-4">
          <div class="px-5 py-3 border-b border-gray-800 flex items-center justify-between">
            <h2 class="text-sm font-semibold text-gray-300">Input</h2>
          </div>
          <pre class="px-5 py-4 font-mono text-sm text-gray-300 overflow-x-auto whitespace-pre-wrap">
{JSON.stringify(task.input, null, 2)}
          </pre>
        </div>

        <!-- Task instructions (human tasks) -->
        {task.task_instructions && (
          <div class="bg-gray-900 border border-gray-800 rounded-xl mb-4">
            <div class="px-5 py-3 border-b border-gray-800">
              <h2 class="text-sm font-semibold text-gray-300">Task Instructions</h2>
            </div>
            <div class="px-5 py-4 text-sm text-gray-300">
              {task.task_instructions}
            </div>
          </div>
        )}

        <!-- Output (rich type-aware viewer) -->
        <div id="output-panel" class:list={[!task.output && "hidden"]}>
          <div class="bg-gray-900 border border-gray-800 rounded-xl mb-4">
            <div class="px-5 py-3 border-b border-gray-800 flex items-center justify-between">
              <h2 class="text-sm font-semibold text-green-300">Output</h2>
              {richOutput && richOutput.kind !== "raw" && (
                <button
                  id="toggle-raw"
                  class="text-xs text-gray-500 hover:text-gray-300 transition-colors px-2 py-1 rounded border border-gray-700 hover:border-gray-500"
                >
                  View raw JSON
                </button>
              )}
            </div>

            {/* ── Rich renderers ── */}
            {richOutput?.kind === "web_research" && (
              <div id="rich-view" class="px-5 py-5 space-y-5">
                <div>
                  <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Summary</h3>
                  <p class="text-gray-200 text-sm leading-relaxed whitespace-pre-wrap">{richOutput.summary}</p>
                </div>
                {richOutput.key_facts && richOutput.key_facts.length > 0 && (
                  <div>
                    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Key Facts</h3>
                    <ul class="space-y-1">
                      {richOutput.key_facts.map((f: string) => (
                        <li class="flex items-start gap-2 text-sm text-gray-300">
                          <span class="text-green-400 mt-0.5 flex-shrink-0">✓</span>
                          <span>{f}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
                {richOutput.sources && richOutput.sources.length > 0 && (
                  <div>
                    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Sources</h3>
                    <ul class="space-y-1">
                      {richOutput.sources.map((s: string) => (
                        <li class="text-sm">
                          <a href={s} target="_blank" rel="noopener noreferrer"
                             class="text-violet-400 hover:text-violet-300 break-all transition-colors">
                            {s}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            )}

            {richOutput?.kind === "web_intel" && (
              <div id="rich-view" class="px-5 py-5 space-y-5">
                <div>
                  <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Intelligence Report</h3>
                  <p class="text-gray-200 text-sm leading-relaxed whitespace-pre-wrap">{richOutput.report}</p>
                </div>
                {richOutput.entities && richOutput.entities.length > 0 && (
                  <div>
                    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Entities Identified</h3>
                    <div class="flex flex-wrap gap-2">
                      {richOutput.entities.map((e: string) => (
                        <span class="px-2 py-1 bg-blue-950/50 border border-blue-800 rounded text-blue-300 text-xs">{e}</span>
                      ))}
                    </div>
                  </div>
                )}
                {richOutput.sources && richOutput.sources.length > 0 && (
                  <div>
                    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Sources</h3>
                    <ul class="space-y-1">
                      {richOutput.sources.map((s: string) => (
                        <li><a href={s} target="_blank" rel="noopener noreferrer" class="text-violet-400 hover:text-violet-300 text-sm break-all">{s}</a></li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            )}

            {richOutput?.kind === "entity_lookup" && (
              <div id="rich-view" class="px-5 py-5">
                <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Entity Data</h3>
                <dl class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  {Object.entries(richOutput.fields).map(([k, v]: [string, any]) => (
                    <div class="bg-gray-950/50 rounded-lg p-3">
                      <dt class="text-xs text-gray-500 mb-1 capitalize">{k.replace(/_/g, " ")}</dt>
                      <dd class="text-sm text-gray-200 break-words">
                        {Array.isArray(v) ? v.join(", ") : (v === null || v === undefined ? "—" : String(v))}
                      </dd>
                    </div>
                  ))}
                </dl>
              </div>
            )}

            {richOutput?.kind === "document_parse" && (
              <div id="rich-view" class="px-5 py-5 space-y-5">
                {richOutput.sections && richOutput.sections.length > 0 ? (
                  <div class="space-y-4">
                    {richOutput.sections.map((s: any) => (
                      <div>
                        {s.title && <h3 class="text-sm font-semibold text-gray-300 mb-1">{s.title}</h3>}
                        <p class="text-sm text-gray-400 whitespace-pre-wrap">{s.content}</p>
                      </div>
                    ))}
                  </div>
                ) : richOutput.raw_text ? (
                  <p class="text-sm text-gray-300 whitespace-pre-wrap">{richOutput.raw_text}</p>
                ) : null}
                {richOutput.tables && richOutput.tables.length > 0 && (
                  <div>
                    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Extracted Tables</h3>
                    {richOutput.tables.map((table: any[], ti: number) => (
                      <div class="overflow-x-auto mb-4">
                        <table class="w-full text-xs border-collapse">
                          {table.map((row: any[], ri: number) => (
                            <tr class="border-b border-gray-800">
                              {row.map((cell: any) => ri === 0 ? (
                                <th class="px-3 py-2 text-left font-semibold text-gray-400 bg-gray-800/50">{String(cell)}</th>
                              ) : (
                                <td class="px-3 py-2 text-gray-300">{String(cell ?? "")}</td>
                              ))}
                            </tr>
                          ))}
                        </table>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            )}

            {richOutput?.kind === "llm_generate" && (
              <div id="rich-view" class="px-5 py-5">
                {(richOutput.model || richOutput.tokens) && (
                  <div class="flex items-center gap-3 mb-3">
                    {richOutput.model && <span class="text-xs px-2 py-0.5 rounded bg-violet-950/50 border border-violet-800 text-violet-300">{richOutput.model}</span>}
                    {richOutput.tokens && <span class="text-xs text-gray-500">{richOutput.tokens} tokens</span>}
                  </div>
                )}
                <p class="text-sm text-gray-200 leading-relaxed whitespace-pre-wrap">{richOutput.text}</p>
              </div>
            )}

            {richOutput?.kind === "audio_transcribe" && (
              <div id="rich-view" class="px-5 py-5">
                <div class="flex items-center gap-3 mb-3">
                  {richOutput.language && (
                    <span class="text-xs px-2 py-0.5 rounded bg-blue-950/50 border border-blue-800 text-blue-300">
                      🌍 {richOutput.language}
                    </span>
                  )}
                  {richOutput.confidence != null && (
                    <span class="text-xs text-gray-500">
                      {Math.round(richOutput.confidence * 100)}% confidence
                    </span>
                  )}
                </div>
                <div class="bg-gray-950/50 border border-gray-800 rounded-lg p-4">
                  <p class="text-sm text-gray-200 leading-relaxed whitespace-pre-wrap font-mono">{richOutput.transcript}</p>
                </div>
              </div>
            )}

            {richOutput?.kind === "pii_detect" && (
              <div id="rich-view" class="px-5 py-5 space-y-5">
                <div class="flex items-center gap-3">
                  <span class:list={[
                    "px-3 py-1.5 rounded-full text-sm font-medium border",
                    richOutput.findings.length === 0
                      ? "bg-green-950/50 border-green-800 text-green-300"
                      : "bg-red-950/50 border-red-800 text-red-300"
                  ]}>
                    {richOutput.findings.length === 0 ? "✓ No PII found" : `⚠ ${richOutput.findings.length} PII finding${richOutput.findings.length > 1 ? "s" : ""}`}
                  </span>
                </div>
                {richOutput.redacted_text && (
                  <div>
                    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Redacted Text</h3>
                    <div class="bg-gray-950/50 border border-gray-800 rounded-lg p-4">
                      <p class="text-sm text-gray-300 whitespace-pre-wrap">{richOutput.redacted_text}</p>
                    </div>
                  </div>
                )}
                {richOutput.findings.length > 0 && (
                  <div>
                    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Findings</h3>
                    <div class="overflow-x-auto">
                      <table class="w-full text-xs">
                        <thead>
                          <tr class="border-b border-gray-800 text-gray-500">
                            <th class="px-3 py-2 text-left font-medium">Type</th>
                            <th class="px-3 py-2 text-left font-medium">Original</th>
                            <th class="px-3 py-2 text-left font-medium">Redacted</th>
                          </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-800">
                          {richOutput.findings.map((f: any) => (
                            <tr>
                              <td class="px-3 py-2">
                                <span class="px-1.5 py-0.5 bg-red-950/40 border border-red-800 rounded text-red-300">{f.type}</span>
                              </td>
                              <td class="px-3 py-2 font-mono text-gray-400 line-through">{f.value}</td>
                              <td class="px-3 py-2 font-mono text-gray-300">{f.redacted}</td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  </div>
                )}
              </div>
            )}

            {richOutput?.kind === "code_execute" && (
              <div id="rich-view" class="px-5 py-5 space-y-4">
                {richOutput.exit_code != null && (
                  <div class="flex items-center gap-2">
                    <span class:list={[
                      "text-xs px-2 py-0.5 rounded-full border font-mono",
                      richOutput.exit_code === 0
                        ? "bg-green-950/50 border-green-800 text-green-300"
                        : "bg-red-950/50 border-red-800 text-red-300"
                    ]}>
                      exit {richOutput.exit_code}
                    </span>
                  </div>
                )}
                {richOutput.stdout && (
                  <div>
                    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">stdout</h3>
                    <pre class="bg-gray-950 border border-gray-800 rounded-lg p-4 text-sm font-mono text-green-300 overflow-x-auto whitespace-pre-wrap">{richOutput.stdout}</pre>
                  </div>
                )}
                {richOutput.stderr && (
                  <div>
                    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">stderr</h3>
                    <pre class="bg-gray-950 border border-red-900/50 rounded-lg p-4 text-sm font-mono text-red-300 overflow-x-auto whitespace-pre-wrap">{richOutput.stderr}</pre>
                  </div>
                )}
                {richOutput.output != null && (
                  <div>
                    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Return value</h3>
                    <pre class="bg-gray-950 border border-gray-800 rounded-lg p-4 text-sm font-mono text-gray-300 overflow-x-auto whitespace-pre-wrap">{JSON.stringify(richOutput.output, null, 2)}</pre>
                  </div>
                )}
              </div>
            )}

            {richOutput?.kind === "screenshot" && (
              <div id="rich-view" class="px-5 py-5">
                {richOutput.url && (
                  <div class="text-xs text-gray-500 mb-3">
                    URL: <a href={richOutput.url} target="_blank" rel="noopener noreferrer" class="text-violet-400 hover:text-violet-300">{richOutput.url}</a>
                  </div>
                )}
                {(richOutput.image_url || richOutput.image_base64) ? (
                  <img
                    src={richOutput.image_url ?? `data:image/png;base64,${richOutput.image_base64}`}
                    alt="Screenshot"
                    class="rounded-lg border border-gray-800 max-w-full shadow-lg"
                    loading="lazy"
                  />
                ) : (
                  <p class="text-gray-500 text-sm">No image available in output.</p>
                )}
              </div>
            )}

            {richOutput?.kind === "data_transform" && (
              <div id="rich-view" class="px-5 py-5 space-y-4">
                {(richOutput.rows_processed != null || richOutput.rows_output != null) && (
                  <div class="flex items-center gap-4 text-xs text-gray-400">
                    {richOutput.rows_processed != null && <span>Input: <strong class="text-gray-200">{richOutput.rows_processed} rows</strong></span>}
                    {richOutput.rows_output != null && <span>Output: <strong class="text-gray-200">{richOutput.rows_output} rows</strong></span>}
                  </div>
                )}
                {Array.isArray(richOutput.result) && richOutput.result.length > 0 && typeof richOutput.result[0] === "object" ? (
                  <div class="overflow-x-auto">
                    <table class="w-full text-xs">
                      <thead>
                        <tr class="border-b border-gray-700 text-gray-500">
                          {Object.keys(richOutput.result[0]).map((k: string) => (
                            <th class="px-3 py-2 text-left font-medium">{k}</th>
                          ))}
                        </tr>
                      </thead>
                      <tbody class="divide-y divide-gray-800">
                        {richOutput.result.slice(0, 50).map((row: any) => (
                          <tr class="hover:bg-gray-800/30">
                            {Object.values(row).map((v: any) => (
                              <td class="px-3 py-2 text-gray-300 max-w-xs truncate">{v === null ? "null" : String(v)}</td>
                            ))}
                          </tr>
                        ))}
                      </tbody>
                    </table>
                    {richOutput.result.length > 50 && (
                      <div class="text-xs text-gray-500 text-center py-2">Showing 50 of {richOutput.result.length} rows</div>
                    )}
                  </div>
                ) : (
                  <pre class="bg-gray-950 border border-gray-800 rounded-lg p-4 text-sm font-mono text-gray-300 overflow-x-auto whitespace-pre-wrap">{JSON.stringify(richOutput.result, null, 2)}</pre>
                )}
              </div>
            )}

            {richOutput?.kind === "moderate_content" && (
              <div id="rich-view" class="px-5 py-5 space-y-4">
                <div class="flex items-center gap-3">
                  <span class:list={[
                    "px-4 py-2 rounded-full text-sm font-bold border",
                    richOutput.verdict === "safe"
                      ? "bg-green-950/50 border-green-700 text-green-300"
                      : richOutput.verdict === "flag"
                      ? "bg-red-950/50 border-red-700 text-red-300"
                      : "bg-yellow-950/50 border-yellow-700 text-yellow-300"
                  ]}>
                    {richOutput.verdict === "safe" ? "✓ SAFE" : richOutput.verdict === "flag" ? "⚠ FLAGGED" : richOutput.verdict?.toUpperCase()}
                  </span>
                  {richOutput.confidence != null && (
                    <span class="text-sm text-gray-400">{Math.round(richOutput.confidence * 100)}% confidence</span>
                  )}
                  {richOutput.recommended_action && (
                    <span class="text-xs px-2 py-0.5 rounded bg-gray-800 border border-gray-700 text-gray-300">
                      Action: {richOutput.recommended_action}
                    </span>
                  )}
                </div>
                {richOutput.violations && richOutput.violations.length > 0 && (
                  <div>
                    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Violations</h3>
                    <div class="space-y-2">
                      {richOutput.violations.map((v: any) => (
                        <div class="bg-red-950/20 border border-red-900/50 rounded-lg p-3">
                          <div class="flex items-center justify-between mb-1">
                            <span class="text-xs font-semibold text-red-300">{v.policy}</span>
                            <span class="text-xs text-gray-500">{Math.round(v.confidence * 100)}% confidence</span>
                          </div>
                          {v.excerpt && <p class="text-xs text-gray-400 italic">"{v.excerpt}"</p>}
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            )}

            {richOutput?.kind === "raw" && (
              <pre id="output-content" class="px-5 py-4 font-mono text-sm text-gray-300 overflow-x-auto whitespace-pre-wrap">
{task.output ? JSON.stringify(task.output, null, 2) : ""}
              </pre>
            )}

            {/* Raw JSON view (hidden by default for rich types) */}
            {richOutput && richOutput.kind !== "raw" && (
              <div id="raw-view" class="hidden border-t border-gray-800">
                <pre class="px-5 py-4 font-mono text-sm text-gray-500 overflow-x-auto whitespace-pre-wrap">
{task.output ? JSON.stringify(task.output, null, 2) : ""}
                </pre>
              </div>
            )}
          </div>
        </div>

        <script is:inline>
          // Toggle between rich and raw view
          const toggleBtn = document.getElementById("toggle-raw");
          const richView = document.getElementById("rich-view");
          const rawView = document.getElementById("raw-view");
          if (toggleBtn && richView && rawView) {
            let showingRaw = false;
            toggleBtn.addEventListener("click", () => {
              showingRaw = !showingRaw;
              richView.classList.toggle("hidden", showingRaw);
              rawView.classList.toggle("hidden", !showingRaw);
              toggleBtn.textContent = showingRaw ? "View formatted" : "View raw JSON";
            });
          }
        </script>

        <!-- Error -->
        <div id="error-panel" class:list={[!task.error && "hidden"]}>
          <div class="bg-red-950/30 border border-red-800 rounded-xl mb-4">
            <div class="px-5 py-3 border-b border-red-800">
              <h2 class="text-sm font-semibold text-red-300">Error</h2>
            </div>
            <pre id="error-content" class="px-5 py-4 font-mono text-sm text-red-300 overflow-x-auto whitespace-pre-wrap">
{task.error ?? ""}
            </pre>
          </div>
        </div>

        <!-- Human task: Submissions review panel -->
        {task.execution_mode === "human" && (
          <div class="bg-gray-900 border border-gray-800 rounded-xl mb-4">
            <div class="px-5 py-3 border-b border-gray-800 flex items-center justify-between">
              <h2 class="text-sm font-semibold text-violet-300">
                Worker Submissions
                <span class="ml-2 text-gray-500 font-normal text-xs">
                  ({submissions.length} total)
                </span>
              </h2>
              <div class="flex items-center gap-3">
                <span class="text-xs text-gray-500">
                  Reward: {task.worker_reward_credits} cr/worker
                </span>
                <a
                  href="/dashboard/review"
                  class="text-xs text-violet-400 hover:text-violet-300 transition-colors"
                >
                  Review queue →
                </a>
              </div>
            </div>

            {submissions.length === 0 ? (
              <div class="px-5 py-8 text-center text-gray-500 text-sm">
                No submissions yet. Workers will appear here once they claim and submit.
              </div>
            ) : (
              <div class="divide-y divide-gray-800">
                {submissions.map((sub: any) => (
                  <div class="px-5 py-4">
                    <div class="flex items-start justify-between gap-4">
                      <div class="flex items-start gap-3 flex-1 min-w-0">
                        <div class="w-8 h-8 rounded-full bg-violet-900/50 border border-violet-800 flex items-center justify-center text-xs font-semibold text-violet-300 flex-shrink-0">
                          {(sub.worker.name ?? "?")[0].toUpperCase()}
                        </div>
                        <div class="min-w-0 flex-1">
                          <div class="flex items-center gap-2 mb-1 flex-wrap">
                            <span class="font-medium text-sm text-gray-200">
                              {sub.worker.name ?? "Anonymous Worker"}
                            </span>
                            <span class="text-xs text-gray-500">Lv {sub.worker.worker_level}</span>
                            {sub.worker.worker_accuracy != null && (
                              <span class="text-xs text-gray-500">
                                {Math.round(sub.worker.worker_accuracy * 100)}% acc
                              </span>
                            )}
                            <span class:list={[
                              "px-2 py-0.5 text-xs rounded-full border",
                              SUB_STATUS_COLORS[sub.status] ?? "bg-gray-800 border-gray-700 text-gray-400"
                            ]}>
                              {sub.status}
                            </span>
                          </div>
                          {sub.submitted_at && (
                            <div class="text-xs text-gray-500 mb-2">
                              Submitted {new Date(sub.submitted_at).toLocaleString()}
                            </div>
                          )}
                          {sub.response && (
                            <div class="mt-2 bg-gray-950 border border-gray-800 rounded-lg p-3 max-h-24 overflow-y-auto">
                              <pre class="text-xs text-gray-300 whitespace-pre-wrap font-mono break-all">{JSON.stringify(sub.response, null, 2)}</pre>
                            </div>
                          )}
                          {sub.worker_note && (
                            <div class="mt-2 text-xs text-gray-400 italic">
                              "{sub.worker_note}"
                            </div>
                          )}
                        </div>
                      </div>
                      <!-- Review actions -->
                      <div class="flex items-center gap-2 flex-shrink-0">
                        {sub.status === "submitted" && (
                          <>
                            <form method="POST">
                              <input type="hidden" name="action" value="approve" />
                              <input type="hidden" name="assignment_id" value={sub.id} />
                              <button
                                type="submit"
                                class="px-3 py-1.5 bg-green-900/50 border border-green-700 text-green-300 text-xs font-medium rounded-lg hover:bg-green-800/50 transition-colors"
                              >
                                ✓ Approve
                              </button>
                            </form>
                            <form method="POST">
                              <input type="hidden" name="action" value="reject" />
                              <input type="hidden" name="assignment_id" value={sub.id} />
                              <button
                                type="submit"
                                class="px-3 py-1.5 bg-red-900/50 border border-red-700 text-red-300 text-xs font-medium rounded-lg hover:bg-red-800/50 transition-colors"
                              >
                                ✕ Reject
                              </button>
                            </form>
                          </>
                        )}
                        {sub.status === "approved" && (
                          <span class="text-green-400 text-xs font-medium">✓ Approved</span>
                        )}
                        {sub.status === "rejected" && (
                          <span class="text-red-400 text-xs font-medium">✕ Rejected</span>
                        )}
                        <span class="text-xs text-gray-600 ml-1">
                          {sub.earnings_credits}cr
                        </span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        )}

        <!-- Endorse Worker — shown for completed human tasks -->
        {task.execution_mode === "human" && task.status === "completed" && submissions.some((s: any) => s.status === "approved") && (
          <div class="bg-gray-900 border border-gray-800 rounded-xl mb-4 px-5 py-4">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="text-sm font-semibold text-gray-300">Endorse a Worker</h3>
                <p class="text-xs text-gray-500 mt-0.5">Recognise great work by endorsing a worker for this task</p>
              </div>
              <button
                id="endorse-open-btn"
                class="px-4 py-2 bg-violet-700 hover:bg-violet-600 text-white text-sm rounded-lg transition-colors"
              >
                ⭐ Endorse Worker
              </button>
            </div>
          </div>
        )}

        <!-- Endorse Worker modal -->
        <div id="endorse-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4">
          <div class="bg-gray-900 border border-gray-700 rounded-xl p-6 w-full max-w-md shadow-xl">
            <h2 class="text-lg font-bold mb-4">Endorse a Worker</h2>
            <div class="mb-4">
              <label class="text-xs text-gray-400 mb-1 block">Select worker</label>
              <select id="endorse-worker-select" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 focus:outline-none focus:border-violet-500">
                {submissions.filter((s: any) => s.status === "approved").map((s: any) => (
                  <option value={s.worker.id} data-task-id={task.id}>
                    {s.worker.name ?? "Worker"} (Lv {s.worker.worker_level})
                  </option>
                ))}
              </select>
            </div>
            <div class="mb-4">
              <label class="text-xs text-gray-400 mb-1 block">Skill tag <span class="text-gray-600">(optional)</span></label>
              <input
                type="text"
                id="endorse-skill-tag"
                placeholder="e.g. fast turnaround, data labeling"
                maxlength="100"
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 focus:outline-none focus:border-violet-500"
              />
              <div class="flex flex-wrap gap-1.5 mt-2">
                {["data labeling", "fast turnaround", "accurate", "thorough", "professional"].map((tag: string) => (
                  <button
                    type="button"
                    class="endorse-tag-pill px-2 py-0.5 text-xs bg-gray-800 border border-gray-700 rounded-full text-gray-400 hover:border-violet-500 hover:text-violet-300 transition-colors"
                    data-tag={tag}
                  >
                    {tag}
                  </button>
                ))}
              </div>
            </div>
            <div class="mb-5">
              <label class="text-xs text-gray-400 mb-1 block">Note <span class="text-gray-600">(optional, max 500 chars)</span></label>
              <textarea
                id="endorse-note"
                maxlength="500"
                rows="3"
                placeholder="Write a short note about the worker's performance..."
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 focus:outline-none focus:border-violet-500 resize-none"
              ></textarea>
            </div>
            <div id="endorse-error" class="hidden mb-3 text-sm text-red-400"></div>
            <div class="flex gap-2 justify-end">
              <button id="endorse-close-btn" class="px-4 py-2 text-sm text-gray-400 hover:text-gray-200 transition-colors">
                Cancel
              </button>
              <button
                id="endorse-submit-btn"
                class="px-4 py-2 bg-violet-700 hover:bg-violet-600 text-white text-sm rounded-lg transition-colors"
              >
                Submit Endorsement
              </button>
            </div>
          </div>
        </div>

        <!-- Rate Worker — shown for any completed task (human or AI) -->
        {task.status === "completed" && (
          <div class="bg-gray-900 border border-gray-800 rounded-xl mb-4 px-5 py-4">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="text-sm font-semibold text-gray-300">⭐ Rate This Task</h3>
                <p class="text-xs text-gray-500 mt-0.5">Leave feedback for the worker who completed this task</p>
              </div>
              <button
                id="rate-open-btn"
                class="px-4 py-2 bg-yellow-600 hover:bg-yellow-500 text-white text-sm rounded-lg transition-colors"
              >
                Leave Rating
              </button>
            </div>
          </div>
        )}

        <!-- Rate Worker modal -->
        <div id="rate-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4">
          <div class="bg-gray-900 border border-gray-700 rounded-xl p-6 w-full max-w-md shadow-xl">
            <h2 class="text-lg font-bold mb-4">⭐ Rate Worker Output</h2>
            <div class="mb-4">
              <label class="text-xs text-gray-400 mb-2 block">Star Rating</label>
              <div class="flex gap-2" id="star-picker">
                {[1, 2, 3, 4, 5].map(n => (
                  <button
                    type="button"
                    class="star-btn w-10 h-10 text-2xl text-gray-600 hover:text-yellow-400 transition-colors"
                    data-score={n}
                  >★</button>
                ))}
              </div>
              <input type="hidden" id="rating-score" value="0" />
            </div>
            <div class="mb-5">
              <label class="text-xs text-gray-400 mb-1 block">Comment <span class="text-gray-600">(optional)</span></label>
              <textarea
                id="rating-comment"
                rows="3"
                maxlength="1000"
                placeholder="Describe the quality of the worker's output…"
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 focus:outline-none focus:border-yellow-500 resize-none"
              ></textarea>
            </div>
            <div id="rate-error" class="hidden mb-3 text-sm text-red-400"></div>
            <div class="flex gap-2 justify-end">
              <button id="rate-close-btn" class="px-4 py-2 text-sm text-gray-400 hover:text-gray-200 transition-colors">
                Cancel
              </button>
              <button
                id="rate-submit-btn"
                class="px-4 py-2 bg-yellow-600 hover:bg-yellow-500 text-white text-sm rounded-lg transition-colors"
              >
                Submit Rating
              </button>
            </div>
          </div>
        </div>

        <!-- Human task: gold standard section -->
        {task.execution_mode === "human" && (
          <div class="bg-gray-900 border border-gray-800 rounded-xl mb-4">
            <div class="px-5 py-3 border-b border-gray-800 flex items-center justify-between">
              <h2 class="text-sm font-semibold text-amber-300">
                {task.is_gold_standard ? "⭐ Gold Standard Task" : "Quality Control"}
              </h2>
              {!task.is_gold_standard && (
                <a
                  href={`/dashboard/quality/mark/${task.id}`}
                  class="text-xs px-3 py-1 bg-amber-600 hover:bg-amber-500 text-white rounded-lg transition-colors"
                >
                  Set gold answer
                </a>
              )}
              {task.is_gold_standard && (
                <a
                  href={`/dashboard/quality/evaluate/${task.id}`}
                  class="text-xs px-3 py-1 bg-violet-600 hover:bg-violet-500 text-white rounded-lg transition-colors"
                >
                  Evaluate submissions
                </a>
              )}
            </div>
            <div class="px-5 py-4 text-sm text-gray-400">
              {task.is_gold_standard ? (
                <p>This is a gold standard task. Worker submissions are auto-graded against the expected answer.</p>
              ) : (
                <p>Mark this task as a gold standard to use it for worker quality evaluation.</p>
              )}
            </div>
          </div>
        )}

        <!-- ── Task Dependency Graph ── -->
        <div id="task-dependencies" class="bg-gray-900 border border-gray-800 rounded-xl mb-4">
          <div class="px-5 py-3 border-b border-gray-800 flex items-center justify-between">
            <h2 class="text-sm font-semibold text-gray-300">🔗 Dependencies</h2>
            {task.status === "pending" && (
              <button
                id="add-dep-btn"
                class="text-xs px-3 py-1.5 bg-violet-600 hover:bg-violet-500 text-white rounded-lg transition-colors"
              >
                + Add dependency
              </button>
            )}
          </div>

          <!-- Add dependency form (hidden by default) -->
          {task.status === "pending" && (
            <div id="add-dep-form" class="hidden px-5 py-4 border-b border-gray-800">
              <p class="text-xs text-gray-400 mb-3">
                Enter the task ID that must complete <em>before</em> this task runs.
              </p>
              <div class="flex items-center gap-2">
                <input
                  id="dep-task-id-input"
                  type="text"
                  placeholder="Upstream task UUID"
                  class="flex-1 bg-gray-800 border border-gray-700 text-gray-200 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-violet-500 font-mono"
                />
                <button
                  id="dep-save-btn"
                  class="px-3 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm rounded-lg transition-colors"
                >
                  Add
                </button>
                <button
                  id="dep-cancel-btn"
                  class="px-3 py-2 bg-gray-700 hover:bg-gray-600 text-gray-300 text-sm rounded-lg transition-colors"
                >
                  Cancel
                </button>
              </div>
              <p id="dep-error" class="hidden text-xs text-red-400 mt-2"></p>
            </div>
          )}

          <div class="px-5 py-4">
            {/* Upstream: what this task waits for */}
            {dependencies.length > 0 && (
              <div class="mb-4">
                <p class="text-xs text-gray-500 uppercase tracking-wide mb-2">Waiting for</p>
                <div class="space-y-2">
                  {dependencies.map((dep: any) => (
                    <div class="flex items-center justify-between gap-3 bg-gray-800/50 rounded-lg px-3 py-2">
                      <div class="flex items-center gap-2 min-w-0">
                        <span class={`inline-block w-2 h-2 rounded-full flex-shrink-0 ${
                          dep.depends_on_status === "completed" ? "bg-green-400"
                          : dep.depends_on_status === "failed" ? "bg-red-400"
                          : dep.depends_on_status === "running" ? "bg-yellow-400"
                          : "bg-gray-500"
                        }`} />
                        <a
                          href={`/dashboard/tasks/${dep.depends_on_id}`}
                          class="text-sm text-violet-400 hover:text-violet-300 truncate font-mono"
                        >
                          {dep.depends_on_title || dep.depends_on_id}
                        </a>
                        <span class="text-xs text-gray-500 flex-shrink-0">
                          {dep.depends_on_status}
                        </span>
                      </div>
                      {task.status === "pending" && (
                        <button
                          class="dep-remove-btn text-xs text-red-500 hover:text-red-400 flex-shrink-0"
                          data-dep-id={dep.id}
                          title="Remove dependency"
                        >
                          ✕
                        </button>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            )}

            {/* Downstream: what's waiting for this task */}
            {dependents.length > 0 && (
              <div>
                <p class="text-xs text-gray-500 uppercase tracking-wide mb-2">Unblocks</p>
                <div class="space-y-2">
                  {dependents.map((dep: any) => (
                    <div class="flex items-center gap-2 bg-gray-800/50 rounded-lg px-3 py-2">
                      <span class={`inline-block w-2 h-2 rounded-full flex-shrink-0 ${
                        dep.depends_on_status === "completed" ? "bg-green-400"
                        : dep.depends_on_status === "failed" ? "bg-red-400"
                        : "bg-gray-500"
                      }`} />
                      <a
                        href={`/dashboard/tasks/${dep.task_id}`}
                        class="text-sm text-violet-400 hover:text-violet-300 truncate font-mono"
                      >
                        {dep.depends_on_title || dep.task_id}
                      </a>
                      <span class="text-xs text-gray-500">
                        {dep.depends_on_status}
                      </span>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {dependencies.length === 0 && dependents.length === 0 && (
              <p class="text-sm text-gray-500 text-center py-2">
                No dependencies configured.
                {task.status === "pending" && " Add one to block this task until another finishes."}
              </p>
            )}
          </div>
        </div>

        <!-- Comments / Discussion -->
        <div id="comments" class="bg-gray-900 border border-gray-800 rounded-xl mb-4">
          <div class="px-5 py-3 border-b border-gray-800 flex items-center justify-between">
            <h2 class="text-sm font-semibold text-gray-300">
              💬 Discussion
              <span class="ml-2 text-gray-500 font-normal text-xs">({comments.length})</span>
            </h2>
          </div>

          <!-- Comment list -->
          <div id="comment-list" class="divide-y divide-gray-800/60">
            {comments.length === 0 && (
              <div class="px-5 py-6 text-center text-gray-500 text-sm">
                No comments yet. Be the first to ask a question or leave a note.
              </div>
            )}
            {comments.map((c: any) => (
              <div class:list={["px-5 py-4", c.parent_id ? "ml-8 bg-gray-950/30" : ""]}>
                <div class="flex items-start gap-3">
                  <div class="w-7 h-7 rounded-full bg-violet-900/50 border border-violet-800 flex items-center justify-center text-xs font-semibold text-violet-300 flex-shrink-0 mt-0.5">
                    {c.author_name?.[0]?.toUpperCase() ?? "?"}
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                      <span class="text-sm font-medium text-gray-200">{c.author_name}</span>
                      {c.is_internal && (
                        <span class="text-xs bg-amber-950/50 border border-amber-800 text-amber-400 px-1.5 py-0.5 rounded">internal</span>
                      )}
                      {c.edited_at && (
                        <span class="text-xs text-gray-600">(edited)</span>
                      )}
                      <span class="text-xs text-gray-600">
                        {new Date(c.created_at).toLocaleString()}
                      </span>
                    </div>
                    <p class="text-sm text-gray-300 whitespace-pre-wrap break-words">{c.body}</p>
                    <button
                      class="text-xs text-gray-600 hover:text-violet-400 mt-1 transition-colors reply-btn"
                      data-comment-id={c.id}
                      data-author={c.author_name}
                    >
                      ↩ reply
                    </button>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <!-- New comment form -->
          <div class="px-5 py-4 border-t border-gray-800">
            <div id="reply-indicator" class="hidden mb-2 text-xs text-violet-400 flex items-center gap-2">
              <span>Replying to <strong id="reply-name"></strong></span>
              <button id="cancel-reply" class="text-gray-500 hover:text-gray-300">[cancel]</button>
            </div>
            <div class="flex gap-3">
              <textarea
                id="comment-body"
                rows="2"
                maxlength="500"
                placeholder="Leave a comment or ask a question…"
                class="flex-1 bg-gray-950 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-600 focus:outline-none focus:border-violet-600 resize-none"
              ></textarea>
              <div class="flex flex-col gap-2">
                <button
                  id="submit-comment"
                  class="px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors whitespace-nowrap"
                >
                  Post
                </button>
                <label class="flex items-center gap-1.5 text-xs text-gray-500 cursor-pointer">
                  <input type="checkbox" id="comment-internal" class="accent-amber-500" />
                  Internal
                </label>
              </div>
            </div>
            <div id="comment-error" class="hidden mt-2 text-xs text-red-400"></div>
            <div class="text-xs text-gray-600 mt-1">Max 500 chars · Internal notes are only visible to you</div>
          </div>
        </div>

        <!-- Retry if failed -->
        {task.status === "failed" && (
          <div class="mt-6">
            <a
              href={`/dashboard/new-task`}
              class="px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors"
            >
              Submit another task →
            </a>
          </div>
        )}

        <!-- Live status bar (SSE-driven) -->
        {isLive && (
          <div id="live-bar" class="mt-6 text-center">
            <div class="inline-flex items-center gap-2 text-sm text-gray-400">
              <span class="w-2 h-2 rounded-full bg-yellow-400 animate-pulse"></span>
              <span id="live-status-text">
                Task is <strong>{task.status}</strong>. Watching for updates…
              </span>
            </div>
          </div>
        )}
      </div>
    ) : null}
  </div>

  {/* Comments interaction script */}
  <script define:vars={{ taskId: id }}>
    let replyToId = null;

    // Reply button handler
    document.querySelectorAll(".reply-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        replyToId = btn.dataset.commentId;
        const indicator = document.getElementById("reply-indicator");
        const nameEl = document.getElementById("reply-name");
        if (indicator && nameEl) {
          nameEl.textContent = btn.dataset.author;
          indicator.classList.remove("hidden");
        }
        document.getElementById("comment-body")?.focus();
      });
    });

    document.getElementById("cancel-reply")?.addEventListener("click", () => {
      replyToId = null;
      document.getElementById("reply-indicator")?.classList.add("hidden");
    });

    document.getElementById("submit-comment")?.addEventListener("click", async () => {
      const body = document.getElementById("comment-body")?.value?.trim();
      const isInternal = document.getElementById("comment-internal")?.checked ?? false;
      const errEl = document.getElementById("comment-error");

      if (!body) {
        if (errEl) { errEl.textContent = "Comment cannot be empty."; errEl.classList.remove("hidden"); }
        return;
      }
      errEl?.classList.add("hidden");

      const submitBtn = document.getElementById("submit-comment");
      if (submitBtn) submitBtn.disabled = true;

      try {
        const res = await fetch(`/api/tasks/${taskId}/comments`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ body, is_internal: isInternal, parent_id: replyToId || null }),
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.detail ?? "Failed to post comment");
        }
        // Reload page to show new comment
        location.reload();
      } catch (e) {
        if (errEl) { errEl.textContent = e.message ?? "Failed to post comment."; errEl.classList.remove("hidden"); }
        if (submitBtn) submitBtn.disabled = false;
      }
    });

    // Ctrl+Enter shortcut for textarea
    document.getElementById("comment-body")?.addEventListener("keydown", (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === "Enter") {
        document.getElementById("submit-comment")?.click();
      }
    });
  </script>

  {/* Tag editor script */}
  <script define:vars={{ taskId: id }}>
    const editBtn = document.getElementById("edit-tags-btn");
    const tagEditor = document.getElementById("tag-editor");
    const cancelBtn = document.getElementById("cancel-tags-btn");
    const saveBtn = document.getElementById("save-tags-btn");
    const tagInput = document.getElementById("tag-input");
    const saveMsg = document.getElementById("tag-save-msg");

    editBtn?.addEventListener("click", () => {
      tagEditor?.classList.toggle("hidden");
      tagInput?.focus();
    });
    cancelBtn?.addEventListener("click", () => {
      tagEditor?.classList.add("hidden");
    });
    saveBtn?.addEventListener("click", async () => {
      const raw = tagInput?.value ?? "";
      const tags = raw.split(",").map(t => t.trim()).filter(Boolean).slice(0, 20);
      saveBtn.disabled = true;
      saveBtn.textContent = "Saving…";
      try {
        const res = await fetch(`/api/tasks/${taskId}/tags`, {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ tags }),
        });
        if (res.ok) {
          saveMsg.textContent = "✓ Tags saved";
          saveMsg.className = "text-xs mt-2 text-green-400";
          setTimeout(() => location.reload(), 800);
        } else {
          saveMsg.textContent = "Failed to save tags.";
          saveMsg.className = "text-xs mt-2 text-red-400";
        }
      } catch {
        saveMsg.textContent = "Network error.";
        saveMsg.className = "text-xs mt-2 text-red-400";
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = "Save";
      }
    });
  </script>

  {/* Duplicate task button script */}
  <script define:vars={{ taskId: id }}>
    const dupBtn = document.getElementById("duplicate-task-btn");
    if (dupBtn) {
      dupBtn.addEventListener("click", async () => {
        dupBtn.disabled = true;
        dupBtn.textContent = "Loading…";
        try {
          const res = await fetch(`/api/tasks/${taskId}/duplicate-params`);
          if (!res.ok) {
            const d = await res.json().catch(() => ({}));
            alert(d.detail ?? "Failed to fetch task params");
            dupBtn.disabled = false;
            dupBtn.textContent = "📋 Duplicate";
            return;
          }
          const params = await res.json();
          // Build query string for pre-filling new-task form
          const qs = new URLSearchParams({ duplicate: taskId });
          if (params.type) qs.set("type", params.type);
          if (params.priority) qs.set("priority", params.priority);
          if (params.input) qs.set("input", JSON.stringify(params.input));
          if (params.tags?.length) qs.set("tags", params.tags.join(","));
          if (params.scheduled_at) qs.set("scheduled_at", params.scheduled_at);
          if (params.webhook_url) qs.set("webhook_url", params.webhook_url);
          if (params.worker_reward_credits) qs.set("worker_reward_credits", String(params.worker_reward_credits));
          if (params.assignments_required) qs.set("assignments_required", String(params.assignments_required));
          if (params.task_instructions) qs.set("task_instructions", params.task_instructions);
          window.location.href = `/dashboard/new-task?${qs.toString()}`;
        } catch {
          alert("Network error — could not fetch task params");
          dupBtn.disabled = false;
          dupBtn.textContent = "📋 Duplicate";
        }
      });
    }
  </script>

  {/* Task dependency management script */}
  <script define:vars={{ taskId: id }}>
    const addDepBtn = document.getElementById("add-dep-btn");
    const addDepForm = document.getElementById("add-dep-form");
    const depSaveBtn = document.getElementById("dep-save-btn");
    const depCancelBtn = document.getElementById("dep-cancel-btn");
    const depInput = document.getElementById("dep-task-id-input");
    const depError = document.getElementById("dep-error");

    addDepBtn?.addEventListener("click", () => {
      addDepForm?.classList.toggle("hidden");
      depInput?.focus();
    });
    depCancelBtn?.addEventListener("click", () => {
      addDepForm?.classList.add("hidden");
      if (depError) depError.classList.add("hidden");
      if (depInput) depInput.value = "";
    });
    depSaveBtn?.addEventListener("click", async () => {
      const depends_on_id = depInput?.value?.trim();
      if (!depends_on_id) {
        if (depError) { depError.textContent = "Please enter a task ID."; depError.classList.remove("hidden"); }
        return;
      }
      depSaveBtn.disabled = true;
      depSaveBtn.textContent = "Adding…";
      try {
        const res = await fetch(`/api/tasks/${taskId}/dependencies`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ depends_on_id }),
        });
        if (!res.ok) {
          const d = await res.json().catch(() => ({}));
          throw new Error(d.detail ?? "Failed to add dependency");
        }
        location.reload();
      } catch (e) {
        if (depError) { depError.textContent = e.message; depError.classList.remove("hidden"); }
        depSaveBtn.disabled = false;
        depSaveBtn.textContent = "Add";
      }
    });

    // Remove dependency buttons
    document.querySelectorAll(".dep-remove-btn").forEach(btn => {
      btn.addEventListener("click", async () => {
        const depId = btn.dataset.depId;
        if (!confirm("Remove this dependency?")) return;
        btn.disabled = true;
        try {
          const res = await fetch(`/api/tasks/${taskId}/dependencies/${depId}`, {
            method: "DELETE",
          });
          if (res.ok || res.status === 204) {
            location.reload();
          } else {
            const d = await res.json().catch(() => ({}));
            alert(d.detail ?? "Failed to remove dependency");
            btn.disabled = false;
          }
        } catch {
          alert("Network error");
          btn.disabled = false;
        }
      });
    });
  </script>

  {/* Endorse Worker modal script */}
  <script>
    const endorseOpenBtn = document.getElementById("endorse-open-btn");
    const endorseModal = document.getElementById("endorse-modal");
    const endorseCloseBtn = document.getElementById("endorse-close-btn");
    const endorseSubmitBtn = document.getElementById("endorse-submit-btn");
    const endorseError = document.getElementById("endorse-error");

    endorseOpenBtn?.addEventListener("click", () => {
      endorseModal?.classList.remove("hidden");
    });
    endorseCloseBtn?.addEventListener("click", () => {
      endorseModal?.classList.add("hidden");
    });
    endorseModal?.addEventListener("click", (e) => {
      if (e.target === endorseModal) endorseModal.classList.add("hidden");
    });

    // Tag pill quick-fill
    document.querySelectorAll<HTMLButtonElement>(".endorse-tag-pill").forEach(pill => {
      pill.addEventListener("click", () => {
        const input = document.getElementById("endorse-skill-tag") as HTMLInputElement;
        if (input) input.value = pill.dataset.tag ?? "";
      });
    });

    endorseSubmitBtn?.addEventListener("click", async () => {
      const workerSelect = document.getElementById("endorse-worker-select") as HTMLSelectElement;
      const skillTag = (document.getElementById("endorse-skill-tag") as HTMLInputElement)?.value.trim();
      const note = (document.getElementById("endorse-note") as HTMLTextAreaElement)?.value.trim();
      const taskId = workerSelect?.selectedOptions[0]?.dataset.taskId;
      const workerId = workerSelect?.value;

      if (!workerId || !taskId) return;

      if (endorseError) endorseError.classList.add("hidden");
      (endorseSubmitBtn as HTMLButtonElement).disabled = true;
      endorseSubmitBtn.textContent = "Submitting…";

      try {
        const res = await fetch(`/api/workers/${workerId}/endorse`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            task_id: taskId,
            skill_tag: skillTag || null,
            note: note || null,
          }),
        });
        const data = await res.json();
        if (res.ok) {
          endorseModal?.classList.add("hidden");
          // Show a brief success toast
          const toast = document.createElement("div");
          toast.className = "fixed bottom-4 right-4 z-50 bg-green-900 border border-green-700 text-green-300 px-4 py-3 rounded-lg text-sm shadow-lg";
          toast.textContent = "⭐ Endorsement submitted successfully!";
          document.body.appendChild(toast);
          setTimeout(() => toast.remove(), 4000);
        } else {
          if (endorseError) {
            endorseError.textContent = data.detail ?? "Failed to submit endorsement";
            endorseError.classList.remove("hidden");
          }
        }
      } catch {
        if (endorseError) {
          endorseError.textContent = "Network error. Please try again.";
          endorseError.classList.remove("hidden");
        }
      } finally {
        (endorseSubmitBtn as HTMLButtonElement).disabled = false;
        endorseSubmitBtn.textContent = "Submit Endorsement";
      }
    });
  </script>

  {/* Rate Worker modal script */}
  <script>
    const rateOpenBtn = document.getElementById("rate-open-btn");
    const rateModal = document.getElementById("rate-modal");
    const rateCloseBtn = document.getElementById("rate-close-btn");
    const rateSubmitBtn = document.getElementById("rate-submit-btn");
    const rateError = document.getElementById("rate-error");
    let selectedScore = 0;

    rateOpenBtn?.addEventListener("click", () => rateModal?.classList.remove("hidden"));
    rateCloseBtn?.addEventListener("click", () => rateModal?.classList.add("hidden"));
    rateModal?.addEventListener("click", (e) => { if (e.target === rateModal) rateModal.classList.add("hidden"); });

    // Star picker interaction
    document.querySelectorAll<HTMLButtonElement>(".star-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        selectedScore = parseInt(btn.dataset.score ?? "0");
        (document.getElementById("rating-score") as HTMLInputElement).value = String(selectedScore);
        document.querySelectorAll<HTMLButtonElement>(".star-btn").forEach((b, i) => {
          b.classList.toggle("text-yellow-400", i < selectedScore);
          b.classList.toggle("text-gray-600", i >= selectedScore);
        });
      });
      btn.addEventListener("mouseenter", () => {
        const hoverScore = parseInt(btn.dataset.score ?? "0");
        document.querySelectorAll<HTMLButtonElement>(".star-btn").forEach((b, i) => {
          b.classList.toggle("text-yellow-300", i < hoverScore);
        });
      });
      btn.addEventListener("mouseleave", () => {
        document.querySelectorAll<HTMLButtonElement>(".star-btn").forEach((b, i) => {
          b.classList.toggle("text-yellow-400", i < selectedScore);
          b.classList.toggle("text-yellow-300", false);
        });
      });
    });

    rateSubmitBtn?.addEventListener("click", async () => {
      if (selectedScore === 0) {
        if (rateError) { rateError.textContent = "Please select a star rating."; rateError.classList.remove("hidden"); }
        return;
      }
      const comment = (document.getElementById("rating-comment") as HTMLTextAreaElement)?.value.trim();
      const taskId = window.location.pathname.split("/").filter(Boolean).pop();

      if (rateError) rateError.classList.add("hidden");
      (rateSubmitBtn as HTMLButtonElement).disabled = true;
      rateSubmitBtn.textContent = "Submitting…";

      try {
        const res = await fetch(`/api/tasks/${taskId}/rate`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ score: selectedScore, comment: comment || null }),
        });
        const data = await res.json();
        if (res.ok) {
          rateModal?.classList.add("hidden");
          const toast = document.createElement("div");
          toast.className = "fixed bottom-4 right-4 z-50 bg-yellow-900 border border-yellow-700 text-yellow-200 px-4 py-3 rounded-lg text-sm shadow-lg";
          toast.textContent = `⭐ ${"★".repeat(selectedScore)} Rating submitted!`;
          document.body.appendChild(toast);
          setTimeout(() => toast.remove(), 4000);
          // Hide the rate button since it's now submitted
          rateOpenBtn?.closest(".bg-gray-900")?.classList.add("hidden");
        } else {
          if (rateError) { rateError.textContent = data.detail ?? "Failed to submit rating"; rateError.classList.remove("hidden"); }
        }
      } catch {
        if (rateError) { rateError.textContent = "Network error"; rateError.classList.remove("hidden"); }
      } finally {
        (rateSubmitBtn as HTMLButtonElement).disabled = false;
        rateSubmitBtn.textContent = "Submit Rating";
      }
    });
  </script>

  {/* SSE client script — only loaded for non-terminal tasks */}
  {isLive && (
    <script define:vars={{ taskId: id }}>
      const TERMINAL = new Set(["completed", "failed", "cancelled"]);
      const STATUS_COLORS = {
        completed: "bg-green-950/50 border-green-800 text-green-300",
        failed:    "bg-red-950/50 border-red-800 text-red-300",
        running:   "bg-yellow-950/50 border-yellow-800 text-yellow-300",
        queued:    "bg-blue-950/50 border-blue-800 text-blue-300",
        pending:   "bg-gray-800/50 border-gray-700 text-gray-300",
        open:      "bg-violet-950/50 border-violet-800 text-violet-300",
        assigned:  "bg-amber-950/50 border-amber-800 text-amber-300",
        cancelled: "bg-gray-800/50 border-gray-700 text-gray-500",
      };

      // We need the bearer token from the cookie to auth the SSE request.
      // Since SSE is a GET, we add it as a query param via a one-time token exchange.
      // Simpler: just poll via fetch since EventSource doesn't support custom headers.
      let lastStatus = null;
      let lastCompleted = null;

      async function poll() {
        try {
          const res = await fetch(`/api/tasks/${taskId}/status`);
          if (!res.ok) return;
          const data = await res.json();

          if (data.status !== lastStatus) {
            lastStatus = data.status;

            // Update status badge
            const badge = document.getElementById("status-badge");
            if (badge) {
              badge.textContent = data.status;
              badge.className = `px-4 py-1.5 rounded-full border text-sm font-medium transition-all ${
                STATUS_COLORS[data.status] ?? "bg-gray-800 border-gray-700 text-gray-300"
              }`;
            }

            // Update live text
            const txt = document.getElementById("live-status-text");
            if (txt) {
              txt.innerHTML = `Task is <strong>${data.status}</strong>. Watching for updates…`;
            }

            // If terminal, reload for full details
            if (TERMINAL.has(data.status)) {
              setTimeout(() => location.reload(), 800);
            }
          }
        } catch (_) {}
      }

      // Poll every 2 seconds
      const intervalId = setInterval(poll, 2000);

      // Stop polling when page unloads
      window.addEventListener("beforeunload", () => clearInterval(intervalId));
    </script>
  )}
</Layout>
