---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Object.fromEntries(
  Astro.cookies.getAll().map((c) => [c.name, c.value])
));
if (!token) return Astro.redirect("/login");

const page = Number(Astro.url.searchParams.get("page") ?? 1);
const status = Astro.url.searchParams.get("status") ?? "";
const type = Astro.url.searchParams.get("type") ?? "";
const tag = Astro.url.searchParams.get("tag") ?? "";

let tasks: any = { items: [], total: 0, page: 1, page_size: 20, has_next: false };
let userTags: any[] = [];

try {
  const qs = new URLSearchParams({ page: String(page), page_size: "20" });
  if (status) qs.set("status", status);
  if (type) qs.set("type", type);
  if (tag) qs.set("tag", tag);
  [tasks, userTags] = await Promise.all([
    apiFetch<any>(`/v1/tasks?${qs}`, { token }),
    apiFetch<any[]>("/v1/tasks/tags", { token }).catch(() => []),
  ]);
} catch (e) {
  return Astro.redirect("/login");
}

const STATUS_COLORS: Record<string, string> = {
  completed: "bg-green-950 text-green-400",
  failed:    "bg-red-950 text-red-400",
  running:   "bg-yellow-950 text-yellow-400",
  queued:    "bg-blue-950 text-blue-400",
  pending:   "bg-gray-800 text-gray-400",
  cancelled: "bg-gray-800 text-gray-500",
  open:      "bg-emerald-950 text-emerald-400",
};
---

<Layout title="Tasks — CrowdSorcerer">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <div class="flex items-center justify-between mb-8">
      <div>
        <div class="text-sm text-gray-500 mb-1">
          <a href="/dashboard" class="hover:text-gray-300 transition-colors">Dashboard</a>
          <span class="mx-2">›</span>
          <span>Tasks</span>
        </div>
        <h1 class="text-2xl font-bold">All tasks</h1>
      </div>
      <div class="flex gap-2">
        <a
          href="/v1/tasks/export?format=csv"
          target="_blank"
          class="px-4 py-2 bg-gray-800 hover:bg-gray-700 border border-gray-700 text-gray-300 text-sm font-medium rounded-lg transition-colors flex items-center gap-1.5"
        >
          <span>⬇️</span> Export CSV
        </a>
        <a
          href="/dashboard/new-task"
          class="px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors"
        >
          + New task
        </a>
      </div>
    </div>

    <!-- Filters -->
    <form class="flex flex-wrap gap-3 mb-4">
      <select name="status" class="bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-300 focus:outline-none focus:border-violet-500">
        <option value="" selected={!status}>All statuses</option>
        {["pending","queued","running","completed","failed","cancelled","open"].map(s => (
          <option value={s} selected={status === s}>{s}</option>
        ))}
      </select>
      <select name="type" class="bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-300 focus:outline-none focus:border-violet-500">
        <option value="" selected={!type}>All types</option>
        {["web_research","entity_lookup","document_parse","data_transform","llm_generate","screenshot","audio_transcribe","pii_detect","code_execute","web_intel","label_image","label_text","rate_quality","verify_fact","moderate_content","compare_rank","answer_question","transcription_review"].map(t => (
          <option value={t} selected={type === t}>{t}</option>
        ))}
      </select>
      {userTags.length > 0 && (
        <select name="tag" class="bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-300 focus:outline-none focus:border-violet-500">
          <option value="" selected={!tag}>All tags</option>
          {userTags.map((tg: any) => (
            <option value={tg.tag} selected={tag === tg.tag}>{tg.tag} ({tg.count})</option>
          ))}
        </select>
      )}
      <button type="submit" class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-sm text-gray-300 rounded-lg transition-colors">
        Filter
      </button>
      {(status || type || tag) && (
        <a href="/dashboard/tasks" class="px-4 py-2 text-sm text-gray-500 hover:text-gray-300 transition-colors self-center">
          Clear
        </a>
      )}
    </form>

    <!-- Tag pills (quick filter) -->
    {userTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-6">
        {userTags.slice(0, 15).map((tg: any) => (
          <a
            href={`/dashboard/tasks?tag=${encodeURIComponent(tg.tag)}`}
            class={`px-2.5 py-1 rounded-full text-xs transition-colors ${
              tag === tg.tag
                ? "bg-violet-600 text-white"
                : "bg-gray-800 text-gray-400 hover:bg-gray-700 hover:text-gray-200"
            }`}
          >
            🏷️ {tg.tag} <span class="opacity-60">{tg.count}</span>
          </a>
        ))}
      </div>
    )}

    <!-- Bulk action toolbar (hidden until tasks are selected) -->
    <div
      id="bulk-toolbar"
      class="hidden sticky top-4 z-20 bg-gray-900 border border-violet-700 rounded-xl px-5 py-3 mb-4 flex items-center justify-between shadow-lg shadow-violet-900/20"
    >
      <div class="text-sm text-gray-300">
        <span id="bulk-count" class="font-semibold text-violet-300">0</span> tasks selected
      </div>
      <div class="flex items-center gap-2">
        <button
          id="bulk-export-btn"
          class="px-3 py-1.5 bg-gray-800 hover:bg-gray-700 border border-gray-700 text-gray-300 text-sm rounded-lg transition-colors"
        >
          ⬇️ Export selected
        </button>
        <button
          id="bulk-retry-btn"
          class="px-3 py-1.5 bg-blue-800 hover:bg-blue-700 text-blue-200 text-sm rounded-lg transition-colors"
        >
          ↻ Retry failed
        </button>
        <button
          id="bulk-cancel-btn"
          class="px-3 py-1.5 bg-red-900 hover:bg-red-800 text-red-300 text-sm rounded-lg transition-colors"
        >
          ✕ Cancel
        </button>
        <button
          id="bulk-clear-btn"
          class="px-3 py-1.5 text-gray-500 hover:text-gray-300 text-sm transition-colors"
        >
          Clear
        </button>
      </div>
    </div>

    <!-- Bulk feedback toast -->
    <div id="bulk-toast" class="hidden mb-4 px-4 py-3 rounded-lg text-sm border"></div>

    <!-- Task list -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl">
      {tasks.items.length === 0 ? (
        <div class="px-6 py-16 text-center">
          <div class="text-4xl mb-3">🔮</div>
          <div class="text-gray-400">No tasks found.</div>
          <a href="/dashboard/new-task" class="text-violet-400 text-sm mt-2 inline-block hover:text-violet-300">
            Submit your first task →
          </a>
        </div>
      ) : (
        <div class="divide-y divide-gray-800">
          <div class="grid grid-cols-12 gap-4 px-6 py-3 text-xs text-gray-500 font-medium border-b border-gray-800">
            <div class="col-span-1 flex items-center">
              <input
                type="checkbox"
                id="select-all"
                class="w-4 h-4 rounded border-gray-600 bg-gray-800 text-violet-500 focus:ring-violet-500 cursor-pointer"
              />
            </div>
            <div class="col-span-3">Type</div>
            <div class="col-span-2">Status</div>
            <div class="col-span-2">Credits</div>
            <div class="col-span-2">Submitted</div>
            <div class="col-span-2">Duration</div>
          </div>
          {tasks.items.map((t: any) => {
            const duration = t.completed_at && t.created_at
              ? Math.round((new Date(t.completed_at).getTime() - new Date(t.created_at).getTime()) / 1000)
              : null;
            return (
              <div class="px-6 py-4 hover:bg-gray-800/50 transition-colors task-row" data-id={t.id} data-status={t.status}>
                <div class="flex items-center gap-3">
                  <!-- Checkbox -->
                  <div onclick="event.stopPropagation()" class="shrink-0">
                    <input
                      type="checkbox"
                      class="task-checkbox w-4 h-4 rounded border-gray-600 bg-gray-800 text-violet-500 focus:ring-violet-500 cursor-pointer"
                      data-id={t.id}
                      data-status={t.status}
                    />
                  </div>
                  <!-- Row content -->
                  <a href={`/dashboard/tasks/${t.id}`} class="flex-1 grid grid-cols-12 gap-3 items-center min-w-0">
                    <div class="col-span-4">
                      <span class="font-mono text-sm text-violet-300">{t.type}</span>
                      {/* Tags */}
                      {t.tags && t.tags.length > 0 && (
                        <div class="flex flex-wrap gap-1 mt-1">
                          {(t.tags as string[]).slice(0, 5).map((tg: string) => (
                            <span class="px-1.5 py-0.5 bg-gray-800 text-gray-500 text-xs rounded">🏷️ {tg}</span>
                          ))}
                        </div>
                      )}
                      {/* Scheduled badge */}
                      {t.scheduled_at && t.status === "pending" && (
                        <div class="mt-1">
                          <span class="text-xs text-amber-400 bg-amber-900/20 px-1.5 py-0.5 rounded">
                            ⏰ {new Date(t.scheduled_at).toLocaleString()}
                          </span>
                        </div>
                      )}
                    </div>
                    <div class="col-span-2">
                      <span class:list={["text-xs px-2 py-0.5 rounded-full", STATUS_COLORS[t.status] ?? "bg-gray-800 text-gray-400"]}>
                        {t.status}
                      </span>
                    </div>
                    <div class="col-span-2 text-sm text-gray-400">
                      {t.credits_used != null ? `${t.credits_used} cr` : "—"}
                    </div>
                    <div class="col-span-2 text-sm text-gray-500 truncate">
                      {new Date(t.created_at).toLocaleString()}
                    </div>
                    <div class="col-span-2 text-sm text-gray-500">
                      {duration != null ? `${duration}s` : "—"}
                    </div>
                  </a>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>

    <!-- Pagination -->
    {(page > 1 || tasks.has_next) && (
      <div class="flex items-center justify-between mt-6">
        <div class="text-sm text-gray-500">
          {tasks.total} tasks total
        </div>
        <div class="flex gap-2">
          {page > 1 && (
            <a
              href={`?page=${page - 1}${status ? `&status=${status}` : ""}${type ? `&type=${type}` : ""}`}
              class="px-3 py-1.5 bg-gray-900 border border-gray-700 rounded-lg text-sm text-gray-300 hover:border-gray-500 transition-colors"
            >
              ← Prev
            </a>
          )}
          <span class="px-3 py-1.5 text-sm text-gray-500">
            Page {page}
          </span>
          {tasks.has_next && (
            <a
              href={`?page=${page + 1}${status ? `&status=${status}` : ""}${type ? `&type=${type}` : ""}`}
              class="px-3 py-1.5 bg-gray-900 border border-gray-700 rounded-lg text-sm text-gray-300 hover:border-gray-500 transition-colors"
            >
              Next →
            </a>
          )}
        </div>
      </div>
    )}
  </div>
</Layout>

<script>
  // ── Selection state ──────────────────────────────────────────────────────
  const selected = new Set<string>();
  const toolbar = document.getElementById("bulk-toolbar") as HTMLDivElement;
  const countEl = document.getElementById("bulk-count") as HTMLSpanElement;
  const selectAll = document.getElementById("select-all") as HTMLInputElement;
  const toast = document.getElementById("bulk-toast") as HTMLDivElement;

  function updateToolbar() {
    countEl.textContent = String(selected.size);
    if (selected.size > 0) {
      toolbar.classList.remove("hidden");
      toolbar.classList.add("flex");
    } else {
      toolbar.classList.add("hidden");
      toolbar.classList.remove("flex");
    }
  }

  function showToast(msg: string, ok: boolean) {
    toast.textContent = msg;
    toast.className = ok
      ? "mb-4 px-4 py-3 rounded-lg text-sm border bg-green-950 border-green-700 text-green-300"
      : "mb-4 px-4 py-3 rounded-lg text-sm border bg-red-950 border-red-700 text-red-300";
    setTimeout(() => { toast.className = "hidden mb-4 px-4 py-3 rounded-lg text-sm border"; }, 4000);
  }

  // Individual checkboxes
  document.querySelectorAll<HTMLInputElement>(".task-checkbox").forEach(cb => {
    cb.addEventListener("change", () => {
      const id = cb.dataset.id!;
      if (cb.checked) selected.add(id);
      else selected.delete(id);
      // Update select-all indeterminate state
      const all = document.querySelectorAll<HTMLInputElement>(".task-checkbox");
      const checkedCount = document.querySelectorAll<HTMLInputElement>(".task-checkbox:checked").length;
      selectAll.indeterminate = checkedCount > 0 && checkedCount < all.length;
      selectAll.checked = checkedCount === all.length;
      updateToolbar();
    });
  });

  // Select all
  selectAll?.addEventListener("change", () => {
    document.querySelectorAll<HTMLInputElement>(".task-checkbox").forEach(cb => {
      cb.checked = selectAll.checked;
      const id = cb.dataset.id!;
      if (selectAll.checked) selected.add(id);
      else selected.delete(id);
    });
    updateToolbar();
  });

  // Clear selection
  document.getElementById("bulk-clear-btn")?.addEventListener("click", () => {
    selected.clear();
    document.querySelectorAll<HTMLInputElement>(".task-checkbox").forEach(cb => { cb.checked = false; });
    if (selectAll) { selectAll.checked = false; selectAll.indeterminate = false; }
    updateToolbar();
  });

  // ── Bulk API call ────────────────────────────────────────────────────────
  async function bulkAction(action: "cancel" | "retry") {
    if (selected.size === 0) return;
    const btn = action === "cancel"
      ? document.getElementById("bulk-cancel-btn")!
      : document.getElementById("bulk-retry-btn")!;
    const origText = btn.textContent;
    btn.textContent = "Working…";
    (btn as HTMLButtonElement).disabled = true;

    try {
      const res = await fetch("/api/tasks/bulk-action", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ task_ids: [...selected], action }),
      });
      const data = await res.json();
      if (res.ok) {
        const s = data.succeeded?.length ?? 0;
        const f = data.failed?.length ?? 0;
        showToast(
          `✓ ${action === "cancel" ? "Cancelled" : "Retried"} ${s} task${s !== 1 ? "s" : ""}${f > 0 ? ` (${f} skipped)` : ""}`,
          true
        );
        setTimeout(() => window.location.reload(), 1200);
      } else {
        showToast(`Error: ${data.detail ?? "Unknown error"}`, false);
        btn.textContent = origText;
        (btn as HTMLButtonElement).disabled = false;
      }
    } catch {
      showToast("Network error. Please try again.", false);
      btn.textContent = origText;
      (btn as HTMLButtonElement).disabled = false;
    }
  }

  document.getElementById("bulk-cancel-btn")?.addEventListener("click", () => bulkAction("cancel"));
  document.getElementById("bulk-retry-btn")?.addEventListener("click", () => bulkAction("retry"));

  // ── Export selected ──────────────────────────────────────────────────────
  document.getElementById("bulk-export-btn")?.addEventListener("click", async () => {
    if (selected.size === 0) return;
    // Build URL with task_ids as repeated query params for the existing export endpoint
    const ids = [...selected];
    const qs = ids.map(id => `task_ids=${id}`).join("&");
    window.open(`/v1/tasks/export?format=csv&${qs}`, "_blank");
  });
</script>
