---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Object.fromEntries(
  Astro.cookies.getAll().map((c) => [c.name, c.value])
));
if (!token) return Astro.redirect("/login");

// Handle approve/reject POST actions
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("action") as string;
  const taskId = form.get("task_id") as string;
  const assignmentId = form.get("assignment_id") as string;
  const reason = form.get("reason") as string | undefined;

  try {
    await apiFetch(`/v1/tasks/${taskId}/submissions/${assignmentId}/${action}`, {
      method: "POST",
      token,
      body: JSON.stringify({ reason: reason || null }),
    });
  } catch (_) {
    // Fall through — errors shown on reload
  }
  return Astro.redirect("/dashboard/review");
}

const page = Number(Astro.url.searchParams.get("page") ?? 1);

let tasksData: any = { items: [], total: 0, page: 1, page_size: 20, has_next: false };
let error: string | null = null;

// Fetch human tasks that have at least one worker submission
try {
  tasksData = await apiFetch<any>(
    `/v1/tasks?execution_mode=human&has_submissions=true&page=${page}&page_size=20`,
    { token }
  );
} catch (e: any) {
  if (e.message?.includes("401") || e.message?.includes("403")) {
    return Astro.redirect("/login");
  }
  error = "Failed to load review queue";
}

// Fetch submissions for each task
const tasksWithSubs: Array<{ task: any; submissions: any[] }> = [];
for (const task of tasksData.items) {
  try {
    const subs = await apiFetch<any[]>(`/v1/tasks/${task.id}/submissions`, { token });
    tasksWithSubs.push({ task, submissions: subs });
  } catch (_) {
    tasksWithSubs.push({ task, submissions: [] });
  }
}

// Summary counts
const totalPending = tasksWithSubs.reduce(
  (n, { submissions }) => n + submissions.filter((s: any) => s.status === "submitted").length,
  0
);
const totalApproved = tasksWithSubs.reduce(
  (n, { submissions }) => n + submissions.filter((s: any) => s.status === "approved").length,
  0
);
const totalRejected = tasksWithSubs.reduce(
  (n, { submissions }) => n + submissions.filter((s: any) => s.status === "rejected").length,
  0
);

const STATUS_COLORS: Record<string, string> = {
  submitted: "bg-yellow-950/40 border-yellow-800 text-yellow-300",
  approved:  "bg-green-950/40 border-green-800 text-green-300",
  rejected:  "bg-red-950/40 border-red-800 text-red-300",
  active:    "bg-blue-950/40 border-blue-800 text-blue-300",
};

const TYPE_LABELS: Record<string, string> = {
  label_image: "Label Image",
  label_text: "Label Text",
  rate_quality: "Rate Quality",
  verify_fact: "Verify Fact",
  moderate_content: "Moderate Content",
  compare_rank: "Compare & Rank",
  answer_question: "Answer Question",
  transcription_review: "Transcription Review",
};
---

<Layout title="Review Submissions — CrowdSorcerer">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <!-- Breadcrumb -->
    <div class="text-sm text-gray-500 mb-6">
      <a href="/dashboard" class="hover:text-gray-300 transition-colors">Dashboard</a>
      <span class="mx-2">›</span>
      <span>Review Submissions</span>
    </div>

    <div class="flex items-start justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold">Review Worker Submissions</h1>
        <p class="text-gray-400 text-sm mt-1">
          Approve or reject work submitted by human workers on your tasks
        </p>
      </div>
    </div>

    <!-- Summary cards -->
    <div class="grid grid-cols-3 gap-4 mb-8">
      {[
        { label: "Pending Review", value: totalPending, color: "text-yellow-300" },
        { label: "Approved", value: totalApproved, color: "text-green-300" },
        { label: "Rejected", value: totalRejected, color: "text-red-400" },
      ].map(({ label, value, color }) => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 text-center">
          <div class={`text-3xl font-bold ${color} mb-1`}>{value}</div>
          <div class="text-xs text-gray-400">{label}</div>
        </div>
      ))}
    </div>

    {error && (
      <div class="bg-red-950/30 border border-red-800 text-red-300 rounded-xl p-4 mb-6 text-sm">
        {error}
      </div>
    )}

    {tasksWithSubs.length === 0 && !error && (
      <div class="text-center py-20 bg-gray-900/50 border border-gray-800 rounded-2xl">
        <div class="text-5xl mb-4">📋</div>
        <h2 class="text-lg font-semibold mb-2">No submissions yet</h2>
        <p class="text-gray-400 text-sm mb-6">
          Workers haven't submitted any responses to your human tasks yet.
        </p>
        <a href="/dashboard/new-task" class="text-violet-400 hover:text-violet-300 text-sm">
          Post a human task →
        </a>
      </div>
    )}

    <!-- Task submission groups -->
    <div class="space-y-8">
      {tasksWithSubs.map(({ task, submissions }) => (
        <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
          <!-- Task header -->
          <div class="flex items-center justify-between px-6 py-4 border-b border-gray-800 bg-gray-900/80">
            <div class="flex items-center gap-3">
              <span class="text-violet-300 font-semibold text-sm">
                {TYPE_LABELS[task.type] ?? task.type}
              </span>
              <span class="font-mono text-xs text-gray-500">{task.id.slice(0, 8)}…</span>
              <span class="text-xs text-gray-400">
                {task.assignments_completed}/{task.assignments_required} workers
              </span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-xs text-gray-400">{new Date(task.created_at).toLocaleDateString()}</span>
              <a
                href={`/dashboard/tasks/${task.id}`}
                class="text-xs text-violet-400 hover:text-violet-300 transition-colors"
              >
                View task →
              </a>
            </div>
          </div>

          <!-- Submissions list -->
          {submissions.length === 0 ? (
            <div class="px-6 py-6 text-center text-gray-500 text-sm">
              No submissions for this task yet
            </div>
          ) : (
            <div class="divide-y divide-gray-800">
              {submissions.map((sub: any) => (
                <div class="px-6 py-5">
                  <div class="flex items-start justify-between gap-4">
                    <!-- Worker info -->
                    <div class="flex items-start gap-4 flex-1 min-w-0">
                      <div class="w-9 h-9 rounded-full bg-violet-900/50 border border-violet-800 flex items-center justify-center text-sm font-semibold text-violet-300 flex-shrink-0">
                        {(sub.worker.name ?? "?")[0].toUpperCase()}
                      </div>
                      <div class="min-w-0 flex-1">
                        <div class="flex items-center gap-2 mb-1">
                          <span class="font-medium text-sm text-gray-200">
                            {sub.worker.name ?? "Anonymous Worker"}
                          </span>
                          <span class="text-xs text-gray-500">Lv {sub.worker.worker_level}</span>
                          {sub.worker.worker_accuracy != null && (
                            <span class="text-xs text-gray-500">
                              {Math.round(sub.worker.worker_accuracy * 100)}% accuracy
                            </span>
                          )}
                          <span class={`px-2 py-0.5 text-xs rounded-full border ${STATUS_COLORS[sub.status] ?? "bg-gray-800 border-gray-700 text-gray-400"}`}>
                            {sub.status}
                          </span>
                        </div>
                        {sub.submitted_at && (
                          <div class="text-xs text-gray-500 mb-2">
                            Submitted {new Date(sub.submitted_at).toLocaleString()}
                          </div>
                        )}

                        <!-- Response preview -->
                        {sub.response && (
                          <div class="mt-2 bg-gray-950 border border-gray-800 rounded-lg p-3 max-h-32 overflow-y-auto">
                            <pre class="text-xs text-gray-300 whitespace-pre-wrap font-mono break-all">{JSON.stringify(sub.response, null, 2)}</pre>
                          </div>
                        )}

                        {sub.worker_note && (
                          <div class="mt-2 text-xs text-gray-400 italic">
                            Note: "{sub.worker_note}"
                          </div>
                        )}
                      </div>
                    </div>

                    <!-- Actions -->
                    <div class="flex items-center gap-2 flex-shrink-0">
                      {sub.status === "submitted" && (
                        <>
                          <form method="POST">
                            <input type="hidden" name="action" value="approve" />
                            <input type="hidden" name="task_id" value={task.id} />
                            <input type="hidden" name="assignment_id" value={sub.id} />
                            <button
                              type="submit"
                              class="px-3 py-1.5 bg-green-900/50 border border-green-700 text-green-300 text-xs font-medium rounded-lg hover:bg-green-800/50 transition-colors"
                            >
                              ✓ Approve
                            </button>
                          </form>
                          <form method="POST">
                            <input type="hidden" name="action" value="reject" />
                            <input type="hidden" name="task_id" value={task.id} />
                            <input type="hidden" name="assignment_id" value={sub.id} />
                            <button
                              type="submit"
                              class="px-3 py-1.5 bg-red-900/50 border border-red-700 text-red-300 text-xs font-medium rounded-lg hover:bg-red-800/50 transition-colors"
                            >
                              ✕ Reject
                            </button>
                          </form>
                        </>
                      )}
                      {sub.status === "approved" && (
                        <span class="text-green-400 text-xs font-medium">✓ Approved</span>
                      )}
                      {sub.status === "rejected" && (
                        <span class="text-red-400 text-xs font-medium">✕ Rejected</span>
                      )}
                      <div class="text-xs text-gray-500 ml-2">
                        {sub.earnings_credits} cr · {sub.xp_earned} XP
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Pagination -->
    {(page > 1 || tasksData.has_next) && (
      <div class="flex items-center justify-between mt-8">
        <a
          href={page > 1 ? `?page=${page - 1}` : "#"}
          class:list={[
            "px-4 py-2 border border-gray-700 rounded-lg text-sm transition-colors",
            page > 1
              ? "text-gray-300 hover:border-gray-600 hover:text-white"
              : "text-gray-600 cursor-not-allowed pointer-events-none",
          ]}
        >
          ← Previous
        </a>
        <span class="text-sm text-gray-400">Page {page} of {Math.ceil(tasksData.total / 20)}</span>
        <a
          href={tasksData.has_next ? `?page=${page + 1}` : "#"}
          class:list={[
            "px-4 py-2 border border-gray-700 rounded-lg text-sm transition-colors",
            tasksData.has_next
              ? "text-gray-300 hover:border-gray-600 hover:text-white"
              : "text-gray-600 cursor-not-allowed pointer-events-none",
          ]}
        >
          Next →
        </a>
      </div>
    )}
  </div>
</Layout>
