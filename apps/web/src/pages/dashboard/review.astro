---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login");

// Handle approve/reject POST actions
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("action") as string;
  const taskId = form.get("task_id") as string;
  const assignmentId = form.get("assignment_id") as string;
  const reason = form.get("reason") as string | undefined;

  try {
    await apiFetch(`/v1/tasks/${taskId}/submissions/${assignmentId}/${action}`, {
      method: "POST",
      token,
      body: JSON.stringify({ reason: reason || null }),
    });
    return Astro.redirect("/dashboard/review");
  } catch (e: any) {
    return Astro.redirect(`/dashboard/review?action_error=${encodeURIComponent(e.message ?? "Action failed — please try again")}`);
  }
}

const page = Number(Astro.url.searchParams.get("page") ?? 1);

let tasksData: any = { items: [], total: 0, page: 1, page_size: 20, has_next: false };
let error: string | null = null;

// Fetch human tasks that have at least one worker submission
try {
  tasksData = await apiFetch<any>(
    `/v1/tasks?execution_mode=human&has_submissions=true&page=${page}&page_size=20`,
    { token }
  );
} catch (e: any) {
  if (e.message?.includes("401") || e.message?.includes("403")) {
    return Astro.redirect("/login");
  }
  error = "Failed to load review queue";
}

// Fetch submissions for all tasks concurrently (avoids sequential N+1 latency)
const tasksWithSubs: Array<{ task: any; submissions: any[] }> = await Promise.all(
  tasksData.items.map(async (task: any) => {
    try {
      const subs = await apiFetch<any[]>(`/v1/tasks/${task.id}/submissions`, { token });
      return { task, submissions: subs ?? [] };
    } catch (_) {
      return { task, submissions: [] };
    }
  })
);

// Summary counts
const totalPending = tasksWithSubs.reduce(
  (n, { submissions }) => n + submissions.filter((s: any) => s.status === "submitted").length,
  0
);
const totalApproved = tasksWithSubs.reduce(
  (n, { submissions }) => n + submissions.filter((s: any) => s.status === "approved").length,
  0
);
const totalRejected = tasksWithSubs.reduce(
  (n, { submissions }) => n + submissions.filter((s: any) => s.status === "rejected").length,
  0
);

const STATUS_COLORS: Record<string, string> = {
  submitted: "bg-yellow-950/40 border-yellow-800 text-yellow-300",
  approved:  "bg-green-950/40 border-green-800 text-green-300",
  rejected:  "bg-red-950/40 border-red-800 text-red-300",
  active:    "bg-blue-950/40 border-blue-800 text-blue-300",
};

const TYPE_LABELS: Record<string, string> = {
  label_image: "Label Image",
  label_text: "Label Text",
  rate_quality: "Rate Quality",
  verify_fact: "Verify Fact",
  moderate_content: "Moderate Content",
  compare_rank: "Compare & Rank",
  answer_question: "Answer Question",
  transcription_review: "Transcription Review",
};
---

<Layout title="Review Submissions — CrowdSorcerer">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <!-- Breadcrumb -->
    <div class="text-sm text-gray-500 mb-6">
      <a href="/dashboard" class="hover:text-gray-300 transition-colors">Dashboard</a>
      <span class="mx-2">›</span>
      <span>Review Submissions</span>
    </div>

    <div class="flex items-start justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold">Review Worker Submissions</h1>
        <p class="text-gray-400 text-sm mt-1">
          Approve or reject work submitted by human workers on your tasks
        </p>
      </div>
    </div>

    <!-- Summary cards -->
    <div class="grid grid-cols-3 gap-4 mb-8">
      {[
        { label: "Pending Review", value: totalPending, color: "text-yellow-300" },
        { label: "Approved", value: totalApproved, color: "text-green-300" },
        { label: "Rejected", value: totalRejected, color: "text-red-400" },
      ].map(({ label, value, color }) => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 text-center">
          <div class={`text-3xl font-bold ${color} mb-1`}>{value}</div>
          <div class="text-xs text-gray-400">{label}</div>
        </div>
      ))}
    </div>

    {error && (
      <div class="bg-red-950/30 border border-red-800 text-red-300 rounded-xl p-4 mb-6 text-sm">
        {error}
      </div>
    )}

    {tasksWithSubs.length === 0 && !error && (
      <div class="text-center py-20 bg-gray-900/50 border border-gray-800 rounded-2xl">
        <div class="text-5xl mb-4">📋</div>
        <h2 class="text-lg font-semibold mb-2">No submissions yet</h2>
        <p class="text-gray-400 text-sm mb-6">
          Workers haven't submitted any responses to your human tasks yet.
        </p>
        <a href="/dashboard/new-task" class="text-violet-400 hover:text-violet-300 text-sm">
          Post a human task →
        </a>
      </div>
    )}

    <!-- Task submission groups -->
    <div class="space-y-8">
      {tasksWithSubs.map(({ task, submissions }) => (
        <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
          <!-- Task header -->
          <div class="flex items-center justify-between px-6 py-4 border-b border-gray-800 bg-gray-900/80">
            <div class="flex items-center gap-3">
              <span class="text-violet-300 font-semibold text-sm">
                {TYPE_LABELS[task.type] ?? task.type}
              </span>
              <span class="font-mono text-xs text-gray-500">{task.id.slice(0, 8)}…</span>
              <span class="text-xs text-gray-400">
                {task.assignments_completed}/{task.assignments_required} workers
              </span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-xs text-gray-400">{new Date(task.created_at).toLocaleDateString()}</span>
              <a
                href={`/dashboard/tasks/${task.id}`}
                class="text-xs text-violet-400 hover:text-violet-300 transition-colors"
              >
                View task →
              </a>
            </div>
          </div>

          <!-- Submissions list -->
          {submissions.length === 0 ? (
            <div class="px-6 py-6 text-center text-gray-500 text-sm">
              No submissions for this task yet
            </div>
          ) : (
            <div class="divide-y divide-gray-800">
              {submissions.map((sub: any) => (
                <div class="px-6 py-5">
                  <div class="flex items-start justify-between gap-4">
                    <!-- Worker info -->
                    <div class="flex items-start gap-4 flex-1 min-w-0">
                      <div class="w-9 h-9 rounded-full bg-violet-900/50 border border-violet-800 flex items-center justify-center text-sm font-semibold text-violet-300 flex-shrink-0">
                        {(sub.worker.name ?? "?")[0].toUpperCase()}
                      </div>
                      <div class="min-w-0 flex-1">
                        <div class="flex items-center gap-2 mb-1">
                          <span class="font-medium text-sm text-gray-200">
                            {sub.worker.name ?? "Anonymous Worker"}
                          </span>
                          <span class="text-xs text-gray-500">Lv {sub.worker.worker_level}</span>
                          {sub.worker.worker_accuracy != null && (
                            <span class="text-xs text-gray-500">
                              {Math.round(sub.worker.worker_accuracy * 100)}% accuracy
                            </span>
                          )}
                          <span class={`px-2 py-0.5 text-xs rounded-full border ${STATUS_COLORS[sub.status] ?? "bg-gray-800 border-gray-700 text-gray-400"}`}>
                            {sub.status}
                          </span>
                        </div>
                        {sub.submitted_at && (
                          <div class="text-xs text-gray-500 mb-2">
                            Submitted {new Date(sub.submitted_at).toLocaleString()}
                          </div>
                        )}

                        <!-- Response preview — type-specific rendering -->
                        {sub.response && (
                          <div class="mt-2">
                            {(task.type === "label_image" || task.type === "label_text") ? (
                              <div>
                                {(sub.response.labels ?? []).length > 0 ? (
                                  <div class="flex flex-wrap gap-1.5">
                                    {(sub.response.labels as string[]).map((l) => (
                                      <span class="px-2.5 py-1 bg-emerald-900/30 border border-emerald-700/50 text-emerald-300 text-xs rounded-lg">{l}</span>
                                    ))}
                                  </div>
                                ) : (
                                  <span class="text-xs text-gray-500 italic">No labels selected</span>
                                )}
                              </div>
                            ) : task.type === "rate_quality" ? (
                              <div>
                                <span class="text-amber-400 text-sm font-semibold">
                                  {"⭐".repeat(Math.max(0, Math.min(5, sub.response.rating ?? 0)))}
                                  <span class="text-gray-300 font-normal ml-1">{sub.response.rating ?? 0}/5</span>
                                </span>
                                {sub.response.justification && (
                                  <p class="text-xs text-gray-400 mt-1 italic">"{sub.response.justification}"</p>
                                )}
                              </div>
                            ) : task.type === "verify_fact" ? (
                              <div>
                                <span class:list={[
                                  "text-sm font-semibold",
                                  sub.response.verdict === "true" ? "text-emerald-400" :
                                  sub.response.verdict === "false" ? "text-red-400" : "text-gray-400"
                                ]}>
                                  {sub.response.verdict === "true" ? "✅ True" :
                                   sub.response.verdict === "false" ? "❌ False" : "❓ Can't tell"}
                                </span>
                                {sub.response.citation && (
                                  <div class="text-xs text-gray-500 mt-1">
                                    Citation:{" "}
                                    <a href={sub.response.citation} target="_blank" rel="noopener"
                                       class="text-violet-400 hover:underline break-all">
                                      {sub.response.citation}
                                    </a>
                                  </div>
                                )}
                              </div>
                            ) : task.type === "moderate_content" ? (
                              <div>
                                <span class:list={[
                                  "text-sm font-semibold",
                                  sub.response.decision === "approve" ? "text-emerald-400" :
                                  sub.response.decision === "reject" ? "text-red-400" : "text-amber-400"
                                ]}>
                                  {sub.response.decision === "approve" ? "✅ Approved" :
                                   sub.response.decision === "reject" ? "🚫 Rejected" : "⚠️ Escalated"}
                                </span>
                                {sub.response.reason && (
                                  <p class="text-xs text-gray-400 mt-1 italic">"{sub.response.reason}"</p>
                                )}
                              </div>
                            ) : task.type === "compare_rank" ? (
                              <div>
                                <span class="text-sm text-gray-300">
                                  Chose: <strong class="text-violet-300 uppercase">{sub.response.choice ?? "—"}</strong>
                                  {sub.response.choice === "tie" && " (about equal)"}
                                </span>
                                {sub.response.reason && (
                                  <p class="text-xs text-gray-400 mt-1 italic">"{sub.response.reason}"</p>
                                )}
                              </div>
                            ) : task.type === "answer_question" ? (
                              <p class="text-sm text-gray-300 leading-relaxed bg-gray-950/50 rounded-lg p-3 border border-gray-800">
                                {sub.response.answer ?? <span class="text-gray-600 italic">No answer provided</span>}
                              </p>
                            ) : task.type === "transcription_review" ? (
                              <div class="bg-gray-950 border border-gray-800 rounded-lg p-3 max-h-32 overflow-y-auto">
                                <p class="text-xs text-gray-300 font-mono whitespace-pre-wrap">{sub.response.corrected_text}</p>
                              </div>
                            ) : (
                              <div class="bg-gray-950 border border-gray-800 rounded-lg p-3 max-h-32 overflow-y-auto">
                                <pre class="text-xs text-gray-300 whitespace-pre-wrap font-mono break-all">{JSON.stringify(sub.response, null, 2)}</pre>
                              </div>
                            )}
                          </div>
                        )}

                        {sub.worker_note && (
                          <div class="mt-2 text-xs text-gray-400 italic">
                            Note: "{sub.worker_note}"
                          </div>
                        )}
                      </div>
                    </div>

                    <!-- Actions -->
                    <div class="flex-shrink-0 text-right">
                      <div class="text-xs text-gray-500 mb-2">
                        {sub.earnings_credits} cr · {sub.xp_earned} XP
                      </div>
                      {sub.status === "submitted" && (
                        <div class="review-actions flex gap-2 justify-end" data-sub-id={sub.id} data-task-id={task.id}>
                          <button
                            type="button"
                            class="approve-btn px-3 py-1.5 bg-green-900/50 border border-green-700 text-green-300 text-xs font-medium rounded-lg hover:bg-green-800/50 transition-colors"
                          >
                            ✓ Approve
                          </button>
                          <button
                            type="button"
                            class="reject-btn px-3 py-1.5 bg-red-900/50 border border-red-700 text-red-300 text-xs font-medium rounded-lg hover:bg-red-800/50 transition-colors"
                          >
                            ✕ Reject
                          </button>
                        </div>
                      )}
                      {sub.status === "approved" && (
                        <span class="text-green-400 text-xs font-medium">✓ Approved</span>
                      )}
                      {sub.status === "rejected" && (
                        <span class="text-red-400 text-xs font-medium">✕ Rejected</span>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Pagination -->
    {(page > 1 || tasksData.has_next) && (
      <div class="flex items-center justify-between mt-8">
        <a
          href={page > 1 ? `?page=${page - 1}` : "#"}
          class:list={[
            "px-4 py-2 border border-gray-700 rounded-lg text-sm transition-colors",
            page > 1
              ? "text-gray-300 hover:border-gray-600 hover:text-white"
              : "text-gray-600 cursor-not-allowed pointer-events-none",
          ]}
        >
          ← Previous
        </a>
        <span class="text-sm text-gray-400">Page {page} of {Math.ceil(tasksData.total / 20)}</span>
        <a
          href={tasksData.has_next ? `?page=${page + 1}` : "#"}
          class:list={[
            "px-4 py-2 border border-gray-700 rounded-lg text-sm transition-colors",
            tasksData.has_next
              ? "text-gray-300 hover:border-gray-600 hover:text-white"
              : "text-gray-600 cursor-not-allowed pointer-events-none",
          ]}
        >
          Next →
        </a>
      </div>
    )}
  </div>
</Layout>

<script>
// ── Review action buttons: approve / reject with optional reason ───────────

function toast(msg: string, success: boolean) {
  const t = document.createElement("div");
  t.textContent = msg;
  t.className = `fixed bottom-6 right-6 z-50 px-4 py-2.5 rounded-lg text-sm font-medium shadow-lg transition-opacity ${
    success
      ? "bg-green-900 border border-green-700 text-green-200"
      : "bg-red-900 border border-red-700 text-red-200"
  }`;
  document.body.appendChild(t);
  setTimeout(() => { t.style.opacity = "0"; setTimeout(() => t.remove(), 400); }, 3500);
}

async function postReviewAction(
  taskId: string,
  subId: string,
  action: "approve" | "reject",
  reason?: string
) {
  const form = new FormData();
  form.set("action", action);
  form.set("task_id", taskId);
  form.set("assignment_id", subId);
  if (reason) form.set("reason", reason);

  const res = await fetch("/dashboard/review", { method: "POST", body: form });
  if (res.redirected || res.ok) {
    // Server redirects on both success and failure; check the final URL for an error param
    const finalUrl = new URL(res.url, window.location.href);
    const errMsg = finalUrl.searchParams.get("action_error");
    if (errMsg) {
      throw new Error(decodeURIComponent(errMsg));
    }
    window.location.reload();
  } else {
    throw new Error("Request failed — please try again");
  }
}

document.querySelectorAll<HTMLElement>(".review-actions").forEach(container => {
  const subId = container.dataset.subId!;
  const taskId = container.dataset.taskId!;

  const approveBtn = container.querySelector<HTMLButtonElement>(".approve-btn")!;
  const rejectBtn = container.querySelector<HTMLButtonElement>(".reject-btn")!;

  approveBtn.addEventListener("click", async () => {
    approveBtn.textContent = "Approving…";
    approveBtn.disabled = true;
    rejectBtn.disabled = true;
    try {
      await postReviewAction(taskId, subId, "approve");
    } catch (e: any) {
      approveBtn.textContent = "✓ Approve";
      approveBtn.disabled = false;
      rejectBtn.disabled = false;
      toast(e.message ?? "Failed — please try again", false);
    }
  });

  rejectBtn.addEventListener("click", () => {
    // First click: expand reason textarea
    if (!container.querySelector(".reject-reason-wrap")) {
      const wrap = document.createElement("div");
      wrap.className = "reject-reason-wrap mt-2 w-48 text-left";
      wrap.innerHTML = `
        <textarea
          class="reject-reason-input w-full text-xs bg-gray-900 border border-red-800/60 rounded-lg p-2 text-gray-300 placeholder-gray-600 focus:outline-none focus:border-red-600 resize-none"
          rows="2"
          placeholder="Reason (optional)…"
        ></textarea>
        <button type="button" class="reject-confirm-btn mt-1.5 w-full px-3 py-1.5 bg-red-900/60 border border-red-700 text-red-300 text-xs font-semibold rounded-lg hover:bg-red-800/60 transition-colors">
          Confirm reject
        </button>
      `;
      container.appendChild(wrap);
      wrap.querySelector<HTMLElement>(".reject-reason-input")?.focus();

      wrap.querySelector<HTMLButtonElement>(".reject-confirm-btn")!.addEventListener("click", async () => {
        const reason = (wrap.querySelector<HTMLTextAreaElement>(".reject-reason-input")?.value ?? "").trim();
        rejectBtn.textContent = "Rejecting…";
        rejectBtn.disabled = true;
        approveBtn.disabled = true;
        try {
          await postReviewAction(taskId, subId, "reject", reason || undefined);
        } catch (e: any) {
          rejectBtn.textContent = "✕ Reject";
          rejectBtn.disabled = false;
          approveBtn.disabled = false;
          wrap.remove();
          toast(e.message ?? "Failed — please try again", false);
        }
      });
    }
  });
});
</script>
