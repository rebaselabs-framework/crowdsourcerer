---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login");

const { orgId } = Astro.params;
const url = new URL(Astro.request.url);
const days = Number(url.searchParams.get("days") ?? 30);

let analytics: any = null;
let orgName = "";
let error: string | null = null;

try {
  analytics = await apiFetch<any>(`/v1/orgs/${orgId}/analytics?days=${days}`, { token });
  orgName = analytics?.org_name ?? "";
} catch (e: any) {
  if (e.message?.includes("401") || e.message?.includes("403")) return Astro.redirect("/login");
  if (e.message?.includes("404")) return Astro.redirect("/dashboard/team");
  error = "Failed to load analytics";
}

const summary = analytics?.summary ?? {};
const byType: any[] = analytics?.by_type ?? [];
const byMember: any[] = analytics?.by_member ?? [];
const daily: any[] = analytics?.daily ?? [];

// Build sparkline data for daily counts
const maxCount = daily.reduce((m: number, d: any) => Math.max(m, d.count), 1);
---

<Layout title={`${orgName} Analytics — CrowdSorcerer`} active="dashboard">
  <div class="max-w-5xl mx-auto px-4 py-10">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
          <a href="/dashboard/team" class="hover:text-indigo-600">← Teams</a>
          <span>/</span>
          <span class="font-medium text-gray-700">{orgName}</span>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">📊 Team Analytics</h1>
        <p class="text-gray-500 mt-0.5">Activity breakdown for the last {days} days.</p>
      </div>
      <!-- Days filter -->
      <div class="flex gap-2">
        {[7, 14, 30, 90].map((d) => (
          <a
            href={`?days=${d}`}
            class={`px-3 py-1.5 text-sm rounded-lg font-medium border transition ${
              d === days
                ? "bg-indigo-600 text-white border-indigo-600"
                : "border-gray-200 text-gray-600 hover:border-indigo-300 hover:text-indigo-700"
            }`}
          >
            {d}d
          </a>
        ))}
      </div>
    </div>

    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl p-4 mb-6">{error}</div>
    )}

    {analytics && (
      <>
        <!-- Summary cards -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          <div class="bg-white rounded-2xl border p-5 shadow-sm">
            <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Total Tasks</p>
            <p class="text-3xl font-bold text-gray-900">{summary.total_tasks?.toLocaleString() ?? 0}</p>
          </div>
          <div class="bg-white rounded-2xl border p-5 shadow-sm">
            <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Completed</p>
            <p class="text-3xl font-bold text-green-600">{summary.completed?.toLocaleString() ?? 0}</p>
            <p class="text-xs text-gray-400 mt-1">{summary.completion_rate ?? 0}% rate</p>
          </div>
          <div class="bg-white rounded-2xl border p-5 shadow-sm">
            <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Failed</p>
            <p class="text-3xl font-bold text-red-500">{summary.failed?.toLocaleString() ?? 0}</p>
          </div>
          <div class="bg-white rounded-2xl border p-5 shadow-sm">
            <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Credits Spent</p>
            <p class="text-3xl font-bold text-indigo-600">{summary.credits_spent?.toLocaleString() ?? 0}</p>
            {summary.avg_duration_ms && (
              <p class="text-xs text-gray-400 mt-1">avg {Math.round(summary.avg_duration_ms / 1000)}s/task</p>
            )}
          </div>
        </div>

        <!-- Daily activity sparkline -->
        {daily.length > 0 && (
          <div class="bg-white rounded-2xl border shadow-sm p-6 mb-8">
            <h2 class="text-sm font-semibold text-gray-700 mb-4">Daily Task Activity</h2>
            <div class="flex items-end gap-1 h-20">
              {daily.map((d: any) => {
                const pct = maxCount > 0 ? Math.round((d.count / maxCount) * 100) : 0;
                const completedPct = d.count > 0 ? Math.round((d.completed / d.count) * 100) : 0;
                return (
                  <div
                    class="flex-1 flex flex-col items-center gap-0.5 group relative"
                    title={`${d.day}: ${d.count} tasks (${d.completed} completed)`}
                  >
                    <div
                      class="w-full rounded-t bg-indigo-400 hover:bg-indigo-500 transition-colors cursor-help"
                      style={`height: ${Math.max(pct, 2)}%`}
                    ></div>
                    <!-- tooltip -->
                    <span class="absolute bottom-full mb-1 hidden group-hover:block text-xs bg-gray-900 text-white px-2 py-1 rounded whitespace-nowrap z-10">
                      {d.day}: {d.count} tasks ({d.completed} ✓)
                    </span>
                  </div>
                );
              })}
            </div>
            <div class="flex justify-between text-xs text-gray-400 mt-2">
              <span>{daily[0]?.day}</span>
              <span>{daily[daily.length - 1]?.day}</span>
            </div>
          </div>
        )}

        <div class="grid md:grid-cols-2 gap-6 mb-8">
          <!-- Task type breakdown -->
          <div class="bg-white rounded-2xl border shadow-sm p-6">
            <h2 class="text-sm font-semibold text-gray-700 mb-4">Tasks by Type</h2>
            {byType.length === 0 ? (
              <p class="text-sm text-gray-400 text-center py-4">No tasks in this period.</p>
            ) : (
              <div class="space-y-3">
                {byType.map((t: any) => {
                  const barPct = byType[0]?.count ? Math.round((t.count / byType[0].count) * 100) : 0;
                  return (
                    <div>
                      <div class="flex justify-between items-center mb-1">
                        <span class="text-sm text-gray-700 font-mono">{t.type}</span>
                        <span class="text-xs text-gray-500">{t.count} tasks · {t.credits} cr · {t.completion_rate}%</span>
                      </div>
                      <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
                        <div
                          class="h-full bg-indigo-500 rounded-full"
                          style={`width: ${barPct}%`}
                        ></div>
                      </div>
                    </div>
                  );
                })}
              </div>
            )}
          </div>

          <!-- Member breakdown -->
          <div class="bg-white rounded-2xl border shadow-sm p-6">
            <h2 class="text-sm font-semibold text-gray-700 mb-4">Member Activity</h2>
            {byMember.length === 0 ? (
              <p class="text-sm text-gray-400 text-center py-4">No member activity.</p>
            ) : (
              <div class="space-y-3">
                {byMember.map((m: any) => (
                  <div class="flex items-center justify-between py-2 border-b border-gray-50 last:border-0">
                    <div class="flex items-center gap-2">
                      <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-xs font-bold uppercase">
                        {(m.name ?? "?")[0]}
                      </div>
                      <div>
                        <p class="text-sm font-medium text-gray-800">{m.name}</p>
                        <p class="text-xs text-gray-400">{m.tasks_created} created · {m.tasks_completed} completed</p>
                      </div>
                    </div>
                    <div class="text-right">
                      <p class="text-sm font-semibold text-indigo-600">{m.credits_spent.toLocaleString()} cr</p>
                      <p class="text-xs text-gray-400">
                        {m.tasks_created > 0 ? Math.round((m.tasks_completed / m.tasks_created) * 100) : 0}% complete
                      </p>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </>
    )}
  </div>
</Layout>
