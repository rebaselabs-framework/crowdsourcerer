---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login");

const url = new URL(Astro.request.url);
const tab = url.searchParams.get("tab") ?? "endpoints";
const page = Number(url.searchParams.get("page") ?? 1);
const taskId = url.searchParams.get("task_id") ?? "";
const successFilter = url.searchParams.get("success") ?? "";
const eventFilter = url.searchParams.get("event_type") ?? "";

let endpoints: any[] = [];
let endpointsTotal = 0;
let logs: any = { items: [], total: 0, page: 1, page_size: 25, has_next: false };
let stats: any = null;
let eventTypes: any = { events: [] };
let payloadTemplates: any[] = [];
let prefEvents: any[] = [];
let error: string | null = null;

try {
  eventTypes = await apiFetch<any>("/v1/webhooks/events", { token });

  if (tab === "endpoints") {
    const r = await apiFetch<any>("/v1/webhooks/endpoints", { token });
    endpoints = r?.items ?? [];
    endpointsTotal = r?.total ?? 0;
  } else if (tab === "templates") {
    const r = await apiFetch<any>("/v1/webhooks/payload-templates", { token });
    payloadTemplates = r?.items ?? [];
  } else if (tab === "preferences") {
    const r = await apiFetch<any>("/v1/webhooks/preferences", { token });
    prefEvents = r?.events ?? [];
  } else {
    const qs = new URLSearchParams({ page: String(page), page_size: "25" });
    if (taskId) qs.set("task_id", taskId);
    if (successFilter !== "") qs.set("success", successFilter);
    if (eventFilter) qs.set("event_type", eventFilter);

    [logs, stats] = await Promise.all([
      apiFetch<any>(`/v1/webhooks/logs?${qs}`, { token }),
      apiFetch<any>("/v1/webhooks/stats", { token }),
    ]);
  }
} catch (e: any) {
  if (e.message?.includes("401") || e.message?.includes("403")) {
    return Astro.redirect("/login");
  }
  error = "Failed to load webhook data";
}

const EVENT_COLORS: Record<string, string> = {
  "task.created": "bg-blue-950 text-blue-400",
  "task.assigned": "bg-indigo-950 text-indigo-400",
  "task.submission_received": "bg-purple-950 text-purple-400",
  "task.completed": "bg-green-950 text-green-400",
  "task.failed": "bg-red-950 text-red-400",
  "task.approved": "bg-emerald-950 text-emerald-400",
  "task.rejected": "bg-orange-950 text-orange-400",
  "sla.breach": "bg-yellow-950 text-yellow-400",
};

const ALL_EVENTS = (eventTypes?.events ?? []).map((e: any) => e.type);
---

<Layout title="Webhooks — CrowdSorcerer">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <!-- Breadcrumb -->
    <div class="text-sm text-gray-500 mb-6">
      <a href="/dashboard" class="hover:text-gray-300 transition-colors">Dashboard</a>
      <span class="mx-2">›</span>
      <span>Webhooks</span>
    </div>

    <div class="flex items-start justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold">Webhooks</h1>
        <p class="text-gray-400 text-sm mt-1">Manage persistent subscriptions and inspect delivery logs</p>
      </div>
    </div>

    {error && (
      <div class="bg-red-950/30 border border-red-800 rounded-xl p-4 mb-6 text-red-300 text-sm">{error}</div>
    )}

    <!-- Tabs -->
    <div class="flex border-b border-gray-800 mb-8 gap-1">
      <a
        href="/dashboard/webhooks?tab=endpoints"
        class:list={[
          "px-5 py-3 text-sm font-medium transition-colors border-b-2 -mb-px",
          tab === "endpoints"
            ? "border-violet-500 text-white"
            : "border-transparent text-gray-400 hover:text-gray-200",
        ]}
      >
        🔌 Endpoints <span class="ml-1.5 text-xs bg-gray-800 text-gray-400 px-1.5 py-0.5 rounded-full">{endpointsTotal}</span>
      </a>
      <a
        href="/dashboard/webhooks?tab=logs"
        class:list={[
          "px-5 py-3 text-sm font-medium transition-colors border-b-2 -mb-px",
          tab === "logs"
            ? "border-violet-500 text-white"
            : "border-transparent text-gray-400 hover:text-gray-200",
        ]}
      >
        📋 Delivery Logs {stats && <span class="ml-1.5 text-xs bg-gray-800 text-gray-400 px-1.5 py-0.5 rounded-full">{stats.total_deliveries}</span>}
      </a>
      <a
        href="/dashboard/webhooks?tab=templates"
        class:list={[
          "px-5 py-3 text-sm font-medium transition-colors border-b-2 -mb-px",
          tab === "templates"
            ? "border-violet-500 text-white"
            : "border-transparent text-gray-400 hover:text-gray-200",
        ]}
      >
        🧩 Payload Templates <span class="ml-1.5 text-xs bg-gray-800 text-gray-400 px-1.5 py-0.5 rounded-full">{payloadTemplates.length}</span>
      </a>
      <a
        href="/dashboard/webhooks?tab=preferences"
        class:list={[
          "px-5 py-3 text-sm font-medium transition-colors border-b-2 -mb-px",
          tab === "preferences"
            ? "border-violet-500 text-white"
            : "border-transparent text-gray-400 hover:text-gray-200",
        ]}
      >
        ⚙️ Event Preferences
      </a>
    </div>

    {/* ─── ENDPOINTS TAB ─────────────────────────────────────────────────────── */}
    {tab === "endpoints" && (
      <div>
        <!-- Create form -->
        <div id="create-form" class="bg-gray-900 border border-gray-800 rounded-xl p-6 mb-8 hidden">
          <h2 class="text-base font-semibold mb-5">Register a new endpoint</h2>
          <div class="grid gap-4">
            <div>
              <label class="block text-xs font-medium text-gray-400 mb-1.5">URL <span class="text-red-400">*</span></label>
              <input
                id="ep-url"
                type="url"
                placeholder="https://your-server.example.com/webhook"
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-sm text-gray-200 font-mono focus:outline-none focus:border-violet-500"
              />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-400 mb-1.5">Description (optional)</label>
              <input
                id="ep-description"
                type="text"
                placeholder="e.g. Production notification receiver"
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-sm text-gray-200 focus:outline-none focus:border-violet-500"
              />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-400 mb-2">Events to receive</label>
              <p class="text-xs text-gray-500 mb-3">Leave all unchecked to receive ALL events.</p>
              <div class="grid grid-cols-2 md:grid-cols-4 gap-2" id="events-checkboxes">
                {ALL_EVENTS.map((evt: string) => (
                  <label class="flex items-center gap-2 text-xs text-gray-300 cursor-pointer">
                    <input type="checkbox" class="event-cb rounded border-gray-600 bg-gray-800 text-violet-500 focus:ring-violet-500" value={evt} />
                    <span class:list={["px-2 py-0.5 rounded-full text-xs", EVENT_COLORS[evt] ?? "bg-gray-800 text-gray-400"]}>{evt}</span>
                  </label>
                ))}
              </div>
            </div>
          </div>
          <div class="flex gap-3 mt-5">
            <button
              id="create-ep-btn"
              class="px-5 py-2.5 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors"
            >
              Register endpoint
            </button>
            <button
              id="cancel-create-btn"
              type="button"
              class="px-5 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm rounded-lg transition-colors"
            >
              Cancel
            </button>
          </div>
          <div id="create-ep-error" class="hidden text-sm text-red-400 bg-red-950/20 border border-red-800 rounded-lg px-3 py-2 mt-3"></div>
          <!-- Secret reveal box (shown after creation) -->
          <div id="secret-box" class="hidden mt-5 bg-amber-950/30 border border-amber-700 rounded-xl p-4">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-amber-400 font-semibold text-sm">🔑 Signing secret — copy now, it won't be shown again!</span>
            </div>
            <code id="secret-value" class="block font-mono text-xs text-amber-300 break-all bg-gray-950 rounded p-3"></code>
            <button id="copy-secret-btn" class="mt-2 text-xs text-amber-400 hover:text-amber-300 underline">Copy to clipboard</button>
          </div>
        </div>

        <!-- Header row -->
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-gray-300">{endpointsTotal} endpoint{endpointsTotal !== 1 ? "s" : ""}</h2>
          <button
            id="show-create-btn"
            class="px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors"
          >
            + Add endpoint
          </button>
        </div>

        {endpoints.length === 0 ? (
          <div class="bg-gray-900 border border-gray-800 rounded-xl px-6 py-16 text-center">
            <div class="text-5xl mb-4">🔌</div>
            <h3 class="font-semibold mb-2">No webhook endpoints yet</h3>
            <p class="text-gray-500 text-sm max-w-md mx-auto">
              Register a persistent endpoint and we'll POST signed JSON to it
              for every event you subscribe to — across all your tasks.
            </p>
            <button
              id="show-create-empty-btn"
              class="mt-5 px-5 py-2.5 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors"
            >
              Register your first endpoint →
            </button>
          </div>
        ) : (
          <div class="space-y-4" id="endpoints-list">
            {endpoints.map((ep: any) => (
              <div class="bg-gray-900 border border-gray-800 rounded-xl p-5" data-ep-id={ep.id}>
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 mb-2 flex-wrap">
                      <span class:list={[
                        "inline-flex items-center gap-1 text-xs font-medium px-2 py-0.5 rounded-full",
                        ep.is_active ? "bg-green-950 text-green-400" : "bg-gray-800 text-gray-500"
                      ]}>
                        <span class:list={[
                          "w-1.5 h-1.5 rounded-full inline-block",
                          ep.is_active ? "bg-green-400" : "bg-gray-500"
                        ]}></span>
                        {ep.is_active ? "Active" : "Paused"}
                      </span>
                      {ep.description && (
                        <span class="text-sm text-gray-300 font-medium">{ep.description}</span>
                      )}
                    </div>
                    <code class="text-xs font-mono text-violet-300 break-all">{ep.url}</code>
                    <div class="flex flex-wrap gap-1.5 mt-2">
                      {ep.events == null || ep.events.length === 0 ? (
                        <span class="text-xs text-gray-500">All events</span>
                      ) : (
                        ep.events.map((evt: string) => (
                          <span class:list={[
                            "text-xs px-2 py-0.5 rounded-full font-mono",
                            EVENT_COLORS[evt] ?? "bg-gray-800 text-gray-400"
                          ]}>
                            {evt}
                          </span>
                        ))
                      )}
                    </div>
                  </div>
                  <div class="flex items-center gap-2 flex-shrink-0">
                    <div class="text-right text-xs text-gray-500 mr-2">
                      <div>{ep.delivery_count} delivered</div>
                      {ep.failure_count > 0 && <div class="text-red-400">{ep.failure_count} failed</div>}
                    </div>
                    <button
                      class="test-ep-btn text-xs px-3 py-1.5 rounded border border-gray-700 text-gray-400 hover:border-violet-500 hover:text-violet-300 transition-colors"
                      data-ep-id={ep.id}
                      title="Send a test ping"
                    >
                      ⚡ Test
                    </button>
                    <button
                      class="toggle-ep-btn text-xs px-3 py-1.5 rounded border border-gray-700 text-gray-400 hover:border-gray-500 hover:text-gray-300 transition-colors"
                      data-ep-id={ep.id}
                      data-active={String(ep.is_active)}
                      title={ep.is_active ? "Pause endpoint" : "Resume endpoint"}
                    >
                      {ep.is_active ? "⏸ Pause" : "▶ Resume"}
                    </button>
                    <button
                      class="rotate-secret-btn text-xs px-3 py-1.5 rounded border border-gray-700 text-gray-400 hover:border-yellow-500 hover:text-yellow-400 transition-colors"
                      data-ep-id={ep.id}
                      title="Rotate signing secret"
                    >
                      🔑 Rotate
                    </button>
                    <button
                      class="delete-ep-btn text-xs px-3 py-1.5 rounded border border-red-900 text-red-400 hover:border-red-500 hover:text-red-300 transition-colors"
                      data-ep-id={ep.id}
                      title="Delete endpoint"
                    >
                      🗑
                    </button>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}

        <!-- Signing docs -->
        <div class="mt-10 bg-gray-900 border border-gray-800 rounded-xl p-6">
          <h3 class="font-semibold mb-3">Verifying webhook signatures</h3>
          <p class="text-sm text-gray-400 mb-4">
            Every delivery includes an <code class="bg-gray-800 px-1.5 py-0.5 rounded font-mono text-xs">X-Crowdsourcerer-Signature</code> header.
            Verify it with your signing secret to ensure the payload is authentic.
          </p>
          <pre class="bg-gray-950 rounded-lg p-4 text-xs font-mono text-gray-300 overflow-x-auto"><code># Python example
import hmac, hashlib

def verify(payload_bytes: bytes, secret: str, signature: str) -&gt; bool:
    expected = hmac.new(secret.encode(), payload_bytes, hashlib.sha256).hexdigest()
    return hmac.compare_digest(expected, signature)

# In your Flask/FastAPI handler:
sig = request.headers.get("X-Crowdsourcerer-Signature", "")
if not verify(request.get_data(), YOUR_SECRET, sig):
    abort(401, "Invalid signature")</code></pre>
        </div>
      </div>
    )}

    {/* ─── DELIVERY LOGS TAB ─────────────────────────────────────────────────── */}
    {tab === "logs" && (
      <div>
        <!-- Stats cards -->
        {stats && (
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
              <div class="text-xs text-gray-500 mb-1">Total deliveries</div>
              <div class="text-3xl font-bold">{stats.total_deliveries}</div>
            </div>
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
              <div class="text-xs text-gray-500 mb-1">Succeeded</div>
              <div class="text-3xl font-bold text-green-400">{stats.succeeded}</div>
            </div>
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
              <div class="text-xs text-gray-500 mb-1">Failed</div>
              <div class="text-3xl font-bold text-red-400">{stats.failed}</div>
            </div>
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
              <div class="text-xs text-gray-500 mb-1">Success rate</div>
              <div class:list={[
                "text-3xl font-bold",
                stats.success_rate >= 95 ? "text-green-400" :
                stats.success_rate >= 80 ? "text-yellow-400" : "text-red-400"
              ]}>
                {stats.success_rate}%
              </div>
            </div>
          </div>
        )}

        <!-- By-event breakdown -->
        {stats && stats.by_event_type && Object.keys(stats.by_event_type).length > 0 && (
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mb-6">
            <h3 class="text-sm font-semibold text-gray-400 mb-3">Deliveries by event type</h3>
            <div class="flex flex-wrap gap-2">
              {(Object.entries(stats.by_event_type) as [string, number][]).map(([evtType, cnt]) => (
                <a
                  href={`/dashboard/webhooks?tab=logs&event_type=${evtType}`}
                  class:list={[
                    "inline-flex items-center gap-2 text-xs px-3 py-1.5 rounded-full border border-transparent hover:opacity-80 transition-opacity cursor-pointer",
                    EVENT_COLORS[evtType] ?? "bg-gray-800 text-gray-400"
                  ]}
                >
                  <span>{evtType}</span>
                  <span class="font-bold">{cnt}</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Filters -->
        <form method="GET" class="bg-gray-900 border border-gray-800 rounded-xl p-4 mb-6 flex gap-3 flex-wrap items-center">
          <input type="hidden" name="tab" value="logs" />
          <input
            type="text"
            name="task_id"
            value={taskId}
            placeholder="Filter by task ID…"
            class="flex-1 min-w-40 bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 font-mono focus:outline-none focus:border-violet-500"
          />
          <select name="event_type" class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 focus:outline-none">
            <option value="">All events</option>
            {eventTypes.events.map((evt: any) => (
              <option value={evt.type} selected={eventFilter === evt.type}>{evt.type}</option>
            ))}
          </select>
          <select name="success" class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 focus:outline-none">
            <option value="">All results</option>
            <option value="true" selected={successFilter === "true"}>Succeeded</option>
            <option value="false" selected={successFilter === "false"}>Failed</option>
          </select>
          <button type="submit" class="px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm rounded-lg transition-colors">
            Filter
          </button>
          {(taskId || successFilter || eventFilter) && (
            <a href="/dashboard/webhooks?tab=logs" class="px-4 py-2 bg-gray-700 hover:bg-gray-600 text-gray-300 text-sm rounded-lg transition-colors">
              Clear
            </a>
          )}
          <span class="ml-auto text-sm text-gray-500">{logs.total} logs</span>
        </form>

        <!-- Logs table -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
          {logs.items.length === 0 ? (
            <div class="px-6 py-16 text-center">
              <div class="text-4xl mb-3">📡</div>
              <h3 class="font-semibold mb-2">No webhook deliveries</h3>
              <p class="text-gray-500 text-sm">
                When tasks with webhook URLs complete, delivery logs will appear here.
              </p>
            </div>
          ) : (
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-gray-800 text-left">
                  <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Result</th>
                  <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Event</th>
                  <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Task</th>
                  <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">URL</th>
                  <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Status</th>
                  <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Attempt</th>
                  <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Duration</th>
                  <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Date</th>
                  <th class="px-4 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-800">
                {logs.items.map((log: any) => (
                  <tr class="hover:bg-gray-800/40 transition-colors">
                    <td class="px-4 py-4">
                      <span class:list={[
                        "inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full",
                        log.success ? "bg-green-950 text-green-400" : "bg-red-950 text-red-400"
                      ]}>
                        <span class="w-1.5 h-1.5 rounded-full inline-block"
                          style={log.success ? "background: #4ade80" : "background: #f87171"}></span>
                        {log.success ? "ok" : "fail"}
                      </span>
                    </td>
                    <td class="px-4 py-4">
                      <span class:list={[
                        "text-xs px-2 py-1 rounded-full font-mono",
                        EVENT_COLORS[log.event_type] ?? "bg-gray-800 text-gray-400"
                      ]}>
                        {log.event_type ?? "task.completed"}
                      </span>
                    </td>
                    <td class="px-4 py-4">
                      <a href={`/dashboard/tasks/${log.task_id}`} class="font-mono text-xs text-violet-300 hover:text-violet-200">
                        {log.task_id.slice(0, 8)}…
                      </a>
                    </td>
                    <td class="px-4 py-4 max-w-xs">
                      <span class="font-mono text-xs text-gray-400 truncate block" title={log.url}>
                        {log.url.length > 40 ? log.url.slice(0, 40) + "…" : log.url}
                      </span>
                    </td>
                    <td class="px-4 py-4">
                      {log.status_code != null ? (
                        <span class:list={[
                          "font-mono text-xs",
                          log.status_code < 300 ? "text-green-400" :
                          log.status_code < 500 ? "text-yellow-400" : "text-red-400"
                        ]}>
                          {log.status_code}
                        </span>
                      ) : (
                        <span class="text-xs text-red-400 italic">{log.error?.slice(0, 30) ?? "timeout"}</span>
                      )}
                    </td>
                    <td class="px-4 py-4 text-center text-gray-400 text-xs">#{log.attempt}</td>
                    <td class="px-4 py-4 text-gray-400 text-xs">
                      {log.duration_ms != null ? `${log.duration_ms}ms` : "—"}
                    </td>
                    <td class="px-4 py-4 text-gray-500 text-xs">
                      {new Date(log.created_at).toLocaleString()}
                    </td>
                    <td class="px-4 py-4">
                      <div class="flex items-center gap-1.5">
                        <button
                          class="retry-btn text-xs px-2.5 py-1 rounded border border-gray-700 text-gray-400 hover:border-violet-500 hover:text-violet-300 transition-colors"
                          data-log-id={log.id}
                          title="Retry to same URL"
                        >
                          ↻ Retry
                        </button>
                        <button
                          class="replay-btn text-xs px-2.5 py-1 rounded border border-gray-700 text-indigo-400 hover:border-indigo-500 hover:text-indigo-300 transition-colors"
                          data-log-id={log.id}
                          title="Replay event to all active endpoints"
                        >
                          ▶ Replay
                        </button>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>

        <!-- Pagination -->
        {(logs.has_next || page > 1) && (
          <div class="flex items-center justify-between mt-6">
            <div class="text-sm text-gray-500">Page {logs.page} · {logs.total} total</div>
            <div class="flex gap-2">
              {page > 1 && (
                <a
                  href={`/dashboard/webhooks?tab=logs&page=${page - 1}${taskId ? `&task_id=${taskId}` : ""}${successFilter !== "" ? `&success=${successFilter}` : ""}${eventFilter ? `&event_type=${eventFilter}` : ""}`}
                  class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-sm text-gray-300 rounded-lg transition-colors"
                >
                  ← Previous
                </a>
              )}
              {logs.has_next && (
                <a
                  href={`/dashboard/webhooks?tab=logs&page=${page + 1}${taskId ? `&task_id=${taskId}` : ""}${successFilter !== "" ? `&success=${successFilter}` : ""}${eventFilter ? `&event_type=${eventFilter}` : ""}`}
                  class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-sm text-gray-300 rounded-lg transition-colors"
                >
                  Next →
                </a>
              )}
            </div>
          </div>
        )}

        <!-- Event Types Reference -->
        <div class="mt-10">
          <h2 class="text-lg font-bold mb-4">Supported event types</h2>
          <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-gray-800">
                  <th class="px-5 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider text-left">Event</th>
                  <th class="px-5 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider text-left">Description</th>
                  <th class="px-5 py-3 text-xs font-semibold text-gray-400 uppercase tracking-wider text-center">Default</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-800">
                {eventTypes.events.map((evt: any) => (
                  <tr class="hover:bg-gray-800/40 transition-colors">
                    <td class="px-5 py-3">
                      <span class:list={["text-xs px-2 py-1 rounded-full font-mono", EVENT_COLORS[evt.type] ?? "bg-gray-800 text-gray-400"]}>
                        {evt.type}
                      </span>
                    </td>
                    <td class="px-5 py-3 text-gray-400 text-xs">{evt.description}</td>
                    <td class="px-5 py-3 text-center text-xs">
                      {evt.is_default ? (
                        <span class="text-green-400">✓ default</span>
                      ) : (
                        <span class="text-gray-600">opt-in</span>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    )}
    {/* ─── PAYLOAD TEMPLATES TAB ─────────────────────────────────────────────── */}
    {tab === "templates" && (
      <div>
        <!-- Header -->
        <div class="flex items-center justify-between mb-6">
          <div>
            <h2 class="text-base font-semibold">Custom Payload Templates</h2>
            <p class="text-xs text-gray-500 mt-1">
              Define per-event JSON templates using <code class="bg-gray-800 px-1 rounded">{"{{field}}"}</code> placeholders.
              When set, the rendered template replaces the default webhook payload.
            </p>
          </div>
          <button
            id="show-template-form-btn"
            class="px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors"
          >
            + Add Template
          </button>
        </div>

        <!-- Add/Edit modal form -->
        <div id="template-form" class="hidden bg-gray-900 border border-gray-800 rounded-xl p-6 mb-8">
          <h3 class="text-sm font-semibold mb-4">Add / Edit Payload Template</h3>
          <div class="grid gap-4">
            <div>
              <label class="block text-xs font-medium text-gray-400 mb-1.5">Event Type <span class="text-red-400">*</span></label>
              <select id="tpl-event-type" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-sm text-gray-200 focus:outline-none focus:border-violet-500">
                {(eventTypes?.events ?? []).map((evt: any) => (
                  <option value={evt.type}>{evt.type}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-400 mb-1.5">Description (optional)</label>
              <input
                id="tpl-description"
                type="text"
                placeholder="e.g. Slack-compatible payload for task completion"
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-sm text-gray-200 focus:outline-none focus:border-violet-500"
              />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-400 mb-1.5">Template JSON <span class="text-red-400">*</span></label>
              <textarea
                id="tpl-template"
                rows={10}
                placeholder={'{\n  "text": "Task {{task_id}} ({{event_type}}) completed at {{occurred_at}}",\n  "task_id": "{{task_id}}",\n  "user_id": "{{user_id}}"\n}'}
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-sm text-gray-200 font-mono focus:outline-none focus:border-violet-500"
              ></textarea>
            </div>
            <!-- Available variables reference -->
            <div class="bg-gray-800/60 rounded-lg p-4">
              <p class="text-xs font-semibold text-gray-400 mb-2">Available variables</p>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-1.5">
                {["task_id", "event_type", "user_id", "occurred_at", "timestamp", "status", "task_type", "title", "result"].map((v) => (
                  <code class="text-xs bg-gray-700 text-violet-300 px-2 py-0.5 rounded font-mono">{`{{${v}}}`}</code>
                ))}
              </div>
            </div>
          </div>
          <div class="flex gap-3 mt-5">
            <button
              id="save-template-btn"
              class="px-5 py-2.5 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors"
            >
              Save template
            </button>
            <button
              id="cancel-template-btn"
              type="button"
              class="px-5 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm rounded-lg transition-colors"
            >
              Cancel
            </button>
          </div>
          <div id="tpl-error" class="hidden text-sm text-red-400 bg-red-950/20 border border-red-800 rounded-lg px-3 py-2 mt-3"></div>
        </div>

        <!-- Templates list -->
        {payloadTemplates.length === 0 ? (
          <div class="bg-gray-900 border border-gray-800 rounded-xl px-6 py-16 text-center">
            <div class="text-5xl mb-4">🧩</div>
            <h3 class="font-semibold mb-2">No payload templates yet</h3>
            <p class="text-gray-500 text-sm max-w-md mx-auto">
              Create a custom JSON template for any event type. Use <code class="text-violet-300">{"{{task_id}}"}</code> style placeholders
              to inject task context at delivery time.
            </p>
          </div>
        ) : (
          <div class="space-y-4" id="templates-list">
            {payloadTemplates.map((tpl: any) => (
              <div class="bg-gray-900 border border-gray-800 rounded-xl p-5" data-tpl-event={tpl.event_type}>
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 mb-2 flex-wrap">
                      <span class:list={["text-xs px-2 py-0.5 rounded-full font-mono", EVENT_COLORS[tpl.event_type] ?? "bg-gray-800 text-gray-400"]}>
                        {tpl.event_type}
                      </span>
                      {tpl.description && (
                        <span class="text-sm text-gray-300">{tpl.description}</span>
                      )}
                    </div>
                    <pre class="text-xs font-mono text-gray-400 bg-gray-950 rounded p-3 overflow-x-auto max-h-32 mt-2">{tpl.template.length > 400 ? tpl.template.slice(0, 400) + "\n…" : tpl.template}</pre>
                    <p class="text-xs text-gray-600 mt-2">Updated {new Date(tpl.updated_at).toLocaleString()}</p>
                  </div>
                  <div class="flex items-center gap-2 flex-shrink-0">
                    <button
                      class="edit-tpl-btn text-xs px-3 py-1.5 rounded border border-gray-700 text-gray-400 hover:border-violet-500 hover:text-violet-300 transition-colors"
                      data-event-type={tpl.event_type}
                      data-description={tpl.description ?? ""}
                      data-template={tpl.template}
                    >
                      ✏ Edit
                    </button>
                    <button
                      class="delete-tpl-btn text-xs px-3 py-1.5 rounded border border-red-900 text-red-400 hover:border-red-500 hover:text-red-300 transition-colors"
                      data-event-type={tpl.event_type}
                    >
                      🗑 Delete
                    </button>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    )}
  </div>

    {/* ─── PREFERENCES TAB ──────────────────────────────────────────────────── */}
    {tab === "preferences" && (
      <div>
        <div class="mb-6">
          <h2 class="text-base font-semibold">Webhook Event Preferences</h2>
          <p class="text-xs text-gray-500 mt-1">
            Control which event types trigger webhook deliveries globally. Disabling an event here
            prevents <em>all</em> your endpoints from receiving it, regardless of their individual subscriptions.
          </p>
        </div>

        <form id="webhook-prefs-form" class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-6">
          <div class="divide-y divide-gray-800">
            {prefEvents.length === 0 ? (
              <div class="px-6 py-8 text-center text-sm text-gray-500">Loading event preferences…</div>
            ) : prefEvents.map((evt: any) => (
              <div class="pref-row flex items-center justify-between px-6 py-4 hover:bg-gray-800/40 transition-colors">
                <div class="flex-1 min-w-0 pr-6">
                  <div class="flex items-center gap-3 mb-0.5">
                    <code class="text-sm font-mono text-violet-300">{evt.type}</code>
                    {evt.is_default && (
                      <span class="text-xs bg-violet-950 text-violet-400 px-1.5 py-0.5 rounded-full">default</span>
                    )}
                    <span class={`pref-status-badge text-xs px-2 py-0.5 rounded-full ${evt.enabled ? "bg-green-950 text-green-400" : "bg-gray-800 text-gray-500"}`}>
                      {evt.enabled ? "Enabled" : "Disabled"}
                    </span>
                  </div>
                  <p class="text-xs text-gray-500">{evt.description}</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer shrink-0">
                  <input
                    type="checkbox"
                    class="pref-toggle sr-only peer"
                    data-event={evt.type}
                    checked={evt.enabled}
                  />
                  <div class="w-10 h-5 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-5 after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-violet-600"></div>
                </label>
              </div>
            ))}
          </div>

          <div class="px-6 py-4 border-t border-gray-800 flex items-center justify-between">
            <span id="prefs-save-msg" class="text-sm text-gray-500"></span>
            <button
              id="save-prefs-btn"
              type="submit"
              class="px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors"
            >
              Save Preferences
            </button>
          </div>
        </form>

        <div class="bg-gray-900/50 border border-gray-800 rounded-xl p-5">
          <h3 class="text-sm font-medium text-gray-300 mb-2">💡 How this works</h3>
          <ul class="text-xs text-gray-500 space-y-1.5">
            <li>• These preferences act as a <strong class="text-gray-400">global master switch</strong> per event type.</li>
            <li>• If an event is <strong class="text-gray-400">disabled here</strong>, none of your endpoints receive it — even if they subscribe to it individually.</li>
            <li>• If an event is <strong class="text-gray-400">enabled here</strong>, your endpoint's own subscription still controls delivery (endpoint must also subscribe).</li>
            <li>• Changes take effect immediately for new events — in-flight deliveries are unaffected.</li>
          </ul>
        </div>
      </div>
    )}

  <script>
    function toast(msg: string, ok = true) {
      const t = document.createElement("div");
      t.className = `fixed bottom-4 right-4 px-4 py-3 rounded-lg text-white text-sm z-50 shadow-lg ${ok ? "bg-emerald-700" : "bg-red-700"}`;
      t.textContent = msg;
      document.body.appendChild(t);
      setTimeout(() => t.remove(), 4000);
    }
    function showFormErr(id: string, msg: string) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = msg;
      el.classList.remove("hidden");
    }
    function hideFormErr(id: string) {
      document.getElementById(id)?.classList.add("hidden");
    }

    // ─── Create endpoint form toggle ──────────────────────────────────────────
    const showBtn = document.getElementById("show-create-btn");
    const showEmptyBtn = document.getElementById("show-create-empty-btn");
    const cancelBtn = document.getElementById("cancel-create-btn");
    const createForm = document.getElementById("create-form");

    function showForm() { createForm?.classList.remove("hidden"); showBtn?.classList.add("hidden"); }
    function hideForm() { createForm?.classList.add("hidden"); showBtn?.classList.remove("hidden"); }

    showBtn?.addEventListener("click", showForm);
    showEmptyBtn?.addEventListener("click", showForm);
    cancelBtn?.addEventListener("click", hideForm);

    // ─── Create endpoint ──────────────────────────────────────────────────────
    document.getElementById("create-ep-btn")?.addEventListener("click", async () => {
      const url = (document.getElementById("ep-url") as HTMLInputElement)?.value?.trim();
      const description = (document.getElementById("ep-description") as HTMLInputElement)?.value?.trim() || null;
      const checked = Array.from(document.querySelectorAll<HTMLInputElement>(".event-cb:checked")).map(c => c.value);
      const events = checked.length > 0 ? checked : null;

      hideFormErr("create-ep-error");
      if (!url) { showFormErr("create-ep-error", "URL is required"); return; }

      const btn = document.getElementById("create-ep-btn") as HTMLButtonElement;
      btn.disabled = true; btn.textContent = "Creating…";

      try {
        const res = await fetch("/api/webhooks/endpoints", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ url, description, events }),
        });
        const data = await res.json();
        if (!res.ok) {
          showFormErr("create-ep-error", data.detail ?? "Failed to create endpoint");
          btn.disabled = false; btn.textContent = "Register endpoint";
          return;
        }

        // Show secret
        const secretBox = document.getElementById("secret-box");
        const secretVal = document.getElementById("secret-value");
        if (secretBox && secretVal && data.secret) {
          secretVal.textContent = data.secret;
          secretBox.classList.remove("hidden");
          secretBox.scrollIntoView({ behavior: "smooth", block: "nearest" });
        }

        btn.textContent = "✓ Created! Refresh to see it";
        btn.disabled = false;
      } catch {
        showFormErr("create-ep-error", "Network error — please try again");
        btn.disabled = false; btn.textContent = "Register endpoint";
      }
    });

    // ─── Copy secret ──────────────────────────────────────────────────────────
    document.getElementById("copy-secret-btn")?.addEventListener("click", () => {
      const val = (document.getElementById("secret-value") as HTMLElement)?.textContent ?? "";
      navigator.clipboard.writeText(val).then(() => {
        const btn = document.getElementById("copy-secret-btn") as HTMLElement;
        btn.textContent = "✓ Copied!";
      });
    });

    // ─── Test ping ────────────────────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>(".test-ep-btn").forEach(btn => {
      btn.addEventListener("click", async () => {
        const epId = btn.dataset.epId;
        const orig = btn.textContent;
        btn.disabled = true; btn.textContent = "Testing…";
        try {
          const res = await fetch(`/api/webhooks/endpoints/${epId}/test`, { method: "POST" });
          const data = await res.json();
          if (data.success) {
            btn.textContent = `✓ ${data.status_code} (${data.duration_ms}ms)`;
            btn.className = btn.className.replace("text-gray-400", "text-green-400").replace("border-gray-700", "border-green-700");
          } else {
            btn.textContent = `✗ ${data.error?.slice(0, 20) ?? "Error"}`;
            btn.className = btn.className.replace("text-gray-400", "text-red-400").replace("border-gray-700", "border-red-700");
          }
        } catch {
          btn.textContent = "✗ Network error";
        }
        setTimeout(() => { btn.disabled = false; btn.textContent = orig!; }, 3000);
      });
    });

    // ─── Toggle active ────────────────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>(".toggle-ep-btn").forEach(btn => {
      btn.addEventListener("click", async () => {
        const epId = btn.dataset.epId;
        const isActive = btn.dataset.active === "true";
        btn.disabled = true;
        try {
          const res = await fetch(`/api/webhooks/endpoints/${epId}`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ is_active: !isActive }),
          });
          if (res.ok) window.location.reload();
          else { const d = await res.json(); toast(d.detail ?? "Failed to toggle endpoint", false); btn.disabled = false; }
        } catch { toast("Network error — please try again", false); btn.disabled = false; }
      });
    });

    // ─── Rotate secret ────────────────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>(".rotate-secret-btn").forEach(btn => {
      btn.addEventListener("click", async () => {
        if (btn.dataset.pending !== "true") {
          btn.dataset.pending = "true";
          const orig = btn.textContent;
          btn.textContent = "Rotate?";
          btn.classList.add("text-yellow-400", "border-yellow-700");
          setTimeout(() => {
            if (btn.dataset.pending === "true") {
              btn.dataset.pending = ""; btn.textContent = orig;
              btn.classList.remove("text-yellow-400", "border-yellow-700");
            }
          }, 3000);
          return;
        }
        btn.dataset.pending = "";
        const epId = btn.dataset.epId;
        btn.disabled = true;
        try {
          const res = await fetch(`/api/webhooks/endpoints/${epId}/rotate-secret`, { method: "POST" });
          const data = await res.json();
          if (res.ok) {
            // Reveal new secret in the secret-box (same as creation flow)
            const secretBox = document.getElementById("secret-box");
            const secretVal = document.getElementById("secret-value");
            if (secretBox && secretVal) {
              secretVal.textContent = data.secret ?? "";
              secretBox.classList.remove("hidden");
              secretBox.scrollIntoView({ behavior: "smooth", block: "center" });
            }
          } else {
            toast(data.detail ?? "Failed to rotate signing secret", false);
          }
        } catch { toast("Network error — please try again", false); }
        btn.disabled = false;
      });
    });

    // ─── Delete endpoint ──────────────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>(".delete-ep-btn").forEach(btn => {
      btn.addEventListener("click", async () => {
        if (btn.dataset.pending !== "true") {
          btn.dataset.pending = "true";
          const orig = btn.textContent;
          btn.textContent = "Delete?";
          btn.classList.add("text-red-400", "border-red-700");
          setTimeout(() => {
            if (btn.dataset.pending === "true") {
              btn.dataset.pending = ""; btn.textContent = orig;
              btn.classList.remove("text-red-400", "border-red-700");
            }
          }, 3000);
          return;
        }
        btn.dataset.pending = "";
        const epId = btn.dataset.epId;
        btn.disabled = true;
        try {
          const res = await fetch(`/api/webhooks/endpoints/${epId}`, { method: "DELETE" });
          if (res.ok || res.status === 204) {
            btn.closest("[data-ep-id]")?.remove();
          } else {
            const d = await res.json();
            toast(d.detail ?? "Failed to delete endpoint", false);
            btn.disabled = false;
          }
        } catch { toast("Network error — please try again", false); btn.disabled = false; }
      });
    });

    // ─── Payload template form toggle ────────────────────────────────────────
    const showTplFormBtn = document.getElementById("show-template-form-btn");
    const cancelTplBtn = document.getElementById("cancel-template-btn");
    const tplForm = document.getElementById("template-form");

    showTplFormBtn?.addEventListener("click", () => tplForm?.classList.remove("hidden"));
    cancelTplBtn?.addEventListener("click", () => tplForm?.classList.add("hidden"));

    // Prefill form for edit
    document.querySelectorAll<HTMLButtonElement>(".edit-tpl-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        const eventType = btn.dataset.eventType ?? "";
        const description = btn.dataset.description ?? "";
        const template = btn.dataset.template ?? "";
        const sel = document.getElementById("tpl-event-type") as HTMLSelectElement;
        if (sel) sel.value = eventType;
        const descEl = document.getElementById("tpl-description") as HTMLInputElement;
        if (descEl) descEl.value = description;
        const tplEl = document.getElementById("tpl-template") as HTMLTextAreaElement;
        if (tplEl) tplEl.value = template;
        tplForm?.classList.remove("hidden");
        tplForm?.scrollIntoView({ behavior: "smooth" });
      });
    });

    // Save template
    document.getElementById("save-template-btn")?.addEventListener("click", async () => {
      const eventType = (document.getElementById("tpl-event-type") as HTMLSelectElement)?.value;
      const description = (document.getElementById("tpl-description") as HTMLInputElement)?.value?.trim() || null;
      const template = (document.getElementById("tpl-template") as HTMLTextAreaElement)?.value?.trim();

      hideFormErr("tpl-error");
      if (!eventType || !template) { showFormErr("tpl-error", "Event type and template body are required"); return; }

      const saveBtn = document.getElementById("save-template-btn") as HTMLButtonElement;
      saveBtn.disabled = true; saveBtn.textContent = "Saving…";

      try {
        const res = await fetch("/api/webhooks/payload-templates", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ event_type: eventType, template, description }),
        });
        if (res.ok || res.status === 201) {
          window.location.reload();
        } else {
          const data = await res.json().catch(() => ({}));
          showFormErr("tpl-error", data.detail ?? "Failed to save template");
        }
      } catch {
        showFormErr("tpl-error", "Network error — please try again");
      }
      saveBtn.disabled = false; saveBtn.textContent = "Save template";
    });

    // Delete template
    document.querySelectorAll<HTMLButtonElement>(".delete-tpl-btn").forEach(btn => {
      btn.addEventListener("click", async () => {
        const eventType = btn.dataset.eventType;
        if (btn.dataset.pending !== "true") {
          btn.dataset.pending = "true";
          const orig = btn.textContent;
          btn.textContent = "Delete?";
          btn.classList.add("text-red-400");
          setTimeout(() => {
            if (btn.dataset.pending === "true") { btn.dataset.pending = ""; btn.textContent = orig; btn.classList.remove("text-red-400"); }
          }, 3000);
          return;
        }
        btn.dataset.pending = "";
        btn.disabled = true;
        try {
          const res = await fetch(`/api/webhooks/payload-templates/${eventType}`, { method: "DELETE" });
          if (res.ok || res.status === 204) {
            btn.closest("[data-tpl-event]")?.remove();
          } else {
            const data = await res.json().catch(() => ({}));
            toast(data.detail ?? "Failed to delete template", false);
            btn.disabled = false;
          }
        } catch { toast("Network error — please try again", false); btn.disabled = false; }
      });
    });

    // ─── Retry webhook log ────────────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>(".retry-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const logId = btn.dataset.logId;
        if (!logId) return;
        const originalText = btn.textContent;
        btn.disabled = true; btn.textContent = "…";
        try {
          const res = await fetch(`/api/webhooks/${logId}/retry`, { method: "POST" });
          const data = await res.json();
          if (res.ok) {
            if (data.success) {
              btn.textContent = "✓ OK";
              btn.classList.remove("border-gray-700", "text-gray-400");
              btn.classList.add("border-green-700", "text-green-400");
            } else {
              btn.textContent = "✗ Fail";
              btn.classList.remove("border-gray-700", "text-gray-400");
              btn.classList.add("border-red-700", "text-red-400");
            }
          } else {
            btn.textContent = originalText ?? "↻ Retry";
            btn.disabled = false;
            toast(data.detail ?? "Retry failed", false);
          }
        } catch {
          btn.disabled = false;
          btn.textContent = originalText ?? "↻ Retry";
          toast("Network error — please try again", false);
        }
      });
    });

    // ─── Replay webhook event ─────────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>(".replay-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const logId = btn.dataset.logId;
        if (!logId) return;
        const originalText = btn.textContent;
        btn.disabled = true; btn.textContent = "…";
        try {
          const res = await fetch(`/api/webhooks/${logId}/replay`, { method: "POST" });
          const data = await res.json();
          if (res.ok) {
            const succeeded = data.endpoints_succeeded ?? 0;
            const total = data.endpoints_targeted ?? 0;
            if (succeeded === total && total > 0) {
              btn.textContent = `✓ ${total} sent`;
              btn.classList.remove("border-gray-700", "text-indigo-400");
              btn.classList.add("border-green-700", "text-green-400");
            } else if (total === 0) {
              btn.textContent = "No endpoints";
              btn.classList.remove("border-gray-700");
              btn.classList.add("border-yellow-700", "text-yellow-400");
            } else {
              btn.textContent = `${succeeded}/${total} ok`;
              btn.classList.remove("border-gray-700");
              btn.classList.add("border-yellow-700", "text-yellow-400");
            }
          } else {
            btn.textContent = originalText ?? "▶ Replay";
            btn.disabled = false;
            toast(data.detail ?? "Replay failed", false);
          }
        } catch {
          btn.disabled = false;
          btn.textContent = originalText ?? "▶ Replay";
          toast("Network error — please try again", false);
        }
      });
    });
  </script>

  <script>
    // ─── Webhook Event Preferences (preferences tab) ────────────────────────
    const prefsForm = document.getElementById("webhook-prefs-form");
    if (prefsForm) {
      const saveMsgEl = document.getElementById("prefs-save-msg");

      // Toggle switch handlers — update state visually
      prefsForm.querySelectorAll<HTMLInputElement>(".pref-toggle").forEach(toggle => {
        toggle.addEventListener("change", () => {
          const row = toggle.closest(".pref-row");
          const badge = row?.querySelector(".pref-status-badge");
          if (badge) {
            badge.textContent = toggle.checked ? "Enabled" : "Disabled";
            badge.className = "pref-status-badge text-xs px-2 py-0.5 rounded-full " +
              (toggle.checked ? "bg-green-950 text-green-400" : "bg-gray-800 text-gray-500");
          }
        });
      });

      prefsForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const saveBtn = prefsForm.querySelector<HTMLButtonElement>("#save-prefs-btn");
        if (saveBtn) { saveBtn.disabled = true; saveBtn.textContent = "Saving…"; }

        const prefs: Record<string, boolean> = {};
        prefsForm.querySelectorAll<HTMLInputElement>(".pref-toggle").forEach(toggle => {
          prefs[toggle.dataset.event ?? ""] = toggle.checked;
        });

        try {
          const res = await fetch("/api/webhooks/preferences", {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ prefs }),
          });
          if (res.ok) {
            if (saveMsgEl) {
              saveMsgEl.textContent = "✓ Preferences saved";
              saveMsgEl.className = "text-sm text-green-400";
              setTimeout(() => { if (saveMsgEl) saveMsgEl.textContent = ""; }, 3000);
            }
          } else {
            if (saveMsgEl) {
              saveMsgEl.textContent = "Failed to save preferences";
              saveMsgEl.className = "text-sm text-red-400";
            }
          }
        } catch {
          if (saveMsgEl) {
            saveMsgEl.textContent = "Network error";
            saveMsgEl.className = "text-sm text-red-400";
          }
        } finally {
          if (saveBtn) { saveBtn.disabled = false; saveBtn.textContent = "Save Preferences"; }
        }
      });
    }
  </script>
</Layout>
