---
import Layout from "@/layouts/Layout.astro";

const HUMAN_TASK_TYPES = [
  { type: "label_image",        label: "Image Labeling",         example: "Bounding boxes, segmentation, classification" },
  { type: "label_text",         label: "Text Labeling",          example: "Sentiment, intent, named entities, toxicity" },
  { type: "rate_quality",       label: "Quality Rating",         example: "1–5 star ratings with rubrics" },
  { type: "verify_fact",        label: "Fact Verification",      example: "True / False / Unverifiable with sources" },
  { type: "moderate_content",   label: "Content Moderation",     example: "Policy compliance, NSFW, spam detection" },
  { type: "compare_rank",       label: "Comparative Ranking",    example: "A/B preference, best-of-N selection" },
  { type: "answer_question",    label: "Question Answering",     example: "Domain-specific Q&A, trivia, research" },
  { type: "transcription_review","label": "Transcription Review","example": "Review and correct AI-generated transcripts" },
];

const PLANS = [
  {
    id: "starter",
    name: "Starter",
    price: 10,
    credits: 1_000,
    tagline: "For developers and side projects.",
    features: [
      "1,000 credits",
      "100 tasks / day",
      "10 pipelines total",
      "20 pipeline runs / day",
      "5 workers per human task",
      "Email support",
    ],
    cta: "Buy Starter",
    ctaHref: "/register?plan=starter",
    highlight: false,
  },
  {
    id: "pro",
    name: "Pro",
    price: 90,
    credits: 10_000,
    tagline: "10% volume discount. For growing teams.",
    badge: "Most popular",
    features: [
      "10,000 credits",
      "500 tasks / day",
      "Unlimited pipelines",
      "100 pipeline runs / day",
      "20 workers per human task",
      "Priority support",
    ],
    cta: "Buy Pro",
    ctaHref: "/register?plan=pro",
    highlight: true,
  },
  {
    id: "enterprise",
    name: "Enterprise",
    price: null,
    credits: null,
    tagline: "Custom volume, SLAs, and integrations.",
    features: [
      "Unlimited tasks & pipelines",
      "Custom credit pricing",
      "100 workers per human task",
      "Dedicated support",
      "Custom SLA agreements",
      "SSO / SAML",
    ],
    cta: "Contact us",
    ctaHref: "mailto:crowdsource@rebaselabs.online?subject=Enterprise%20inquiry",
    highlight: false,
  },
];

const COMPARISON_ROWS = [
  { feature: "Credits included",         starter: "1,000",    pro: "10,000",      enterprise: "Custom" },
  { feature: "Tasks / day",              starter: "100",      pro: "500",         enterprise: "Unlimited" },
  { feature: "Pipelines (total)",        starter: "10",       pro: "Unlimited",   enterprise: "Unlimited" },
  { feature: "Pipeline runs / day",      starter: "20",       pro: "100",         enterprise: "Unlimited" },
  { feature: "Batch task size",          starter: "25",       pro: "50",          enterprise: "50" },
  { feature: "Workers per human task",   starter: "5",        pro: "20",          enterprise: "100" },
  { feature: "API key scopes",           starter: "✓",        pro: "✓",           enterprise: "✓" },
  { feature: "Webhooks",                 starter: "✓",        pro: "✓",           enterprise: "✓" },
  { feature: "Org / team sharing",       starter: "✓",        pro: "✓",           enterprise: "✓" },
  { feature: "A/B experiments",          starter: "✓",        pro: "✓",           enterprise: "✓" },
  { feature: "Priority routing",         starter: "✓",        pro: "✓",           enterprise: "✓" },
  { feature: "SLA guarantees",           starter: "24 h",     pro: "8 h",         enterprise: "Custom" },
  { feature: "Dedicated support",        starter: "—",        pro: "—",           enterprise: "✓" },
  { feature: "SSO / SAML",               starter: "—",        pro: "—",           enterprise: "✓" },
];

const FAQ = [
  {
    q: "Do credits expire?",
    a: "No. Credits you purchase never expire.",
  },
  {
    q: "What happens if a task fails?",
    a: "Credits are refunded automatically for failed tasks, including timeouts where no worker claims the task inside the window you set. You're only charged for successful completions.",
  },
  {
    q: "How are rewards priced?",
    a: "You set the reward per worker (minimum 5 credits). Workers earn exactly that — we don't mark it up. The platform fee is folded into the credit cost separately.",
  },
  {
    q: "Can I get multiple workers on the same task?",
    a: "Yes. Set assignments_required (up to 20 on Pro) to get N independent submissions, then use a consensus strategy: any_first, majority_vote, unanimous, or requester_review.",
  },
  {
    q: "Can I chain AI steps with human steps?",
    a: "Yes — through pipelines. A pipeline can post a human task, then run an LLM summary on the result, then post another human task for QA. All on the same balance and audit trail. See /docs for pipeline shapes.",
  },
  {
    q: "What if I need more than 10,000 credits?",
    a: "Buy multiple Pro packs or contact us for a volume discount. Enterprise contracts start at $500/month for custom pricing.",
  },
  {
    q: "Is there a rate limit on API calls?",
    a: "There's a global 200 requests/minute per IP and stricter limits on auth endpoints. Per-API-key custom limits are available on Starter and above.",
  },
  {
    q: "Do you offer a sandbox / test environment?",
    a: "Yes — the API Sandbox at /docs/sandbox lets you submit real tasks with a real API key so you can see the full flow before building your integration.",
  },
];
---

<Layout title="Pricing — CrowdSorcerer">

  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-12 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold mb-4">
      Simple, transparent pricing
    </h1>
    <p class="text-xl text-gray-400 max-w-xl mx-auto mb-6">
      Credits never expire. Pay as you go — no monthly subscription.
      Set the reward you pay workers, pay a small platform fee, you're done.
    </p>
    <p class="text-sm text-gray-500">$1 = 100 credits &nbsp;·&nbsp; Min reward 5¢ per worker &nbsp;·&nbsp; Credits refunded on failed tasks</p>
  </section>

  <!-- Plan cards -->
  <section class="max-w-6xl mx-auto px-6 pb-20">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {PLANS.map((plan) => (
        <div class:list={[
          "rounded-2xl border p-6 flex flex-col relative",
          plan.highlight
            ? "bg-gradient-to-b from-violet-950/60 to-gray-900 border-violet-600 shadow-lg shadow-violet-900/20"
            : "bg-gray-900 border-gray-800"
        ]}>
          {plan.badge && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="bg-violet-600 text-white text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full whitespace-nowrap">
                {plan.badge}
              </span>
            </div>
          )}

          <div class="mb-4">
            <div class:list={["text-sm font-semibold mb-1", plan.highlight ? "text-violet-300" : "text-gray-400"]}>
              {plan.name}
            </div>
            {plan.price === null ? (
              <div class="text-3xl font-bold">Custom</div>
            ) : plan.price === 0 ? (
              <div class="text-3xl font-bold">Free</div>
            ) : (
              <div class="text-3xl font-bold">${plan.price}</div>
            )}
            {plan.credits !== null && (
              <div class:list={["text-sm font-medium mt-0.5", plan.highlight ? "text-violet-400" : "text-gray-500"]}>
                {plan.credits.toLocaleString()} credits
              </div>
            )}
            <p class="text-xs text-gray-500 mt-2">{plan.tagline}</p>
          </div>

          <ul class="space-y-2 mb-6 flex-1">
            {plan.features.map((f) => (
              <li class="flex items-start gap-2 text-sm text-gray-400">
                <span class:list={["mt-0.5 flex-shrink-0", plan.highlight ? "text-violet-400" : "text-emerald-500"]}>✓</span>
                {f}
              </li>
            ))}
          </ul>

          <a
            href={plan.ctaHref}
            class:list={[
              "block text-center py-2.5 rounded-xl text-sm font-semibold transition-colors",
              plan.highlight
                ? "bg-violet-600 hover:bg-violet-500 text-white"
                : plan.id === "enterprise"
                  ? "bg-gray-800 hover:bg-gray-700 text-gray-200 border border-gray-700"
                  : "border border-gray-700 hover:border-gray-500 text-gray-300"
            ]}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Plan comparison table -->
  <section class="max-w-6xl mx-auto px-6 pb-20">
    <h2 class="text-2xl font-bold mb-6 text-center">Compare plans</h2>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full min-w-[640px] text-sm">
          <thead>
            <tr class="border-b border-gray-800">
              <th class="text-left px-5 py-4 text-gray-400 font-medium w-2/5">Feature</th>
              {PLANS.map((p) => (
                <th class:list={[
                  "text-center px-4 py-4 font-semibold w-[15%]",
                  p.highlight ? "text-violet-300" : "text-gray-300"
                ]}>
                  {p.name}
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {COMPARISON_ROWS.map((row, i) => (
              <tr class:list={["border-b border-gray-800/50", i % 2 !== 0 ? "bg-gray-800/20" : ""]}>
                <td class="px-5 py-3 text-gray-400">{row.feature}</td>
                {([row.starter, row.pro, row.enterprise] as string[]).map((val, pi) => (
                  <td class:list={[
                    "px-4 py-3 text-center",
                    val === "—" ? "text-gray-700" : PLANS[pi].highlight ? "text-violet-300 font-medium" : "text-gray-300",
                  ]}>
                    {val}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Task pricing -->
  <section class="max-w-3xl mx-auto px-6 pb-20">
    <div>
      <!-- Human tasks -->
      <div>
        <h2 class="text-xl font-bold mb-2">👥 Task pricing</h2>
        <p class="text-sm text-gray-400 mb-5">
          You set the reward per task. Workers earn exactly what you set — no markup.
          Minimum reward: <span class="text-gray-300 font-medium">5 credits (5¢)</span>.
        </p>

        <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-5">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-800">
                <th class="text-left px-4 py-3 text-gray-500 font-medium">Task type</th>
                <th class="text-left px-4 py-3 text-gray-500 font-medium">Typical use</th>
              </tr>
            </thead>
            <tbody>
              {HUMAN_TASK_TYPES.map((t, i) => (
                <tr class:list={["border-b border-gray-800/40", i % 2 !== 0 ? "bg-gray-800/20" : ""]}>
                  <td class="px-4 py-2.5">
                    <div class="text-gray-200 text-sm">{t.label}</div>
                    <div class="font-mono text-gray-500 text-[11px]">{t.type}</div>
                  </td>
                  <td class="px-4 py-2.5 text-gray-500 text-xs">{t.example}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- How human task billing works -->
        <div class="bg-violet-950/30 border border-violet-800/40 rounded-xl p-4 text-sm">
          <div class="font-semibold text-violet-300 mb-2">How it works</div>
          <ol class="space-y-1.5 text-gray-400 list-decimal list-inside">
            <li>Set your <strong class="text-gray-300">reward per worker</strong> (e.g. 10 credits)</li>
            <li>Set <strong class="text-gray-300">number of workers</strong> (e.g. 3 for majority vote)</li>
            <li>Credits are reserved (3 × 10 = 30 credits)</li>
            <li>Workers complete the task and earn the reward</li>
            <li>Unused slots are refunded if task closes early</li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- What $10 gets you -->
  <section class="max-w-6xl mx-auto px-6 pb-20">
    <div class="bg-gradient-to-r from-violet-950/40 via-gray-900 to-indigo-950/40 border border-violet-800/30 rounded-2xl p-8 md:p-10">
      <h3 class="text-center text-sm text-gray-500 uppercase tracking-widest mb-6">What $10 gets you</h3>
      <div class="grid md:grid-cols-4 gap-6 text-center">
        {[
          { value: "~330 labels", desc: "at 3¢ per assignment", icon: "🏷️" },
          { value: "~100 QA reviews", desc: "at 10¢ per assignment", icon: "⭐" },
          { value: "~50 moderations", desc: "3 workers × ~7¢ each", icon: "🛡️" },
          { value: "Any mix", desc: "credits cover every task type", icon: "🔮" },
        ].map(({ value, desc, icon }) => (
          <div>
            <div class="text-3xl mb-2">{icon}</div>
            <div class="font-bold text-gray-200 text-lg">{value}</div>
            <div class="text-sm text-gray-500">{desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-3xl mx-auto px-6 pb-20">
    <h2 class="text-2xl font-bold text-center mb-10">Frequently asked questions</h2>
    <div class="space-y-0 border border-gray-800 rounded-2xl overflow-hidden">
      {FAQ.map((item, i) => (
        <details class:list={["group", i !== 0 ? "border-t border-gray-800" : ""]}>
          <summary class="flex items-center justify-between gap-4 px-6 py-4 cursor-pointer list-none hover:bg-gray-800/30 transition-colors">
            <span class="font-medium text-gray-200 text-sm">{item.q}</span>
            <span class="text-gray-500 flex-shrink-0 group-open:rotate-45 transition-transform text-lg leading-none">+</span>
          </summary>
          <div class="px-6 pb-4 text-sm text-gray-400 leading-relaxed">{item.a}</div>
        </details>
      ))}
    </div>
  </section>

  <!-- Enterprise section -->
  <section class="max-w-4xl mx-auto px-6 pb-20">
    <div class="grid md:grid-cols-2 gap-8 bg-gray-900 border border-gray-800 rounded-2xl p-8 md:p-10 items-center">
      <div>
        <div class="text-xs font-bold uppercase tracking-widest text-violet-400 mb-3">Enterprise</div>
        <h2 class="text-2xl font-bold mb-3">Need more scale?</h2>
        <p class="text-gray-400 text-sm mb-5">
          Enterprise plans include custom credit pricing, dedicated infrastructure,
          SLA agreements, SSO, and white-glove onboarding. Starting at $500/month.
        </p>
        <ul class="space-y-2 text-sm text-gray-400 mb-6">
          {[
            "Unlimited tasks and pipeline runs",
            "Custom SLA with response time guarantees",
            "Up to 100 workers per human task",
            "SSO / SAML integration",
            "Dedicated Slack / Teams support channel",
            "Custom webhook payload templates",
            "Volume discounts over 100K credits/month",
          ].map((f) => (
            <li class="flex items-center gap-2">
              <span class="text-emerald-500">✓</span> {f}
            </li>
          ))}
        </ul>
        <a
          href="mailto:crowdsource@rebaselabs.online?subject=Enterprise%20inquiry"
          class="inline-block px-6 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-200 rounded-xl text-sm font-medium border border-gray-700 hover:border-gray-500 transition-colors"
        >
          Contact sales →
        </a>
      </div>
      <div class="text-center">
        <div class="text-7xl mb-4">🏢</div>
        <div class="text-gray-500 text-sm">
          Email <a href="mailto:crowdsource@rebaselabs.online" class="text-violet-400 hover:text-violet-300">crowdsource@rebaselabs.online</a><br />
          with your use case and volume estimates.<br />
          Typical response within 24 hours.
        </div>
      </div>
    </div>
  </section>

  <!-- Crypto payment -->
  <section class="max-w-4xl mx-auto px-6 pb-20">
    <div class="bg-gray-900/50 border border-gray-800 rounded-2xl p-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-2xl">💎</span>
        <div>
          <h3 class="font-semibold">Pay with crypto</h3>
          <p class="text-sm text-gray-500">Send to any of the wallets below — we'll credit your account manually within 24 hours.</p>
        </div>
      </div>
      <div class="grid sm:grid-cols-3 gap-4 text-xs font-mono">
        <div class="bg-gray-800/50 rounded-lg p-3">
          <div class="text-gray-500 mb-1">Bitcoin (BTC)</div>
          <div class="text-gray-300 break-all">bc1qvzvwjcvpcztwcuv5ef42frzlq2xn46g7usxfcm</div>
        </div>
        <div class="bg-gray-800/50 rounded-lg p-3">
          <div class="text-gray-500 mb-1">Solana (SOL)</div>
          <div class="text-gray-300 break-all">8tGVz7wUr89bVQVR4MbiUQPfnEHeGPzSgjWqjorsZ91o</div>
        </div>
        <div class="bg-gray-800/50 rounded-lg p-3">
          <div class="text-gray-500 mb-1">EVM (ETH / Base / USDC)</div>
          <div class="text-gray-300 break-all">0x16F086e2292eA895B0eC3a4DeBb255e3d6fD9E01</div>
        </div>
      </div>
      <p class="text-xs text-gray-500 mt-3">
        After sending, email <a href="mailto:crowdsource@rebaselabs.online" class="text-violet-400">crowdsource@rebaselabs.online</a> with your transaction hash and account email.
      </p>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="max-w-4xl mx-auto px-6 pb-24 text-center">
    <h2 class="text-3xl font-bold mb-4">Ready to build?</h2>
    <p class="text-gray-400 mb-8">We're onboarding beta users one at a time. Tell us what you want to build and we'll get you a key.</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="mailto:crowdsource@rebaselabs.online?subject=CrowdSorcerer%20early%20access" class="px-8 py-3 bg-violet-600 hover:bg-violet-500 text-white font-semibold rounded-xl transition-colors">
        Request early access
      </a>
      <a href="/docs" class="px-8 py-3 border border-gray-700 hover:border-gray-500 text-gray-300 font-semibold rounded-xl transition-colors">
        Read the docs
      </a>
    </div>
  </section>

</Layout>
