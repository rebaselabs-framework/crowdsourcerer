---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Web Research at Scale — CrowdSorcerer Use Cases"
  description="Automate competitor analysis, market research, price monitoring, and news aggregation with CrowdSorcerer's AI web research workers. From 5¢ per page."
  ogType="article"
>
  <div class="max-w-4xl mx-auto px-6 py-20">
    <!-- Breadcrumb -->
    <div class="text-sm text-gray-500 mb-10">
      <a href="/" class="hover:text-gray-300 transition-colors">Home</a>
      <span class="mx-2">›</span>
      <a href="/use-cases" class="hover:text-gray-300 transition-colors">Use Cases</a>
      <span class="mx-2">›</span>
      <span>Web Research</span>
    </div>

    <!-- Hero -->
    <div class="mb-12">
      <div class="text-5xl mb-6">🌐</div>
      <h1 class="text-4xl font-bold mb-4">Web Research at Scale</h1>
      <p class="text-xl text-gray-400 leading-relaxed max-w-2xl">
        Stop spending hours manually browsing the web. CrowdSorcerer's <code class="text-violet-300 bg-violet-950/50 px-1.5 py-0.5 rounded text-sm">web_research</code> and
        <code class="text-violet-300 bg-violet-950/50 px-1.5 py-0.5 rounded text-sm">web_intel</code> task types
        let you submit URLs or queries and get back structured summaries, extracted facts, and key insights — automatically.
      </p>
    </div>

    <!-- Use cases grid -->
    <div class="grid sm:grid-cols-2 gap-6 mb-14">
      {[
        { icon: "📈", title: "Competitor Analysis", desc: "Monitor competitor pricing, features, blog posts, and announcements in real-time." },
        { icon: "📰", title: "News Aggregation", desc: "Pull and summarize relevant industry news across hundreds of sources daily." },
        { icon: "💰", title: "Price Monitoring", desc: "Track product prices across e-commerce sites and trigger alerts on changes." },
        { icon: "🏭", title: "Market Intelligence", desc: "Research industry players, funding rounds, executive changes, and market trends." },
        { icon: "👥", title: "Lead Research", desc: "Enrich lead lists with company info, tech stack, recent news, and social presence." },
        { icon: "🔍", title: "SEO Auditing", desc: "Batch-crawl pages for title tags, meta descriptions, structured data, and performance signals." },
      ].map(({ icon, title, desc }) => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-2xl mb-2">{icon}</div>
          <h3 class="font-semibold mb-1">{title}</h3>
          <p class="text-gray-400 text-sm">{desc}</p>
        </div>
      ))}
    </div>

    <!-- Code example -->
    <div class="mb-14">
      <h2 class="text-2xl font-bold mb-4">API Example</h2>
      <p class="text-gray-400 mb-4">Submit a web research task in seconds:</p>
      <pre class="bg-gray-900 border border-gray-800 rounded-xl p-5 overflow-x-auto text-sm font-mono text-gray-300"><code>{`curl -X POST https://api.crowdsorcerer.dev/v1/tasks \\
  -H "Authorization: Bearer YOUR_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "type": "web_research",
    "input": {
      "url": "https://competitor.com/pricing",
      "query": "Extract all pricing plans, features, and costs"
    },
    "priority": "normal"
  }'

# Response:
{
  "id": "task_abc123",
  "status": "queued",
  "estimated_credits": 5
}`}</code></pre>
    </div>

    <!-- Pricing -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 mb-14">
      <h2 class="text-xl font-bold mb-4">Pricing</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {[
          { task: "web_research", credits: 5, usd: "$0.05", desc: "Single URL + query" },
          { task: "web_intel", credits: 10, usd: "$0.10", desc: "Deep analysis + structured report" },
          { task: "Bulk (100+)", credits: 4, usd: "$0.04", desc: "Pro plan volume discount" },
        ].map(({ task, credits, usd, desc }) => (
          <div class="bg-gray-800/50 rounded-lg p-4 text-center">
            <div class="font-mono text-violet-300 text-sm mb-1">{task}</div>
            <div class="text-2xl font-bold text-emerald-400">{usd}</div>
            <div class="text-xs text-gray-500 mt-1">{credits} credits · {desc}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center">
      <h2 class="text-2xl font-bold mb-3">Start researching the web at scale</h2>
      <p class="text-gray-400 mb-6">500 free credits on signup. No credit card required.</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/register" class="px-6 py-3 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold transition-colors">
          Get started free →
        </a>
        <a href="/docs/api-reference" class="px-6 py-3 rounded-xl border border-gray-700 hover:border-gray-500 text-gray-300 transition-colors">
          API Reference
        </a>
      </div>
    </div>
  </div>
</Layout>
