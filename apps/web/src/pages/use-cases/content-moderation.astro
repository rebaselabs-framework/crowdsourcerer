---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Content Moderation at Scale — CrowdSorcerer Use Cases"
  description="Keep your platform safe with AI + human review of user-generated content, images, and profiles. CrowdSorcerer's moderate_content task type scales with your growth. From 2¢/item."
  ogType="article"
>
  <div class="max-w-4xl mx-auto px-6 py-20">
    <div class="text-sm text-gray-500 mb-10">
      <a href="/" class="hover:text-gray-300 transition-colors">Home</a>
      <span class="mx-2">›</span>
      <a href="/use-cases" class="hover:text-gray-300 transition-colors">Use Cases</a>
      <span class="mx-2">›</span>
      <span>Content Moderation</span>
    </div>

    <div class="mb-12">
      <div class="text-5xl mb-6">🛡️</div>
      <h1 class="text-4xl font-bold mb-4">Content Moderation at Scale</h1>
      <p class="text-xl text-gray-400 leading-relaxed max-w-2xl">
        Protect your community without building a full moderation team. The
        <code class="text-violet-300 bg-violet-950/50 px-1.5 py-0.5 rounded text-sm">moderate_content</code> and
        <code class="text-violet-300 bg-violet-950/50 px-1.5 py-0.5 rounded text-sm">pii_detect</code> task types
        review text, images, profiles, and files — flagging violations with confidence scores and explanations.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6 mb-14">
      {[
        { icon: "💬", title: "Text Moderation", desc: "Detect hate speech, harassment, spam, misinformation, and policy violations in posts and comments." },
        { icon: "🖼️", title: "Image Review", desc: "Flag NSFW content, violence, fake documents, and copyright violations in uploads." },
        { icon: "👤", title: "Profile Verification", desc: "Review user profiles for fake identities, impersonation, and fraudulent listings." },
        { icon: "🔒", title: "PII Detection", desc: "Find and redact social security numbers, credit cards, passports, and personal data from documents." },
        { icon: "⚖️", title: "Policy Enforcement", desc: "Apply custom content policies with AI + human escalation for borderline cases." },
        { icon: "📊", title: "Moderation Analytics", desc: "Track violation trends, category breakdowns, and false-positive rates over time." },
      ].map(({ icon, title, desc }) => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-2xl mb-2">{icon}</div>
          <h3 class="font-semibold mb-1">{title}</h3>
          <p class="text-gray-400 text-sm">{desc}</p>
        </div>
      ))}
    </div>

    <div class="mb-14">
      <h2 class="text-2xl font-bold mb-4">API Example</h2>
      <pre class="bg-gray-900 border border-gray-800 rounded-xl p-5 overflow-x-auto text-sm font-mono text-gray-300"><code>{`curl -X POST https://api.crowdsorcerer.dev/v1/tasks \\
  -H "Authorization: Bearer YOUR_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "type": "moderate_content",
    "input": {
      "content": "User-generated text or image URL here...",
      "content_type": "text",
      "policies": ["hate_speech", "harassment", "spam", "adult"],
      "threshold": 0.7
    }
  }'

# Response output:
{
  "verdict": "flag",
  "confidence": 0.92,
  "violations": [
    { "policy": "harassment", "confidence": 0.92, "excerpt": "..." }
  ],
  "recommended_action": "remove"
}`}</code></pre>
    </div>

    <div class="bg-amber-950/20 border border-amber-800/40 rounded-xl p-6 mb-14">
      <h2 class="text-lg font-semibold text-amber-300 mb-2">🤝 Human-in-the-loop</h2>
      <p class="text-gray-400 text-sm">
        Set a confidence threshold. Items below it are automatically routed to our
        18-type worker network for human review — with full audit trails, appeals workflow,
        and mediator escalation for disputes.
      </p>
    </div>

    <div class="text-center">
      <h2 class="text-2xl font-bold mb-3">Scale your moderation safely</h2>
      <p class="text-gray-400 mb-6">500 free credits on signup. No credit card required.</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/register" class="px-6 py-3 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold transition-colors">
          Get started free →
        </a>
        <a href="/docs/api-reference" class="px-6 py-3 rounded-xl border border-gray-700 hover:border-gray-500 text-gray-300 transition-colors">
          API Reference
        </a>
      </div>
    </div>
  </div>
</Layout>
