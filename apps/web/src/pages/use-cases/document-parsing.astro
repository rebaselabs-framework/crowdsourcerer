---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Document Parsing & Data Extraction — CrowdSorcerer Use Cases"
  description="Extract structured data from PDFs, invoices, contracts, and scanned documents at scale. CrowdSorcerer's document_parse task type handles any format. From 3¢/doc."
  ogType="article"
>
  <div class="max-w-4xl mx-auto px-6 py-20">
    <!-- Breadcrumb -->
    <div class="text-sm text-gray-500 mb-10">
      <a href="/" class="hover:text-gray-300 transition-colors">Home</a>
      <span class="mx-2">›</span>
      <a href="/use-cases" class="hover:text-gray-300 transition-colors">Use Cases</a>
      <span class="mx-2">›</span>
      <span>Document Parsing</span>
    </div>

    <!-- Hero -->
    <div class="mb-12">
      <div class="text-5xl mb-6">📄</div>
      <h1 class="text-4xl font-bold mb-4">Document Parsing & Extraction</h1>
      <p class="text-xl text-gray-400 leading-relaxed max-w-2xl">
        Transform unstructured documents into clean, structured data. The
        <code class="text-violet-300 bg-violet-950/50 px-1.5 py-0.5 rounded text-sm">document_parse</code> task type
        handles PDFs, Word docs, scanned images, invoices, contracts, and more — returning JSON-structured results.
      </p>
    </div>

    <!-- Use cases grid -->
    <div class="grid sm:grid-cols-2 gap-6 mb-14">
      {[
        { icon: "🧾", title: "Invoice Processing", desc: "Extract vendor, line items, totals, due dates, and payment terms from any invoice format." },
        { icon: "📑", title: "Contract Analysis", desc: "Pull out parties, key clauses, obligations, dates, and termination terms automatically." },
        { icon: "🏥", title: "Medical Records", desc: "Parse clinical notes, lab results, and patient data while preserving structure." },
        { icon: "🏦", title: "Financial Statements", desc: "Extract balance sheet line items, P&L data, and footnotes from SEC filings." },
        { icon: "📋", title: "Forms & Applications", desc: "Process job applications, insurance forms, and government documents at scale." },
        { icon: "📚", title: "Research Papers", desc: "Extract abstracts, citations, tables, and key findings from academic literature." },
      ].map(({ icon, title, desc }) => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-2xl mb-2">{icon}</div>
          <h3 class="font-semibold mb-1">{title}</h3>
          <p class="text-gray-400 text-sm">{desc}</p>
        </div>
      ))}
    </div>

    <!-- Code example -->
    <div class="mb-14">
      <h2 class="text-2xl font-bold mb-4">API Example</h2>
      <p class="text-gray-400 mb-4">Parse an invoice from a URL or base64-encoded content:</p>
      <pre class="bg-gray-900 border border-gray-800 rounded-xl p-5 overflow-x-auto text-sm font-mono text-gray-300"><code>{`curl -X POST https://crowdsourcerer.rebaselabs.online/v1/tasks \\
  -H "Authorization: Bearer YOUR_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "type": "document_parse",
    "input": {
      "url": "https://example.com/invoice-2024-01.pdf",
      "extract": ["vendor_name", "invoice_number", "total_amount",
                  "line_items", "due_date", "payment_terms"]
    }
  }'

# Response output:
{
  "vendor_name": "Acme Corp",
  "invoice_number": "INV-2024-0042",
  "total_amount": 4850.00,
  "due_date": "2024-02-15",
  "line_items": [
    { "description": "Software License", "qty": 1, "unit_price": 4500.00 },
    { "description": "Support", "qty": 1, "unit_price": 350.00 }
  ]
}`}</code></pre>
    </div>

    <!-- Supported formats -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 mb-14">
      <h2 class="text-xl font-bold mb-4">Supported Formats</h2>
      <div class="flex flex-wrap gap-2">
        {["PDF", "DOCX", "XLSX", "PNG/JPG (OCR)", "HTML", "CSV", "TXT", "RTF", "PPTX", "Scanned docs"].map(f => (
          <span class="px-3 py-1.5 bg-gray-800 rounded-lg text-sm text-gray-300 font-medium">{f}</span>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center">
      <h2 class="text-2xl font-bold mb-3">Automate your document workflow</h2>
      <p class="text-gray-400 mb-6">500 free credits on signup. No credit card required.</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/register" class="px-6 py-3 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold transition-colors">
          Get started free →
        </a>
        <a href="/docs/api-reference" class="px-6 py-3 rounded-xl border border-gray-700 hover:border-gray-500 text-gray-300 transition-colors">
          API Reference
        </a>
      </div>
    </div>
  </div>
</Layout>
