---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Data Transformation & Normalization — CrowdSorcerer Use Cases"
  description="Normalize, clean, and transform messy datasets at scale. CrowdSorcerer's data_transform task converts between formats, merges fields, and standardizes records. From 1¢/record."
  ogType="article"
>
  <div class="max-w-4xl mx-auto px-6 py-20">
    <div class="text-sm text-gray-500 mb-10">
      <a href="/" class="hover:text-gray-300 transition-colors">Home</a>
      <span class="mx-2">›</span>
      <a href="/use-cases" class="hover:text-gray-300 transition-colors">Use Cases</a>
      <span class="mx-2">›</span>
      <span>Data Transformation</span>
    </div>

    <div class="mb-12">
      <div class="text-5xl mb-6">🔄</div>
      <h1 class="text-4xl font-bold mb-4">Data Transformation & Normalization</h1>
      <p class="text-xl text-gray-400 leading-relaxed max-w-2xl">
        Clean, reshape, and standardize data without writing custom ETL pipelines. The
        <code class="text-violet-300 bg-violet-950/50 px-1.5 py-0.5 rounded text-sm">data_transform</code> task type
        handles format conversion, field mapping, deduplication, and normalization at any scale.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6 mb-14">
      {[
        { icon: "🔀", title: "Format Conversion", desc: "Convert CSV → JSON, XML → CSV, YAML → JSON, or any custom schema mapping." },
        { icon: "🧹", title: "Data Cleaning", desc: "Fix typos, standardize date formats, normalize phone numbers and addresses." },
        { icon: "🔗", title: "Schema Mapping", desc: "Map fields between different data models or API schemas automatically." },
        { icon: "📊", title: "Aggregation", desc: "Group, sum, average, and pivot data across thousands of records in one task." },
        { icon: "🏷️", title: "Tagging & Classification", desc: "Auto-tag and categorize records based on content, rules, or ML classifiers." },
        { icon: "🔍", title: "Deduplication", desc: "Identify and remove duplicate records using fuzzy matching across datasets." },
      ].map(({ icon, title, desc }) => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-2xl mb-2">{icon}</div>
          <h3 class="font-semibold mb-1">{title}</h3>
          <p class="text-gray-400 text-sm">{desc}</p>
        </div>
      ))}
    </div>

    <div class="mb-14">
      <h2 class="text-2xl font-bold mb-4">API Example</h2>
      <pre class="bg-gray-900 border border-gray-800 rounded-xl p-5 overflow-x-auto text-sm font-mono text-gray-300"><code>{`curl -X POST https://crowdsourcerer.rebaselabs.online/v1/tasks \\
  -H "Authorization: Bearer YOUR_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "type": "data_transform",
    "input": {
      "data": [
        { "Name": "john doe", "Phone": "555-1234", "Date": "01/15/24" },
        { "Name": "Jane Smith", "Phone": "(555) 5678", "Date": "2024-01-16" }
      ],
      "transformations": [
        { "op": "normalize_name", "field": "Name" },
        { "op": "format_phone", "field": "Phone", "format": "E164" },
        { "op": "parse_date", "field": "Date", "output_format": "ISO8601" }
      ]
    }
  }'`}</code></pre>
    </div>

    <div class="text-center">
      <h2 class="text-2xl font-bold mb-3">Clean your data pipeline</h2>
      <p class="text-gray-400 mb-6">1,000 free credits on signup. No credit card required.</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/register" class="px-6 py-3 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold transition-colors">
          Get started free →
        </a>
        <a href="/docs/api-reference" class="px-6 py-3 rounded-xl border border-gray-700 hover:border-gray-500 text-gray-300 transition-colors">
          API Reference
        </a>
      </div>
    </div>
  </div>
</Layout>
