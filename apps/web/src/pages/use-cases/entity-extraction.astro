---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Entity & Business Data Enrichment — CrowdSorcerer Use Cases"
  description="Enrich your data with verified company info, executive contacts, addresses, and firmographic data via CrowdSorcerer's entity_lookup task type. From 2¢/entity."
  ogType="article"
>
  <div class="max-w-4xl mx-auto px-6 py-20">
    <!-- Breadcrumb -->
    <div class="text-sm text-gray-500 mb-10">
      <a href="/" class="hover:text-gray-300 transition-colors">Home</a>
      <span class="mx-2">›</span>
      <a href="/use-cases" class="hover:text-gray-300 transition-colors">Use Cases</a>
      <span class="mx-2">›</span>
      <span>Entity Extraction</span>
    </div>

    <!-- Hero -->
    <div class="mb-12">
      <div class="text-5xl mb-6">🏢</div>
      <h1 class="text-4xl font-bold mb-4">Entity & Business Data Enrichment</h1>
      <p class="text-xl text-gray-400 leading-relaxed max-w-2xl">
        Turn incomplete records into full business profiles. The
        <code class="text-violet-300 bg-violet-950/50 px-1.5 py-0.5 rounded text-sm">entity_lookup</code> task type
        looks up companies, people, locations, products, and more — returning verified, structured data you can use immediately.
      </p>
    </div>

    <!-- Use cases grid -->
    <div class="grid sm:grid-cols-2 gap-6 mb-14">
      {[
        { icon: "🚀", title: "Lead Enrichment", desc: "Append company size, industry, revenue, funding, and tech stack to your CRM leads." },
        { icon: "👤", title: "Executive Lookup", desc: "Find verified contact details, LinkedIn profiles, and professional backgrounds for decision-makers." },
        { icon: "📍", title: "Address Verification", desc: "Validate and standardize postal addresses with geo-coordinates worldwide." },
        { icon: "💼", title: "Company Research", desc: "Get founding date, headcount, products, recent news, and competitor landscape." },
        { icon: "🔗", title: "Data Deduplication", desc: "Identify and merge duplicate entity records across your database." },
        { icon: "🌍", title: "International Entities", desc: "Lookup businesses registered in 190+ countries with local registry data." },
      ].map(({ icon, title, desc }) => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="text-2xl mb-2">{icon}</div>
          <h3 class="font-semibold mb-1">{title}</h3>
          <p class="text-gray-400 text-sm">{desc}</p>
        </div>
      ))}
    </div>

    <!-- Code example -->
    <div class="mb-14">
      <h2 class="text-2xl font-bold mb-4">API Example</h2>
      <pre class="bg-gray-900 border border-gray-800 rounded-xl p-5 overflow-x-auto text-sm font-mono text-gray-300"><code>{`curl -X POST https://api.crowdsorcerer.dev/v1/tasks \\
  -H "Authorization: Bearer YOUR_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "type": "entity_lookup",
    "input": {
      "name": "Stripe Inc",
      "type": "company",
      "fields": ["founded", "employees", "revenue", "hq_address",
                 "ceo", "products", "funding_total", "tech_stack"]
    }
  }'

# Response output:
{
  "name": "Stripe, Inc.",
  "founded": 2010,
  "employees": "~8,000",
  "revenue": "$14.4B (2023)",
  "hq_address": "354 Oyster Point Blvd, South San Francisco, CA",
  "ceo": "Patrick Collison",
  "products": ["Stripe Payments", "Stripe Atlas", "Radar", "Billing"],
  "funding_total": "$8.7B",
  "tech_stack": ["AWS", "Ruby", "Go", "React"]
}`}</code></pre>
    </div>

    <!-- CTA -->
    <div class="text-center">
      <h2 class="text-2xl font-bold mb-3">Enrich your data pipeline</h2>
      <p class="text-gray-400 mb-6">500 free credits on signup. No credit card required.</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/register" class="px-6 py-3 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold transition-colors">
          Get started free →
        </a>
        <a href="/docs/api-reference" class="px-6 py-3 rounded-xl border border-gray-700 hover:border-gray-500 text-gray-300 transition-colors">
          API Reference
        </a>
      </div>
    </div>
  </div>
</Layout>
