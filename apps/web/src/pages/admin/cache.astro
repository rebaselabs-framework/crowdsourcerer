---
/**
 * Admin — Task Result Cache
 * Shows cache hit stats, credits saved, and per-type breakdown.
 * Allows admins to flush expired entries or wipe the entire cache.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login");

let cacheStats: any = null;
let error: string | null = null;

try {
  cacheStats = await apiFetch<any>("/v1/admin/cache/stats", { token });
} catch (e: any) {
  if (e.message?.includes("403") || e.message?.includes("401")) {
    return Astro.redirect("/login");
  }
  error = "Failed to load cache statistics";
}

const hitRate =
  cacheStats && cacheStats.total_entries > 0
    ? ((cacheStats.total_hits / (cacheStats.total_entries + cacheStats.total_hits)) * 100).toFixed(1)
    : "0.0";
---

<Layout title="Task Cache — Admin">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <a href="/admin" class="text-xs text-gray-500 hover:text-gray-300 mb-2 inline-block">← Admin</a>
        <h1 class="text-2xl font-bold">Task Result Cache</h1>
        <p class="text-gray-400 text-sm mt-0.5">
          AI task deduplication — identical inputs return cached results instantly.
        </p>
      </div>
      <div class="flex gap-3">
        <button
          id="flush-expired-btn"
          class="px-4 py-2 bg-yellow-900/40 hover:bg-yellow-900/60 text-yellow-300 text-sm rounded-lg border border-yellow-800/50 transition-colors"
        >
          🧹 Flush expired
        </button>
        <button
          id="flush-all-btn"
          class="px-4 py-2 bg-red-900/40 hover:bg-red-900/60 text-red-300 text-sm rounded-lg border border-red-800/50 transition-colors"
        >
          🗑 Flush all
        </button>
      </div>
    </div>

    {error && (
      <div class="bg-red-950/30 border border-red-800 rounded-xl p-4 text-red-300 text-sm mb-6">
        {error}
      </div>
    )}

    {cacheStats && (
      <>
        <!-- Summary stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="text-xs text-gray-500 mb-1">Cached entries</div>
            <div class="text-3xl font-bold text-white">{cacheStats.total_entries.toLocaleString()}</div>
            {cacheStats.expired_entries > 0 && (
              <div class="text-xs text-yellow-500 mt-1">{cacheStats.expired_entries} expired</div>
            )}
          </div>
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="text-xs text-gray-500 mb-1">Total cache hits</div>
            <div class="text-3xl font-bold text-emerald-400">{cacheStats.total_hits.toLocaleString()}</div>
            <div class="text-xs text-gray-500 mt-1">API calls avoided</div>
          </div>
          <div class="bg-gray-900 border border-amber-800/40 rounded-xl p-5">
            <div class="text-xs text-gray-500 mb-1">Credits saved</div>
            <div class="text-3xl font-bold text-amber-300">{cacheStats.credits_saved.toLocaleString()}</div>
            <div class="text-xs text-gray-500 mt-1">{cacheStats.cache_hit_fee}cr fee per hit</div>
          </div>
          <div class="bg-gray-900 border border-blue-800/40 rounded-xl p-5">
            <div class="text-xs text-gray-500 mb-1">Approx. hit rate</div>
            <div class="text-3xl font-bold text-blue-300">{hitRate}%</div>
            <div class="text-xs text-gray-500 mt-1">of duplicate submissions</div>
          </div>
        </div>

        <!-- How it works callout -->
        <div class="bg-blue-950/20 border border-blue-800/30 rounded-xl px-5 py-4 mb-8 flex items-start gap-4">
          <span class="text-2xl mt-0.5">💡</span>
          <div class="text-sm text-blue-200/80 leading-relaxed">
            <strong class="text-blue-300">How caching works:</strong> When an AI task is submitted, its type +
            input are hashed. If a matching, non-expired result exists, the cached output is returned instantly
            and the requester is charged only <strong>{cacheStats.cache_hit_fee} credit</strong> instead of the
            full cost — the difference is automatically refunded. Cache misses run normally and store the result.
          </div>
        </div>

        <!-- Per-type breakdown -->
        {cacheStats.by_type.length > 0 ? (
          <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-8">
            <div class="px-5 py-4 border-b border-gray-800">
              <h2 class="font-semibold text-sm">Cache entries by task type</h2>
            </div>
            <table class="w-full text-sm">
              <thead class="border-b border-gray-800">
                <tr class="text-xs text-gray-500 uppercase tracking-wider">
                  <th class="px-5 py-3 text-left">Task type</th>
                  <th class="px-5 py-3 text-right">Entries</th>
                  <th class="px-5 py-3 text-right">Cache hits</th>
                  <th class="px-5 py-3 text-right">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-800">
                {cacheStats.by_type.map((row: any) => (
                  <tr class="hover:bg-gray-800/30 transition-colors">
                    <td class="px-5 py-3 font-mono text-violet-300">{row.task_type}</td>
                    <td class="px-5 py-3 text-right text-gray-300">{row.entries}</td>
                    <td class="px-5 py-3 text-right">
                      <span class:list={["font-semibold", row.hits > 0 ? "text-emerald-400" : "text-gray-500"]}>
                        {row.hits.toLocaleString()}
                      </span>
                    </td>
                    <td class="px-5 py-3 text-right">
                      <button
                        class="flush-type-btn text-xs text-red-400 hover:text-red-300 transition-colors"
                        data-type={row.task_type}
                      >
                        Flush
                      </button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <div class="bg-gray-900/40 border border-dashed border-gray-700 rounded-2xl p-10 text-center mb-8">
            <div class="text-3xl mb-3">📭</div>
            <p class="text-gray-500 text-sm">No cached entries yet. Results will appear here after AI tasks complete.</p>
          </div>
        )}

        <!-- Status message -->
        <div id="status-msg" class="hidden text-sm rounded-lg px-4 py-3 border"></div>
      </>
    )}
  </div>
</Layout>

<script>
  const statusEl = document.getElementById("status-msg")!;

  function showStatus(msg: string, ok: boolean) {
    statusEl.textContent = msg;
    statusEl.className = ok
      ? "text-sm rounded-lg px-4 py-3 border bg-emerald-950/30 border-emerald-800/50 text-emerald-300"
      : "text-sm rounded-lg px-4 py-3 border bg-red-950/30 border-red-800/50 text-red-300";
    statusEl.classList.remove("hidden");
    setTimeout(() => statusEl.classList.add("hidden"), 4000);
  }

  async function flushCache(params: string, label: string) {
    const confirmed = confirm(`${label} — are you sure?`);
    if (!confirmed) return;
    try {
      const res = await fetch(`/api/admin/cache/flush?${params}`, { method: "DELETE" });
      const body = await res.json().catch(() => ({}));
      if (res.ok) {
        showStatus(`✅ Deleted ${body.deleted ?? 0} cache entries. Reload to refresh stats.`, true);
      } else {
        showStatus(`Error: ${body.detail ?? "Unknown error"}`, false);
      }
    } catch {
      showStatus("Network error — please try again.", false);
    }
  }

  document.getElementById("flush-expired-btn")?.addEventListener("click", () =>
    flushCache("expired_only=true", "Flush all expired cache entries")
  );

  document.getElementById("flush-all-btn")?.addEventListener("click", () =>
    flushCache("", "Flush ALL cache entries (this cannot be undone)")
  );

  document.querySelectorAll<HTMLButtonElement>(".flush-type-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const type = btn.dataset.type!;
      flushCache(`task_type=${encodeURIComponent(type)}`, `Flush all cached entries for '${type}'`);
    });
  });
</script>
