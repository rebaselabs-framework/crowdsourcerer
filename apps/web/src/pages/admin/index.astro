---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login");

let stats: any = null;
let sweeperStatus: any = null;
let activeAlerts: any = null;
let cacheStats: any = null;
let error: string | null = null;

try {
  [stats, sweeperStatus, activeAlerts, cacheStats] = await Promise.all([
    apiFetch<any>("/v1/admin/stats", { token }),
    apiFetch<any>("/v1/admin/sweeper/status", { token }).catch(() => null),
    apiFetch<any>("/v1/admin/alerts?status=active&limit=1", { token }).catch(() => null),
    apiFetch<any>("/v1/admin/cache/stats", { token }).catch(() => null),
  ]);
} catch (e: any) {
  if (e.message?.includes("403")) {
    error = "forbidden";
  } else if (e.message?.includes("401")) {
    return Astro.redirect("/login");
  } else {
    error = "Failed to load admin stats";
  }
}
---

<Layout title="Admin — CrowdSorcerer">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <div class="flex items-start justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold">Admin Dashboard</h1>
        <p class="text-gray-400 text-sm mt-1">Platform overview and user management</p>
      </div>
      <div class="flex gap-3">
        <a href="/admin/health" class="px-4 py-2 bg-green-900/50 hover:bg-green-900/70 text-sm text-green-300 rounded-lg transition-colors border border-green-800/50">
          System Health →
        </a>
        <a href="/admin/analytics" class="px-4 py-2 bg-violet-900/50 hover:bg-violet-900/70 text-sm text-violet-300 rounded-lg transition-colors border border-violet-800/50">
          📊 Analytics →
        </a>
        <a href="/admin/onboarding-funnel" class="px-4 py-2 bg-blue-900/50 hover:bg-blue-900/70 text-sm text-blue-300 rounded-lg transition-colors border border-blue-800/50">
          🚀 Requester Onboarding →
        </a>
        <a href="/admin/worker-onboarding-funnel" class="px-4 py-2 bg-teal-900/50 hover:bg-teal-900/70 text-sm text-teal-300 rounded-lg transition-colors border border-teal-800/50">
          👷 Worker Onboarding →
        </a>
        <a href="/admin/billing" class="px-4 py-2 bg-emerald-900/50 hover:bg-emerald-900/70 text-sm text-emerald-300 rounded-lg transition-colors border border-emerald-800/50">
          💳 Billing →
        </a>
        <a href="/admin/alerts" class={`relative px-4 py-2 text-sm rounded-lg transition-colors border ${(activeAlerts?.total ?? 0) > 0 ? "bg-red-900/40 hover:bg-red-900/60 text-red-300 border-red-700/50" : "bg-gray-800/50 hover:bg-gray-700/70 text-gray-300 border-gray-700/50"}`}>
          🚨 Alerts {(activeAlerts?.total ?? 0) > 0 && <span class="ml-1 bg-red-500 text-white text-xs font-bold px-1.5 py-0.5 rounded-full">{activeAlerts.total}</span>}
        </a>
        <a href="/admin/audit-log" class="px-4 py-2 bg-gray-800/50 hover:bg-gray-700/70 text-sm text-gray-300 rounded-lg transition-colors border border-gray-700/50">
          📋 Audit Log →
        </a>
        <a href="/admin/announcements" class="px-4 py-2 bg-blue-900/30 hover:bg-blue-900/50 text-sm text-blue-300 rounded-lg transition-colors border border-blue-800/50">
          📢 Announcements →
        </a>
        <a href="/admin/users" class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-sm text-gray-300 rounded-lg transition-colors">
          Manage users →
        </a>
      </div>
    </div>

    {error === "forbidden" ? (
      <div class="bg-red-950/30 border border-red-800 rounded-xl p-8 text-center">
        <div class="text-4xl mb-4">🚫</div>
        <h2 class="text-xl font-bold mb-2 text-red-400">Access Denied</h2>
        <p class="text-gray-400 text-sm">You need admin privileges to view this page.</p>
        <a href="/dashboard" class="inline-block mt-4 text-violet-400 hover:text-violet-300 text-sm">← Back to dashboard</a>
      </div>
    ) : error ? (
      <div class="bg-red-950/30 border border-red-800 rounded-xl p-4 text-red-300 text-sm">
        {error}
      </div>
    ) : stats ? (
      <>
        <!-- System alerts banner (shown when active alerts exist) -->
        {(activeAlerts?.total ?? 0) > 0 && (
          <div class="bg-red-950/30 border border-red-700/50 rounded-xl px-5 py-3 mb-4 flex items-center justify-between">
            <div class="flex items-center gap-3 text-red-400 text-sm">
              <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse inline-block"></span>
              <strong>{activeAlerts.total} active system alert{activeAlerts.total !== 1 ? "s" : ""}</strong>
              — system health needs attention
            </div>
            <a href="/admin/alerts" class="text-xs text-red-300 hover:text-red-200 font-medium">
              View alerts →
            </a>
          </div>
        )}

        <!-- Platform health banner -->
        <div class={`rounded-xl px-5 py-3 mb-4 flex items-center justify-between ${(activeAlerts?.total ?? 0) > 0 ? "bg-yellow-950/20 border border-yellow-800/40" : "bg-green-950/20 border border-green-800/40"}`}>
          <div class={`flex items-center gap-2 text-sm ${(activeAlerts?.total ?? 0) > 0 ? "text-yellow-400" : "text-green-400"}`}>
            <span class={`w-2 h-2 rounded-full animate-pulse inline-block ${(activeAlerts?.total ?? 0) > 0 ? "bg-yellow-400" : "bg-green-400"}`}></span>
            {(activeAlerts?.total ?? 0) > 0 ? "Platform degraded — check alerts" : "Platform is operational"}
          </div>
          <div class="text-xs text-gray-500">
            Stats as of {new Date(stats.generated_at).toLocaleString()}
          </div>
        </div>

        <!-- Sweeper status banner -->
        {sweeperStatus && (
          <div class:list={[
            "rounded-xl px-5 py-3 mb-8 flex items-center justify-between text-sm",
            sweeperStatus.sweeper_running
              ? "bg-blue-950/20 border border-blue-800/40"
              : "bg-yellow-950/20 border border-yellow-800/40"
          ]}>
            <div class:list={["flex items-center gap-3", sweeperStatus.sweeper_running ? "text-blue-400" : "text-yellow-400"]}>
              <span class:list={["w-2 h-2 rounded-full inline-block", sweeperStatus.sweeper_running ? "bg-blue-400 animate-pulse" : "bg-yellow-400"]}></span>
              <span>
                Timeout sweeper: {sweeperStatus.sweeper_running ? "running" : "stopped"}
              </span>
              {sweeperStatus.expired_pending_sweep > 0 && (
                <span class="bg-yellow-900/60 text-yellow-300 text-xs px-2 py-0.5 rounded-full">
                  {sweeperStatus.expired_pending_sweep} expired waiting
                </span>
              )}
            </div>
            <div class="flex items-center gap-4 text-gray-400 text-xs">
              <span>Timed out last 24h: <strong class="text-white">{sweeperStatus.timed_out_last_24h}</strong></span>
              <form method="POST" action="/api/admin/sweep">
                <button type="submit"
                  class="px-3 py-1 bg-gray-800 hover:bg-gray-700 text-gray-300 rounded text-xs transition-colors">
                  Run sweep now
                </button>
              </form>
            </div>
          </div>
        )}

        <!-- User stats -->
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Users</h2>
        <div class="grid grid-cols-4 gap-4 mb-8">
          {[
            { label: "Total users", value: stats.users.total, color: "text-white" },
            { label: "Active", value: stats.users.active, color: "text-green-400" },
            { label: "Workers", value: stats.users.workers, color: "text-violet-400" },
            { label: "New this week", value: stats.users.new_this_week, color: "text-blue-400" },
          ].map(({ label, value, color }) => (
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
              <div class="text-xs text-gray-500 mb-1">{label}</div>
              <div class:list={["text-3xl font-bold", color]}>{value.toLocaleString()}</div>
            </div>
          ))}
        </div>

        <!-- Task stats -->
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Tasks</h2>
        <div class="grid grid-cols-4 gap-4 mb-6">
          {[
            { label: "Total tasks", value: stats.tasks.total, color: "text-white" },
            { label: "Completed", value: stats.tasks.completed, color: "text-green-400" },
            { label: "Failed", value: stats.tasks.failed, color: "text-red-400" },
            { label: "This week", value: stats.tasks.this_week, color: "text-blue-400" },
          ].map(({ label, value, color }) => (
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
              <div class="text-xs text-gray-500 mb-1">{label}</div>
              <div class:list={["text-3xl font-bold", color]}>{value.toLocaleString()}</div>
            </div>
          ))}
        </div>
        <div class="grid grid-cols-3 gap-4 mb-8">
          {[
            { label: "Success rate", value: `${stats.tasks.success_rate}%`, color: "text-green-400" },
            { label: "Running / Queued", value: stats.tasks.running, color: "text-yellow-400" },
            { label: "Open human tasks", value: stats.tasks.open_human, color: "text-violet-400" },
          ].map(({ label, value, color }) => (
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
              <div class="text-xs text-gray-500 mb-1">{label}</div>
              <div class:list={["text-3xl font-bold", color]}>{value}</div>
            </div>
          ))}
        </div>

        <!-- Task type breakdown + other metrics side by side -->
        <div class="grid grid-cols-2 gap-6 mb-8">
          <!-- Task type breakdown -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl">
            <div class="px-5 py-4 border-b border-gray-800">
              <h3 class="font-semibold text-sm">Task type breakdown</h3>
            </div>
            <div class="divide-y divide-gray-800">
              {stats.tasks.type_breakdown.map((item: any) => {
                const pct = stats.tasks.total > 0
                  ? Math.round(item.count / stats.tasks.total * 100)
                  : 0;
                return (
                  <div class="flex items-center justify-between px-5 py-3">
                    <span class="font-mono text-sm text-violet-300">{item.type}</span>
                    <div class="flex items-center gap-3">
                      <div class="w-24 h-1.5 bg-gray-800 rounded-full overflow-hidden">
                        <div
                          class="h-full bg-violet-500 rounded-full"
                          style={`width: ${pct}%`}
                        ></div>
                      </div>
                      <span class="text-sm text-gray-400 w-8 text-right">{item.count}</span>
                    </div>
                  </div>
                );
              })}
              {stats.tasks.type_breakdown.length === 0 && (
                <div class="px-5 py-6 text-center text-gray-500 text-sm">No tasks yet</div>
              )}
            </div>
          </div>

          <!-- Other metrics -->
          <div class="space-y-4">
            <!-- Credits -->
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
              <h3 class="font-semibold text-sm mb-3">Credits</h3>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <div class="text-xs text-gray-500 mb-1">In circulation</div>
                  <div class="text-xl font-bold text-violet-300">
                    {stats.credits.in_circulation.toLocaleString()}
                  </div>
                </div>
                <div>
                  <div class="text-xs text-gray-500 mb-1">Total purchased</div>
                  <div class="text-xl font-bold">
                    {stats.credits.total_purchased.toLocaleString()}
                  </div>
                </div>
              </div>
            </div>

            <!-- Worker assignments -->
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
              <h3 class="font-semibold text-sm mb-3">Worker Assignments</h3>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <div class="text-xs text-gray-500 mb-1">Total</div>
                  <div class="text-xl font-bold">{stats.worker_assignments.total.toLocaleString()}</div>
                </div>
                <div>
                  <div class="text-xs text-gray-500 mb-1">Submitted</div>
                  <div class="text-xl font-bold text-green-400">
                    {stats.worker_assignments.submitted.toLocaleString()}
                  </div>
                </div>
              </div>
            </div>

            <!-- Webhooks -->
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
              <h3 class="font-semibold text-sm mb-3">Webhooks</h3>
              <div class="grid grid-cols-3 gap-4">
                <div>
                  <div class="text-xs text-gray-500 mb-1">Total</div>
                  <div class="text-xl font-bold">{stats.webhooks.total}</div>
                </div>
                <div>
                  <div class="text-xs text-gray-500 mb-1">Failed</div>
                  <div class="text-xl font-bold text-red-400">{stats.webhooks.failed}</div>
                </div>
                <div>
                  <div class="text-xs text-gray-500 mb-1">Success rate</div>
                  <div class="text-xl font-bold text-green-400">{stats.webhooks.success_rate}%</div>
                </div>
              </div>
            </div>

            <!-- Task result cache summary -->
            {cacheStats && (
              <a
                href="/admin/cache"
                class="block bg-gray-900 border border-emerald-800/30 hover:border-emerald-600/50 rounded-xl p-5 transition-colors"
              >
                <div class="flex items-center justify-between mb-3">
                  <h3 class="font-semibold text-sm">Result Cache</h3>
                  <span class="text-xs text-gray-500">→</span>
                </div>
                <div class="grid grid-cols-3 gap-4">
                  <div>
                    <div class="text-xs text-gray-500 mb-1">Entries</div>
                    <div class="text-xl font-bold">{cacheStats.total_entries}</div>
                  </div>
                  <div>
                    <div class="text-xs text-gray-500 mb-1">Hits</div>
                    <div class="text-xl font-bold text-emerald-400">{cacheStats.total_hits.toLocaleString()}</div>
                  </div>
                  <div>
                    <div class="text-xs text-gray-500 mb-1">Credits saved</div>
                    <div class="text-xl font-bold text-amber-300">{cacheStats.credits_saved.toLocaleString()}</div>
                  </div>
                </div>
              </a>
            )}
          </div>
        </div>

        <!-- Quick links -->
        <div class="grid grid-cols-4 gap-4">
          <a href="/admin/users" class="bg-gray-900 border border-gray-800 hover:border-gray-600 rounded-xl p-5 transition-colors">
            <div class="text-2xl mb-2">👥</div>
            <div class="font-semibold text-sm mb-1">User Management</div>
            <div class="text-xs text-gray-500">View, search, update all users</div>
          </a>
          <a href="/admin/tasks" class="bg-gray-900 border border-gray-800 hover:border-gray-600 rounded-xl p-5 transition-colors">
            <div class="text-2xl mb-2">📋</div>
            <div class="font-semibold text-sm mb-1">All Tasks</div>
            <div class="text-xs text-gray-500">See tasks across all users</div>
          </a>
          <a href="/dashboard/quality" class="bg-gray-900 border border-gray-800 hover:border-gray-600 rounded-xl p-5 transition-colors">
            <div class="text-2xl mb-2">🎯</div>
            <div class="font-semibold text-sm mb-1">Quality Control</div>
            <div class="text-xs text-gray-500">Worker accuracy + gold standards</div>
          </a>
          <a href="/dashboard/review" class="bg-gray-900 border border-gray-800 hover:border-gray-600 rounded-xl p-5 transition-colors">
            <div class="text-2xl mb-2">📬</div>
            <div class="font-semibold text-sm mb-1">Review Queue</div>
            <div class="text-xs text-gray-500">Approve / reject human submissions</div>
          </a>
          <a href="/admin/payouts" class="bg-gray-900 border border-emerald-800/30 hover:border-emerald-600/50 rounded-xl p-5 transition-colors">
            <div class="text-2xl mb-2">💸</div>
            <div class="font-semibold text-sm mb-1">Payout Requests</div>
            <div class="text-xs text-gray-500">Review & approve worker withdrawals</div>
          </a>
          <a href="/admin/analytics" class="bg-gray-900 border border-violet-800/30 hover:border-violet-600/50 rounded-xl p-5 transition-colors">
            <div class="text-2xl mb-2">📊</div>
            <div class="font-semibold text-sm mb-1">Analytics</div>
            <div class="text-xs text-gray-500">Charts: throughput, growth, revenue</div>
          </a>
          <a href="/admin/reputation" class="bg-gray-900 border border-orange-800/30 hover:border-orange-600/50 rounded-xl p-5 transition-colors">
            <div class="text-2xl mb-2">⭐</div>
            <div class="font-semibold text-sm mb-1">Worker Reputation</div>
            <div class="text-xs text-gray-500">Trust scores, strikes, bans</div>
          </a>
          <a href="/admin/workers" class="bg-gray-900 border border-violet-800/30 hover:border-violet-600/50 rounded-xl p-5 transition-colors">
            <div class="text-2xl mb-2">👷</div>
            <div class="font-semibold text-sm mb-1">Worker Management</div>
            <div class="text-xs text-gray-500">Ban, strike, and manage workers</div>
          </a>
          <a href="/admin/queue" class="bg-gray-900 border border-blue-800/30 hover:border-blue-600/50 rounded-xl p-5 transition-colors">
            <div class="text-2xl mb-2">⏳</div>
            <div class="font-semibold text-sm mb-1">Task Queue</div>
            <div class="text-xs text-gray-500">Live queue by priority + ETA estimates</div>
          </a>
          <a href="/admin/health" class="bg-gray-900 border border-green-800/30 hover:border-green-600/50 rounded-xl p-5 transition-colors">
            <div class="text-2xl mb-2">🏥</div>
            <div class="font-semibold text-sm mb-1">System Health</div>
            <div class="text-xs text-gray-500">DB ping, error rate, queue depth</div>
          </a>
          <a href="/admin/audit-log" class="bg-gray-900 border border-gray-700/30 hover:border-gray-500/50 rounded-xl p-5 transition-colors">
            <div class="text-2xl mb-2">📋</div>
            <div class="font-semibold text-sm mb-1">Audit Log</div>
            <div class="text-xs text-gray-500">All admin actions + history</div>
          </a>
          <a href="/admin/alerts" class={`bg-gray-900 rounded-xl p-5 transition-colors border ${(activeAlerts?.total ?? 0) > 0 ? "border-red-700/50 hover:border-red-500/50" : "border-gray-700/30 hover:border-gray-500/50"}`}>
            <div class="text-2xl mb-2">🚨</div>
            <div class="font-semibold text-sm mb-1 flex items-center gap-2">
              System Alerts
              {(activeAlerts?.total ?? 0) > 0 && (
                <span class="bg-red-500 text-white text-xs font-bold px-1.5 py-0.5 rounded-full">{activeAlerts.total}</span>
              )}
            </div>
            <div class="text-xs text-gray-500">Health alerts: error spikes, sweeper stalls</div>
          </a>
          <a href="/admin/cache" class="bg-gray-900 border border-emerald-800/30 hover:border-emerald-600/50 rounded-xl p-5 transition-colors">
            <div class="text-2xl mb-2">⚡</div>
            <div class="font-semibold text-sm mb-1">Result Cache</div>
            <div class="text-xs text-gray-500">
              {cacheStats ? `${cacheStats.total_hits} hits · ${cacheStats.credits_saved} credits saved` : "AI task deduplication cache"}
            </div>
          </a>
          <a href="/admin/setup" class="bg-gray-900 border border-violet-800/30 hover:border-violet-600/50 rounded-xl p-5 transition-colors">
            <div class="text-2xl mb-2">⚙️</div>
            <div class="font-semibold text-sm mb-1">Setup Checklist</div>
            <div class="text-xs text-gray-500">Verify env vars, services, and integrations</div>
          </a>
        </div>
      </>
    ) : null}
  </div>
</Layout>
