---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Object.fromEntries(
  Astro.cookies.getAll().map((c) => [c.name, c.value])
));
if (!token) return Astro.redirect("/login");

let stats: any = null;
let error: string | null = null;

try {
  stats = await apiFetch<any>("/v1/admin/stats", { token });
} catch (e: any) {
  if (e.message?.includes("403")) {
    error = "forbidden";
  } else if (e.message?.includes("401")) {
    return Astro.redirect("/login");
  } else {
    error = "Failed to load admin stats";
  }
}
---

<Layout title="Admin — CrowdSorcerer">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <div class="flex items-start justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold">Admin Dashboard</h1>
        <p class="text-gray-400 text-sm mt-1">Platform overview and user management</p>
      </div>
      <div class="flex gap-3">
        <a href="/admin/users" class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-sm text-gray-300 rounded-lg transition-colors">
          Manage users →
        </a>
      </div>
    </div>

    {error === "forbidden" ? (
      <div class="bg-red-950/30 border border-red-800 rounded-xl p-8 text-center">
        <div class="text-4xl mb-4">🚫</div>
        <h2 class="text-xl font-bold mb-2 text-red-400">Access Denied</h2>
        <p class="text-gray-400 text-sm">You need admin privileges to view this page.</p>
        <a href="/dashboard" class="inline-block mt-4 text-violet-400 hover:text-violet-300 text-sm">← Back to dashboard</a>
      </div>
    ) : error ? (
      <div class="bg-red-950/30 border border-red-800 rounded-xl p-4 text-red-300 text-sm">
        {error}
      </div>
    ) : stats ? (
      <>
        <!-- Platform health banner -->
        <div class="bg-green-950/20 border border-green-800/40 rounded-xl px-5 py-3 mb-8 flex items-center justify-between">
          <div class="flex items-center gap-2 text-green-400 text-sm">
            <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse inline-block"></span>
            Platform is operational
          </div>
          <div class="text-xs text-gray-500">
            Stats as of {new Date(stats.generated_at).toLocaleString()}
          </div>
        </div>

        <!-- User stats -->
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Users</h2>
        <div class="grid grid-cols-4 gap-4 mb-8">
          {[
            { label: "Total users", value: stats.users.total, color: "text-white" },
            { label: "Active", value: stats.users.active, color: "text-green-400" },
            { label: "Workers", value: stats.users.workers, color: "text-violet-400" },
            { label: "New this week", value: stats.users.new_this_week, color: "text-blue-400" },
          ].map(({ label, value, color }) => (
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
              <div class="text-xs text-gray-500 mb-1">{label}</div>
              <div class:list={["text-3xl font-bold", color]}>{value.toLocaleString()}</div>
            </div>
          ))}
        </div>

        <!-- Task stats -->
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Tasks</h2>
        <div class="grid grid-cols-4 gap-4 mb-6">
          {[
            { label: "Total tasks", value: stats.tasks.total, color: "text-white" },
            { label: "Completed", value: stats.tasks.completed, color: "text-green-400" },
            { label: "Failed", value: stats.tasks.failed, color: "text-red-400" },
            { label: "This week", value: stats.tasks.this_week, color: "text-blue-400" },
          ].map(({ label, value, color }) => (
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
              <div class="text-xs text-gray-500 mb-1">{label}</div>
              <div class:list={["text-3xl font-bold", color]}>{value.toLocaleString()}</div>
            </div>
          ))}
        </div>
        <div class="grid grid-cols-3 gap-4 mb-8">
          {[
            { label: "Success rate", value: `${stats.tasks.success_rate}%`, color: "text-green-400" },
            { label: "Running / Queued", value: stats.tasks.running, color: "text-yellow-400" },
            { label: "Open human tasks", value: stats.tasks.open_human, color: "text-violet-400" },
          ].map(({ label, value, color }) => (
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
              <div class="text-xs text-gray-500 mb-1">{label}</div>
              <div class:list={["text-3xl font-bold", color]}>{value}</div>
            </div>
          ))}
        </div>

        <!-- Task type breakdown + other metrics side by side -->
        <div class="grid grid-cols-2 gap-6 mb-8">
          <!-- Task type breakdown -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl">
            <div class="px-5 py-4 border-b border-gray-800">
              <h3 class="font-semibold text-sm">Task type breakdown</h3>
            </div>
            <div class="divide-y divide-gray-800">
              {stats.tasks.type_breakdown.map((item: any) => {
                const pct = stats.tasks.total > 0
                  ? Math.round(item.count / stats.tasks.total * 100)
                  : 0;
                return (
                  <div class="flex items-center justify-between px-5 py-3">
                    <span class="font-mono text-sm text-violet-300">{item.type}</span>
                    <div class="flex items-center gap-3">
                      <div class="w-24 h-1.5 bg-gray-800 rounded-full overflow-hidden">
                        <div
                          class="h-full bg-violet-500 rounded-full"
                          style={`width: ${pct}%`}
                        ></div>
                      </div>
                      <span class="text-sm text-gray-400 w-8 text-right">{item.count}</span>
                    </div>
                  </div>
                );
              })}
              {stats.tasks.type_breakdown.length === 0 && (
                <div class="px-5 py-6 text-center text-gray-500 text-sm">No tasks yet</div>
              )}
            </div>
          </div>

          <!-- Other metrics -->
          <div class="space-y-4">
            <!-- Credits -->
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
              <h3 class="font-semibold text-sm mb-3">Credits</h3>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <div class="text-xs text-gray-500 mb-1">In circulation</div>
                  <div class="text-xl font-bold text-violet-300">
                    {stats.credits.in_circulation.toLocaleString()}
                  </div>
                </div>
                <div>
                  <div class="text-xs text-gray-500 mb-1">Total purchased</div>
                  <div class="text-xl font-bold">
                    {stats.credits.total_purchased.toLocaleString()}
                  </div>
                </div>
              </div>
            </div>

            <!-- Worker assignments -->
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
              <h3 class="font-semibold text-sm mb-3">Worker Assignments</h3>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <div class="text-xs text-gray-500 mb-1">Total</div>
                  <div class="text-xl font-bold">{stats.worker_assignments.total.toLocaleString()}</div>
                </div>
                <div>
                  <div class="text-xs text-gray-500 mb-1">Submitted</div>
                  <div class="text-xl font-bold text-green-400">
                    {stats.worker_assignments.submitted.toLocaleString()}
                  </div>
                </div>
              </div>
            </div>

            <!-- Webhooks -->
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
              <h3 class="font-semibold text-sm mb-3">Webhooks</h3>
              <div class="grid grid-cols-3 gap-4">
                <div>
                  <div class="text-xs text-gray-500 mb-1">Total</div>
                  <div class="text-xl font-bold">{stats.webhooks.total}</div>
                </div>
                <div>
                  <div class="text-xs text-gray-500 mb-1">Failed</div>
                  <div class="text-xl font-bold text-red-400">{stats.webhooks.failed}</div>
                </div>
                <div>
                  <div class="text-xs text-gray-500 mb-1">Success rate</div>
                  <div class="text-xl font-bold text-green-400">{stats.webhooks.success_rate}%</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Quick links -->
        <div class="grid grid-cols-3 gap-4">
          <a href="/admin/users" class="bg-gray-900 border border-gray-800 hover:border-gray-600 rounded-xl p-5 transition-colors">
            <div class="text-2xl mb-2">👥</div>
            <div class="font-semibold text-sm mb-1">User Management</div>
            <div class="text-xs text-gray-500">View, search, update all users</div>
          </a>
          <a href="/admin/tasks" class="bg-gray-900 border border-gray-800 hover:border-gray-600 rounded-xl p-5 transition-colors">
            <div class="text-2xl mb-2">📋</div>
            <div class="font-semibold text-sm mb-1">All Tasks</div>
            <div class="text-xs text-gray-500">See tasks across all users</div>
          </a>
          <a href="/dashboard/quality" class="bg-gray-900 border border-gray-800 hover:border-gray-600 rounded-xl p-5 transition-colors">
            <div class="text-2xl mb-2">🎯</div>
            <div class="font-semibold text-sm mb-1">Quality Control</div>
            <div class="text-xs text-gray-500">Worker accuracy + gold standards</div>
          </a>
        </div>
      </>
    ) : null}
  </div>
</Layout>
