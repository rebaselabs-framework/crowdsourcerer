---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login");

const page = Number(Astro.url.searchParams.get("page") ?? 1);
const search = Astro.url.searchParams.get("search") ?? "";
const isBanned = Astro.url.searchParams.get("is_banned") ?? "";
const sortBy = Astro.url.searchParams.get("sort_by") ?? "reputation_score";
const order = Astro.url.searchParams.get("order") ?? "asc";

let workers: any[] = [];
let error: string | null = null;

try {
  const qs = new URLSearchParams({ page: String(page), page_size: "30", sort_by: sortBy, order });
  if (search) qs.set("search", search);
  if (isBanned) qs.set("is_banned", isBanned);
  workers = await apiFetch<any[]>(`/v1/admin/reputation/workers?${qs}`, { token });
} catch (e: any) {
  if (e.message?.includes("403")) error = "forbidden";
  else if (e.message?.includes("401")) return Astro.redirect("/login");
  else error = "Failed to load worker reputation data";
}

function tierColor(score: number) {
  if (score >= 90) return "text-yellow-400";
  if (score >= 75) return "text-green-400";
  if (score >= 60) return "text-blue-400";
  if (score >= 40) return "text-gray-300";
  if (score >= 20) return "text-orange-400";
  return "text-red-400";
}
---

<Layout title="Worker Reputation — Admin">
  <div class="max-w-7xl mx-auto px-6 py-10">
    <!-- Breadcrumb -->
    <div class="text-sm text-gray-500 mb-6">
      <a href="/admin" class="hover:text-gray-300 transition-colors">Admin</a>
      <span class="mx-2">›</span>
      <span>Worker Reputation</span>
    </div>

    <div class="flex items-start justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold">Worker Reputation</h1>
        <p class="text-gray-400 text-sm mt-1">Trust scores, strikes, and moderation</p>
      </div>
      <button
        id="recalcBtn"
        class="px-4 py-2 bg-violet-900/50 hover:bg-violet-900/70 text-violet-300 text-sm rounded-lg border border-violet-800/50 transition-colors"
      >
        🔄 Recalculate All
      </button>
    </div>

    {error === "forbidden" ? (
      <div class="bg-red-950/30 border border-red-800 rounded-xl p-8 text-center">
        <div class="text-4xl mb-4">🚫</div>
        <h2 class="text-xl font-bold mb-2 text-red-400">Access Denied</h2>
        <p class="text-gray-400 text-sm">Admin access required.</p>
      </div>
    ) : error ? (
      <div class="bg-red-950/30 border border-red-800 rounded-xl p-4 text-red-300 text-sm">{error}</div>
    ) : (
      <>
        <!-- Filters -->
        <form method="GET" class="flex gap-3 mb-6">
          <input
            name="search"
            value={search}
            placeholder="Search by email or name…"
            class="flex-1 bg-gray-900 border border-gray-700 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-violet-600"
          />
          <select
            name="is_banned"
            class="bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-sm"
          >
            <option value="">All workers</option>
            <option value="false" selected={isBanned === "false"}>Active</option>
            <option value="true" selected={isBanned === "true"}>Banned</option>
          </select>
          <select
            name="sort_by"
            class="bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-sm"
          >
            <option value="reputation_score" selected={sortBy === "reputation_score"}>Sort: Score</option>
            <option value="strike_count" selected={sortBy === "strike_count"}>Sort: Strikes</option>
            <option value="tasks_completed" selected={sortBy === "tasks_completed"}>Sort: Tasks</option>
            <option value="created_at" selected={sortBy === "created_at"}>Sort: Joined</option>
          </select>
          <select
            name="order"
            class="bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-sm"
          >
            <option value="asc" selected={order === "asc"}>↑ Asc</option>
            <option value="desc" selected={order === "desc"}>↓ Desc</option>
          </select>
          <button type="submit" class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-sm text-gray-300 rounded-lg">Filter</button>
        </form>

        <!-- Legend -->
        <div class="flex gap-4 mb-4 text-xs">
          {[
            ["text-yellow-400", "Elite (90+)"],
            ["text-green-400", "Expert (75+)"],
            ["text-blue-400", "Proficient (60+)"],
            ["text-gray-300", "Developing (40+)"],
            ["text-orange-400", "Novice (20+)"],
            ["text-red-400", "Untrusted (<20)"],
          ].map(([color, label]) => (
            <span class:list={["flex items-center gap-1", color]}>
              <span class="w-2 h-2 rounded-full bg-current inline-block"></span> {label}
            </span>
          ))}
        </div>

        <!-- Workers table -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
          <table class="w-full text-sm">
            <thead class="border-b border-gray-800 text-xs text-gray-500 uppercase tracking-wider">
              <tr>
                <th class="text-left px-5 py-3">Worker</th>
                <th class="text-center px-4 py-3">Score</th>
                <th class="text-center px-4 py-3">Tier</th>
                <th class="text-center px-4 py-3">Strikes</th>
                <th class="text-center px-4 py-3">Tasks</th>
                <th class="text-center px-4 py-3">Level</th>
                <th class="text-center px-4 py-3">Accuracy</th>
                <th class="text-center px-4 py-3">Status</th>
                <th class="text-right px-5 py-3">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
              {workers.length === 0 ? (
                <tr>
                  <td colspan="9" class="text-center py-12 text-gray-500">No workers found.</td>
                </tr>
              ) : workers.map((w: any) => (
                <tr class:list={["hover:bg-gray-800/30 transition-colors", w.is_banned ? "opacity-60" : ""]}>
                  <td class="px-5 py-3">
                    <div class="font-medium text-white">{w.name || w.email.split("@")[0]}</div>
                    <div class="text-xs text-gray-500">{w.email}</div>
                  </td>
                  <td class="px-4 py-3 text-center">
                    <span class:list={["text-lg font-bold", tierColor(w.reputation_score)]}>
                      {w.reputation_score.toFixed(1)}
                    </span>
                  </td>
                  <td class="px-4 py-3 text-center">
                    <span class:list={["text-xs font-medium px-2 py-0.5 rounded-full", tierColor(w.reputation_score), "bg-gray-800"]}>
                      {w.tier}
                    </span>
                  </td>
                  <td class="px-4 py-3 text-center">
                    <span class:list={["font-semibold", w.strike_count > 0 ? "text-red-400" : "text-gray-500"]}>
                      {w.strike_count}
                    </span>
                  </td>
                  <td class="px-4 py-3 text-center text-gray-300">{w.tasks_completed.toLocaleString()}</td>
                  <td class="px-4 py-3 text-center text-violet-400">Lv {w.level}</td>
                  <td class="px-4 py-3 text-center">
                    {w.worker_accuracy != null ? (
                      <span class:list={["text-sm", w.worker_accuracy >= 0.8 ? "text-green-400" : w.worker_accuracy >= 0.6 ? "text-yellow-400" : "text-red-400"]}>
                        {(w.worker_accuracy * 100).toFixed(0)}%
                      </span>
                    ) : (
                      <span class="text-gray-600 text-xs">—</span>
                    )}
                  </td>
                  <td class="px-4 py-3 text-center">
                    {w.is_banned ? (
                      <span class="bg-red-900/50 text-red-400 text-xs px-2 py-0.5 rounded-full border border-red-800/50">Banned</span>
                    ) : (
                      <span class="bg-green-900/30 text-green-400 text-xs px-2 py-0.5 rounded-full border border-green-800/30">Active</span>
                    )}
                  </td>
                  <td class="px-5 py-3 text-right">
                    <div class="flex items-center justify-end gap-2">
                      <button
                        class="text-xs text-orange-400 hover:text-orange-300 strike-btn"
                        data-worker-id={w.id}
                        data-worker-name={w.name || w.email}
                        title="Issue strike"
                      >
                        ⚡ Strike
                      </button>
                      {w.is_banned ? (
                        <button
                          class="text-xs text-green-400 hover:text-green-300 unban-btn"
                          data-worker-id={w.id}
                          title="Unban worker"
                        >
                          ✅ Unban
                        </button>
                      ) : (
                        <button
                          class="text-xs text-red-400 hover:text-red-300 ban-btn"
                          data-worker-id={w.id}
                          data-worker-name={w.name || w.email}
                          title="Ban worker"
                        >
                          🚫 Ban
                        </button>
                      )}
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <div class="flex justify-center gap-3 mt-6">
          {page > 1 && (
            <a href={`?page=${page - 1}&search=${search}&is_banned=${isBanned}&sort_by=${sortBy}&order=${order}`}
               class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-sm rounded-lg">← Previous</a>
          )}
          <span class="px-4 py-2 text-sm text-gray-400">Page {page}</span>
          {workers.length === 30 && (
            <a href={`?page=${page + 1}&search=${search}&is_banned=${isBanned}&sort_by=${sortBy}&order=${order}`}
               class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-sm rounded-lg">Next →</a>
          )}
        </div>
      </>
    )}
  </div>

  <!-- Strike Modal -->
  <div id="strikeModal" class="fixed inset-0 bg-black/70 z-50 hidden flex items-center justify-center">
    <div class="bg-gray-900 border border-gray-700 rounded-2xl p-8 w-full max-w-md">
      <h2 class="text-lg font-bold mb-4">⚡ Issue Strike</h2>
      <p class="text-sm text-gray-400 mb-4">Worker: <strong id="strikeName" class="text-white"></strong></p>
      <form id="strikeForm">
        <input type="hidden" id="strikeWorkerId" />
        <div class="mb-4">
          <label class="block text-xs text-gray-400 mb-1">Severity</label>
          <select id="strikeSeverity" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm">
            <option value="warning">⚠️ Warning (−2 pts)</option>
            <option value="minor">Minor (−5 pts)</option>
            <option value="major">Major (−15 pts)</option>
            <option value="critical">Critical (−30 pts)</option>
          </select>
        </div>
        <div class="mb-4">
          <label class="block text-xs text-gray-400 mb-1">Reason <span class="text-red-400">*</span></label>
          <textarea id="strikeReason" rows="3" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-violet-600" placeholder="Describe the issue…"></textarea>
        </div>
        <div class="flex gap-3">
          <button type="submit" class="flex-1 py-2 bg-orange-700 hover:bg-orange-600 text-white text-sm rounded-lg font-medium">Issue Strike</button>
          <button type="button" id="closeStrike" class="flex-1 py-2 bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm rounded-lg">Cancel</button>
        </div>
        <p id="strikeMsg" class="mt-3 text-sm text-center hidden"></p>
      </form>
    </div>
  </div>

  <!-- Ban Modal -->
  <div id="banModal" class="fixed inset-0 bg-black/70 z-50 hidden flex items-center justify-center">
    <div class="bg-gray-900 border border-gray-700 rounded-2xl p-8 w-full max-w-md">
      <h2 class="text-lg font-bold mb-4">🚫 Ban Worker</h2>
      <p class="text-sm text-gray-400 mb-4">Worker: <strong id="banName" class="text-white"></strong></p>
      <form id="banForm">
        <input type="hidden" id="banWorkerId" />
        <div class="mb-4">
          <label class="block text-xs text-gray-400 mb-1">Reason <span class="text-red-400">*</span></label>
          <textarea id="banReason" rows="3" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-violet-600" placeholder="Reason for ban…"></textarea>
        </div>
        <div class="flex gap-3">
          <button type="submit" class="flex-1 py-2 bg-red-700 hover:bg-red-600 text-white text-sm rounded-lg font-medium">Ban Worker</button>
          <button type="button" id="closeBan" class="flex-1 py-2 bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm rounded-lg">Cancel</button>
        </div>
        <p id="banMsg" class="mt-3 text-sm text-center hidden"></p>
      </form>
    </div>
  </div>
</Layout>

<script>
// Proxy routes handle auth via httpOnly cookie — no client-side token needed

// Strike modal
const strikeModal = document.getElementById("strikeModal")!;
const strikeForm = document.getElementById("strikeForm")!;
document.querySelectorAll(".strike-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    (document.getElementById("strikeWorkerId") as HTMLInputElement).value = btn.getAttribute("data-worker-id")!;
    document.getElementById("strikeName")!.textContent = btn.getAttribute("data-worker-name")!;
    (document.getElementById("strikeReason") as HTMLTextAreaElement).value = "";
    document.getElementById("strikeMsg")!.classList.add("hidden");
    strikeModal.classList.remove("hidden");
  });
});
document.getElementById("closeStrike")!.addEventListener("click", () => strikeModal.classList.add("hidden"));
strikeForm.addEventListener("submit", async (e) => {
  e.preventDefault();
  const workerId = (document.getElementById("strikeWorkerId") as HTMLInputElement).value;
  const severity = (document.getElementById("strikeSeverity") as HTMLSelectElement).value;
  const reason = (document.getElementById("strikeReason") as HTMLTextAreaElement).value.trim();
  if (!reason) return;
  const msg = document.getElementById("strikeMsg")!;
  try {
    const res = await fetch(`/api/admin/reputation/workers/${workerId}/strikes`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ severity, reason }),
    });
    const data = await res.json();
    if (res.ok) {
      msg.textContent = `✅ Strike issued. New score: ${data.new_reputation_score?.toFixed(1)}`;
      msg.className = "mt-3 text-sm text-center text-green-400";
      msg.classList.remove("hidden");
      setTimeout(() => { strikeModal.classList.add("hidden"); location.reload(); }, 1500);
    } else {
      msg.textContent = data.detail || "Error issuing strike";
      msg.className = "mt-3 text-sm text-center text-red-400";
      msg.classList.remove("hidden");
    }
  } catch { msg.textContent = "Network error"; msg.className = "mt-3 text-sm text-center text-red-400"; msg.classList.remove("hidden"); }
});

// Ban modal
const banModal = document.getElementById("banModal")!;
const banForm = document.getElementById("banForm")!;
document.querySelectorAll(".ban-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    (document.getElementById("banWorkerId") as HTMLInputElement).value = btn.getAttribute("data-worker-id")!;
    document.getElementById("banName")!.textContent = btn.getAttribute("data-worker-name")!;
    (document.getElementById("banReason") as HTMLTextAreaElement).value = "";
    document.getElementById("banMsg")!.classList.add("hidden");
    banModal.classList.remove("hidden");
  });
});
document.getElementById("closeBan")!.addEventListener("click", () => banModal.classList.add("hidden"));
banForm.addEventListener("submit", async (e) => {
  e.preventDefault();
  const workerId = (document.getElementById("banWorkerId") as HTMLInputElement).value;
  const reason = (document.getElementById("banReason") as HTMLTextAreaElement).value.trim();
  if (!reason) return;
  const msg = document.getElementById("banMsg")!;
  try {
    const res = await fetch(`/api/admin/reputation/workers/${workerId}/ban`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ reason }),
    });
    const data = await res.json();
    if (res.ok) {
      msg.textContent = "✅ Worker banned.";
      msg.className = "mt-3 text-sm text-center text-green-400";
      msg.classList.remove("hidden");
      setTimeout(() => { banModal.classList.add("hidden"); location.reload(); }, 1500);
    } else {
      msg.textContent = data.detail || "Error banning worker";
      msg.className = "mt-3 text-sm text-center text-red-400";
      msg.classList.remove("hidden");
    }
  } catch { msg.textContent = "Network error"; msg.className = "mt-3 text-sm text-center text-red-400"; msg.classList.remove("hidden"); }
});

// Unban buttons
document.querySelectorAll(".unban-btn").forEach(btn => {
  btn.addEventListener("click", async () => {
    if (!confirm("Unban this worker?")) return;
    const workerId = btn.getAttribute("data-worker-id")!;
    await fetch(`/api/admin/reputation/workers/${workerId}/unban`, {
      method: "POST",
    });
    location.reload();
  });
});

// Recalculate
document.getElementById("recalcBtn")!.addEventListener("click", async () => {
  if (!confirm("Recalculate ALL worker reputation scores? This may take a moment.")) return;
  const res = await fetch("/api/admin/reputation/recalculate", {
    method: "POST",
  });
  const data = await res.json();
  alert(data.message || "Done");
  location.reload();
});
</script>
