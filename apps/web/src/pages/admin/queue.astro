---
/**
 * Admin — Task Queue Visibility
 * Shows all pending/running/queued tasks grouped by priority with ETA estimates.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login");

const modeFilter = Astro.url.searchParams.get("mode") ?? "";

let queue: any = null;
let error = "";

try {
  const qs = new URLSearchParams();
  if (modeFilter) qs.set("execution_mode", modeFilter);
  queue = await apiFetch<any>(`/v1/admin/queue?${qs}`, { token });
} catch (e: any) {
  if ((e as Error).message?.includes("403")) return Astro.redirect("/dashboard");
  error = (e as Error).message ?? "Failed to load task queue";
}

const PRIORITY_META: Record<string, { label: string; dot: string; ring: string }> = {
  urgent: { label: "🔴 Urgent", dot: "bg-red-500",    ring: "border-red-800/50" },
  high:   { label: "🟠 High",   dot: "bg-orange-500", ring: "border-orange-800/50" },
  normal: { label: "🟡 Normal", dot: "bg-yellow-500", ring: "border-yellow-800/50" },
  low:    { label: "🟢 Low",    dot: "bg-green-500",  ring: "border-green-800/50" },
};

const STATUS_COLORS: Record<string, string> = {
  pending:  "bg-gray-800 text-gray-400",
  queued:   "bg-blue-950 text-blue-400",
  running:  "bg-violet-950 text-violet-400",
  open:     "bg-teal-950 text-teal-400",
  assigned: "bg-indigo-950 text-indigo-400",
};

function modeLabel(mode: string): string {
  return mode === "human" ? "👤 Human" : "🤖 AI";
}
---

<Layout title="Task Queue — Admin — CrowdSorcerer">
  <div class="max-w-7xl mx-auto px-6 py-10">
    <!-- Breadcrumb -->
    <div class="text-sm text-gray-500 mb-6">
      <a href="/admin" class="hover:text-gray-300 transition-colors">Admin</a>
      <span class="mx-2">›</span>
      <span>Task Queue</span>
    </div>

    <div class="flex items-start justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold">⏳ Task Queue</h1>
        <p class="text-gray-400 text-sm mt-1">Live view of all tasks awaiting or currently in processing</p>
      </div>
      {queue && (
        <div class="text-sm text-gray-500">
          <span class="font-medium text-white">{queue.queue_size}</span> tasks in queue
          <span class="mx-2">·</span>
          ETA confidence:
          <span class:list={[
            "font-medium",
            queue.eta_model?.confidence === "high" ? "text-green-400" :
            queue.eta_model?.confidence === "medium" ? "text-yellow-400" : "text-red-400"
          ]}>
            {queue.eta_model?.confidence ?? "low"}
          </span>
        </div>
      )}
    </div>

    {error && (
      <div class="rounded-xl bg-red-900/30 border border-red-700 p-4 text-red-300 text-sm mb-6">{error}</div>
    )}

    <!-- Filters -->
    <form method="GET" class="bg-gray-900 border border-gray-800 rounded-xl p-4 mb-6 flex gap-3 flex-wrap items-center">
      <select name="mode" class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 focus:outline-none">
        <option value="">All execution modes</option>
        <option value="ai" selected={modeFilter === "ai"}>🤖 AI tasks only</option>
        <option value="human" selected={modeFilter === "human"}>👤 Human tasks only</option>
      </select>
      <button type="submit" class="px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm rounded-lg transition-colors">
        Apply
      </button>
      {modeFilter && (
        <a href="/admin/queue" class="px-4 py-2 bg-gray-700 hover:bg-gray-600 text-gray-300 text-sm rounded-lg transition-colors">
          Clear
        </a>
      )}
      <button
        type="button"
        id="refresh-btn"
        class="ml-auto px-4 py-2 border border-gray-700 hover:border-violet-500 text-gray-400 hover:text-violet-300 text-sm rounded-lg transition-colors"
      >
        ↻ Refresh
      </button>
    </form>

    {!queue || queue.queue_size === 0 ? (
      <div class="bg-gray-900 border border-gray-800 rounded-xl px-6 py-20 text-center">
        <div class="text-5xl mb-4">✅</div>
        <h3 class="text-lg font-semibold mb-2 text-gray-300">Queue is empty</h3>
        <p class="text-gray-500 text-sm">All tasks are either completed or there are none pending.</p>
      </div>
    ) : (
      <div class="space-y-6">
        {queue.by_priority.filter((p: any) => p.count > 0).map((group: any) => {
          const meta = PRIORITY_META[group.priority] ?? PRIORITY_META.normal;
          return (
            <div class:list={["bg-gray-900 border rounded-xl overflow-hidden", meta.ring]}>
              <!-- Priority header -->
              <div class="px-6 py-3 bg-gray-800/50 border-b border-gray-800 flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span class:list={["h-2.5 w-2.5 rounded-full flex-shrink-0", meta.dot]}></span>
                  <span class="font-semibold text-sm">{meta.label}</span>
                  <span class="text-gray-500 text-xs">({group.count} task{group.count !== 1 ? "s" : ""})</span>
                </div>
                {group.oldest_age_minutes > 0 && (
                  <span class="text-xs text-gray-500">
                    Oldest: <span class:list={[
                      "font-medium",
                      group.oldest_age_minutes > 120 ? "text-red-400" :
                      group.oldest_age_minutes > 30 ? "text-yellow-400" : "text-gray-300"
                    ]}>
                      {group.oldest_age_minutes < 60
                        ? `${group.oldest_age_minutes}m`
                        : `${(group.oldest_age_minutes / 60).toFixed(1)}h`}
                    </span>
                  </span>
                )}
              </div>

              <!-- Task rows -->
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="border-b border-gray-800 text-left">
                      <th class="px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">Task ID</th>
                      <th class="px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">Type</th>
                      <th class="px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">Mode</th>
                      <th class="px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                      <th class="px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">Age</th>
                      <th class="px-4 py-2.5 text-xs font-semibold text-gray-500 uppercase tracking-wider">ETA</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-gray-800">
                    {group.tasks.slice(0, 20).map((task: any) => (
                      <tr class="hover:bg-gray-800/40 transition-colors">
                        <td class="px-4 py-3">
                          <a
                            href={`/dashboard/tasks/${task.id}`}
                            class="font-mono text-xs text-violet-300 hover:text-violet-200"
                          >
                            {task.id.slice(0, 8)}…
                          </a>
                        </td>
                        <td class="px-4 py-3 text-xs text-gray-300 font-mono">{task.type}</td>
                        <td class="px-4 py-3 text-xs text-gray-400">{modeLabel(task.execution_mode)}</td>
                        <td class="px-4 py-3">
                          <span class:list={[
                            "text-xs px-2 py-0.5 rounded-full font-medium",
                            STATUS_COLORS[task.status] ?? "bg-gray-800 text-gray-400"
                          ]}>
                            {task.status}
                          </span>
                        </td>
                        <td class="px-4 py-3 text-xs text-gray-400">
                          {task.age_minutes < 60
                            ? `${task.age_minutes}m`
                            : `${(task.age_minutes / 60).toFixed(1)}h`}
                        </td>
                        <td class="px-4 py-3">
                          <span class:list={[
                            "text-xs font-medium",
                            task.eta_label === "Overdue" ? "text-red-400" :
                            task.has_eta_sample ? "text-gray-300" : "text-gray-600"
                          ]}>
                            {task.eta_label}
                            {!task.has_eta_sample && <span class="text-gray-600 ml-1">est.</span>}
                          </span>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>

              {group.count > 20 && (
                <div class="px-6 py-3 bg-gray-900/50 text-xs text-gray-500 text-center border-t border-gray-800">
                  Showing first 20 of {group.count} {group.priority}-priority tasks
                </div>
              )}
            </div>
          );
        })}
      </div>
    )}

    <!-- ETA model info -->
    {queue?.eta_model && (
      <div class="mt-8 bg-gray-900/50 border border-gray-800 rounded-xl p-5">
        <h3 class="text-sm font-semibold text-gray-400 mb-2">📊 ETA Model</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-xs">
          <div>
            <div class="text-gray-500">Data lookback</div>
            <div class="text-gray-200 font-medium mt-0.5">{queue.eta_model.lookback_days} days</div>
          </div>
          <div>
            <div class="text-gray-500">Task types w/ data</div>
            <div class="text-gray-200 font-medium mt-0.5">{queue.eta_model.covered_task_types} / {queue.eta_model.total_queue_types}</div>
          </div>
          <div>
            <div class="text-gray-500">Confidence</div>
            <div class:list={[
              "font-medium mt-0.5",
              queue.eta_model.confidence === "high" ? "text-green-400" :
              queue.eta_model.confidence === "medium" ? "text-yellow-400" : "text-red-400"
            ]}>
              {queue.eta_model.confidence}
            </div>
          </div>
          <div>
            <div class="text-gray-500">Generated</div>
            <div class="text-gray-400 font-mono mt-0.5">
              {new Date(queue.generated_at).toLocaleTimeString()}
            </div>
          </div>
        </div>
        <p class="text-xs text-gray-600 mt-3">
          ETAs are estimated from average completion times for matching task types over the past {queue.eta_model.lookback_days} days.
          Tasks without historical data show fallback estimates (30s for AI, 4h for human).
        </p>
      </div>
    )}
  </div>

  <script>
    document.getElementById("refresh-btn")?.addEventListener("click", () => {
      window.location.reload();
    });
  </script>
</Layout>
