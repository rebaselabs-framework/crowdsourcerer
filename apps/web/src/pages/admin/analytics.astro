---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login");

let analytics: any = null;
let error: string | null = null;

try {
  analytics = await apiFetch<any>("/v1/admin/analytics?days=30", { token });
} catch (e: any) {
  if (e.message?.includes("403")) {
    error = "forbidden";
  } else if (e.message?.includes("401")) {
    return Astro.redirect("/login");
  } else {
    error = "Failed to load analytics";
  }
}

// Pre-process for charts (server-side JSON)
const chartData = analytics ? {
  days: analytics.all_days.map((d: string) => {
    const dt = new Date(d);
    return dt.toLocaleDateString("en-US", { month: "short", day: "numeric" });
  }),
  tasksTotal:     analytics.daily_tasks.map((d: any) => d.total),
  tasksCompleted: analytics.daily_tasks.map((d: any) => d.completed),
  tasksFailed:    analytics.daily_tasks.map((d: any) => d.failed),
  tasksHuman:     analytics.daily_tasks.map((d: any) => d.human),
  tasksAI:        analytics.daily_tasks.map((d: any) => d.ai),
  signupsTotal:   analytics.daily_signups.map((d: any) => d.total),
  signupsWorkers: analytics.daily_signups.map((d: any) => d.workers),
  creditsConsumed: analytics.daily_credits_consumed,
  completionsTotal: analytics.daily_worker_completions.map((d: any) => d.total),
  completionsCredits: analytics.daily_worker_completions.map((d: any) => d.credits_earned),
  hours: Array.from({length: 24}, (_, i) => `${i}:00`),
  hourlyTasks: analytics.hourly_tasks_today,
} : null;
---

<Layout title="Analytics — CrowdSorcerer Admin">
  <div class="max-w-7xl mx-auto px-6 py-10">
    <div class="flex items-start justify-between mb-8">
      <div>
        <div class="flex items-center gap-2 mb-1">
          <a href="/admin" class="text-gray-500 hover:text-gray-300 text-sm transition-colors">Admin</a>
          <span class="text-gray-500">/</span>
          <span class="text-sm text-gray-300">Analytics</span>
        </div>
        <h1 class="text-2xl font-bold">Platform Analytics</h1>
        <p class="text-gray-400 text-sm mt-1">30-day trends — task throughput, growth, worker activity</p>
      </div>
      <div class="flex gap-3 items-center">
        <span class="text-xs text-gray-500">
          Last updated: {analytics ? new Date(analytics.generated_at).toLocaleString() : "—"}
        </span>
        <a href="/admin" class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-sm text-gray-300 rounded-lg transition-colors">
          ← Dashboard
        </a>
      </div>
    </div>

    {error === "forbidden" ? (
      <div class="bg-red-950/30 border border-red-800 rounded-xl p-8 text-center">
        <div class="text-4xl mb-4">🚫</div>
        <h2 class="text-xl font-bold mb-2 text-red-400">Access Denied</h2>
        <p class="text-gray-400 text-sm">You need admin privileges to view this page.</p>
        <a href="/dashboard" class="inline-block mt-4 text-violet-400 hover:text-violet-300 text-sm">← Back to dashboard</a>
      </div>
    ) : error ? (
      <div class="bg-red-950/30 border border-red-800 rounded-xl p-4 text-red-300 text-sm">{error}</div>
    ) : analytics && chartData ? (
      <>
        <!-- Summary KPIs -->
        <div class="grid grid-cols-5 gap-4 mb-8">
          {[
            {
              label: "Total tasks (30d)",
              value: chartData.tasksTotal.reduce((a: number, b: number) => a + b, 0).toLocaleString(),
              sub: `${chartData.tasksCompleted.reduce((a: number, b: number) => a + b, 0)} completed`,
              color: "text-white",
              icon: "📋",
            },
            {
              label: "New signups (30d)",
              value: chartData.signupsTotal.reduce((a: number, b: number) => a + b, 0).toLocaleString(),
              sub: `${chartData.signupsWorkers.reduce((a: number, b: number) => a + b, 0)} workers`,
              color: "text-blue-400",
              icon: "👤",
            },
            {
              label: "Credits consumed (30d)",
              value: chartData.creditsConsumed.reduce((a: number, b: number) => a + b, 0).toLocaleString(),
              sub: `≈ $${(chartData.creditsConsumed.reduce((a: number, b: number) => a + b, 0) / 100).toFixed(2)} revenue`,
              color: "text-yellow-400",
              icon: "💰",
            },
            {
              label: "Worker completions (30d)",
              value: chartData.completionsTotal.reduce((a: number, b: number) => a + b, 0).toLocaleString(),
              sub: `${chartData.completionsCredits.reduce((a: number, b: number) => a + b, 0)} credits paid out`,
              color: "text-violet-400",
              icon: "✅",
            },
            {
              label: "Tasks today",
              value: chartData.hourlyTasks.reduce((a: number, b: number) => a + b, 0).toLocaleString(),
              sub: `peak: ${Math.max(...chartData.hourlyTasks)} tasks/hr`,
              color: "text-green-400",
              icon: "📈",
            },
          ].map(({ label, value, sub, color, icon }) => (
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs text-gray-500">{label}</span>
                <span class="text-lg">{icon}</span>
              </div>
              <div class:list={["text-2xl font-bold mb-1", color]}>{value}</div>
              <div class="text-xs text-gray-500">{sub}</div>
            </div>
          ))}
        </div>

        <!-- Row 1: Task throughput + Signups -->
        <div class="grid grid-cols-2 gap-6 mb-6">
          <!-- Task throughput -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-semibold text-sm">Task Throughput (30 days)</h3>
              <div class="flex items-center gap-4 text-xs text-gray-500">
                <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-violet-500 inline-block"></span> Total</span>
                <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-green-500 inline-block"></span> Done</span>
                <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-red-500 inline-block"></span> Failed</span>
              </div>
            </div>
            <div class="relative h-52">
              <canvas id="taskThroughputChart"></canvas>
            </div>
          </div>

          <!-- User signups -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-semibold text-sm">User Growth (30 days)</h3>
              <div class="flex items-center gap-4 text-xs text-gray-500">
                <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-blue-500 inline-block"></span> All users</span>
                <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-violet-500 inline-block"></span> Workers</span>
              </div>
            </div>
            <div class="relative h-52">
              <canvas id="signupsChart"></canvas>
            </div>
          </div>
        </div>

        <!-- Row 2: Credits consumed + Worker completions -->
        <div class="grid grid-cols-2 gap-6 mb-6">
          <!-- Credits consumed -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-semibold text-sm">Credits Consumed (30 days)</h3>
              <span class="text-xs text-gray-500">= platform revenue proxy</span>
            </div>
            <div class="relative h-52">
              <canvas id="creditsChart"></canvas>
            </div>
          </div>

          <!-- Worker activity -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-semibold text-sm">Worker Completions (30 days)</h3>
              <div class="flex items-center gap-4 text-xs text-gray-500">
                <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-violet-500 inline-block"></span> Submissions</span>
                <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-yellow-500 inline-block"></span> Credits paid</span>
              </div>
            </div>
            <div class="relative h-52">
              <canvas id="workerChart"></canvas>
            </div>
          </div>
        </div>

        <!-- Row 3: AI vs Human tasks + Hourly today -->
        <div class="grid grid-cols-2 gap-6 mb-6">
          <!-- AI vs Human -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-semibold text-sm">AI vs Human Tasks (30 days)</h3>
              <div class="flex items-center gap-4 text-xs text-gray-500">
                <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-cyan-500 inline-block"></span> AI</span>
                <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-pink-500 inline-block"></span> Human</span>
              </div>
            </div>
            <div class="relative h-52">
              <canvas id="taskModeChart"></canvas>
            </div>
          </div>

          <!-- Hourly today -->
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-semibold text-sm">Hourly Activity Today</h3>
              <span class="text-xs text-gray-500">tasks created by hour</span>
            </div>
            <div class="relative h-52">
              <canvas id="hourlyChart"></canvas>
            </div>
          </div>
        </div>

        <!-- Top Workers table -->
        <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
          <div class="px-5 py-4 border-b border-gray-800 flex items-center justify-between">
            <h3 class="font-semibold text-sm">🏆 Top Workers</h3>
            <a href="/worker/leaderboard" class="text-xs text-violet-400 hover:text-violet-300 transition-colors">
              Full leaderboard →
            </a>
          </div>
          {analytics.top_workers.length > 0 ? (
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-gray-800">
                    <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-8">#</th>
                    <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Worker</th>
                    <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Level</th>
                    <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">XP</th>
                    <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Tasks</th>
                    <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Accuracy</th>
                    <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Streak</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-800">
                  {analytics.top_workers.map((w: any, i: number) => (
                    <tr class="hover:bg-gray-800/40 transition-colors">
                      <td class="px-5 py-3 text-gray-500 text-xs">{i + 1}</td>
                      <td class="px-5 py-3">
                        <div class="flex items-center gap-3">
                          <div class="w-8 h-8 rounded-full bg-violet-900/60 flex items-center justify-center text-xs font-bold text-violet-300">
                            {w.name.charAt(0).toUpperCase()}
                          </div>
                          <span class="font-medium">{w.name}</span>
                        </div>
                      </td>
                      <td class="px-5 py-3 text-right">
                        <span class="bg-violet-900/40 text-violet-300 text-xs px-2 py-0.5 rounded-full">Lv {w.level}</span>
                      </td>
                      <td class="px-5 py-3 text-right font-mono text-yellow-400">{w.xp.toLocaleString()}</td>
                      <td class="px-5 py-3 text-right text-green-400">{w.tasks_completed}</td>
                      <td class="px-5 py-3 text-right">
                        {w.accuracy !== null ? (
                          <span class:list={[w.accuracy >= 80 ? "text-green-400" : w.accuracy >= 60 ? "text-yellow-400" : "text-red-400"]}>
                            {w.accuracy}%
                          </span>
                        ) : (
                          <span class="text-gray-500">—</span>
                        )}
                      </td>
                      <td class="px-5 py-3 text-right">
                        {w.streak_days > 0 ? (
                          <span class="text-orange-400">🔥 {w.streak_days}d</span>
                        ) : (
                          <span class="text-gray-500">—</span>
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ) : (
            <div class="px-5 py-10 text-center text-gray-500 text-sm">
              No workers have completed tasks yet.
            </div>
          )}
        </div>

        <!-- Payout summary -->
        {Object.keys(analytics.payout_summary).length > 0 && (
          <div class="mt-6 bg-gray-900 border border-gray-800 rounded-xl p-5">
            <h3 class="font-semibold text-sm mb-4">💸 Payout Summary</h3>
            <div class="grid grid-cols-4 gap-4">
              {(["pending", "processing", "paid", "rejected"] as const).map((status) => {
                const info = analytics.payout_summary[status] || { count: 0, usd: 0 };
                const colors: {[key: string]: string} = {
                  pending: "text-yellow-400",
                  processing: "text-blue-400",
                  paid: "text-green-400",
                  rejected: "text-red-400",
                };
                return (
                  <div class="bg-gray-800/50 rounded-lg p-4">
                    <div class="text-xs text-gray-500 mb-1 capitalize">{status}</div>
                    <div class:list={["text-xl font-bold", colors[status]]}>${info.usd.toFixed(2)}</div>
                    <div class="text-xs text-gray-500">{info.count} request{info.count !== 1 ? "s" : ""}</div>
                  </div>
                );
              })}
            </div>
          </div>
        )}
      </>
    ) : null}
  </div>

  <!-- Chart rendering (client-side) -->
  {chartData && (
    <script is:inline define:vars={{ chartData }}>
      function _loadChartJs(cb) {
        if (window.Chart) { cb(); return; }
        const s = document.createElement("script");
        s.src = "https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js";
        s.onload = cb;
        document.head.appendChild(s);
      }
      _loadChartJs(function() {
      const CHART_DEFAULTS = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: "#1f2937",
            borderColor: "#374151",
            borderWidth: 1,
            titleColor: "#f9fafb",
            bodyColor: "#d1d5db",
          },
        },
        scales: {
          x: {
            ticks: { color: "#6b7280", font: { size: 10 }, maxRotation: 45, maxTicksLimit: 10 },
            grid: { color: "#1f2937" },
          },
          y: {
            ticks: { color: "#6b7280", font: { size: 10 } },
            grid: { color: "#1f2937" },
            beginAtZero: true,
          },
        },
      };

      function makeChart(id, config) {
        const el = document.getElementById(id);
        if (!el) return;
        return new Chart(el, { ...config });
      }

      // 1. Task Throughput
      makeChart("taskThroughputChart", {
        type: "line",
        data: {
          labels: chartData.days,
          datasets: [
            {
              label: "Total",
              data: chartData.tasksTotal,
              borderColor: "#8b5cf6",
              backgroundColor: "rgba(139,92,246,0.08)",
              fill: true,
              tension: 0.3,
              pointRadius: 2,
            },
            {
              label: "Completed",
              data: chartData.tasksCompleted,
              borderColor: "#22c55e",
              backgroundColor: "transparent",
              tension: 0.3,
              pointRadius: 2,
            },
            {
              label: "Failed",
              data: chartData.tasksFailed,
              borderColor: "#ef4444",
              backgroundColor: "transparent",
              tension: 0.3,
              pointRadius: 2,
            },
          ],
        },
        options: CHART_DEFAULTS,
      });

      // 2. User Signups
      makeChart("signupsChart", {
        type: "bar",
        data: {
          labels: chartData.days,
          datasets: [
            {
              label: "All users",
              data: chartData.signupsTotal,
              backgroundColor: "rgba(59,130,246,0.7)",
              borderRadius: 4,
            },
            {
              label: "Workers",
              data: chartData.signupsWorkers,
              backgroundColor: "rgba(139,92,246,0.7)",
              borderRadius: 4,
            },
          ],
        },
        options: {
          ...CHART_DEFAULTS,
          scales: {
            ...CHART_DEFAULTS.scales,
            x: { ...CHART_DEFAULTS.scales.x, stacked: false },
            y: { ...CHART_DEFAULTS.scales.y, stacked: false },
          },
        },
      });

      // 3. Credits consumed
      makeChart("creditsChart", {
        type: "bar",
        data: {
          labels: chartData.days,
          datasets: [
            {
              label: "Credits consumed",
              data: chartData.creditsConsumed,
              backgroundColor: "rgba(234,179,8,0.7)",
              borderRadius: 4,
            },
          ],
        },
        options: CHART_DEFAULTS,
      });

      // 4. Worker completions
      makeChart("workerChart", {
        type: "line",
        data: {
          labels: chartData.days,
          datasets: [
            {
              label: "Submissions",
              data: chartData.completionsTotal,
              borderColor: "#8b5cf6",
              backgroundColor: "rgba(139,92,246,0.08)",
              fill: true,
              tension: 0.3,
              pointRadius: 2,
              yAxisID: "y",
            },
            {
              label: "Credits paid",
              data: chartData.completionsCredits,
              borderColor: "#eab308",
              backgroundColor: "transparent",
              tension: 0.3,
              pointRadius: 2,
              yAxisID: "y1",
            },
          ],
        },
        options: {
          ...CHART_DEFAULTS,
          scales: {
            ...CHART_DEFAULTS.scales,
            y: {
              ...CHART_DEFAULTS.scales.y,
              position: "left",
            },
            y1: {
              type: "linear",
              display: true,
              position: "right",
              ticks: { color: "#6b7280", font: { size: 10 } },
              grid: { drawOnChartArea: false },
              beginAtZero: true,
            },
          },
        },
      });

      // 5. AI vs Human tasks
      makeChart("taskModeChart", {
        type: "line",
        data: {
          labels: chartData.days,
          datasets: [
            {
              label: "AI tasks",
              data: chartData.tasksAI,
              borderColor: "#06b6d4",
              backgroundColor: "rgba(6,182,212,0.08)",
              fill: true,
              tension: 0.3,
              pointRadius: 2,
            },
            {
              label: "Human tasks",
              data: chartData.tasksHuman,
              borderColor: "#ec4899",
              backgroundColor: "rgba(236,72,153,0.08)",
              fill: true,
              tension: 0.3,
              pointRadius: 2,
            },
          ],
        },
        options: CHART_DEFAULTS,
      });

      // 6. Hourly today
      makeChart("hourlyChart", {
        type: "bar",
        data: {
          labels: chartData.hours,
          datasets: [
            {
              label: "Tasks",
              data: chartData.hourlyTasks,
              backgroundColor: (ctx) => {
                const max = Math.max(...chartData.hourlyTasks);
                const val = ctx.raw;
                const alpha = max > 0 ? 0.3 + (val / max) * 0.7 : 0.3;
                return `rgba(139,92,246,${alpha})`;
              },
              borderRadius: 4,
            },
          ],
        },
        options: {
          ...CHART_DEFAULTS,
          scales: {
            x: {
              ticks: { color: "#6b7280", font: { size: 9 }, maxRotation: 0 },
              grid: { color: "#1f2937" },
            },
            y: {
              ticks: { color: "#6b7280", font: { size: 10 } },
              grid: { color: "#1f2937" },
              beginAtZero: true,
            },
          },
        },
      });
      }); // end _loadChartJs
    </script>
  )}
</Layout>
