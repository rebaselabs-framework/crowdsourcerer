---
/**
 * /admin/setup — System configuration checklist.
 * Shows which platform features are enabled based on env vars,
 * without exposing credentials.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);
if (!token) return Astro.redirect("/login");

let config: any = null;
let error = "";

try {
  config = await apiFetch<any>("/v1/admin/config/status", { token });
} catch (e: any) {
  const msg = e.message ?? "";
  if (msg.includes("401")) return Astro.redirect("/login");
  if (msg.includes("403") || msg.includes("Not an admin")) {
    return Astro.redirect("/dashboard");
  }
  error = msg || "Failed to load configuration status";
}

interface Check {
  name: string;
  configured: boolean;
  detail: string;
  required: boolean;
}

// Pre-compute entries so the template doesn't need TypeScript casts
const configEntries: Array<[string, Check]> = config
  ? Object.entries(config.checks as Record<string, Check>)
  : [];
---

<Layout title="Setup Checklist — CrowdSorcerer Admin">
  <div class="max-w-3xl mx-auto px-6 py-10">
    <!-- Header -->
    <div class="flex items-center gap-3 mb-2">
      <a href="/admin" class="text-gray-500 hover:text-gray-300 text-sm transition-colors">← Admin</a>
    </div>
    <h1 class="text-2xl font-bold text-white mb-1">⚙️ Setup Checklist</h1>
    <p class="text-gray-400 text-sm mb-8">
      Verify that all required services are configured for production use.
    </p>

    {error ? (
      <div class="bg-red-900/30 border border-red-700 text-red-300 rounded-lg p-4 text-sm">{error}</div>
    ) : config ? (
      <>
        <!-- Summary banner -->
        <div class:list={[
          "rounded-xl border px-5 py-4 mb-8 flex items-center gap-4",
          config.ready
            ? "bg-emerald-900/20 border-emerald-700/40"
            : "bg-amber-900/20 border-amber-700/40"
        ]}>
          <span class="text-3xl">{config.ready ? "✅" : "⚠️"}</span>
          <div>
            <div class="font-semibold text-white">
              {config.ready ? "Required services configured" : "Action required"}
            </div>
            <div class="text-sm text-gray-400 mt-0.5">
              {config.summary}
              {!config.ready && " — fix the items marked Required below before going to production."}
              {config.ready && !config.all_optional_configured && " — some optional features are disabled."}
            </div>
          </div>
        </div>

        <!-- Config checklist -->
        <div class="space-y-3">
          {configEntries.map(([key, check]) => (
            <div class:list={[
              "rounded-xl border p-4 flex items-start gap-4",
              check.configured
                ? "bg-gray-800/40 border-gray-700/50"
                : check.required
                  ? "bg-red-900/20 border-red-700/40"
                  : "bg-gray-800/20 border-gray-700/30"
            ]}>
              <!-- Status icon -->
              <div class:list={[
                "flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold mt-0.5",
                check.configured
                  ? "bg-emerald-900/50 text-emerald-400"
                  : check.required
                    ? "bg-red-900/50 text-red-400"
                    : "bg-gray-700 text-gray-500"
              ]}>
                {check.configured ? "✓" : check.required ? "!" : "–"}
              </div>

              <!-- Content -->
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="font-medium text-white text-sm">{check.name}</span>
                  {check.required && !check.configured && (
                    <span class="text-xs px-1.5 py-0.5 bg-red-900/50 text-red-300 border border-red-700/40 rounded font-medium">
                      Required
                    </span>
                  )}
                  {check.required && check.configured && (
                    <span class="text-xs px-1.5 py-0.5 bg-emerald-900/50 text-emerald-400 border border-emerald-700/40 rounded font-medium">
                      Required ✓
                    </span>
                  )}
                  {!check.required && check.configured && (
                    <span class="text-xs text-gray-500">Optional</span>
                  )}
                  {!check.required && !check.configured && (
                    <span class="text-xs text-gray-500">Optional — disabled</span>
                  )}
                </div>
                <p class="text-sm text-gray-400 mt-0.5">{check.detail}</p>
              </div>

              <!-- Setup link for un-configured items -->
              {!check.configured && (
                <div class="flex-shrink-0 text-right">
                  {key === "email" && (
                    <span class="text-xs text-gray-500">Set SMTP_* env vars</span>
                  )}
                  {key === "stripe" && (
                    <a href="https://dashboard.stripe.com" target="_blank" rel="noopener"
                       class="text-xs text-violet-400 hover:text-violet-300">
                      Stripe dashboard ↗
                    </a>
                  )}
                  {key === "google_oauth" && (
                    <a href="https://console.cloud.google.com/apis/credentials" target="_blank" rel="noopener"
                       class="text-xs text-violet-400 hover:text-violet-300">
                      Google Console ↗
                    </a>
                  )}
                  {key === "rebasekit" && (
                    <a href="https://rebaselabs.online" target="_blank" rel="noopener"
                       class="text-xs text-violet-400 hover:text-violet-300">
                      RebaseLabs ↗
                    </a>
                  )}
                  {(key === "jwt_secret" || key === "api_key_salt") && (
                    <span class="text-xs text-amber-400">Set in Coolify env vars</span>
                  )}
                </div>
              )}
            </div>
          ))}
        </div>

        <!-- Instructions for unconfigured items -->
        {!config.ready && (
          <div class="mt-8 bg-gray-800/50 border border-gray-700 rounded-xl p-5 text-sm text-gray-300 space-y-2">
            <p class="font-semibold text-white">How to configure</p>
            <p>Set the missing environment variables in your Coolify → Service → Environment Variables panel, then redeploy.</p>
            <ul class="list-disc list-inside space-y-1 text-gray-400 mt-2">
              <li><code class="text-violet-300">JWT_SECRET</code> — run <code>openssl rand -hex 32</code></li>
              <li><code class="text-violet-300">API_KEY_SALT</code> — run <code>openssl rand -hex 32</code></li>
              <li><code class="text-violet-300">REBASEKIT_API_KEY</code> — from RebaseLabs dashboard</li>
            </ul>
          </div>
        )}

        <!-- Optional features guide -->
        {config.ready && !config.all_optional_configured && (
          <div class="mt-8 bg-gray-800/30 border border-gray-700/50 rounded-xl p-5 text-sm text-gray-400">
            <p class="font-semibold text-gray-300 mb-2">Optional feature setup</p>
            <ul class="space-y-1.5">
              <li>
                <span class="text-white font-medium">Email notifications:</span>
                Set <code class="text-violet-300">EMAIL_ENABLED=true</code>,
                <code class="text-violet-300">SMTP_HOST</code>,
                <code class="text-violet-300">SMTP_USER</code>,
                <code class="text-violet-300">SMTP_PASS</code>
              </li>
              <li>
                <span class="text-white font-medium">Stripe billing:</span>
                Set <code class="text-violet-300">STRIPE_SECRET_KEY</code> and
                <code class="text-violet-300">STRIPE_WEBHOOK_SECRET</code>
              </li>
              <li>
                <span class="text-white font-medium">Google OAuth:</span>
                Create OAuth 2.0 credentials at
                <a href="https://console.cloud.google.com/apis/credentials" target="_blank" rel="noopener"
                   class="text-violet-400 hover:text-violet-300">Google Cloud Console</a>,
                set <code class="text-violet-300">GOOGLE_CLIENT_ID</code> and
                <code class="text-violet-300">GOOGLE_CLIENT_SECRET</code>.
                Redirect URI: <code class="text-violet-300">https://crowdsourcerer.rebaselabs.online/v1/auth/google/callback</code>
              </li>
            </ul>
          </div>
        )}
      </>
    ) : null}
  </div>
</Layout>
