        </div>
      </a>
      <a href="/dashboard/security" class="bg-gray-900 border border-gray-800 hover:border-red-600 rounded-xl p-4 transition-colors flex items-center gap-3">
        <span class="text-xl">🔐</span>
        <div>
          <div class="font-medium text-sm">Security</div>
          <div class="text-xs text-gray-500">Two-factor authentication</div>
        </div>
      </a>
      <a href="/dashboard/scheduled" class="bg-gray-900 border border-gray-800 hover:border-amber-600 rounded-xl p-4 transition-colors flex items-center gap-3">
        <span class="text-xl">⏰</span>
