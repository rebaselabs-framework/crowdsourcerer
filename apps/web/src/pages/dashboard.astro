---
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);

if (!token) {
  return Astro.redirect("/login");
}

let user: any = null;
let credits: any = null;
let tasks: any = null;
let apiKeys: any = [];
let onboardingStatus: any = null;
let pendingReviewCount = 0;
let dashboardError: string | null = null;

try {
  [user, credits, tasks, apiKeys] = await Promise.all([
    apiFetch<any>("/v1/users/me", { token }),
    apiFetch<any>("/v1/credits", { token }),
    apiFetch<any>("/v1/tasks?page_size=5", { token }),
    apiFetch<any>("/v1/api-keys", { token }),
  ]);
} catch (e: any) {
  if (e.message?.includes("401") || e.message?.includes("403")) return Astro.redirect("/login");
  dashboardError = "Failed to load dashboard data. Please try again.";
}

// Non-blocking: fetch onboarding status + pending review count
try {
  const [onboardingData, reviewSummary] = await Promise.all([
    apiFetch<any>("/v1/requester-onboarding/status", { token }).catch(() => null),
    apiFetch<any>("/v1/tasks/review-summary", { token }).catch(() => null),
  ]);
  onboardingStatus = onboardingData;
  pendingReviewCount = reviewSummary?.pending_count ?? 0;
} catch (_) {}

const TASK_TYPE_LABELS: Record<string, string> = {
  web_research: "Web Research",
  web_intel: "Web Intel",
  llm_generate: "LLM Generate",
  llm_transform: "LLM Transform",
  llm_extract: "LLM Extract",
  llm_classify: "LLM Classify",
  llm_score: "LLM Score",
  llm_compare: "LLM Compare",
  data_transform: "Data Transform",
  entity_lookup: "Entity Lookup",
  screenshot: "Screenshot",
  pii_detect: "PII Detection",
  label_image: "Label Image",
  label_text: "Classify Text",
  rate_quality: "Rate Quality",
  verify_fact: "Verify Fact",
  moderate_content: "Moderate Content",
  compare_rank: "A/B Compare",
  answer_question: "Answer Question",
  transcription_review: "Transcription Review",
};

// Show onboarding banner if not yet complete and not skipped
const showOnboardingBanner = Boolean(
  onboardingStatus &&
  !onboardingStatus.all_complete &&
  !onboardingStatus.skipped_at
);
---

<Layout title="Dashboard — CrowdSorcerer">
  <div class="max-w-5xl mx-auto px-6 py-10">

    {dashboardError && (
      <div class="bg-red-900/30 border border-red-800 text-red-300 rounded-xl p-5 mb-6 flex items-center justify-between gap-4">
        <span>⚠️ {dashboardError}</span>
        <a href="/dashboard" class="text-sm text-red-400 hover:text-red-300 underline whitespace-nowrap">Try again</a>
      </div>
    )}

    <!-- New-user onboarding banner -->
    {showOnboardingBanner && (
      <div class="bg-gradient-to-r from-violet-950/60 to-indigo-950/40 border border-violet-700/50 rounded-xl px-6 py-5 mb-8">
        <div class="flex items-start justify-between gap-4">
          <div>
            <div class="flex items-center gap-2 mb-1.5">
              <span class="text-xl">🚀</span>
              <h2 class="font-semibold text-violet-200 text-base">Welcome to CrowdSorcerer!</h2>
            </div>
            <p class="text-sm text-gray-400 mb-3">
              You have <strong class="text-violet-300">{(credits?.available ?? 100).toLocaleString()} free credits</strong> — enough for
              {(credits?.available ?? 100) >= 10 ? ` ${Math.floor((credits?.available ?? 100) / 10).toLocaleString()} web research tasks` : " several quick tasks"}.
              Complete the quick-start guide to earn <strong class="text-amber-300">+200 bonus credits</strong>.
            </p>
            <div class="flex flex-wrap gap-3">
              <a href="/dashboard/requester-onboarding"
                class="inline-flex items-center gap-1.5 px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-semibold rounded-lg transition-colors">
                📋 Quick-start guide
              </a>
              <a href="/dashboard/new-task"
                class="inline-flex items-center gap-1.5 px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-200 text-sm font-medium rounded-lg transition-colors border border-gray-700">
                + Create first task
              </a>
              <a href="/docs"
                class="inline-flex items-center gap-1.5 px-4 py-2 text-gray-400 hover:text-gray-200 text-sm transition-colors">
                Read docs →
              </a>
            </div>
          </div>
          <div class="flex-shrink-0 hidden sm:flex flex-col items-center gap-1 bg-amber-900/20 border border-amber-800/40 rounded-xl px-4 py-3">
            <span class="text-2xl">🎁</span>
            <span class="text-xs text-amber-300 font-semibold whitespace-nowrap">+200 bonus</span>
            <span class="text-xs text-gray-500 whitespace-nowrap">on completion</span>
          </div>
        </div>
      </div>
    )}

    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold">Dashboard</h1>
        <p class="text-gray-400 text-sm mt-0.5">{user?.email}</p>
      </div>
      <a
        href="/dashboard/new-task"
        class="px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors"
      >
        + New task
      </a>
    </div>

    <!-- Stats -->
    <div class:list={["grid gap-4 mb-8", pendingReviewCount > 0 ? "grid-cols-2 sm:grid-cols-4" : "grid-cols-3"]}>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="flex items-center justify-between mb-1">
          <div class="text-sm text-gray-400">Credits available</div>
          <a href="/dashboard/credits" class="text-xs text-violet-400 hover:text-violet-300">Buy more →</a>
        </div>
        <div class="text-3xl font-bold text-violet-300">{credits?.available?.toLocaleString() ?? 0}</div>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="text-sm text-gray-400 mb-1">Credits used</div>
        <div class="text-3xl font-bold">{credits?.total_used?.toLocaleString() ?? 0}</div>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
        <div class="text-sm text-gray-400 mb-1">Total tasks</div>
        <div class="text-3xl font-bold">{tasks?.total ?? 0}</div>
      </div>
      {pendingReviewCount > 0 && (
        <a
          href="/dashboard/review"
          class="bg-yellow-950/30 border border-yellow-700/50 hover:border-yellow-600 rounded-xl p-5 transition-colors"
        >
          <div class="flex items-center justify-between mb-1">
            <div class="text-sm text-yellow-400/80">Pending review</div>
            <span class="text-[10px] font-semibold bg-yellow-500 text-yellow-950 rounded-full px-1.5 py-0.5">!</span>
          </div>
          <div class="text-3xl font-bold text-yellow-300">{pendingReviewCount}</div>
          <div class="text-xs text-yellow-600 mt-0.5">submissions →</div>
        </a>
      )}
    </div>

    <!-- Recent tasks -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl mb-6">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-800">
        <h2 class="font-semibold">Recent tasks</h2>
        <a href="/dashboard/tasks" class="text-sm text-violet-400 hover:text-violet-300">View all →</a>
      </div>
      {tasks?.items?.length === 0 ? (
        <!-- Rich empty state: first-task launcher -->
        <div class="px-6 py-8">
          <div class="text-center mb-6">
            <div class="text-3xl mb-2">🔮</div>
            <h3 class="font-semibold text-gray-200 mb-1">Submit your first task</h3>
            <p class="text-sm text-gray-500">Choose a task type below to get started — each one runs in seconds.</p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-6">
            {[
              { type: "web_research",  icon: "🌐", label: "Web Research",  desc: "Scrape any URL + extract key points",   credits: 10, hoverBorder: "hover:border-violet-700/60", textClass: "text-violet-400", hoverText: "group-hover:text-violet-300" },
              { type: "llm_generate",  icon: "🤖", label: "LLM Generate",  desc: "Generate text with Claude or GPT-4",   credits: 1,  hoverBorder: "hover:border-indigo-700/60",  textClass: "text-indigo-400",  hoverText: "group-hover:text-indigo-300"  },
              { type: "entity_lookup", icon: "🏢", label: "Entity Lookup", desc: "Enrich a company or person's profile", credits: 5,  hoverBorder: "hover:border-sky-700/60",    textClass: "text-sky-400",     hoverText: "group-hover:text-sky-300"     },
            ].map(({ type, icon, label, desc, credits, hoverBorder, textClass, hoverText }) => (
              <a href={`/dashboard/new-task?preset=${type}`}
                class={`group bg-gray-800/60 hover:bg-gray-800 border border-gray-700 ${hoverBorder} rounded-xl p-4 transition-all`}>
                <div class="text-2xl mb-2">{icon}</div>
                <div class="text-sm font-semibold text-gray-200 group-hover:text-white mb-1">{label}</div>
                <div class="text-xs text-gray-500 mb-3">{desc}</div>
                <div class="flex items-center justify-between">
                  <span class="text-xs text-gray-600">{credits} credit{credits !== 1 ? "s" : ""}</span>
                  <span class={`text-xs ${textClass} ${hoverText} font-medium`}>Try it →</span>
                </div>
              </a>
            ))}
          </div>
          <div class="text-center">
            <a href="/dashboard/new-task" class="text-sm text-gray-400 hover:text-gray-200 transition-colors">
              See all 18 task types →
            </a>
          </div>
        </div>
      ) : (
        <div class="divide-y divide-gray-800">
          {tasks?.items?.map((t: any) => (
            <a href={`/dashboard/tasks/${t.id}`} class="flex items-center justify-between px-6 py-4 hover:bg-gray-800/50 transition-colors">
              <div class="flex items-center gap-3">
                <span class="text-sm text-gray-200 font-medium">{TASK_TYPE_LABELS[t.type] ?? t.type}</span>
                <span class:list={[
                  "text-xs px-2 py-0.5 rounded-full",
                  t.status === "completed" ? "bg-green-950 text-green-400" :
                  t.status === "failed" ? "bg-red-950 text-red-400" :
                  t.status === "running" ? "bg-yellow-950 text-yellow-400" :
                  t.status === "open" ? "bg-emerald-950 text-emerald-400" :
                  t.status === "queued" ? "bg-blue-950 text-blue-400" :
                  "bg-gray-800 text-gray-400"
                ]}>
                  {t.status}
                </span>
              </div>
              <div class="flex items-center gap-4 text-sm text-gray-500">
                {t.execution_mode === "human" && (t.assignments_completed ?? 0) > 0 && (
                  <span class="text-xs text-yellow-500/80">
                    {t.assignments_completed}/{t.assignments_required} workers
                  </span>
                )}
                {t.credits_used && <span>{t.credits_used} cr</span>}
                <span>{new Date(t.created_at).toLocaleDateString()}</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Quick links — organised into sections for clarity -->
    <div class="space-y-6 mb-6">

      <!-- Tasks & Work -->
      <div>
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Tasks &amp; Work</h2>
        <div class="grid grid-cols-5 gap-3">
          {[
            { href: "/dashboard/requester", icon: "🎛️", label: "Requester Hub", sub: "Mission control", accent: "border-violet-800/50 hover:border-violet-600 text-violet-200" },
            { href: "/dashboard/tasks", icon: "📋", label: "All Tasks", sub: "View &amp; filter" },
            { href: "/dashboard/scheduled", icon: "⏰", label: "Scheduled", sub: "Deferred tasks" },
            { href: "/dashboard/review", icon: "✅", label: "Review", sub: "Human submissions" },
            { href: "/dashboard/disputes", icon: "⚖️", label: "Disputes", sub: "Resolve conflicts", accent: "hover:border-red-700" },
            { href: "/dashboard/quality", icon: "🎯", label: "Quality", sub: "Gold standards" },
            { href: "/dashboard/pipelines", icon: "⛓️", label: "Pipelines", sub: "Chain tasks", accent: "hover:border-violet-600" },
            { href: "/dashboard/triggers", icon: "🤖", label: "Triggers", sub: "Automate pipelines", accent: "hover:border-orange-600" },
            { href: "/dashboard/batch-upload", icon: "📤", label: "Batch Upload", sub: "CSV → tasks", accent: "hover:border-violet-700" },
            { href: "/dashboard/export", icon: "💾", label: "Export", sub: "Download task data" },
          ].map(({ href, icon, label, sub, accent }) => (
            <a href={href} class:list={["bg-gray-900 border border-gray-800 rounded-xl p-4 transition-colors flex items-center gap-3 hover:border-gray-600", accent ?? ""]}>
              <span class="text-xl flex-shrink-0">{icon}</span>
              <div class="min-w-0">
                <div class:list={["font-medium text-sm truncate", accent?.includes("text-") ? "text-violet-200" : ""]}>{label}</div>
                <div class="text-xs text-gray-500 truncate" set:html={sub}></div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Analytics & Insights -->
      <div>
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Analytics &amp; Insights</h2>
        <div class="grid grid-cols-5 gap-3">
          {[
            { href: "/dashboard/analytics", icon: "📊", label: "Usage Analytics", sub: "Costs &amp; trends", accent: "hover:border-blue-600" },
            { href: "/dashboard/revenue", icon: "💰", label: "Revenue", sub: "Spend &amp; forecast", accent: "hover:border-green-600" },
            { href: "/dashboard/sla", icon: "⏱", label: "SLA Monitor", sub: "Task deadlines", accent: "hover:border-amber-600" },
            { href: "/dashboard/experiments", icon: "🧪", label: "A/B Tests", sub: "Compare configs", accent: "hover:border-violet-600" },
            { href: "/dashboard/search", icon: "🔍", label: "Search", sub: "Find anything" },
          ].map(({ href, icon, label, sub, accent }) => (
            <a href={href} class:list={["bg-gray-900 border border-gray-800 rounded-xl p-4 transition-colors flex items-center gap-3 hover:border-gray-600", accent ?? ""]}>
              <span class="text-xl flex-shrink-0">{icon}</span>
              <div class="min-w-0">
                <div class="font-medium text-sm truncate">{label}</div>
                <div class="text-xs text-gray-500 truncate" set:html={sub}></div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Templates & Integrations -->
      <div>
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Templates &amp; Integrations</h2>
        <div class="grid grid-cols-5 gap-3">
          {[
            { href: "/dashboard/task-templates", icon: "📝", label: "My Templates", sub: "Saved configs", accent: "hover:border-violet-600" },
            { href: "/dashboard/marketplace", icon: "🏪", label: "Marketplace", sub: "Community templates", accent: "hover:border-emerald-600" },
            { href: "/dashboard/webhooks", icon: "📡", label: "Webhooks", sub: "Delivery logs" },
            { href: "/dashboard/api-keys", icon: "🔑", label: "API Keys", sub: "Manage keys" },
            { href: "/dashboard/team", icon: "🏢", label: "Teams", sub: "Shared credits", accent: "hover:border-indigo-600" },
          ].map(({ href, icon, label, sub, accent }) => (
            <a href={href} class:list={["bg-gray-900 border border-gray-800 rounded-xl p-4 transition-colors flex items-center gap-3 hover:border-gray-600", accent ?? ""]}>
              <span class="text-xl flex-shrink-0">{icon}</span>
              <div class="min-w-0">
                <div class="font-medium text-sm truncate">{label}</div>
                <div class="text-xs text-gray-500 truncate" set:html={sub}></div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Account & Settings -->
      <div>
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Account &amp; Settings</h2>
        <div class="grid grid-cols-5 gap-3">
          {[
            { href: "/dashboard/billing", icon: "💳", label: "Billing", sub: "Plans & credits", accent: "hover:border-green-600" },
            { href: "/dashboard/quota", icon: "📈", label: "Plan & Quota", sub: "Usage limits" },
            { href: "/dashboard/profile", icon: "👤", label: "My Profile", sub: "Bio & avatar", accent: "hover:border-indigo-600" },
            { href: "/dashboard/security", icon: "🔐", label: "Security", sub: "2FA & sessions", accent: "hover:border-red-600" },
            { href: "/dashboard/notifications", icon: "🔔", label: "Notifications", sub: "Activity feed" },
            { href: "/dashboard/notification-preferences", icon: "⚙️", label: "Alert Settings", sub: "Email & preferences" },
            { href: "/dashboard/saved-searches", icon: "📌", label: "Task Alerts", sub: "Saved searches" },
            { href: "/dashboard/referrals", icon: "🎁", label: "Invite Friends", sub: "Earn bonus credits" },
            { href: "/dashboard/worker/skill-quiz", icon: "🧠", label: "Skill Assessment", sub: "Level up" },
            { href: "/dashboard/requester-onboarding", icon: "🚀", label: "Get Started", sub: "Onboarding guide", accent: "hover:border-violet-600" },
          ].map(({ href, icon, label, sub, accent }) => (
            <a href={href} class:list={["bg-gray-900 border border-gray-800 rounded-xl p-4 transition-colors flex items-center gap-3 hover:border-gray-600", accent ?? ""]}>
              <span class="text-xl flex-shrink-0">{icon}</span>
              <div class="min-w-0">
                <div class="font-medium text-sm truncate">{label}</div>
                <div class="text-xs text-gray-500 truncate" set:html={sub}></div>
              </div>
            </a>
          ))}
        </div>
      </div>

    </div>

    <!-- API Keys -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-800">
        <h2 class="font-semibold">API Keys</h2>
        <a href="/dashboard/api-keys" class="text-sm text-violet-400 hover:text-violet-300">Manage →</a>
      </div>
      {apiKeys.length === 0 ? (
        <div class="px-6 py-8 text-center text-gray-500 text-sm">
          No API keys yet.
          <a href="/dashboard/api-keys" class="text-violet-400 ml-1">Create one →</a>
        </div>
      ) : (
        <div class="divide-y divide-gray-800">
          {apiKeys.map((k: any) => (
            <div class="flex items-center justify-between px-6 py-4">
              <div>
                <div class="font-medium text-sm">{k.name}</div>
                <div class="font-mono text-xs text-gray-500">{k.prefix}...</div>
              </div>
              <div class="text-xs text-gray-500">
                {k.last_used_at
                  ? `Last used ${new Date(k.last_used_at).toLocaleDateString()}`
                  : "Never used"}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</Layout>
