---
/**
 * Public worker profile page — /workers/{id}
 * No auth required.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch } from "@/lib/api";

const { id } = Astro.params as { id: string };

let profile: any = null;
let verifiedSkills: any[] = [];
let endorsements: any[] = [];
let endorsementCount = 0;
let portfolioItems: any[] = [];
let taskStats: any[] = [];
let recentActivity: any[] = [];
let error = "";

try {
  [profile, verifiedSkills] = await Promise.all([
    apiFetch<any>(`/v1/workers/${id}/profile`),
    apiFetch<any[]>(`/v1/workers/${id}/verified-skills`).catch(() => []),
  ]);
} catch (e: any) {
  error = e.message ?? "Worker not found";
}

if (profile) {
  try {
    const [endorsementsData, countData, portfolioData, statsData, activityData] = await Promise.all([
      apiFetch<any>(`/v1/workers/${id}/endorsements?limit=20`).catch(() => ({ items: [], total: 0 })),
      apiFetch<any>(`/v1/workers/${id}/endorsements/count`).catch(() => ({ count: 0 })),
      apiFetch<any>(`/v1/workers/${id}/portfolio`).catch(() => ({ items: [] })),
      apiFetch<any[]>(`/v1/workers/${id}/task-stats`).catch(() => []),
      apiFetch<any[]>(`/v1/workers/${id}/recent-activity?limit=10`).catch(() => []),
    ]);
    endorsements = endorsementsData.items ?? [];
    endorsementCount = countData.count ?? 0;
    portfolioItems = portfolioData.items ?? [];
    taskStats = Array.isArray(statsData) ? statsData : [];
    recentActivity = Array.isArray(activityData) ? activityData : [];
  } catch (_) {
    endorsements = [];
    endorsementCount = 0;
    portfolioItems = [];
    taskStats = [];
    recentActivity = [];
  }
}

function levelLabel(level: number): string {
  if (level >= 10) return "Expert";
  if (level >= 7)  return "Advanced";
  if (level >= 4)  return "Intermediate";
  return "Beginner";
}

function levelColor(level: number): string {
  if (level >= 10) return "text-yellow-400";
  if (level >= 7)  return "text-purple-400";
  if (level >= 4)  return "text-blue-400";
  return "text-gray-400";
}

function reputationLabel(score: number): string {
  if (score >= 80) return "Excellent";
  if (score >= 60) return "Good";
  if (score >= 40) return "Fair";
  return "Building";
}

function reputationColor(score: number): string {
  if (score >= 80) return "text-green-400";
  if (score >= 60) return "text-blue-400";
  if (score >= 40) return "text-yellow-400";
  return "text-gray-400";
}

function pct(v: number | null | undefined): string {
  if (v == null) return "—";
  return `${Math.round(v * 100)}%`;
}

function memberSince(ts: string): string {
  return new Date(ts).toLocaleDateString("en-US", { month: "long", year: "numeric" });
}

function relativeTime(ts: string): string {
  const diff = Date.now() - new Date(ts).getTime();
  const days = Math.floor(diff / 86400000);
  if (days === 0) return "Today";
  if (days === 1) return "Yesterday";
  if (days < 7) return `${days}d ago`;
  if (days < 30) return `${Math.floor(days / 7)}w ago`;
  if (days < 365) return `${Math.floor(days / 30)}mo ago`;
  return `${Math.floor(days / 365)}y ago`;
}

function profLabel(level: number): string {
  const labels = ["", "Novice", "Beginner", "Competent", "Proficient", "Expert"];
  return labels[level] ?? `L${level}`;
}

function taskTypeIcon(type: string): string {
  const icons: Record<string, string> = {
    // Human task types
    label_image: "🖼️", label_text: "📝", rate_quality: "⭐",
    verify_fact: "✅", moderate_content: "🛡️", compare_rank: "🏆",
    answer_question: "💬", transcription_review: "🎧",
    // AI task types
    web_research: "🌐", entity_lookup: "🏢", document_parse: "📄",
    data_transform: "🔄", llm_generate: "🤖", screenshot: "📸",
    audio_transcribe: "🎙️", pii_detect: "🔒", code_execute: "⚡",
    web_intel: "🕵️",
  };
  return icons[type] ?? "📋";
}

// Compute max tasks_completed across all task types for bar scaling
const maxTasksStat = taskStats.reduce((m, s) => Math.max(m, s.tasks_completed), 1);

const title = profile ? `${profile.name ?? "Worker"} — CrowdSorcerer` : "Worker Profile — CrowdSorcerer";
---

<Layout title={title}>
  <div class="max-w-3xl mx-auto px-6 py-10">

    {error && (
      <div class="bg-red-900/30 border border-red-700 text-red-300 rounded-lg p-6 text-center">
        <p class="text-lg font-medium">Profile not found</p>
        <p class="text-sm mt-1 text-red-400">{error}</p>
        <a href="/dashboard/marketplace" class="mt-4 inline-block text-sm text-indigo-400 hover:underline">
          ← Browse tasks
        </a>
      </div>
    )}

    {profile && (
      <div class="space-y-8">

        {/* ── Header ──────────────────────────────────────────── */}
        <div class="bg-gray-800 border border-gray-700 rounded-xl p-8">
          <div class="flex items-start gap-6">
            {/* Avatar */}
            <div class="flex-shrink-0">
              {profile.avatar_url ? (
                <img
                  src={profile.avatar_url}
                  alt={profile.name ?? "Worker avatar"}
                  class="w-20 h-20 rounded-full object-cover border-2 border-indigo-500"
                />
              ) : (
                <div class="w-20 h-20 rounded-full bg-indigo-700/40 border-2 border-indigo-500 flex items-center justify-center text-3xl font-bold text-indigo-300">
                  {(profile.name ?? "?")[0].toUpperCase()}
                </div>
              )}
            </div>

            {/* Info */}
            <div class="flex-1 min-w-0">
              <h1 class="text-2xl font-bold text-white">
                {profile.name ?? "Anonymous Worker"}
              </h1>
              <p class="text-sm text-gray-400 mt-0.5">Member since {memberSince(profile.member_since)}</p>

              {profile.bio && (
                <p class="mt-3 text-gray-300 text-sm leading-relaxed max-w-prose">{profile.bio}</p>
              )}

              {/* Location & website */}
              {(profile.location || profile.website_url) && (
                <div class="mt-2 flex flex-wrap items-center gap-3 text-xs text-gray-400">
                  {profile.location && (
                    <span class="flex items-center gap-1">
                      <span>📍</span>
                      <span>{profile.location}</span>
                    </span>
                  )}
                  {profile.website_url && (
                    <a
                      href={profile.website_url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-center gap-1 text-indigo-400 hover:text-indigo-300 transition-colors"
                    >
                      <span>🔗</span>
                      <span>{new URL(profile.website_url).hostname}</span>
                    </a>
                  )}
                </div>
              )}

              {/* Level badge */}
              <div class="mt-3 flex flex-wrap gap-2">
                <span class={`inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold bg-gray-700 ${levelColor(profile.worker_level)}`}>
                  ⭐ Level {profile.worker_level} · {levelLabel(profile.worker_level)}
                </span>
                <span class={`inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold bg-gray-700 ${reputationColor(profile.reputation_score)}`}>
                  🏅 {reputationLabel(profile.reputation_score)} rep
                </span>
                {profile.worker_streak_days > 0 && (
                  <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold bg-orange-900/40 text-orange-300">
                    🔥 {profile.worker_streak_days}-day streak
                  </span>
                )}
                {profile.avg_feedback_score != null && profile.total_ratings_received > 0 && (
                  <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold bg-yellow-900/40 text-yellow-300">
                    {"★".repeat(Math.round(profile.avg_feedback_score))}{"☆".repeat(5 - Math.round(profile.avg_feedback_score))} {profile.avg_feedback_score.toFixed(1)} ({profile.total_ratings_received})
                  </span>
                )}
              </div>
            </div>
          </div>
        </div>

        {/* ── Stats ───────────────────────────────────────────── */}
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {[
            { label: "Tasks Done",  value: profile.worker_tasks_completed.toLocaleString(), icon: "✅" },
            { label: "Accuracy",    value: pct(profile.worker_accuracy),                     icon: "🎯" },
            { label: "Reliability", value: pct(profile.worker_reliability),                  icon: "⏱️" },
            { label: "Reputation",  value: `${Math.round(profile.reputation_score)}/100`,    icon: "🏅" },
          ].map(s => (
            <div class="bg-gray-800 border border-gray-700 rounded-lg p-4 text-center">
              <div class="text-2xl mb-1">{s.icon}</div>
              <div class="text-xl font-bold text-white">{s.value}</div>
              <div class="text-xs text-gray-400 mt-0.5">{s.label}</div>
            </div>
          ))}
        </div>

        {/* ── Quick actions (auth-gated client-side) ─────────── */}
        <div id="worker-actions" class="hidden flex-wrap gap-3">
          <a
            id="invite-btn"
            href="/workers/browse"
            class="inline-flex items-center gap-2 px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white rounded-lg text-sm font-medium transition-colors"
          >
            ✉️ Invite to task
          </a>
          <button
            id="share-btn"
            class="inline-flex items-center gap-2 px-4 py-2 border border-gray-600 hover:border-gray-400 text-gray-300 hover:text-white rounded-lg text-sm font-medium transition-colors"
          >
            🔗 Share profile
          </button>
        </div>

        {/* ── Verified Skills highlight ────────────────────── */}
        {verifiedSkills.length > 0 && (
          <div class="bg-amber-900/20 border border-amber-700/50 rounded-xl p-6">
            <h2 class="text-lg font-semibold text-amber-300 mb-1 flex items-center gap-2">
              🏅 Verified Skills
            </h2>
            <p class="text-xs text-amber-600 mb-4">
              Achieved Proficient+ level with ≥90% accuracy and verified task history
            </p>
            <div class="flex flex-wrap gap-2">
              {verifiedSkills.map((s: any) => (
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-amber-900/40 border border-amber-700/60 rounded-lg text-sm font-medium text-amber-200">
                  🏅 {s.task_type.replace(/_/g, " ")}
                  <span class="text-xs text-amber-400 ml-1">
                    {s.proficiency_label} · {s.tasks_completed} tasks
                  </span>
                </span>
              ))}
            </div>
          </div>
        )}

        {/* ── Skills ──────────────────────────────────────────── */}
        {profile.skills?.length > 0 && (
          <div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
            <h2 class="text-lg font-semibold text-white mb-4">Skills</h2>
            <div class="space-y-3">
              {profile.skills.map((skill: any) => {
                const isVerified = verifiedSkills.some((vs: any) => vs.task_type === skill.task_type);
                return (
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                      <span class="text-sm font-medium text-gray-200">
                        {skill.task_type.replace(/_/g, " ")}
                      </span>
                      {isVerified && (
                        <span class="text-xs bg-amber-900/50 text-amber-400 border border-amber-700/50 px-1.5 py-0.5 rounded" title="Verified skill">
                          🏅 Verified
                        </span>
                      )}
                      {skill.certified && !isVerified && (
                        <span class="text-xs bg-emerald-900/50 text-emerald-400 border border-emerald-700/50 px-1.5 py-0.5 rounded">
                          ✓ Certified
                        </span>
                      )}
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="text-xs text-gray-400">{skill.tasks_completed} tasks</span>
                      {/* Proficiency dots */}
                      <div class="flex gap-1">
                        {[1,2,3,4,5].map(i => (
                          <div class={`w-2 h-2 rounded-full ${i <= skill.proficiency_level ? (isVerified ? "bg-amber-400" : "bg-indigo-400") : "bg-gray-600"}`} />
                        ))}
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {/* ── Task-type Performance Bars ───────────────────── */}
        {taskStats.length > 0 && (
          <div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
            <h2 class="text-lg font-semibold text-white mb-4">📊 Performance by Task Type</h2>
            <div class="space-y-4">
              {taskStats.slice(0, 8).map((stat: any) => {
                const barPct = Math.round((stat.tasks_completed / maxTasksStat) * 100);
                const accPct = stat.avg_accuracy != null ? Math.round(stat.avg_accuracy * 100) : null;
                const isVerified = verifiedSkills.some((vs: any) => vs.task_type === stat.task_type);
                return (
                  <div>
                    <div class="flex items-center justify-between mb-1.5">
                      <div class="flex items-center gap-2">
                        <span class="text-base">{taskTypeIcon(stat.task_type)}</span>
                        <span class="text-sm font-medium text-gray-200">
                          {stat.task_type.replace(/_/g, " ")}
                        </span>
                        {isVerified && (
                          <span class="text-[10px] bg-amber-900/50 text-amber-400 border border-amber-700/50 px-1.5 py-0.5 rounded" title="Verified">
                            🏅
                          </span>
                        )}
                      </div>
                      <div class="flex items-center gap-3 text-xs text-gray-400">
                        <span>{stat.tasks_completed} tasks</span>
                        {accPct != null && (
                          <span class={accPct >= 90 ? "text-green-400" : accPct >= 70 ? "text-yellow-400" : "text-red-400"}>
                            {accPct}% acc
                          </span>
                        )}
                        <span class="text-gray-500">{profLabel(stat.proficiency_level)}</span>
                      </div>
                    </div>
                    {/* Progress bar */}
                    <div class="h-1.5 bg-gray-700 rounded-full overflow-hidden">
                      <div
                        class={`h-full rounded-full transition-all ${isVerified ? "bg-amber-500" : "bg-violet-600"}`}
                        style={`width: ${barPct}%`}
                      />
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {/* ── Recent Activity ───────────────────────────────── */}
        {recentActivity.length > 0 && (
          <div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
            <h2 class="text-lg font-semibold text-white mb-4">🕒 Recent Activity</h2>
            <div class="space-y-2">
              {recentActivity.map((act: any) => (
                <div class="flex items-center justify-between py-2 border-b border-gray-700/60 last:border-0">
                  <div class="flex items-center gap-2.5">
                    <span class="text-lg">{taskTypeIcon(act.task_type)}</span>
                    <div>
                      <p class="text-sm text-gray-200 capitalize">{act.task_type.replace(/_/g, " ")}</p>
                      <p class="text-xs text-gray-500">{act.submitted_at ? relativeTime(act.submitted_at) : "—"}</p>
                    </div>
                  </div>
                  <div class="flex items-center gap-3 text-xs">
                    {act.earnings_credits > 0 && (
                      <span class="text-emerald-400">+{act.earnings_credits} cr</span>
                    )}
                    {act.xp_earned > 0 && (
                      <span class="text-violet-400">+{act.xp_earned} XP</span>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* ── Badges ──────────────────────────────────────────── */}
        {profile.badges?.length > 0 && (
          <div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
            <h2 class="text-lg font-semibold text-white mb-4">Badges</h2>
            <div class="flex flex-wrap gap-3">
              {profile.badges.map((badge: any) => (
                <div
                  class="group relative bg-gray-700/50 border border-gray-600 rounded-lg px-3 py-2 flex items-center gap-2 cursor-default"
                  title={badge.badge_description ?? badge.badge_name}
                >
                  <span class="text-lg">🏆</span>
                  <span class="text-sm font-medium text-gray-200">{badge.badge_name}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* ── Endorsements ─────────────────────────────────── */}
        <div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-white flex items-center gap-2">
              ⭐ Endorsements
              <span class="text-sm font-normal text-gray-400">({endorsementCount})</span>
            </h2>
          </div>
          {endorsements.length === 0 ? (
            <p class="text-sm text-gray-500">No endorsements yet.</p>
          ) : (
            <div class="space-y-4">
              {endorsements.map((e: any) => (
                <div class="border-b border-gray-700 pb-4 last:border-0 last:pb-0">
                  <div class="flex items-start gap-3">
                    <div class="w-7 h-7 rounded-full bg-violet-900/40 border border-violet-700 flex items-center justify-center text-xs text-violet-300 flex-shrink-0">
                      ⭐
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="flex flex-wrap gap-1.5 items-center mb-1">
                        <span class="text-xs text-gray-400">A requester</span>
                        {e.skill_tag && (
                          <span class="px-2 py-0.5 bg-violet-900/40 border border-violet-700/60 text-violet-300 text-xs rounded-full">
                            {e.skill_tag}
                          </span>
                        )}
                        <span class="text-xs text-gray-600">
                          {new Date(e.created_at).toLocaleDateString()}
                        </span>
                      </div>
                      {e.note && (
                        <p class="text-sm text-gray-300 leading-relaxed">"{e.note}"</p>
                      )}
                    </div>
                  </div>
                </div>
              ))}
              {endorsementCount > 20 && (
                <p class="text-xs text-gray-500 text-center pt-1">
                  Showing 20 of {endorsementCount} endorsements
                </p>
              )}
            </div>
          )}
        </div>

        {/* ── Ratings ──────────────────────────────────────── */}
        {(profile.avg_feedback_score != null || profile.total_ratings_received > 0) && (
          <div class="bg-gray-800 border border-gray-700 rounded-xl p-6 mb-4">
            <h2 class="text-base font-semibold mb-3">⭐ Feedback Ratings</h2>
            <div class="flex items-center gap-4">
              <div class="text-center">
                <div class="text-3xl font-bold text-yellow-400">
                  {profile.avg_feedback_score != null ? profile.avg_feedback_score.toFixed(1) : "—"}
                </div>
                <div class="text-xs text-gray-500 mt-1">Avg Score</div>
              </div>
              <div class="text-center">
                <div class="text-3xl font-bold text-indigo-400">{profile.total_ratings_received}</div>
                <div class="text-xs text-gray-500 mt-1">Ratings</div>
              </div>
              {profile.avg_feedback_score != null && (
                <div class="text-2xl text-yellow-400">
                  {"★".repeat(Math.round(profile.avg_feedback_score))}
                  {"☆".repeat(5 - Math.round(profile.avg_feedback_score))}
                </div>
              )}
            </div>
          </div>
        )}

        {/* ── Portfolio Showcase ────────────────────────────── */}
        {portfolioItems.length > 0 && (
          <div class="bg-gray-800 border border-gray-700 rounded-xl p-6 mb-4">
            <h2 class="text-base font-semibold mb-4">🗂️ Portfolio Showcase</h2>
            <div class="grid sm:grid-cols-2 gap-3">
              {portfolioItems.map((item: any) => (
                <div class="bg-gray-900 border border-gray-700 rounded-lg p-4">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-xs font-medium bg-indigo-900/50 text-indigo-300 px-2 py-0.5 rounded-full uppercase">
                      {item.task_type?.replace("_", " ")}
                    </span>
                  </div>
                  {item.caption && (
                    <p class="text-sm text-gray-300 italic mb-2">"{item.caption}"</p>
                  )}
                  {item.result_snippet && (
                    <p class="text-xs text-gray-500 line-clamp-2">{item.result_snippet}</p>
                  )}
                  <div class="text-xs text-gray-600 mt-2">
                    Pinned {new Date(item.pinned_at).toLocaleDateString()}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* ── No content placeholder ────────────────────────── */}
        {profile.skills?.length === 0 && profile.badges?.length === 0 && endorsementCount === 0 && (
          <div class="bg-gray-800 border border-gray-700 rounded-xl p-8 text-center text-gray-400">
            <p class="text-4xl mb-3">🌱</p>
            <p>This worker is just getting started.</p>
          </div>
        )}

      </div>
    )}
  </div>
</Layout>

<script>
  // ── Worker profile client-side interactions ──────────────────────────────

  // Show action buttons only when user is authenticated (has auth cookie)
  const hasCookie = document.cookie.includes("cs_token=");
  if (hasCookie) {
    const actionsDiv = document.getElementById("worker-actions");
    if (actionsDiv) {
      actionsDiv.classList.remove("hidden");
      actionsDiv.classList.add("flex");
    }
  }

  // Share profile
  const shareBtn = document.getElementById("share-btn");
  if (shareBtn) {
    shareBtn.addEventListener("click", async () => {
      const url = window.location.href;
      const title = document.title;
      if (navigator.share) {
        try {
          await navigator.share({ title, url });
        } catch (_) { /* cancelled */ }
      } else {
        // Clipboard fallback
        try {
          await navigator.clipboard.writeText(url);
          shareBtn.textContent = "✓ Link copied!";
          setTimeout(() => { (shareBtn as HTMLButtonElement).textContent = "🔗 Share profile"; }, 2000);
        } catch (_) {
          window.prompt("Copy this link:", url);
        }
      }
    });
  }
</script>
