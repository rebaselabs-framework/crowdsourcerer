---
/**
 * Public worker profile page — /workers/{id}
 * No auth required.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch } from "@/lib/api";

const { id } = Astro.params as { id: string };

let profile: any = null;
let error = "";

try {
  profile = await apiFetch<any>(`/v1/workers/${id}/profile`);
} catch (e: any) {
  error = e.message ?? "Worker not found";
}

function levelLabel(level: number): string {
  if (level >= 10) return "Expert";
  if (level >= 7)  return "Advanced";
  if (level >= 4)  return "Intermediate";
  return "Beginner";
}

function levelColor(level: number): string {
  if (level >= 10) return "text-yellow-400";
  if (level >= 7)  return "text-purple-400";
  if (level >= 4)  return "text-blue-400";
  return "text-gray-400";
}

function reputationLabel(score: number): string {
  if (score >= 80) return "Excellent";
  if (score >= 60) return "Good";
  if (score >= 40) return "Fair";
  return "Building";
}

function reputationColor(score: number): string {
  if (score >= 80) return "text-green-400";
  if (score >= 60) return "text-blue-400";
  if (score >= 40) return "text-yellow-400";
  return "text-gray-400";
}

function pct(v: number | null | undefined): string {
  if (v == null) return "—";
  return `${Math.round(v * 100)}%`;
}

function memberSince(ts: string): string {
  return new Date(ts).toLocaleDateString("en-US", { month: "long", year: "numeric" });
}

const title = profile ? `${profile.name ?? "Worker"} — CrowdSorcerer` : "Worker Profile — CrowdSorcerer";
---

<Layout title={title}>
  <div class="max-w-3xl mx-auto px-6 py-10">

    {error && (
      <div class="bg-red-900/30 border border-red-700 text-red-300 rounded-lg p-6 text-center">
        <p class="text-lg font-medium">Profile not found</p>
        <p class="text-sm mt-1 text-red-400">{error}</p>
        <a href="/dashboard/marketplace" class="mt-4 inline-block text-sm text-indigo-400 hover:underline">
          ← Browse tasks
        </a>
      </div>
    )}

    {profile && (
      <div class="space-y-8">

        {/* ── Header ──────────────────────────────────────────── */}
        <div class="bg-gray-800 border border-gray-700 rounded-xl p-8">
          <div class="flex items-start gap-6">
            {/* Avatar */}
            <div class="flex-shrink-0">
              {profile.avatar_url ? (
                <img
                  src={profile.avatar_url}
                  alt={profile.name ?? "Worker avatar"}
                  class="w-20 h-20 rounded-full object-cover border-2 border-indigo-500"
                />
              ) : (
                <div class="w-20 h-20 rounded-full bg-indigo-700/40 border-2 border-indigo-500 flex items-center justify-center text-3xl font-bold text-indigo-300">
                  {(profile.name ?? "?")[0].toUpperCase()}
                </div>
              )}
            </div>

            {/* Info */}
            <div class="flex-1 min-w-0">
              <h1 class="text-2xl font-bold text-white">
                {profile.name ?? "Anonymous Worker"}
              </h1>
              <p class="text-sm text-gray-400 mt-0.5">Member since {memberSince(profile.member_since)}</p>

              {profile.bio && (
                <p class="mt-3 text-gray-300 text-sm leading-relaxed max-w-prose">{profile.bio}</p>
              )}

              {/* Level badge */}
              <div class="mt-3 flex flex-wrap gap-2">
                <span class={`inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold bg-gray-700 ${levelColor(profile.worker_level)}`}>
                  ⭐ Level {profile.worker_level} · {levelLabel(profile.worker_level)}
                </span>
                <span class={`inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold bg-gray-700 ${reputationColor(profile.reputation_score)}`}>
                  🏅 Reputation: {reputationLabel(profile.reputation_score)} ({Math.round(profile.reputation_score)}/100)
                </span>
                {profile.worker_streak_days > 0 && (
                  <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold bg-orange-900/40 text-orange-300">
                    🔥 {profile.worker_streak_days}-day streak
                  </span>
                )}
              </div>
            </div>
          </div>
        </div>

        {/* ── Stats ───────────────────────────────────────────── */}
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {[
            { label: "Tasks Done",  value: profile.worker_tasks_completed.toLocaleString(), icon: "✅" },
            { label: "Accuracy",    value: pct(profile.worker_accuracy),                     icon: "🎯" },
            { label: "Reliability", value: pct(profile.worker_reliability),                  icon: "⏱️" },
            { label: "Total XP",    value: profile.worker_xp.toLocaleString(),               icon: "✨" },
          ].map(s => (
            <div class="bg-gray-800 border border-gray-700 rounded-lg p-4 text-center">
              <div class="text-2xl mb-1">{s.icon}</div>
              <div class="text-xl font-bold text-white">{s.value}</div>
              <div class="text-xs text-gray-400 mt-0.5">{s.label}</div>
            </div>
          ))}
        </div>

        {/* ── Skills ──────────────────────────────────────────── */}
        {profile.skills?.length > 0 && (
          <div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
            <h2 class="text-lg font-semibold text-white mb-4">Skills</h2>
            <div class="space-y-3">
              {profile.skills.map((skill: any) => (
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <span class="text-sm font-medium text-gray-200">
                      {skill.task_type.replace(/_/g, " ")}
                    </span>
                    {skill.certified && (
                      <span class="text-xs bg-emerald-900/50 text-emerald-400 border border-emerald-700/50 px-1.5 py-0.5 rounded">
                        ✓ Certified
                      </span>
                    )}
                  </div>
                  <div class="flex items-center gap-3">
                    <span class="text-xs text-gray-400">{skill.tasks_completed} tasks</span>
                    {/* Proficiency dots */}
                    <div class="flex gap-1">
                      {[1,2,3,4,5].map(i => (
                        <div class={`w-2 h-2 rounded-full ${i <= skill.proficiency_level ? "bg-indigo-400" : "bg-gray-600"}`} />
                      ))}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* ── Badges ──────────────────────────────────────────── */}
        {profile.badges?.length > 0 && (
          <div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
            <h2 class="text-lg font-semibold text-white mb-4">Badges</h2>
            <div class="flex flex-wrap gap-3">
              {profile.badges.map((badge: any) => (
                <div
                  class="group relative bg-gray-700/50 border border-gray-600 rounded-lg px-3 py-2 flex items-center gap-2 cursor-default"
                  title={badge.badge_description ?? badge.badge_name}
                >
                  <span class="text-lg">🏆</span>
                  <span class="text-sm font-medium text-gray-200">{badge.badge_name}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* ── No content placeholder ────────────────────────── */}
        {profile.skills?.length === 0 && profile.badges?.length === 0 && (
          <div class="bg-gray-800 border border-gray-700 rounded-xl p-8 text-center text-gray-400">
            <p class="text-4xl mb-3">🌱</p>
            <p>This worker is just getting started.</p>
          </div>
        )}

      </div>
    )}
  </div>
</Layout>
