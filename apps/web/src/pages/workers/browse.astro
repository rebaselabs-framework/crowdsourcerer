---
/**
 * Worker Skill Marketplace — browse workers by skill, reputation, and certifications.
 * Requesters can browse and invite workers to their open tasks.
 */
import Layout from "@/layouts/Layout.astro";
import { apiFetch, getToken } from "@/lib/api";

const token = getToken(Astro.cookies);

if (!token) {
  return Astro.redirect("/login?next=/workers/browse");
}

const url = new URL(Astro.request.url);
const page       = parseInt(url.searchParams.get("page") ?? "1");
const skill      = url.searchParams.get("skill") ?? "";
const verified   = url.searchParams.get("verified") === "true";
const minRep     = url.searchParams.get("min_rep") ?? "0";
const minTasks   = url.searchParams.get("min_tasks") ?? "0";
const cert       = url.searchParams.get("cert") ?? "";
const sort       = url.searchParams.get("sort") ?? "reputation";

let workers: any  = null;
let userTasks: any = null;
let error = "";

const params = new URLSearchParams({
  page: String(page),
  limit: "18",
  sort,
  min_reputation: minRep,
  min_tasks: minTasks,
  ...(skill      ? { skill }             : {}),
  ...(verified   ? { verified_only: "true" } : {}),
  ...(cert       ? { cert }              : {}),
});

try {
  workers = await apiFetch(`/v1/workers/browse?${params}`, { token });
  // Load requester's open tasks for the invite modal
  const taskResp = await apiFetch<any>("/v1/tasks?execution_mode=human&status=open&page_size=50", { token }).catch(() => null);
  userTasks = taskResp?.items ?? [];
} catch (e: any) {
  error = e.message ?? "Failed to load workers";
}

const TASK_TYPES = [
  "label_image", "label_text", "rate_quality", "verify_fact",
  "moderate_content", "compare_rank", "answer_question", "transcription_review",
];
const SORT_OPTIONS = [
  { value: "reputation", label: "Top Reputation" },
  { value: "tasks",      label: "Most Tasks" },
  { value: "accuracy",   label: "Best Accuracy" },
];
---

<Layout title="Worker Marketplace — CrowdSorcerer">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold">👷 Worker Marketplace</h1>
        <p class="text-sm text-gray-500 mt-1">Browse skilled workers and invite them to your tasks</p>
      </div>
      <a href="/workers" class="text-sm text-violet-400 hover:underline">← All workers</a>
    </div>

    <!-- Filter bar -->
    <form method="GET" class="bg-gray-800 rounded-xl border border-gray-700 p-4 mb-6 flex flex-wrap gap-3 items-end">
      <!-- Skill -->
      <div>
        <label for="skill" class="block text-xs font-medium text-gray-500 mb-1">Skill</label>
        <select id="skill" name="skill" class="border border-gray-600 bg-gray-700 rounded px-2 py-1.5 text-sm">
          <option value="">All skills</option>
          {TASK_TYPES.map(t => (
            <option value={t} selected={skill === t}>{t.replace(/_/g, " ")}</option>
          ))}
        </select>
      </div>

      <!-- Sort -->
      <div>
        <label for="sort" class="block text-xs font-medium text-gray-500 mb-1">Sort by</label>
        <select id="sort" name="sort" class="border border-gray-600 bg-gray-700 rounded px-2 py-1.5 text-sm">
          {SORT_OPTIONS.map(s => (
            <option value={s.value} selected={sort === s.value}>{s.label}</option>
          ))}
        </select>
      </div>

      <!-- Min reputation -->
      <div>
        <label for="min_rep" class="block text-xs font-medium text-gray-500 mb-1">Min reputation</label>
        <input type="number" id="min_rep" name="min_rep" min="0" max="100" value={minRep}
               class="border border-gray-600 bg-gray-700 rounded px-2 py-1.5 text-sm w-20" />
      </div>

      <!-- Min tasks -->
      <div>
        <label for="min_tasks" class="block text-xs font-medium text-gray-500 mb-1">Min tasks done</label>
        <input type="number" id="min_tasks" name="min_tasks" min="0" value={minTasks}
               class="border border-gray-600 bg-gray-700 rounded px-2 py-1.5 text-sm w-20" />
      </div>

      <!-- Verified only -->
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="checkbox" name="verified" value="true" checked={verified}
               class="rounded" />
        Verified skills only
      </label>

      <button type="submit"
              class="bg-violet-600 text-white px-4 py-1.5 rounded text-sm hover:bg-violet-500">
        🔍 Filter
      </button>
      <a href="/workers/browse" class="text-sm text-gray-500 hover:underline self-center">Clear</a>
    </form>

    {error && (
      <div class="bg-red-900/30 border border-red-700 rounded-lg p-4 mb-6 text-red-300">
        {error}
      </div>
    )}

    {workers && (
      <>
        <!-- Result count + Select all -->
        <div class="flex items-center justify-between mb-4">
          <p class="text-sm text-gray-500">
            {workers.total} worker{workers.total !== 1 ? "s" : ""} found
            {skill ? ` with ${skill.replace(/_/g, " ")} skill` : ""}
            — page {workers.page} of {workers.pages}
          </p>
          <button
            id="select-all-btn"
            class="text-xs text-indigo-600 hover:text-indigo-500 font-medium"
          >
            Select all
          </button>
        </div>

        <!-- Worker grid -->
        {workers.items.length === 0 ? (
          <div class="text-center py-16 text-gray-400">
            <p class="text-4xl mb-3">🔍</p>
            <p class="text-lg font-medium">No workers match your filters</p>
            <p class="text-sm mt-1">Try adjusting your search criteria</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {workers.items.map((w: any) => (
              <div
                class="worker-card bg-gray-800 rounded-xl border border-gray-700 p-5 hover:shadow-md transition-shadow relative"
                data-worker-id={w.id}
                data-worker-name={w.name || "Anonymous Worker"}
              >
                <!-- Select checkbox -->
                <label class="absolute top-3 left-3 cursor-pointer z-10">
                  <input
                    type="checkbox"
                    class="worker-checkbox w-4 h-4 text-indigo-600 rounded border-gray-300 cursor-pointer"
                    data-worker-id={w.id}
                  />
                </label>
                <!-- Worker header -->
                <div class="flex items-start gap-3 mb-3 pl-7">
                  <div class="w-12 h-12 rounded-full overflow-hidden bg-gradient-to-br from-indigo-400 to-purple-600 flex items-center justify-center flex-shrink-0">
                    {w.avatar_url ? (
                      <img src={w.avatar_url} alt={w.name || "Worker"} class="w-full h-full object-cover" />
                    ) : (
                      <span class="text-white font-bold text-lg">
                        {(w.name || "?")[0].toUpperCase()}
                      </span>
                    )}
                  </div>
                  <div class="min-w-0">
                    <a href={w.profile_url} class="font-semibold hover:text-violet-400 truncate block">
                      {w.name || "Anonymous Worker"}
                    </a>
                    <div class="flex items-center gap-2 text-xs text-gray-500 mt-0.5">
                      <span>Lv.{w.worker_level}</span>
                      <span>·</span>
                      <span>{w.worker_tasks_completed} tasks</span>
                      {w.worker_accuracy != null && (
                        <>
                          <span>·</span>
                          <span>{w.worker_accuracy}% acc.</span>
                        </>
                      )}
                    </div>
                    <div class="mt-1">
                      <span class:list={[
                        "text-xs px-1.5 py-0.5 rounded-full font-medium",
                        w.availability_status === "available" ? "bg-green-950/50 text-green-400 border border-green-800" :
                        w.availability_status === "busy" ? "bg-yellow-950/50 text-yellow-400 border border-yellow-800" :
                        "bg-gray-800 text-gray-500 border border-gray-700"
                      ]}>
                        {w.availability_status === "available" ? "🟢 Available" : w.availability_status === "busy" ? "🟡 Busy" : "🔴 Away"}
                      </span>
                    </div>
                  </div>
                  <!-- Reputation badge -->
                  <div class={`ml-auto text-center px-2 py-1 rounded-lg text-xs font-bold flex-shrink-0 ${
                    w.reputation_score >= 80 ? "bg-yellow-900/30 text-yellow-300" :
                    w.reputation_score >= 60 ? "bg-green-900/30 text-green-300" :
                    w.reputation_score >= 40 ? "bg-blue-900/30 text-blue-300" :
                    "bg-gray-700 text-gray-300"
                  }`}>
                    ⭐ {w.reputation_score}
                  </div>
                </div>

                <!-- Bio -->
                {w.bio && (
                  <p class="text-xs text-gray-400 mb-3 line-clamp-2">{w.bio}</p>
                )}

                <!-- Skills -->
                {w.skills.length > 0 && (
                  <div class="mb-3">
                    <p class="text-xs font-medium text-gray-400 mb-1.5">Skills</p>
                    <div class="flex flex-wrap gap-1">
                      {w.skills.slice(0, 4).map((s: any) => (
                        <span class={`text-xs px-2 py-0.5 rounded-full border ${
                          s.verified
                            ? "bg-amber-900/20 border-amber-700 text-amber-300"
                            : "bg-gray-700 border-gray-600 text-gray-300"
                        }`}>
                          {s.verified ? "🏅 " : ""}{s.task_type.replace(/_/g, " ")} L{s.proficiency_level}
                        </span>
                      ))}
                      {w.skills.length > 4 && (
                        <span class="text-xs text-gray-400">+{w.skills.length - 4} more</span>
                      )}
                    </div>
                  </div>
                )}

                <!-- Stats row -->
                <div class="flex items-center gap-3 text-xs text-gray-500 border-t border-gray-700 pt-3 mb-3">
                  {w.verified_skill_count > 0 && (
                    <span title="Verified skills">🏅 {w.verified_skill_count} verified</span>
                  )}
                  {w.cert_count > 0 && (
                    <span title="Certifications">🎓 {w.cert_count} certs</span>
                  )}
                  {w.endorsement_count > 0 && (
                    <span title="Endorsements">👍 {w.endorsement_count}</span>
                  )}
                </div>

                <!-- Actions -->
                <div class="flex gap-2">
                  <a href={w.profile_url}
                     class="flex-1 text-center text-xs border border-gray-600 rounded-lg py-1.5 hover:bg-gray-700">
                    View Profile
                  </a>
                  <button
                    onclick={`openInviteModal('${w.id}', '${(w.name || "this worker").replace(/'/g, "\\'")}' )`}
                    class="flex-1 text-xs bg-indigo-600 text-white rounded-lg py-1.5 hover:bg-indigo-700">
                    ✉️ Invite
                  </button>
                </div>
              </div>
            ))}
          </div>
        )}

        <!-- Pagination -->
        {workers.pages > 1 && (
          <div class="flex items-center justify-center gap-2 mt-8">
            {workers.page > 1 && (
              <a href={`?${new URLSearchParams({ ...Object.fromEntries(url.searchParams), page: String(workers.page - 1) })}`}
                 class="px-4 py-2 border border-gray-700 rounded-lg text-sm hover:bg-gray-800">
                ← Prev
              </a>
            )}
            <span class="text-sm text-gray-500">Page {workers.page} of {workers.pages}</span>
            {workers.page < workers.pages && (
              <a href={`?${new URLSearchParams({ ...Object.fromEntries(url.searchParams), page: String(workers.page + 1) })}`}
                 class="px-4 py-2 border border-gray-700 rounded-lg text-sm hover:bg-gray-800">
                Next →
              </a>
            )}
          </div>
        )}
      </>
    )}
  </div>

  <!-- Bulk Selection Bar -->
  <div id="bulk-bar" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-40 hidden">
    <div class="bg-gray-900 border border-gray-700 rounded-2xl shadow-2xl px-5 py-3 flex items-center gap-4">
      <span id="bulk-count" class="text-white font-semibold text-sm">0 selected</span>
      <button
        id="bulk-invite-btn"
        class="bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors"
      >
        ✉️ Bulk Invite
      </button>
      <button
        id="bulk-clear-btn"
        class="text-gray-400 hover:text-white text-sm transition-colors"
      >
        Clear
      </button>
    </div>
  </div>

  <!-- Bulk Invite Modal -->
  <div id="bulkInviteModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50">
    <div class="bg-gray-900 border border-gray-800 rounded-xl w-full max-w-md mx-4 p-6">
      <h2 class="text-lg font-bold mb-1">✉️ Bulk Invite Workers</h2>
      <p class="text-sm text-gray-500 mb-4">
        Invite <span id="bulkWorkerList" class="font-medium text-gray-300"></span> to one of your tasks.
      </p>

      <!-- Task selector -->
      <div class="mb-4">
        <label for="bulkTaskSelect" class="block text-sm font-medium mb-1">Task</label>
        <select id="bulkTaskSelect" class="w-full border border-gray-600 bg-gray-700 rounded-lg px-3 py-2 text-sm">
          <option value="">-- Select a task --</option>
          {(userTasks ?? []).map((t: any) => (
            <option value={t.id}>{t.title || t.task_type} ({t.status})</option>
          ))}
        </select>
        {(userTasks ?? []).length === 0 && (
          <p class="text-xs text-amber-600 mt-1">No open human tasks. <a href="/dashboard/new-task" class="underline">Create one first.</a></p>
        )}
      </div>

      <!-- Optional message -->
      <div class="mb-5">
        <label for="bulkMessage" class="block text-sm font-medium mb-1">Message <span class="text-gray-400 font-normal">(optional)</span></label>
        <textarea id="bulkMessage" rows="2"
                  placeholder="Hi! I think you'd be great for this task..."
                  class="w-full border border-gray-600 bg-gray-700 rounded-lg px-3 py-2 text-sm resize-none"></textarea>
      </div>

      <div id="bulkError" class="hidden text-red-600 text-sm mb-3"></div>
      <div id="bulkSuccess" class="hidden text-green-600 text-sm mb-3"></div>

      <div class="flex gap-3">
        <button onclick="closeBulkModal()"
                class="flex-1 border border-gray-600 rounded-lg py-2 text-sm hover:bg-gray-800">
          Cancel
        </button>
        <button onclick="submitBulkInvite()"
                class="flex-1 bg-indigo-600 text-white rounded-lg py-2 text-sm font-medium hover:bg-indigo-700">
          Send All Invites
        </button>
      </div>
    </div>
  </div>

  <!-- Invite Modal -->
  <div id="inviteModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50">
    <div class="bg-gray-900 border border-gray-800 rounded-xl w-full max-w-md mx-4 p-6">
      <h2 class="text-lg font-bold mb-1">✉️ Invite Worker</h2>
      <p class="text-sm text-gray-500 mb-4">Invite <span id="inviteWorkerName" class="font-medium"></span> to one of your open tasks</p>

      <input type="hidden" id="inviteWorkerId" />

      <!-- Task selector -->
      <div class="mb-4">
        <label for="inviteTaskSelect" class="block text-sm font-medium mb-1">Task</label>
        <select id="inviteTaskSelect" class="w-full border border-gray-600 bg-gray-700 rounded-lg px-3 py-2 text-sm">
          <option value="">-- Select a task --</option>
          {(userTasks ?? []).map((t: any) => (
            <option value={t.id}>{t.title || t.task_type} ({t.status})</option>
          ))}
        </select>
        {(userTasks ?? []).length === 0 && (
          <p class="text-xs text-amber-600 mt-1">No open human tasks. <a href="/dashboard/new-task" class="underline">Create one first.</a></p>
        )}
      </div>

      <!-- Optional message -->
      <div class="mb-5">
        <label for="inviteMessage" class="block text-sm font-medium mb-1">Message <span class="text-gray-400 font-normal">(optional)</span></label>
        <textarea id="inviteMessage" rows="3"
                  placeholder="Hi! I think you'd be great for this task..."
                  class="w-full border border-gray-600 bg-gray-700 rounded-lg px-3 py-2 text-sm resize-none"></textarea>
      </div>

      <div id="inviteError" class="hidden text-red-600 text-sm mb-3"></div>
      <div id="inviteSuccess" class="hidden text-green-600 text-sm mb-3"></div>

      <div class="flex gap-3">
        <button onclick="closeInviteModal()"
                class="flex-1 border border-gray-600 rounded-lg py-2 text-sm hover:bg-gray-800">
          Cancel
        </button>
        <button onclick="submitInvite()"
                class="flex-1 bg-indigo-600 text-white rounded-lg py-2 text-sm font-medium hover:bg-indigo-700">
          Send Invite
        </button>
      </div>
    </div>
  </div>

  <script>
    declare global {
      interface Window {
        openInviteModal?: (workerId: string, workerName: string) => void;
        submitInvite?: () => Promise<void>;
        closeBulkModal?: () => void;
        submitBulkInvite?: () => Promise<void>;
      }
    }

    // ── Single invite ──────────────────────────────────────────────────────
    function openInviteModal(workerId: string, workerName: string) {
      (document.getElementById("inviteWorkerId") as HTMLInputElement).value = workerId;
      document.getElementById("inviteWorkerName")!.textContent = workerName;
      document.getElementById("inviteError")!.classList.add("hidden");
      document.getElementById("inviteSuccess")!.classList.add("hidden");
      (document.getElementById("inviteMessage") as HTMLTextAreaElement).value = "";
      const modal = document.getElementById("inviteModal")!;
      modal.classList.remove("hidden");
      modal.classList.add("flex");
    }

    function closeInviteModal() {
      const modal = document.getElementById("inviteModal")!;
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }

    async function submitInvite() {
      const workerId = (document.getElementById("inviteWorkerId") as HTMLInputElement).value;
      const taskId   = (document.getElementById("inviteTaskSelect") as HTMLSelectElement).value;
      const message  = (document.getElementById("inviteMessage") as HTMLTextAreaElement).value.trim();
      const errEl    = document.getElementById("inviteError")!;
      const okEl     = document.getElementById("inviteSuccess")!;

      errEl.classList.add("hidden");
      okEl.classList.add("hidden");

      if (!taskId) {
        errEl.textContent = "Please select a task.";
        errEl.classList.remove("hidden");
        return;
      }

      try {
        const res = await fetch(`/api/tasks/${taskId}/invite`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ worker_id: workerId, message: message || null }),
        });
        const data = await res.json();
        if (!res.ok) {
          errEl.textContent = data.detail ?? "Failed to send invite";
          errEl.classList.remove("hidden");
          return;
        }
        okEl.textContent = "✅ Invite sent! The worker will be notified.";
        okEl.classList.remove("hidden");
        setTimeout(() => closeInviteModal(), 2000);
      } catch {
        errEl.textContent = "Network error. Please try again.";
        errEl.classList.remove("hidden");
      }
    }

    // Close modal on backdrop click
    document.getElementById("inviteModal")?.addEventListener("click", (e) => {
      if (e.target === e.currentTarget) closeInviteModal();
    });

    // ── Multi-select + Bulk Invite ─────────────────────────────────────────
    const selectedWorkers = new Map<string, string>(); // id → name
    const bulkBar = document.getElementById("bulk-bar")!;
    const bulkCountEl = document.getElementById("bulk-count")!;

    function updateBulkBar() {
      const count = selectedWorkers.size;
      bulkCountEl.textContent = `${count} selected`;
      if (count > 0) {
        bulkBar.classList.remove("hidden");
      } else {
        bulkBar.classList.add("hidden");
      }
    }

    document.querySelectorAll<HTMLInputElement>(".worker-checkbox").forEach(cb => {
      cb.addEventListener("change", () => {
        const card = cb.closest<HTMLElement>(".worker-card")!;
        const id = card.dataset.workerId!;
        const name = card.dataset.workerName!;
        if (cb.checked) {
          selectedWorkers.set(id, name);
          card.classList.add("ring-2", "ring-indigo-500");
        } else {
          selectedWorkers.delete(id);
          card.classList.remove("ring-2", "ring-indigo-500");
        }
        updateBulkBar();
      });
    });

    document.getElementById("select-all-btn")?.addEventListener("click", () => {
      const checkboxes = document.querySelectorAll<HTMLInputElement>(".worker-checkbox");
      const allChecked = Array.from(checkboxes).every(c => c.checked);
      checkboxes.forEach(cb => {
        cb.checked = !allChecked;
        cb.dispatchEvent(new Event("change"));
      });
    });

    document.getElementById("bulk-clear-btn")?.addEventListener("click", () => {
      document.querySelectorAll<HTMLInputElement>(".worker-checkbox").forEach(cb => {
        cb.checked = false;
        cb.closest<HTMLElement>(".worker-card")?.classList.remove("ring-2", "ring-indigo-500");
      });
      selectedWorkers.clear();
      updateBulkBar();
    });

    document.getElementById("bulk-invite-btn")?.addEventListener("click", () => {
      const names = Array.from(selectedWorkers.values()).slice(0, 3).join(", ");
      const extra = selectedWorkers.size > 3 ? ` +${selectedWorkers.size - 3} more` : "";
      document.getElementById("bulkWorkerList")!.textContent = names + extra;
      document.getElementById("bulkError")!.classList.add("hidden");
      document.getElementById("bulkSuccess")!.classList.add("hidden");
      (document.getElementById("bulkMessage") as HTMLTextAreaElement).value = "";
      const modal = document.getElementById("bulkInviteModal")!;
      modal.classList.remove("hidden");
      modal.classList.add("flex");
    });

    function closeBulkModal() {
      const modal = document.getElementById("bulkInviteModal")!;
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }

    document.getElementById("bulkInviteModal")?.addEventListener("click", (e) => {
      if (e.target === e.currentTarget) closeBulkModal();
    });

    async function submitBulkInvite() {
      const taskId  = (document.getElementById("bulkTaskSelect") as HTMLSelectElement).value;
      const message = (document.getElementById("bulkMessage") as HTMLTextAreaElement).value.trim();
      const errEl   = document.getElementById("bulkError")!;
      const okEl    = document.getElementById("bulkSuccess")!;

      errEl.classList.add("hidden");
      okEl.classList.add("hidden");

      if (!taskId) {
        errEl.textContent = "Please select a task.";
        errEl.classList.remove("hidden");
        return;
      }

      try {
        const res = await fetch(`/api/tasks/${taskId}/bulk-invite`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            worker_ids: Array.from(selectedWorkers.keys()),
            message: message || null,
          }),
        });
        const data = await res.json();
        if (!res.ok) {
          errEl.textContent = data.detail ?? "Failed to send invites";
          errEl.classList.remove("hidden");
          return;
        }
        okEl.textContent = `✅ Sent ${data.invited} invite${data.invited !== 1 ? "s" : ""}${data.skipped > 0 ? ` (${data.skipped} skipped — already invited or not found)` : ""}`;
        okEl.classList.remove("hidden");
        setTimeout(() => {
          closeBulkModal();
          // Uncheck all
          document.getElementById("bulk-clear-btn")?.click();
        }, 3000);
      } catch {
        errEl.textContent = "Network error. Please try again.";
        errEl.classList.remove("hidden");
      }
    }

    // Make bulk functions global for inline onclick
    window.openInviteModal = openInviteModal;
    window.submitInvite = submitInvite;
    window.closeBulkModal = closeBulkModal;
    window.submitBulkInvite = submitBulkInvite;
  </script>
</Layout>
