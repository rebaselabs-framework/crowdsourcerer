---
import Layout from "@/layouts/Layout.astro";
import { setAuthCookies } from "@/lib/auth";

// Check platform config to conditionally show Google OAuth
let googleOAuthEnabled = false;
try {
  const API_URL = import.meta.env.PUBLIC_API_URL ?? "http://api:8100";
  const cfgRes = await fetch(`${API_URL}/v1/config`);
  if (cfgRes.ok) {
    const cfg = await cfgRes.json();
    googleOAuthEnabled = !!cfg.google_oauth;
  }
} catch { /* silently ignore — default to hidden */ }

// Check for OAuth errors passed back from Google callback
const oauthError = Astro.url.searchParams.get("oauth_error");

let error = oauthError
  ? oauthError === "account_disabled"
    ? "Your account has been disabled."
    : "Google sign-in failed. Please try again or use email/password below."
  : "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const email = form.get("email") as string;
  const password = form.get("password") as string;

  try {
    const res = await fetch(
      `${import.meta.env.PUBLIC_API_URL ?? "http://api:8100"}/v1/auth/login`,
      {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, password }),
      }
    );

    if (!res.ok) {
      if (res.status === 429) {
        const data = await res.json().catch(() => ({}));
        error = data.error ?? "Too many login attempts — please wait a minute";
      } else {
        error = "Invalid email or password";
      }
    } else {
      const data = await res.json();
      // 2FA required — redirect to TOTP verification page
      if (data.requires_2fa && data.pending_token) {
        return Astro.redirect(`/login-2fa?pt=${encodeURIComponent(data.pending_token)}`);
      }
      setAuthCookies(
        Astro.cookies,
        data.access_token,
        data.refresh_token,
        data.expires_in,
        data.refresh_expires_in,
      );
      return Astro.redirect("/dashboard");
    }
  } catch (e) {
    error = "Network error — please try again";
  }
}
---

<Layout title="Sign in — CrowdSorcerer">
  <div class="min-h-screen flex items-center justify-center px-6">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <div class="text-4xl mb-3">🔮</div>
        <h1 class="text-2xl font-bold">Welcome back</h1>
      </div>

      {error && (
        <div class="bg-red-950/50 border border-red-800 rounded-lg px-4 py-3 text-sm text-red-300 mb-6">
          {error}
        </div>
      )}

      {/* Google OAuth button — only shown when configured on the backend */}
      {googleOAuthEnabled && (
        <a
          href="/v1/auth/google?next=/dashboard"
          class="flex items-center justify-center gap-3 w-full border border-gray-600 hover:border-gray-400 bg-gray-900 hover:bg-gray-800 text-gray-200 font-medium py-3 rounded-lg transition-colors mb-4"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Continue with Google
        </a>
      )}

      {/* Divider — only when Google OAuth is shown */}
      {googleOAuthEnabled && (
        <div class="flex items-center gap-3 mb-4">
          <div class="flex-1 h-px bg-gray-700"></div>
          <span class="text-xs text-gray-500">or continue with email</span>
          <div class="flex-1 h-px bg-gray-700"></div>
        </div>
      )}

      <form method="POST" class="space-y-4">
        <div>
          <label for="login-email" class="block text-sm text-gray-400 mb-1">Email</label>
          <input
            id="login-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2.5 text-gray-100 focus:outline-none focus:ring-2 focus:ring-violet-500/40 focus:border-violet-500 transition-colors"
            placeholder="you@example.com"
          />
        </div>
        <div>
          <div class="flex items-center justify-between mb-1">
            <label for="login-password" class="block text-sm text-gray-400">Password</label>
            <a href="/forgot-password" class="text-xs text-violet-400 hover:text-violet-300 transition-colors">
              Forgot password?
            </a>
          </div>
          <input
            id="login-password"
            name="password"
            type="password"
            required
            autocomplete="current-password"
            class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2.5 text-gray-100 focus:outline-none focus:ring-2 focus:ring-violet-500/40 focus:border-violet-500 transition-colors"
          />
        </div>
        <button
          type="submit"
          class="w-full bg-violet-600 hover:bg-violet-500 text-white font-semibold py-3 rounded-lg transition-colors"
        >
          Sign in
        </button>
      </form>

      <p class="text-center text-sm text-gray-500 mt-6">
        No account?
        <a href="/register" class="text-violet-400 hover:text-violet-300 ml-1">Sign up free</a>
      </p>
    </div>
  </div>
</Layout>
