---
/**
 * Interactive API Sandbox — try any CrowdSorcerer API call live in the browser.
 * Works with your own API key (no auth cookie required).
 */
import Layout from "@/layouts/Layout.astro";

const PUBLIC_API = import.meta.env.PUBLIC_API_URL ?? "https://crowdsourcerer.rebaselabs.online";

const TASKS = [
  {
    id: "web_research",
    name: "Web Research",
    credits: 10,
    description: "Scrape and summarize any URL.",
    fields: [
      { name: "url", type: "string", placeholder: "https://example.com", required: true },
      { name: "instruction", type: "string", placeholder: "Extract the main article text", required: false },
    ],
    example: { type: "web_research", input: { url: "https://news.ycombinator.com", instruction: "List the top 5 stories" } },
  },
  {
    id: "llm_generate",
    name: "LLM Generate",
    credits: 5,
    description: "Generate text with a large language model.",
    fields: [
      { name: "prompt", type: "textarea", placeholder: "Write a haiku about APIs", required: true },
      { name: "model", type: "string", placeholder: "gpt-4o (optional)", required: false },
      { name: "max_tokens", type: "number", placeholder: "512", required: false },
    ],
    example: { type: "llm_generate", input: { prompt: "Write a haiku about REST APIs", max_tokens: 100 } },
  },
  {
    id: "entity_lookup",
    name: "Entity Lookup",
    credits: 5,
    description: "Enrich company or person data.",
    fields: [
      { name: "entity_type", type: "select", options: ["company", "person"], required: true },
      { name: "name", type: "string", placeholder: "Stripe", required: false },
      { name: "domain", type: "string", placeholder: "stripe.com", required: false },
    ],
    example: { type: "entity_lookup", input: { entity_type: "company", domain: "stripe.com" } },
  },
  {
    id: "document_parse",
    name: "Document Parse",
    credits: 3,
    description: "Extract text and tables from documents.",
    fields: [
      { name: "url", type: "string", placeholder: "https://example.com/doc.pdf", required: true },
      { name: "extract_tables", type: "boolean", required: false },
    ],
    example: { type: "document_parse", input: { url: "https://www.w3.org/WAI/WCAG21/wcag21.pdf", extract_tables: true } },
  },
  {
    id: "data_transform",
    name: "Data Transform",
    credits: 3,
    description: "Apply LLM-powered transformations to structured data.",
    fields: [
      { name: "data", type: "textarea", placeholder: '[{"name":"Alice","age":30}]', required: true },
      { name: "instruction", type: "string", placeholder: "Convert all names to uppercase", required: true },
    ],
    example: { type: "data_transform", input: { data: [{"name":"Alice","age":30},{"name":"Bob","age":25}], instruction: "Add a greeting field 'Hello, <name>!'" } },
  },
  {
    id: "pii_detect",
    name: "PII Detection",
    credits: 4,
    description: "Detect and redact PII in text.",
    fields: [
      { name: "text", type: "textarea", placeholder: "My email is alice@example.com and phone is 555-1234", required: true },
      { name: "redact", type: "boolean", required: false },
    ],
    example: { type: "pii_detect", input: { text: "Contact John Smith at john@example.com or (415) 555-0100", redact: true } },
  },
  {
    id: "moderate_content",
    name: "Content Moderation",
    credits: 2,
    description: "Classify text for harmful content.",
    fields: [
      { name: "text", type: "textarea", placeholder: "Text to moderate…", required: true },
    ],
    example: { type: "moderate_content", input: { text: "This is a perfectly normal sentence with no harmful content." } },
  },
  {
    id: "code_execute",
    name: "Code Execute",
    credits: 8,
    description: "Run sandboxed code and return stdout/stderr.",
    fields: [
      { name: "language", type: "select", options: ["python", "javascript", "bash"], required: true },
      { name: "code", type: "textarea", placeholder: "print('hello world')", required: true },
    ],
    example: { type: "code_execute", input: { language: "python", code: "import math\nprint(math.pi)\nprint([x**2 for x in range(10)])" } },
  },
];
---

<Layout title="API Sandbox — CrowdSorcerer Docs">
  <div class="max-w-5xl mx-auto px-4 py-10">

    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center gap-2 text-sm text-gray-500 mb-4">
        <a href="/docs" class="hover:text-violet-400 transition-colors">Docs</a>
        <span>›</span>
        <span class="text-gray-300">API Sandbox</span>
      </div>
      <h1 class="text-3xl font-bold mb-2">🧪 Interactive API Sandbox</h1>
      <p class="text-gray-400 max-w-2xl">
        Try the CrowdSorcerer API live in your browser. Enter your API key, pick a task type,
        fill in the fields, and fire a real request — no setup required.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">

      <!-- Left column: controls -->
      <div class="lg:col-span-2 space-y-4">

        <!-- API key -->
        <div class="rounded-xl bg-gray-900 border border-gray-800 p-4">
          <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">
            🔑 API Key
          </label>
          <input
            id="api-key"
            type="password"
            placeholder="sk-cs-..."
            class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:border-violet-500 transition-colors"
          />
          <p class="text-xs text-gray-600 mt-1.5">
            Get your key from <a href="/dashboard/api-keys" class="text-violet-400 hover:text-violet-300">Dashboard → API Keys</a>
          </p>
        </div>

        <!-- Task type selector -->
        <div class="rounded-xl bg-gray-900 border border-gray-800 p-4">
          <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">
            📋 Task Type
          </label>
          <div class="space-y-1" id="task-type-list">
            {TASKS.map((t, i) => (
              <button
                class={`task-type-btn w-full text-left px-3 py-2.5 rounded-lg text-sm transition-colors flex items-center justify-between ${i === 0 ? "bg-violet-700/30 border border-violet-600/50 text-violet-300" : "text-gray-400 hover:bg-gray-800 hover:text-gray-200"}`}
                data-id={t.id}
              >
                <span>{t.name}</span>
                <span class="text-xs text-gray-500">{t.credits}cr</span>
              </button>
            ))}
          </div>
        </div>

        <!-- Options -->
        <div class="rounded-xl bg-gray-900 border border-gray-800 p-4">
          <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">
            ⚙️ Options
          </label>
          <div class="space-y-2">
            <div>
              <label class="text-xs text-gray-400 block mb-1">Polling interval (ms)</label>
              <input
                id="poll-interval"
                type="number"
                value="1500"
                min="500"
                max="10000"
                step="500"
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 focus:outline-none focus:border-violet-500"
              />
            </div>
            <div>
              <label class="text-xs text-gray-400 block mb-1">Max wait (s)</label>
              <input
                id="max-wait"
                type="number"
                value="60"
                min="10"
                max="300"
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 focus:outline-none focus:border-violet-500"
              />
            </div>
          </div>
        </div>

      </div>

      <!-- Right column: request builder + response -->
      <div class="lg:col-span-3 space-y-4">

        <!-- Request builder -->
        <div class="rounded-xl bg-gray-900 border border-gray-800 p-5" id="request-panel">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-sm font-semibold text-gray-200" id="panel-title">Web Research</h2>
            <div class="flex items-center gap-2">
              <button
                id="load-example-btn"
                class="text-xs text-violet-400 hover:text-violet-300 transition-colors"
              >Load example</button>
              <span class="text-gray-700">|</span>
              <button
                id="raw-toggle-btn"
                class="text-xs text-gray-400 hover:text-gray-200 transition-colors"
              >Switch to raw JSON</button>
            </div>
          </div>

          <!-- Form view -->
          <div id="form-view" class="space-y-3"></div>

          <!-- Raw JSON view (hidden by default) -->
          <div id="raw-view" class="hidden">
            <textarea
              id="raw-json"
              rows="12"
              class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-3 text-sm text-gray-200 font-mono placeholder-gray-600 focus:outline-none focus:border-violet-500 transition-colors"
              placeholder="{}"
            ></textarea>
          </div>

          <!-- Submit -->
          <div class="flex items-center gap-3 mt-5">
            <button
              id="run-btn"
              class="flex-1 py-2.5 rounded-xl bg-violet-600 hover:bg-violet-500 text-white text-sm font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
            >
              ▶ Run Request
            </button>
            <button
              id="copy-curl-btn"
              class="px-4 py-2.5 rounded-xl border border-gray-700 text-sm text-gray-400 hover:border-violet-500 hover:text-violet-300 transition-colors whitespace-nowrap"
              title="Copy cURL command"
            >
              Copy cURL
            </button>
          </div>
        </div>

        <!-- Code examples tabs -->
        <div class="rounded-xl bg-gray-900 border border-gray-800 p-5" id="code-panel">
          <div class="flex items-center gap-1 mb-3">
            {["cURL", "Python", "JavaScript", "Node SDK"].map((lang, i) => (
              <button
                class={`code-tab-btn px-3 py-1.5 rounded-lg text-xs font-medium transition-colors ${i === 0 ? "bg-violet-700/30 text-violet-300 border border-violet-600/50" : "text-gray-500 hover:text-gray-300"}`}
                data-lang={lang}
              >
                {lang}
              </button>
            ))}
            <button
              id="copy-code-btn"
              class="ml-auto text-xs text-gray-500 hover:text-gray-300 transition-colors"
            >📋 Copy</button>
          </div>
          <pre id="code-example"
            class="text-xs text-gray-300 font-mono overflow-x-auto whitespace-pre bg-gray-800 rounded-lg p-4 leading-relaxed max-h-48 overflow-y-auto"
          ></pre>
        </div>

        <!-- Response panel -->
        <div class="rounded-xl bg-gray-900 border border-gray-800 p-5" id="response-panel">
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-sm font-semibold text-gray-200">Response</h2>
            <div class="flex items-center gap-2">
              <span id="response-status" class="text-xs px-2 py-1 rounded-full hidden"></span>
              <span id="response-time" class="text-xs text-gray-500 hidden"></span>
              <button id="copy-response-btn" class="text-xs text-gray-500 hover:text-gray-300 transition-colors hidden">
                📋 Copy
              </button>
            </div>
          </div>
          <div id="response-placeholder" class="py-12 text-center text-gray-600 text-sm">
            Press <strong class="text-gray-500">Run Request</strong> to see the response here
          </div>
          <div id="response-loading" class="hidden py-8 text-center">
            <div class="inline-flex items-center gap-2 text-violet-400 text-sm">
              <span class="animate-spin">⚙️</span>
              <span id="loading-label">Submitting task…</span>
            </div>
          </div>
          <pre
            id="response-output"
            class="hidden text-xs text-gray-300 font-mono overflow-x-auto whitespace-pre bg-gray-800 rounded-lg p-4 leading-relaxed max-h-96 overflow-y-auto"
          ></pre>
        </div>

      </div>
    </div>
  </div>

  <script define:vars={{ TASKS, PUBLIC_API }}>
    // ── State ────────────────────────────────────────────────────────────────
    let currentTask = TASKS[0];
    let isRawMode = false;
    let currentLang = "cURL";

    // ── DOM refs ──────────────────────────────────────────────────────────────
    const apiKeyInput = document.getElementById("api-key");
    const formView = document.getElementById("form-view");
    const rawView = document.getElementById("raw-view");
    const rawJson = document.getElementById("raw-json");
    const rawToggleBtn = document.getElementById("raw-toggle-btn");
    const loadExampleBtn = document.getElementById("load-example-btn");
    const runBtn = document.getElementById("run-btn");
    const copyCurlBtn = document.getElementById("copy-curl-btn");
    const codeExample = document.getElementById("code-example");
    const copyCodeBtn = document.getElementById("copy-code-btn");
    const copyResponseBtn = document.getElementById("copy-response-btn");
    const responseOutput = document.getElementById("response-output");
    const responsePlaceholder = document.getElementById("response-placeholder");
    const responseLoading = document.getElementById("response-loading");
    const responseStatus = document.getElementById("response-status");
    const responseTime = document.getElementById("response-time");
    const loadingLabel = document.getElementById("loading-label");
    const panelTitle = document.getElementById("panel-title");

    // ── Build form for a task ─────────────────────────────────────────────────
    function buildForm(task) {
      formView.innerHTML = "";
      task.fields.forEach((f) => {
        const wrapper = document.createElement("div");
        let inputEl;

        if (f.type === "textarea") {
          inputEl = document.createElement("textarea");
          inputEl.rows = 3;
          inputEl.className = "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-600 focus:outline-none focus:border-violet-500 transition-colors font-mono resize-y";
          inputEl.placeholder = f.placeholder ?? "";
        } else if (f.type === "select") {
          inputEl = document.createElement("select");
          inputEl.className = "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 focus:outline-none focus:border-violet-500 transition-colors";
          (f.options ?? []).forEach((opt) => {
            const o = document.createElement("option");
            o.value = opt;
            o.textContent = opt;
            inputEl.appendChild(o);
          });
        } else if (f.type === "boolean") {
          inputEl = document.createElement("input");
          inputEl.type = "checkbox";
          inputEl.className = "w-4 h-4 rounded accent-violet-500";
        } else if (f.type === "number") {
          inputEl = document.createElement("input");
          inputEl.type = "number";
          inputEl.className = "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-600 focus:outline-none focus:border-violet-500 transition-colors";
          inputEl.placeholder = f.placeholder ?? "";
        } else {
          inputEl = document.createElement("input");
          inputEl.type = "text";
          inputEl.className = "w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-600 focus:outline-none focus:border-violet-500 transition-colors";
          inputEl.placeholder = f.placeholder ?? "";
        }

        inputEl.dataset.field = f.name;
        if (f.required) inputEl.required = true;

        const label = document.createElement("label");
        label.className = "text-xs text-gray-400 mb-1 flex items-center gap-1";
        label.innerHTML = `<span>${f.name}</span>${f.required ? '<span class="text-red-400">*</span>' : '<span class="text-gray-600">(optional)</span>'}`;

        if (f.type === "boolean") {
          const row = document.createElement("div");
          row.className = "flex items-center gap-2";
          row.appendChild(inputEl);
          const spanLabel = document.createElement("span");
          spanLabel.textContent = f.name;
          spanLabel.className = "text-xs text-gray-400";
          row.appendChild(spanLabel);
          wrapper.appendChild(row);
        } else {
          wrapper.appendChild(label);
          wrapper.appendChild(inputEl);
        }
        formView.appendChild(wrapper);
      });
    }

    function getFormPayload() {
      const input = {};
      currentTask.fields.forEach((f) => {
        const el = formView.querySelector(`[data-field="${f.name}"]`);
        if (!el) return;
        if (f.type === "boolean") {
          if (el.checked) input[f.name] = true;
        } else if (f.type === "number") {
          const v = el.value.trim();
          if (v) input[f.name] = Number(v);
        } else if (f.type === "textarea") {
          const v = el.value.trim();
          if (!v) return;
          // Try parsing as JSON
          if (v.startsWith("[") || v.startsWith("{")) {
            try { input[f.name] = JSON.parse(v); return; } catch {}
          }
          input[f.name] = v;
        } else {
          const v = el.value.trim();
          if (v) input[f.name] = v;
        }
      });
      return { type: currentTask.id, input };
    }

    function getPayload() {
      if (isRawMode) {
        try { return JSON.parse(rawJson.value); } catch { return null; }
      }
      return getFormPayload();
    }

    // ── Code examples ──────────────────────────────────────────────────────────
    function buildCurl(payload, key) {
      const k = key || "<YOUR_API_KEY>";
      return `curl -X POST "${PUBLIC_API}/v1/tasks" \\
  -H "Authorization: Bearer ${k}" \\
  -H "Content-Type: application/json" \\
  -d '${JSON.stringify(payload, null, 2).replace(/'/g, "'\\''")}'\n\n# Then poll for result:\ncurl "${PUBLIC_API}/v1/tasks/<TASK_ID>" \\
  -H "Authorization: Bearer ${k}"`;
    }

    function buildPython(payload, key) {
      const k = key || "YOUR_API_KEY";
      return `import time, requests

API_KEY = "${k}"
BASE = "${PUBLIC_API}"

# Submit task
r = requests.post(
    f"{BASE}/v1/tasks",
    json=${JSON.stringify(payload, null, 2).replace(/^/gm, "    ").trimStart()},
    headers={"Authorization": f"Bearer {API_KEY}"}
)
task = r.json()
task_id = task["task_id"]
print(f"Task submitted: {task_id}")

# Poll until done
while True:
    r = requests.get(f"{BASE}/v1/tasks/{task_id}",
                     headers={"Authorization": f"Bearer {API_KEY}"})
    data = r.json()
    status = data.get("status")
    print(f"Status: {status}")
    if status in ("completed", "failed"):
        print(data.get("output") or data.get("error"))
        break
    time.sleep(2)`;
    }

    function buildJS(payload, key) {
      const k = key || "YOUR_API_KEY";
      return `const BASE = "${PUBLIC_API}";
const API_KEY = "${k}";

// Submit task
const res = await fetch(\`\${BASE}/v1/tasks\`, {
  method: "POST",
  headers: {
    "Authorization": \`Bearer \${API_KEY}\`,
    "Content-Type": "application/json",
  },
  body: JSON.stringify(${JSON.stringify(payload, null, 2).replace(/^/gm, "  ").trimStart()}),
});
const { task_id } = await res.json();
console.log("Task ID:", task_id);

// Poll until done
while (true) {
  const r = await fetch(\`\${BASE}/v1/tasks/\${task_id}\`, {
    headers: { "Authorization": \`Bearer \${API_KEY}\` },
  });
  const data = await r.json();
  if (["completed", "failed"].includes(data.status)) {
    console.log(data.output ?? data.error);
    break;
  }
  await new Promise(r => setTimeout(r, 2000));
}`;
    }

    function buildNodeSdk(payload, key) {
      const k = key || "YOUR_API_KEY";
      return `import CrowdSorcerer from "@crowdsourcerer/sdk";

const cs = new CrowdSorcerer({ apiKey: "${k}" });

const task = await cs.tasks.create(
  ${JSON.stringify(payload, null, 2).replace(/^/gm, "  ").trimStart()}
);
console.log("Task ID:", task.task_id);

// Wait for completion (SDK auto-polls)
const result = await cs.tasks.waitForCompletion(task.task_id);
console.log(result.output);`;
    }

    function updateCodeExample() {
      const payload = getPayload() ?? currentTask.example;
      const key = apiKeyInput.value.trim();
      const builders = {
        cURL: buildCurl,
        Python: buildPython,
        JavaScript: buildJS,
        "Node SDK": buildNodeSdk,
      };
      const fn = builders[currentLang] ?? buildCurl;
      codeExample.textContent = fn(payload, key);
    }

    // ── Tab switching ──────────────────────────────────────────────────────────
    document.querySelectorAll(".code-tab-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        currentLang = btn.dataset.lang;
        document.querySelectorAll(".code-tab-btn").forEach((b) => {
          b.classList.toggle("bg-violet-700/30", b.dataset.lang === currentLang);
          b.classList.toggle("text-violet-300", b.dataset.lang === currentLang);
          b.classList.toggle("border", b.dataset.lang === currentLang);
          b.classList.toggle("border-violet-600/50", b.dataset.lang === currentLang);
          b.classList.toggle("text-gray-500", b.dataset.lang !== currentLang);
        });
        updateCodeExample();
      });
    });

    // ── Task type selection ────────────────────────────────────────────────────
    document.querySelectorAll(".task-type-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.dataset.id;
        const task = TASKS.find((t) => t.id === id);
        if (!task) return;
        currentTask = task;
        panelTitle.textContent = task.name;

        document.querySelectorAll(".task-type-btn").forEach((b) => {
          const active = b.dataset.id === id;
          b.className = `task-type-btn w-full text-left px-3 py-2.5 rounded-lg text-sm transition-colors flex items-center justify-between ${
            active
              ? "bg-violet-700/30 border border-violet-600/50 text-violet-300"
              : "text-gray-400 hover:bg-gray-800 hover:text-gray-200"
          }`;
        });

        buildForm(task);
        updateCodeExample();
        // Reset response
        showResponsePanel("placeholder");
      });
    });

    // ── Raw / Form toggle ─────────────────────────────────────────────────────
    rawToggleBtn.addEventListener("click", () => {
      isRawMode = !isRawMode;
      if (isRawMode) {
        const payload = getFormPayload();
        rawJson.value = JSON.stringify(payload, null, 2);
        formView.classList.add("hidden");
        rawView.classList.remove("hidden");
        rawToggleBtn.textContent = "Switch to form";
      } else {
        formView.classList.remove("hidden");
        rawView.classList.add("hidden");
        rawToggleBtn.textContent = "Switch to raw JSON";
      }
    });

    loadExampleBtn.addEventListener("click", () => {
      const ex = currentTask.example;
      if (isRawMode) {
        rawJson.value = JSON.stringify(ex, null, 2);
      } else {
        currentTask.fields.forEach((f) => {
          const val = ex.input[f.name];
          if (val === undefined) return;
          const el = formView.querySelector(`[data-field="${f.name}"]`);
          if (!el) return;
          if (f.type === "boolean") el.checked = !!val;
          else el.value = typeof val === "object" ? JSON.stringify(val, null, 2) : String(val);
        });
      }
      updateCodeExample();
    });

    // ── Copy helpers ───────────────────────────────────────────────────────────
    function flashCopied(btn, orig) {
      btn.textContent = "✓ Copied!";
      setTimeout(() => { btn.textContent = orig; }, 1500);
    }

    copyCurlBtn.addEventListener("click", () => {
      const payload = getPayload() ?? currentTask.example;
      navigator.clipboard.writeText(buildCurl(payload, apiKeyInput.value.trim())).catch(() => {});
      flashCopied(copyCurlBtn, "Copy cURL");
    });

    copyCodeBtn.addEventListener("click", () => {
      navigator.clipboard.writeText(codeExample.textContent ?? "").catch(() => {});
      flashCopied(copyCodeBtn, "📋 Copy");
    });

    copyResponseBtn.addEventListener("click", () => {
      navigator.clipboard.writeText(responseOutput.textContent ?? "").catch(() => {});
      flashCopied(copyResponseBtn, "📋 Copy");
    });

    // ── Response panel helpers ─────────────────────────────────────────────────
    function showResponsePanel(mode, text, statusCode, durationMs) {
      responsePlaceholder.classList.toggle("hidden", mode !== "placeholder");
      responseLoading.classList.toggle("hidden", mode !== "loading");
      responseOutput.classList.toggle("hidden", mode !== "result");
      responseStatus.classList.toggle("hidden", mode !== "result");
      responseTime.classList.toggle("hidden", mode !== "result");
      copyResponseBtn.classList.toggle("hidden", mode !== "result");

      if (mode === "result") {
        responseOutput.textContent = text;
        responseStatus.textContent = String(statusCode);
        const isOk = statusCode >= 200 && statusCode < 300;
        responseStatus.className = `text-xs px-2 py-1 rounded-full ${
          isOk ? "bg-emerald-900/40 text-emerald-400" : "bg-red-900/40 text-red-400"
        }`;
        responseTime.textContent = `${durationMs}ms`;
      }
      if (mode === "loading") {
        loadingLabel.textContent = "Submitting task…";
      }
    }

    // ── API key change — rebuild code examples ─────────────────────────────────
    apiKeyInput.addEventListener("input", updateCodeExample);

    // ── Run request ────────────────────────────────────────────────────────────
    runBtn.addEventListener("click", async () => {
      const key = apiKeyInput.value.trim();
      if (!key) {
        alert("Please enter your API key first.");
        apiKeyInput.focus();
        return;
      }

      const payload = getPayload();
      if (!payload) {
        alert("Invalid JSON in raw editor.");
        return;
      }

      runBtn.disabled = true;
      showResponsePanel("loading");
      const t0 = Date.now();

      try {
        // 1. Submit task
        const submitRes = await fetch(`${PUBLIC_API}/v1/tasks`, {
          method: "POST",
          headers: {
            "Authorization": `Bearer ${key}`,
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
        });
        const submitData = await submitRes.json();
        const totalDuration = () => Date.now() - t0;

        if (!submitRes.ok) {
          showResponsePanel("result",
            JSON.stringify(submitData, null, 2),
            submitRes.status, totalDuration()
          );
          runBtn.disabled = false;
          return;
        }

        const taskId = submitData.task_id;
        if (!taskId) {
          showResponsePanel("result",
            JSON.stringify(submitData, null, 2),
            submitRes.status, totalDuration()
          );
          runBtn.disabled = false;
          return;
        }

        // 2. Poll for result
        const pollInterval = parseInt(document.getElementById("poll-interval").value, 10) || 1500;
        const maxWaitMs = (parseInt(document.getElementById("max-wait").value, 10) || 60) * 1000;

        loadingLabel.textContent = `Task ${taskId.slice(0, 8)}… — polling…`;

        while (Date.now() - t0 < maxWaitMs) {
          await new Promise((r) => setTimeout(r, pollInterval));

          const pollRes = await fetch(`${PUBLIC_API}/v1/tasks/${taskId}`, {
            headers: { "Authorization": `Bearer ${key}` },
          });
          const data = await pollRes.json();

          if (data.status === "completed" || data.status === "failed") {
            showResponsePanel("result",
              JSON.stringify(data, null, 2),
              pollRes.status,
              totalDuration()
            );
            runBtn.disabled = false;
            return;
          }

          loadingLabel.textContent = `Status: ${data.status ?? "pending"}…`;
        }

        // Timeout
        showResponsePanel("result",
          JSON.stringify({ error: "Timed out waiting for task to complete", task_id: taskId }, null, 2),
          408, totalDuration()
        );
      } catch (err) {
        showResponsePanel("result",
          JSON.stringify({ error: String(err) }, null, 2),
          0, Date.now() - t0
        );
      }
      runBtn.disabled = false;
    });

    // ── Init ───────────────────────────────────────────────────────────────────
    buildForm(currentTask);
    updateCodeExample();
  </script>
</Layout>
