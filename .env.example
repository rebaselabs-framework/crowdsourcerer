# Database
POSTGRES_PASSWORD=changeme

# Security (generate with: openssl rand -hex 32)
JWT_SECRET=changeme
API_KEY_SALT=changeme

# RebaseKit (get from api.rebaselabs.online)
REBASEKIT_API_KEY=your-rebasekit-api-key
REBASEKIT_BASE_URL=https://api.rebaselabs.online

# Stripe (optional, for fiat payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Web
PUBLIC_API_URL=http://api:8100

# Toggle debug mode
DEBUG=false
